<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <GenerateProgramFile>false</GenerateProgramFile>
    <AssemblyName>Meridian.FSharp.Tests</AssemblyName>
    <RootNamespace>Meridian.FSharp.Tests</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="DomainTests.fs" />
    <Compile Include="ValidationTests.fs" />
    <Compile Include="CalculationTests.fs" />
    <Compile Include="CanonicalizationTests.fs" />
    <Compile Include="PipelineTests.fs" />
    <Compile Include="RiskPolicyTests.fs" />
    <Compile Include="TradingTransitionTests.fs" />
    <Compile Include="LedgerKernelTests.fs" />
    <Compile Include="DirectLendingInteropTests.fs" />
    <Compile Include="CashFlowProjectorTests.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="FSharp.Core" />
    <PackageReference Include="FsUnit.xUnit" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Meridian.Backtesting.Sdk\Meridian.Backtesting.Sdk.csproj" />
    <ProjectReference Include="..\..\src\Meridian.Execution.Sdk\Meridian.Execution.Sdk.csproj" />
    <ProjectReference Include="..\..\src\Meridian.FSharp\Meridian.FSharp.fsproj" />
    <ProjectReference Include="..\..\src\Meridian.FSharp.DirectLending.Aggregates\Meridian.FSharp.DirectLending.Aggregates.fsproj" />
    <ProjectReference Include="..\..\src\Meridian.FSharp.Trading\Meridian.FSharp.Trading.fsproj" />
    <ProjectReference Include="..\..\src\Meridian.FSharp.Ledger\Meridian.FSharp.Ledger.fsproj" />
    <ProjectReference Include="..\..\src\Meridian.Ledger\Meridian.Ledger.csproj" />
  </ItemGroup>
</Project>
