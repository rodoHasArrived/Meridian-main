// Workstation Delivery Diagram
// Meridian v1.8.x
// Last Updated: 2026-04-07
//
// This diagram shows how the WPF workstation and the React workstation shell
// converge on shared run, portfolio, ledger, and security-reference services.

digraph WorkstationDelivery {
  rankdir=LR;
  graph [fontname="Helvetica", fontsize=12, bgcolor="white", compound=true, pad=0.5];
  node  [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled"];
  edge  [fontname="Helvetica", fontsize=9, color="#4a5568"];

  labelloc="t";
  label="Meridian - Workstation Delivery\nShared read models across WPF and web workstation surfaces | v1.8.x";

  subgraph cluster_surfaces {
    label="Operator Surfaces";
    color="#805ad5";
    style="rounded";
    bgcolor="#faf5ff";

    WPF_SURFACES [fillcolor="#805ad5", fontcolor="white",
                  label="Meridian.Wpf\nResearchWorkspaceShellPage\nTradingWorkspaceShellPage\nGovernanceWorkspaceShellPage"];
    WEB_SHELL [fillcolor="#805ad5", fontcolor="white",
               label="React workstation shell\n/workstation\nbootstrap + drill-in screens"];
    API_SURFACE [fillcolor="#c4b5fd",
                 label="Workstation + portfolio routes\n/api/workstation/*\n/api/portfolio/*\n/api/strategies/*"];
  }

  subgraph cluster_delivery {
    label="Shared Delivery Services";
    color="#2b6cb0";
    style="rounded";
    bgcolor="#dbeafe";

    WPF_WORKSPACE [fillcolor="#bfdbfe",
                   label="StrategyRunWorkspaceService\nactive run context\nrun browser + promotion handoff"];
    WORKSTATION_ENDPOINTS [fillcolor="#93c5fd",
                           label="WorkstationEndpoints\nsession / research / trading\nledger / fills / attribution\nsecurity master / reconciliation"];
    RUN_READ [fillcolor="#bfdbfe",
              label="StrategyRunReadService\nsummary, detail, equity curve,\nfills, attribution"];
    PORTFOLIO_READ [fillcolor="#dbeafe",
                    label="PortfolioReadService\npositions, exposure,\nsecurity enrichment"];
    LEDGER_READ [fillcolor="#dbeafe",
                 label="LedgerReadService\ntrial balance,\njournal, ledger rollups"];
    CASH_FLOW [fillcolor="#dbeafe",
               label="CashFlowProjectionService\ncash ladder / bucketed flows"];
    SECURITY_LOOKUP [fillcolor="#dbeafe",
                     label="SecurityMasterSecurityReferenceLookup\nenrich symbols with authoritative\nasset-class + identifier data"];
    SECURITY_QUERY [fillcolor="#d1fae5",
                    label="ISecurityMasterQueryService\nsecurity detail / history / identity"];
    RECONCILIATION_NOTE [shape=note, fillcolor="#feebc8",
                         label="Reconciliation endpoints use\nIReconciliationRunService\n(see fund-ops-reconciliation.dot)"];
  }

  subgraph cluster_state {
    label="Shared State";
    color="#c53030";
    style="rounded";
    bgcolor="#fff5f5";

    RUN_STORE [shape=cylinder, fillcolor="#fecaca",
               label="StrategyRunStore\nbacktest / paper / live runs"];
    SECURITY_STATE [shape=cylinder, fillcolor="#fecaca",
                    label="Security Master projections\ncache + backing store"];
  }

  WPF_SURFACES -> WPF_WORKSPACE [label="desktop pages"];
  WEB_SHELL -> API_SURFACE [label="XHR / fetch"];
  API_SURFACE -> WORKSTATION_ENDPOINTS [label="route groups"];

  WPF_WORKSPACE -> RUN_READ [label="desktop drill-ins"];
  WPF_WORKSPACE -> CASH_FLOW [label="cash flow panels"];

  WORKSTATION_ENDPOINTS -> RUN_READ [label="runs / ledger / fills"];
  WORKSTATION_ENDPOINTS -> CASH_FLOW [label="cash-flow projections"];
  WORKSTATION_ENDPOINTS -> SECURITY_QUERY [label="security master detail"];
  WORKSTATION_ENDPOINTS -> RECONCILIATION_NOTE [style=dashed, color="#ed8936"];

  RUN_READ -> PORTFOLIO_READ [label="portfolio summaries"];
  RUN_READ -> LEDGER_READ [label="ledger summaries"];
  PORTFOLIO_READ -> SECURITY_LOOKUP [label="enrich positions"];
  LEDGER_READ -> SECURITY_LOOKUP [label="enrich trial balance"];
  SECURITY_LOOKUP -> SECURITY_QUERY [label="lookup by symbol / identifier"];

  RUN_READ -> RUN_STORE [label="read run entries"];
  CASH_FLOW -> RUN_STORE [label="iterate cash-flow metrics"];
  SECURITY_QUERY -> SECURITY_STATE [label="query projections"];

  subgraph cluster_legend {
    label="Legend";
    style="rounded";
    color="#666666";
    bgcolor="#fafafa";

    LEG_UI [fillcolor="#805ad5", fontcolor="white", label="Operator surface"];
    LEG_APP [fillcolor="#bfdbfe", label="Application service"];
    LEG_SUPPORT [fillcolor="#dbeafe", label="Supporting read model"];
    LEG_STORE [shape=cylinder, fillcolor="#fecaca", label="Shared persisted state"];
  }
}
