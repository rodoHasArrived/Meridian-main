// Fund Operations Reconciliation Diagram
// Meridian v1.8.x
// Last Updated: 2026-04-07
//
// This diagram shows the current governance/fund-ops reconciliation loop across
// workstation views, reconciliation services, the F# reconciliation engine, and
// the persisted break queue/history repository.

digraph FundOpsReconciliation {
  rankdir=LR;
  graph [fontname="Helvetica", fontsize=12, bgcolor="white", compound=true, pad=0.5];
  node  [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled"];
  edge  [fontname="Helvetica", fontsize=9, color="#4a5568"];

  labelloc="t";
  label="Meridian - Fund Ops and Reconciliation\nGovernance workspace, reconciliation engine, and review loop | v1.8.x";

  subgraph cluster_surfaces {
    label="Governance Surfaces";
    color="#805ad5";
    style="rounded";
    bgcolor="#faf5ff";

    GOVERNANCE_UI [fillcolor="#805ad5", fontcolor="white",
                   label="Governance workspace\nGovernanceWorkspaceShellPage\nFundLedgerViewModel"];
    API_CLIENT [fillcolor="#c4b5fd",
                label="IWorkstationReconciliationApiClient\nreview / resolve / dismiss"];
    WORKSTATION_API [fillcolor="#c4b5fd",
                     label="WorkstationEndpoints\n/api/workstation/reconciliation/*\n/api/workstation/runs/*"];
  }

  subgraph cluster_workbench {
    label="Workbench and Read Models";
    color="#2b6cb0";
    style="rounded";
    bgcolor="#dbeafe";

    WORKBENCH [fillcolor="#93c5fd",
               label="FundReconciliationWorkbenchService\ncompose snapshot + break queue\noperator actions"];
    RUN_WORKSPACE [fillcolor="#bfdbfe",
                   label="StrategyRunWorkspaceService\nrecorded runs + active run context"];
    RECON_READ [fillcolor="#bfdbfe",
                label="ReconciliationReadService\nfund snapshot assembly"];
    FUND_ACCOUNT [fillcolor="#dbeafe",
                  label="IFundAccountService\naccount-run reconciliation results"];
    CASH_FLOW [fillcolor="#dbeafe",
               label="CashFlowProjectionService\ncash ladder side panels"];
  }

  subgraph cluster_engine {
    label="Reconciliation Engine";
    color="#38a169";
    style="rounded";
    bgcolor="#f0fff4";

    RUN_SERVICE [fillcolor="#a7f3d0",
                 label="ReconciliationRunService\nRunAsync / GetLatest / GetHistory"];
    RUN_READ [fillcolor="#d1fae5",
              label="StrategyRunReadService\nload StrategyRunDetail"];
    PROJECTION [fillcolor="#d1fae5",
                label="ReconciliationProjectionService\nportfolio-vs-ledger checks\noptional banking checks"];
    FSHARP_ENGINE [fillcolor="#6ee7b7",
                   label="LedgerInterop.ReconcilePortfolioLedgerChecks\nF# reconciliation rules"];
    BANK_SOURCE [fillcolor="#d1fae5",
                 label="IBankTransactionSource\noptional bank transaction feed"];
  }

  subgraph cluster_state {
    label="Persisted State";
    color="#c53030";
    style="rounded";
    bgcolor="#fff5f5";

    RUN_STORE [shape=cylinder, fillcolor="#fecaca",
               label="StrategyRunStore\nrun metrics + ledger inputs"];
    RECON_REPO [shape=cylinder, fillcolor="#fecaca",
                label="IReconciliationRunRepository\nsummary, detail, break queue,\nhistory per run"];
  }

  GOVERNANCE_UI -> WORKBENCH [label="open workspace"];
  GOVERNANCE_UI -> API_CLIENT [label="review / resolve / dismiss"];
  API_CLIENT -> WORKSTATION_API [label="HTTP calls"];

  WORKBENCH -> RECON_READ [label="build snapshot"];
  WORKBENCH -> FUND_ACCOUNT [label="account-run details"];
  WORKBENCH -> RUN_WORKSPACE [label="run inventory"];
  WORKBENCH -> API_CLIENT [label="workflow actions"];
  RUN_WORKSPACE -> CASH_FLOW [label="cash flow detail"];

  WORKSTATION_API -> RUN_SERVICE [label="create run / get detail / history"];
  WORKSTATION_API -> RECON_REPO [style=dashed, color="#2b6cb0",
                                 label="break queue reads"];

  RUN_SERVICE -> RUN_READ [label="load strategy run"];
  RUN_SERVICE -> PROJECTION [label="build checks"];
  RUN_SERVICE -> BANK_SOURCE [style=dashed, color="#38a169",
                              label="optional bank data"];
  PROJECTION -> FSHARP_ENGINE [label="reconcile check set"];
  RUN_SERVICE -> RECON_REPO [label="save summary + detail"];

  RUN_READ -> RUN_STORE [label="read portfolio / ledger"];
  CASH_FLOW -> RUN_STORE [label="read cash flows"];
  RECON_READ -> RECON_REPO [label="recent reconciliation state"];

  subgraph cluster_legend {
    label="Legend";
    style="rounded";
    color="#666666";
    bgcolor="#fafafa";

    LEG_UI [fillcolor="#805ad5", fontcolor="white", label="Operator surface"];
    LEG_APP [fillcolor="#93c5fd", label="Workbench service"];
    LEG_ENGINE [fillcolor="#a7f3d0", label="Reconciliation engine"];
    LEG_STORE [shape=cylinder, fillcolor="#fecaca", label="Persisted state"];
  }
}
