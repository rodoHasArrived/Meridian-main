// Strategy Lifecycle Diagram
// Meridian v1.7.x
// Last Updated: 2026-03-23
//
// This diagram shows the full strategy lifecycle: registration, activation,
// state machine, portfolio tracking, and promotion from backtest to live.
//
// Generate: dot -Tpng strategy-lifecycle.dot -o strategy-lifecycle.png
//           dot -Tsvg strategy-lifecycle.dot -o strategy-lifecycle.svg

digraph StrategyLifecycle {
  rankdir=TB;
  graph [fontname="Helvetica", fontsize=12, bgcolor="white", compound=true, pad=0.5];
  node  [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled"];
  edge  [fontname="Helvetica", fontsize=9, color="#4a5568"];

  // Title
  labelloc="t";
  label="Meridian - Strategy Lifecycle\nRegistration → Backtest → Paper → Live | v1.7.x";

  // Strategy SDK
  subgraph cluster_sdk {
    label="Strategy SDK (Meridian.Backtesting.Sdk)";
    color="#805ad5";
    style="rounded";
    bgcolor="#faf5ff";

    I_LIFECYCLE [shape=ellipse, fillcolor="#ddd6fe",
                 label="IStrategyLifecycle\n[Interface]\n\nInitialize(context)\nOnBarClosed(bar)\nOnTrade(trade)\nOnQuote(bbo)\nOnDepth(lob)\nOnAssetEvent(ev)\nFinalize(context)"];

    I_CONTEXT [shape=ellipse, fillcolor="#ddd6fe",
               label="IBacktestContext / ILiveContext\n[Interface]\n\nPortfolioState\nCurrentTime\nUniverse\nOrderGateway\nRisk controls"];

    STRATEGY_IMPL [fillcolor="#e9d5ff",
                   label="User Strategy\n[Implements IStrategyLifecycle]\n\nCustom signal logic\nOrder management\nRisk rules\nPosition sizing"];
  }

  // Run Types
  subgraph cluster_runtypes {
    label="Run Types (RunType enum)";
    color="#2b6cb0";
    style="rounded";
    bgcolor="#dbeafe";

    BACKTEST [fillcolor="#bfdbfe",
              label="Backtest\n\nHistorical JSONL replay\nFull metrics output\nNo live orders\nDeterministic execution"];

    PAPER [fillcolor="#bfdbfe",
           label="Paper Trading\n\nReal-time market data\nSimulated order fills\nZero capital risk\nLive market validation"];

    LIVE [fillcolor="#93c5fd",
          label="Live Trading\n[Future]\n\nReal broker connection\nReal capital at risk\nPromotion from Paper"];
  }

  // Strategy Lifecycle Manager
  subgraph cluster_manager {
    label="Strategy Management (Meridian.Strategies)";
    color="#2c7a7b";
    style="rounded";
    bgcolor="#d1fae5";

    SLM [fillcolor="#6ee7b7",
         label="StrategyLifecycleManager\n\nRegister strategy\nActivate/Pause/Stop\nThread-safe state transitions\nEvent dispatching\nError isolation per strategy"];

    RUN_STORE [shape=cylinder, fillcolor="#a7f3d0",
               label="StrategyRunStore\n\nPersist run metadata\nStatus + timestamps\nSymbol universe\nResult summary\nRun history"];

    I_REPO [shape=ellipse, fillcolor="#a7f3d0",
            label="IStrategyRepository\n[Interface]\n\nQuery runs by type\nFilter by status/date\nGet run details"];
  }

  // Strategy State Machine
  subgraph cluster_states {
    label="Strategy State Machine (StrategyStatus)";
    color="#ed8936";
    style="rounded";
    bgcolor="#fffaf0";

    S_INIT [shape=oval, fillcolor="#feebc8",
            label="Initialized\n\nLoaded, not running\nContext validated\nReadiness check passed"];

    S_RUN [shape=oval, fillcolor="#68d391",
           label="Running\n\nReceiving events\nOrders accepted\nActive position tracking"];

    S_PAUSE [shape=oval, fillcolor="#fbd38d",
             label="Paused\n\nEvent dispatch suspended\nPositions held\nOrders blocked\nResumable"];

    S_STOP [shape=oval, fillcolor="#fc8181",
            label="Stopped\n\nFinalize() called\nPositions closed\nFinal metrics recorded\nTerminal state"];

    S_ERROR [shape=oval, fillcolor="#fed7d7",
             label="Error\n\nUnhandled exception\nSafe shutdown\nError logged\nRetry possible"];

    // State transitions
    S_INIT -> S_RUN [label="Activate()", color="#38a169"];
    S_RUN -> S_PAUSE [label="Pause()", color="#ed8936"];
    S_PAUSE -> S_RUN [label="Resume()", color="#38a169"];
    S_RUN -> S_STOP [label="Stop()", color="#c53030"];
    S_PAUSE -> S_STOP [label="Stop()", color="#c53030"];
    S_RUN -> S_ERROR [label="exception", color="#c53030", style=dashed];
    S_ERROR -> S_INIT [label="Reset()", color="#2b6cb0", style=dashed];
  }

  // Portfolio Tracking
  subgraph cluster_portfolio {
    label="Portfolio & Performance Tracking";
    color="#c53030";
    style="rounded";
    bgcolor="#fee2e2";

    PORT_READ [fillcolor="#fecaca",
               label="PortfolioReadService\n\nQuery open positions\nCurrent cash balance\nUnrealized P&L\nAllocations by symbol\nAccount-level exposure"];

    LEDGER_READ [fillcolor="#fecaca",
                 label="LedgerReadService\n\nTrade history\nFill journal\nCommissions paid\nCash flow timeline\nNet P&L by date"];

    RUN_READ [fillcolor="#fecaca",
              label="StrategyRunReadService\n\nRun metadata\nFinal metrics per run\nComparison across runs\nP&L curve time series"];

    PORT_SNAP [shape=cylinder, fillcolor="#feb2b2",
               label="Portfolio Snapshots\n\nEOD position snapshots\nNAV time series\nDrawdown history\nRisk exposure history"];
  }

  // Promotion Path
  subgraph cluster_promote {
    label="Backtest → Live Promotion Path";
    color="#38a169";
    style="rounded";
    bgcolor="#c6f6d5";

    PROMOTE [fillcolor="#9ae6b4",
             label="BacktestToLivePromoter\n\nValidate backtest quality\nMetrics threshold check\nPaper trading dry run\nRisk limit validation\nPromotion approval gate"];

    RISK_CHECK [fillcolor="#9ae6b4",
                label="Risk Validation\n\nMin Sharpe ratio\nMax drawdown limit\nMin trade count\nMin win rate\nMax position size"];

    PROMOTION_GATE [shape=diamond, fillcolor="#68d391",
                    label="Approved?\nPaper → Live"];
  }

  // Data Flow
  STRATEGY_IMPL -> I_LIFECYCLE [style=dashed, label="implements"];
  I_LIFECYCLE -> SLM [color="#2c7a7b", penwidth=2, label="register"];
  I_CONTEXT -> STRATEGY_IMPL [style=dashed, label="injected"];

  BACKTEST -> SLM [color="#2b6cb0", label="RunType.Backtest"];
  PAPER -> SLM [color="#2b6cb0", label="RunType.Paper"];
  LIVE -> SLM [color="#2b6cb0", style=dashed, label="RunType.Live"];

  SLM -> S_INIT [color="#ed8936", penwidth=2, label="create"];
  SLM -> RUN_STORE [color="#2c7a7b", label="persist"];
  RUN_STORE -> I_REPO [style=dashed];

  S_STOP -> PORT_SNAP [color="#c53030", label="record EOD"];
  PORT_SNAP -> PORT_READ [color="#c53030", style=dashed];
  PORT_SNAP -> LEDGER_READ [color="#c53030", style=dashed];
  PORT_SNAP -> RUN_READ [color="#c53030", style=dashed];

  RUN_READ -> PROMOTE [color="#38a169", label="evaluate metrics"];
  PROMOTE -> RISK_CHECK [color="#38a169"];
  RISK_CHECK -> PROMOTION_GATE [color="#38a169"];
  PROMOTION_GATE -> PAPER [color="#38a169", label="Paper first"];
  PROMOTION_GATE -> LIVE [color="#38a169", style=dashed, label="Direct to Live"];
  PROMOTION_GATE -> BACKTEST [color="#c53030", style=dashed, label="Rejected:\nrevise strategy"];

  // Legend
  subgraph cluster_legend {
    label="Legend";
    style="rounded";
    color="#666666";
    bgcolor="#fafafa";

    LEG [shape=plaintext,
         label="━━ Primary flow\n─ ─ Reference / Optional\nOval = State machine node\nDiamond = Decision point"];
  }
}
