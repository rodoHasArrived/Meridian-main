{
  "metadata": [
    {
      "src": [
        { "src": "../..", "files": [ "src/**/*.csproj" ], "exclude": [ "src/**/*.fsproj" ] }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net9.0"
      }
    }
  ],
  "build": {
    "content": [
      { "files": [ "docs/**/*.md", "docs/**/toc.yml" ], "src": "../.." },
      { "files": [ "api/**.yml", "api/index.md" ] }
    ],
    "resource": [
      { "files": [ "docs/**/*.png", "docs/**/*.svg", "docs/**/*.puml" ], "src": "../.." }
    ],
    "output": "../_site",
    "template": [ "default", "modern" ],
    "globalMetadata": {
      "_appTitle": "IB Data Collector",
      "_enableSearch": true
    }
  }
}
