          "properties": {
            "Default": {
              "type": "string",
              "default": "Information"
            },
            "Override": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "Microsoft": {
                  "type": "string",
                  "default": "Warning"
                },
                "System": {
                  "type": "string",
                  "default": "Warning"
                }
              }
