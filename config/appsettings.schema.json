          "type": "boolean",
          "default": true
        },
        "NotifyConnectionStatus": {
          "type": "boolean",
          "default": true
        },
        "NotifyErrors": {
          "type": "boolean",
          "default": true
        },
        "NotifyBackfillComplete": {
          "type": "boolean",
          "default": true
        },
        "NotifyDataGaps": {
          "type": "boolean",
          "default": true
        },
        "NotifyStorageWarnings": {
          "type": "boolean",
          "default": true
        },
        "QuietHoursEnabled": {
          "type": "boolean",
          "default": false
