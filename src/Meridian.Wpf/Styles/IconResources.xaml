    <!-- ========================================== -->
    <!-- ICON FONT FAMILY -->
    <!-- ========================================== -->

    <FontFamily x:Key="SymbolThemeFontFamily">Segoe MDL2 Assets</FontFamily>

    <!-- ========================================== -->
    <!-- ICON STYLES (Using TextBlock for WPF) -->
    <!-- ========================================== -->

    <!-- Small Icon (12px) -->
    <Style x:Key="IconSmallStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="{StaticResource SymbolThemeFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- Medium Icon (16px) - Default -->
    <Style x:Key="IconMediumStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontFamily" Value="{StaticResource SymbolThemeFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- Large Icon (20px) -->
    <Style x:Key="IconLargeStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontFamily" Value="{StaticResource SymbolThemeFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- Extra Large Icon (24px) -->
    <Style x:Key="IconXLargeStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontFamily" Value="{StaticResource SymbolThemeFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- Hero Icon (32px) -->
    <Style x:Key="IconHeroStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontFamily" Value="{StaticResource SymbolThemeFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- Accent Icon Styles -->
    <Style x:Key="IconSuccessStyle" TargetType="TextBlock" BasedOn="{StaticResource IconMediumStyle}">
        <Setter Property="Foreground" Value="{StaticResource SuccessColorBrush}" />
    </Style>

    <Style x:Key="IconWarningStyle" TargetType="TextBlock" BasedOn="{StaticResource IconMediumStyle}">
        <Setter Property="Foreground" Value="{StaticResource WarningColorBrush}" />
    </Style>

    <Style x:Key="IconErrorStyle" TargetType="TextBlock" BasedOn="{StaticResource IconMediumStyle}">
        <Setter Property="Foreground" Value="{StaticResource ErrorColorBrush}" />
    </Style>

    <Style x:Key="IconInfoStyle" TargetType="TextBlock" BasedOn="{StaticResource IconMediumStyle}">
        <Setter Property="Foreground" Value="{StaticResource InfoColorBrush}" />
    </Style>

    <Style x:Key="IconMutedStyle" TargetType="TextBlock" BasedOn="{StaticResource IconMediumStyle}">
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextMutedBrush}" />
    </Style>

    <!-- Empty State Icon -->
    <Style x:Key="EmptyStateIconStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="48" />
        <Setter Property="FontFamily" Value="{StaticResource SymbolThemeFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextMutedBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- ── Extra icon glyphs referenced by individual views ── -->
    <!-- IconKey: credentials / API-key icon (Segoe MDL2 "Permissions") -->
    <sys:String x:Key="IconKey">&#xE8AC;</sys:String>
    <!-- IconKeyboard: keyboard icon (reuses the KeyboardShortcut glyph) -->
    <sys:String x:Key="IconKeyboard">&#xE765;</sys:String>
    <!-- IconWizard: setup-wizard / wand icon (Segoe MDL2 "DeveloperTools") -->
    <sys:String x:Key="IconWizard">&#xE8D7;</sys:String>
    <!-- IconWrench: tool/wrench icon (Segoe MDL2 "Repair") -->
    <sys:String x:Key="IconWrench">&#xE90F;</sys:String>

</ResourceDictionary>
