<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Premium cards: white/off-white bg, 8px radius, hairline border, subtle elevation shadow -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PremiumPanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#1A6BB5" BlurRadius="0" ShadowDepth="0" Opacity="0" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SectionCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <Style x:Key="WorkspaceShellHeaderCardStyle" TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
        <Setter Property="Margin" Value="0,0,0,24" />
    </Style>

    <Style x:Key="WorkspaceSectionCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Margin" Value="0,0,0,24" />
    </Style>

    <Style x:Key="WorkspaceKpiTileStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundMediumBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="16,10" />
    </Style>

    <Style x:Key="WorkspaceQueueItemCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundLightBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="WorkspaceDockHostStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PremiumPanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="CompactCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ConsoleCardSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <!-- ElevatedCardStyle: subtle drop shadow for raised panel feel -->
    <Style x:Key="ElevatedSurfaceCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PremiumPanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#1A2A4A" BlurRadius="18" ShadowDepth="2" Direction="270" Opacity="0.10" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TerminalCardStyle: elevated surface for code/data panels -->
    <Style x:Key="TerminalCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundHoverBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Padding" Value="18" />
    </Style>

    <!-- Metric cards: prominent left-accent bar, modern radii -->
    <Style x:Key="MetricCardSuccessStyle" TargetType="Border" BasedOn="{StaticResource MetricCardStyle}">
        <Setter Property="BorderThickness" Value="4,1,1,1" />
        <Setter Property="BorderBrush" Value="{StaticResource SuccessColorBrush}" />
    </Style>

    <Style x:Key="MetricCardDangerStyle" TargetType="Border" BasedOn="{StaticResource MetricCardStyle}">
        <Setter Property="BorderThickness" Value="4,1,1,1" />
        <Setter Property="BorderBrush" Value="{StaticResource ErrorColorBrush}" />
    </Style>

    <Style x:Key="MetricCardWarningStyle" TargetType="Border" BasedOn="{StaticResource MetricCardStyle}">
        <Setter Property="BorderThickness" Value="4,1,1,1" />
        <Setter Property="BorderBrush" Value="{StaticResource WarningColorBrush}" />
    </Style>

    <Style x:Key="MetricCardInfoStyle" TargetType="Border" BasedOn="{StaticResource MetricCardStyle}">
        <Setter Property="BorderThickness" Value="4,1,1,1" />
        <Setter Property="BorderBrush" Value="{StaticResource InfoColorBrush}" />
    </Style>

    <!-- Badges: pill-shaped, elegant sizing -->
    <Style x:Key="NeutralBadgeStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundHoverBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="SuccessBadgeStyle" TargetType="Border" BasedOn="{StaticResource NeutralBadgeStyle}">
        <Setter Property="Background" Value="{StaticResource ConsoleAccentGreenAlpha10Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SuccessColorBrush}" />
    </Style>

    <Style x:Key="DangerBadgeStyle" TargetType="Border" BasedOn="{StaticResource NeutralBadgeStyle}">
        <Setter Property="Background" Value="{StaticResource ConsoleAccentRedAlpha10Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ErrorColorBrush}" />
    </Style>

    <Style x:Key="WarningBadgeInlineStyle" TargetType="Border" BasedOn="{StaticResource NeutralBadgeStyle}">
        <Setter Property="Background" Value="{StaticResource ConsoleAccentOrangeAlpha10Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WarningColorBrush}" />
    </Style>

    <Style x:Key="InfoBadgeInlineStyle" TargetType="Border" BasedOn="{StaticResource NeutralBadgeStyle}">
        <Setter Property="Background" Value="{StaticResource ConsoleAccentBlueAlpha10Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource InfoColorBrush}" />
    </Style>

    <Style x:Key="HorizontalDividerStyle" TargetType="Rectangle">
        <Setter Property="Height" Value="1" />
        <Setter Property="Fill" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="Opacity" Value="0.8" />
    </Style>
</ResourceDictionary>
