<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Premium type stack: Segoe UI Variable preferred, Segoe UI fallback -->
    <FontFamily x:Key="MeridianDisplayFontFamily">Segoe UI Variable Display, Segoe UI Semibold, Segoe UI</FontFamily>
    <FontFamily x:Key="MeridianBodyFontFamily">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="MeridianDataFontFamily">Cascadia Mono, JetBrains Mono, Consolas</FontFamily>

    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MeridianDisplayFontFamily}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="LineHeight" Value="28" />
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MeridianDisplayFontFamily}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        <Setter Property="LineHeight" Value="20" />
    </Style>

    <Style x:Key="CardDescriptionStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MeridianBodyFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="20" />
    </Style>

    <Style x:Key="PanelIntro" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MeridianBodyFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="MaxWidth" Value="620" />
    </Style>

    <Style x:Key="PanelBullet" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MeridianBodyFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="18" />
        <Setter Property="MaxWidth" Value="620" />
    </Style>

    <Style x:Key="PanelStatus" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MeridianBodyFontFamily}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextMutedBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="MaxWidth" Value="620" />
    </Style>

    <Style x:Key="ShellSectionLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MeridianBodyFontFamily}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextMutedBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Typography.Capitals" Value="AllSmallCaps" />
    </Style>

    <Style x:Key="StudioPanelTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MeridianDisplayFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
    </Style>

    <Style x:Key="StudioValueStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MeridianBodyFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="BodyStrongTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MeridianBodyFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
    </Style>

    <!-- Metric value: large, precise, premium feel -->
    <Style x:Key="MetricValueStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MeridianDisplayFontFamily}" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

    <!-- Eyebrow label: tighter tracking, uppercase, very muted -->
    <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MeridianBodyFontFamily}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextMutedBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="Typography.Capitals" Value="AllSmallCaps" />
    </Style>

    <Style x:Key="DataValueStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MeridianDataFontFamily}" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
    </Style>

    <Style x:Key="DataLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MeridianBodyFontFamily}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextMutedBrush}" />
        <Setter Property="Typography.Capitals" Value="AllSmallCaps" />
    </Style>
</ResourceDictionary>
