<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Institutional premium palette -->
    <Color x:Key="ConsoleBackgroundDark">#08111B</Color>
    <Color x:Key="ConsoleBackgroundMedium">#0E1824</Color>
    <Color x:Key="ConsoleBackgroundLight">#152131</Color>
    <Color x:Key="ConsoleBackgroundHover">#1B2A3D</Color>
    <Color x:Key="ConsoleBackgroundActive">#213349</Color>

    <Color x:Key="ConsoleBorderColor">#24384C</Color>
    <Color x:Key="ConsoleBorderHover">#33506B</Color>
    <Color x:Key="ConsoleBorderFocus">#42C6D6</Color>

    <Color x:Key="ConsoleTextPrimary">#E8F1FA</Color>
    <Color x:Key="ConsoleTextSecondary">#AABCCD</Color>
    <Color x:Key="ConsoleTextMuted">#6E859C</Color>
    <Color x:Key="ConsoleTextDisabled">#526579</Color>

    <Color x:Key="ConsoleAccentGreen">#2CC68F</Color>
    <Color x:Key="ConsoleAccentGreenDim">#1F8F67</Color>
    <Color x:Key="ConsoleAccentGreenLight">#58DDB0</Color>
    <Color x:Key="ConsoleAccentBlue">#42C6D6</Color>
    <Color x:Key="ConsoleAccentBlueDim">#2694A6</Color>
    <Color x:Key="ConsoleAccentPurple">#7AB3FF</Color>
    <Color x:Key="ConsoleAccentPurpleDim">#4F78C3</Color>
    <Color x:Key="ConsoleAccentRed">#E56A72</Color>
    <Color x:Key="ConsoleAccentRedDim">#B24A52</Color>
    <Color x:Key="ConsoleAccentOrange">#E4A84B</Color>
    <Color x:Key="ConsoleAccentOrangeDim">#B47F34</Color>
    <Color x:Key="ConsoleAccentCyan">#6FD7FF</Color>
    <Color x:Key="ConsoleAccentCyanDim">#3599C5</Color>
    <Color x:Key="ConsoleAccentPink">#D48BC9</Color>
    <Color x:Key="ConsoleAccentYellow">#F0C86A</Color>

    <Color x:Key="ConsoleAccentGreenAlpha10">#1A2CC68F</Color>
    <Color x:Key="ConsoleAccentGreenAlpha20">#332CC68F</Color>
    <Color x:Key="ConsoleAccentBlueAlpha10">#1A42C6D6</Color>
    <Color x:Key="ConsoleAccentBlueAlpha20">#3342C6D6</Color>
    <Color x:Key="ConsoleAccentRedAlpha10">#1AE56A72</Color>
    <Color x:Key="ConsoleAccentRedAlpha20">#33E56A72</Color>
    <Color x:Key="ConsoleAccentOrangeAlpha10">#1AE4A84B</Color>
    <Color x:Key="ConsoleAccentOrangeAlpha20">#33E4A84B</Color>
    <Color x:Key="ConsoleAccentPurpleAlpha10">#1A7AB3FF</Color>

    <Color x:Key="ModeLiveColor">#42C6D6</Color>
    <Color x:Key="ModePaperColor">#7AB3FF</Color>
    <Color x:Key="ModeFixtureColor">#E4A84B</Color>
    <Color x:Key="ModeHealthyColor">#2CC68F</Color>
    <Color x:Key="ModeCriticalColor">#E56A72</Color>

    <SolidColorBrush x:Key="ConsoleBackgroundDarkBrush" Color="{StaticResource ConsoleBackgroundDark}" />
    <SolidColorBrush x:Key="ConsoleBackgroundMediumBrush" Color="{StaticResource ConsoleBackgroundMedium}" />
    <SolidColorBrush x:Key="ConsoleBackgroundLightBrush" Color="{StaticResource ConsoleBackgroundLight}" />
    <SolidColorBrush x:Key="ConsoleBackgroundHoverBrush" Color="{StaticResource ConsoleBackgroundHover}" />
    <SolidColorBrush x:Key="ConsoleBackgroundActiveBrush" Color="{StaticResource ConsoleBackgroundActive}" />
    <SolidColorBrush x:Key="ConsoleBorderBrush" Color="{StaticResource ConsoleBorderColor}" />
    <SolidColorBrush x:Key="ConsoleBorderHoverBrush" Color="{StaticResource ConsoleBorderHover}" />
    <SolidColorBrush x:Key="ConsoleBorderFocusBrush" Color="{StaticResource ConsoleBorderFocus}" />
    <SolidColorBrush x:Key="ConsoleTextPrimaryBrush" Color="{StaticResource ConsoleTextPrimary}" />
    <SolidColorBrush x:Key="ConsoleTextSecondaryBrush" Color="{StaticResource ConsoleTextSecondary}" />
    <SolidColorBrush x:Key="ConsoleTextMutedBrush" Color="{StaticResource ConsoleTextMuted}" />
    <SolidColorBrush x:Key="ConsoleTextDisabledBrush" Color="{StaticResource ConsoleTextDisabled}" />
    <SolidColorBrush x:Key="SuccessColorBrush" Color="{StaticResource ConsoleAccentGreen}" />
    <SolidColorBrush x:Key="WarningColorBrush" Color="{StaticResource ConsoleAccentOrange}" />
    <SolidColorBrush x:Key="ErrorColorBrush" Color="{StaticResource ConsoleAccentRed}" />
    <SolidColorBrush x:Key="InfoColorBrush" Color="{StaticResource ConsoleAccentBlue}" />
    <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource ConsoleAccentCyan}" />
    <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource ConsoleAccentPurple}" />
    <SolidColorBrush x:Key="ConsoleAccentGreenDimBrush" Color="{StaticResource ConsoleAccentGreenDim}" />
    <SolidColorBrush x:Key="ConsoleAccentGreenLightBrush" Color="{StaticResource ConsoleAccentGreenLight}" />
    <SolidColorBrush x:Key="ConsoleAccentGreenAlpha10Brush" Color="{StaticResource ConsoleAccentGreenAlpha10}" />
    <SolidColorBrush x:Key="ConsoleAccentGreenAlpha20Brush" Color="{StaticResource ConsoleAccentGreenAlpha20}" />
    <SolidColorBrush x:Key="ConsoleAccentBlueAlpha10Brush" Color="{StaticResource ConsoleAccentBlueAlpha10}" />
    <SolidColorBrush x:Key="ConsoleAccentBlueAlpha20Brush" Color="{StaticResource ConsoleAccentBlueAlpha20}" />
    <SolidColorBrush x:Key="ConsoleAccentRedAlpha10Brush" Color="{StaticResource ConsoleAccentRedAlpha10}" />
    <SolidColorBrush x:Key="ConsoleAccentRedAlpha20Brush" Color="{StaticResource ConsoleAccentRedAlpha20}" />
    <SolidColorBrush x:Key="ConsoleAccentOrangeAlpha10Brush" Color="{StaticResource ConsoleAccentOrangeAlpha10}" />
    <SolidColorBrush x:Key="ConsoleAccentOrangeAlpha20Brush" Color="{StaticResource ConsoleAccentOrangeAlpha20}" />
    <SolidColorBrush x:Key="ConsoleAccentPurpleAlpha10Brush" Color="{StaticResource ConsoleAccentPurpleAlpha10}" />

    <SolidColorBrush x:Key="ModeLiveBrush" Color="{StaticResource ModeLiveColor}" />
    <SolidColorBrush x:Key="ModePaperBrush" Color="{StaticResource ModePaperColor}" />
    <SolidColorBrush x:Key="ModeFixtureBrush" Color="{StaticResource ModeFixtureColor}" />
    <SolidColorBrush x:Key="ModeHealthyBrush" Color="{StaticResource ModeHealthyColor}" />
    <SolidColorBrush x:Key="ModeCriticalBrush" Color="{StaticResource ModeCriticalColor}" />

    <LinearGradientBrush x:Key="GlowGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource ConsoleAccentBlue}" Offset="0" />
        <GradientStop Color="{StaticResource ConsoleAccentGreen}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ShellWindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#08111B" Offset="0" />
        <GradientStop Color="#0C1520" Offset="0.55" />
        <GradientStop Color="#132234" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ShellRailBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0D1722" Offset="0" />
        <GradientStop Color="#0A121B" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeaderBandBackgroundBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#102131" Offset="0" />
        <GradientStop Color="#0C1B29" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PremiumPanelBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#162232" Offset="0" />
        <GradientStop Color="#111B28" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="ProgressSuccessBrush" Color="{StaticResource ConsoleAccentGreen}" />
    <SolidColorBrush x:Key="ProgressWarningBrush" Color="{StaticResource ConsoleAccentOrange}" />
    <SolidColorBrush x:Key="ProgressErrorBrush" Color="{StaticResource ConsoleAccentRed}" />
    <SolidColorBrush x:Key="ProgressInfoBrush" Color="{StaticResource ConsoleAccentBlue}" />
    <SolidColorBrush x:Key="SkeletonBackgroundBrush" Color="{StaticResource ConsoleBackgroundLight}" />
    <SolidColorBrush x:Key="SkeletonHighlightBrush" Color="{StaticResource ConsoleBorderColor}" />
    <SolidColorBrush x:Key="FocusVisualPrimaryBrush" Color="{StaticResource ConsoleAccentBlue}" />
    <SolidColorBrush x:Key="FocusVisualSecondaryBrush" Color="{StaticResource ConsoleBackgroundDark}" />
</ResourceDictionary>
