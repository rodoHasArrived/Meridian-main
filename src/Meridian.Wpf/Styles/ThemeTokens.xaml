<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:views="clr-namespace:Meridian.Wpf.Views">

    <!-- Premium institutional trading platform palette: dark workstation inspired by the Meridian reference mockups. -->

    <!-- Backgrounds: layered navy canvas, panel, hover, and active states -->
    <Color x:Key="ConsoleBackgroundDark">#030A13</Color>
    <Color x:Key="ConsoleBackgroundMedium">#07111D</Color>
    <Color x:Key="ConsoleBackgroundLight">#0B1724</Color>
    <Color x:Key="ConsoleBackgroundHover">#122437</Color>
    <Color x:Key="ConsoleBackgroundActive">#19344F</Color>
    <!-- Elevated card surface: blue-black tint for dense market workbenches -->
    <Color x:Key="ConsoleCardSurface">#0A1522</Color>
    <Color x:Key="ConsoleCardSurfaceRaised">#0E1D2E</Color>

    <!-- Borders: refined hairline separators -->
    <Color x:Key="ConsoleBorderColor">#1B3046</Color>
    <Color x:Key="ConsoleBorderHover">#2A5F86</Color>
    <Color x:Key="ConsoleBorderFocus">#20C7F5</Color>
    <Color x:Key="ConsoleBorderStrong">#386B8F</Color>

    <!-- Text: high-contrast primary, balanced secondaries -->
    <Color x:Key="ConsoleTextPrimary">#F3F8FF</Color>
    <Color x:Key="ConsoleTextSecondary">#A9BCD1</Color>
    <Color x:Key="ConsoleTextMuted">#6E88A4</Color>
    <Color x:Key="ConsoleTextDisabled">#40576F</Color>

    <!-- Accents: premium institutional palette -->
    <Color x:Key="ConsoleAccentGreen">#2DD4A4</Color>
    <Color x:Key="ConsoleAccentGreenDim">#12A77E</Color>
    <Color x:Key="ConsoleAccentGreenLight">#7AF7D0</Color>
    <Color x:Key="ConsoleAccentBlue">#2D9CDB</Color>
    <Color x:Key="ConsoleAccentBlueDim">#1477A8</Color>
    <Color x:Key="ConsoleAccentBlueVibrant">#37BDF8</Color>
    <Color x:Key="ConsoleAccentPurple">#9B7CFF</Color>
    <Color x:Key="ConsoleAccentPurpleDim">#7256D8</Color>
    <Color x:Key="ConsoleAccentRed">#F05D75</Color>
    <Color x:Key="ConsoleAccentRedDim">#D53E5A</Color>
    <Color x:Key="ConsoleAccentOrange">#F6B44B</Color>
    <Color x:Key="ConsoleAccentOrangeDim">#D89026</Color>
    <Color x:Key="ConsoleAccentCyan">#20D3F7</Color>
    <Color x:Key="ConsoleAccentCyanDim">#1396BC</Color>
    <Color x:Key="ConsoleAccentPink">#EC6DAE</Color>
    <Color x:Key="ConsoleAccentYellow">#F5D45A</Color>

    <!-- Alpha overlays for active/badge backgrounds -->
    <Color x:Key="ConsoleAccentGreenAlpha10">#1A2DD4A4</Color>
    <Color x:Key="ConsoleAccentGreenAlpha20">#332DD4A4</Color>
    <Color x:Key="ConsoleAccentBlueAlpha10">#1A2D9CDB</Color>
    <Color x:Key="ConsoleAccentBlueAlpha20">#332D9CDB</Color>
    <Color x:Key="ConsoleAccentRedAlpha10">#1AF05D75</Color>
    <Color x:Key="ConsoleAccentRedAlpha20">#33F05D75</Color>
    <Color x:Key="ConsoleAccentOrangeAlpha10">#1AF6B44B</Color>
    <Color x:Key="ConsoleAccentOrangeAlpha20">#33F6B44B</Color>
    <Color x:Key="ConsoleAccentPurpleAlpha10">#1A9B7CFF</Color>

    <!-- Chart preview tokens from the Meridian design-system bundle -->
    <Color x:Key="ChartSurfaceColor">#0B1520</Color>
    <Color x:Key="ChartPlotAreaColor">#08101A</Color>
    <Color x:Key="ChartGridLineColor">#1A2D44</Color>
    <Color x:Key="ChartAxisLabelColor">#A8B5C4</Color>
    <Color x:Key="ChartBorderColor">#2A4566</Color>
    <Color x:Key="ChartCrosshairColor">#2AB2D4</Color>
    <Color x:Key="ChartPrimaryLineColor">#2AB2D4</Color>
    <Color x:Key="ChartSecondaryLineColor">#60A5FA</Color>
    <Color x:Key="ChartEquityColor">#26BF86</Color>
    <Color x:Key="ChartEquityAlpha20Color">#3326BF86</Color>
    <Color x:Key="ChartDrawdownColor">#DE5878</Color>
    <Color x:Key="ChartDrawdownAlpha20Color">#33DE5878</Color>
    <Color x:Key="ChartWarningLineColor">#D69E38</Color>

    <!-- Mode indicator colors -->
    <Color x:Key="ModeLiveColor">#1A6BB5</Color>
    <Color x:Key="ModePaperColor">#7C3AED</Color>
    <Color x:Key="ModeFixtureColor">#D97706</Color>
    <Color x:Key="ModeHealthyColor">#16A34A</Color>
    <Color x:Key="ModeCriticalColor">#DC2626</Color>

    <!-- Top bar colors: premium deep navy brand bar -->
    <Color x:Key="TopBarBackground">#020812</Color>
    <Color x:Key="TopBarText">#F3F8FF</Color>
    <Color x:Key="TopBarBorder">#15283C</Color>
    <Color x:Key="TopBarIconAccent">#20D3F7</Color>

    <!-- ── Solid brushes ── -->
    <SolidColorBrush x:Key="ConsoleBackgroundDarkBrush"    Color="{StaticResource ConsoleBackgroundDark}" />
    <SolidColorBrush x:Key="ConsoleBackgroundMediumBrush"  Color="{StaticResource ConsoleBackgroundMedium}" />
    <SolidColorBrush x:Key="ConsoleBackgroundLightBrush"   Color="{StaticResource ConsoleBackgroundLight}" />
    <SolidColorBrush x:Key="ConsoleBackgroundHoverBrush"   Color="{StaticResource ConsoleBackgroundHover}" />
    <SolidColorBrush x:Key="ConsoleBackgroundActiveBrush"  Color="{StaticResource ConsoleBackgroundActive}" />
    <SolidColorBrush x:Key="ConsoleCardSurfaceBrush"       Color="{StaticResource ConsoleCardSurface}" />
    <SolidColorBrush x:Key="ConsoleCardSurfaceRaisedBrush" Color="{StaticResource ConsoleCardSurfaceRaised}" />
    <SolidColorBrush x:Key="ConsoleBorderBrush"            Color="{StaticResource ConsoleBorderColor}" />
    <SolidColorBrush x:Key="ConsoleBorderHoverBrush"       Color="{StaticResource ConsoleBorderHover}" />
    <SolidColorBrush x:Key="ConsoleBorderFocusBrush"       Color="{StaticResource ConsoleBorderFocus}" />
    <SolidColorBrush x:Key="ConsoleBorderStrongBrush"      Color="{StaticResource ConsoleBorderStrong}" />
    <SolidColorBrush x:Key="BorderSubtleBrush"             Color="{StaticResource ConsoleBorderColor}" />
    <SolidColorBrush x:Key="ConsoleTextPrimaryBrush"       Color="{StaticResource ConsoleTextPrimary}" />
    <SolidColorBrush x:Key="ConsoleTextSecondaryBrush"     Color="{StaticResource ConsoleTextSecondary}" />
    <SolidColorBrush x:Key="ConsoleTextMutedBrush"         Color="{StaticResource ConsoleTextMuted}" />
    <SolidColorBrush x:Key="ConsoleTextDisabledBrush"      Color="{StaticResource ConsoleTextDisabled}" />
    <!-- Legacy aliases retained for older page XAML -->
    <SolidColorBrush x:Key="ConsoleTextBrush"              Color="{StaticResource ConsoleTextPrimary}" />
    <SolidColorBrush x:Key="ConsoleBackgroundBrush"        Color="{StaticResource ConsoleBackgroundLight}" />
    <SolidColorBrush x:Key="ConsoleWindowBackgroundBrush"  Color="{StaticResource ConsoleBackgroundDark}" />
    <SolidColorBrush x:Key="ConsoleWindowBorderBrush"      Color="{StaticResource ConsoleBorderColor}" />
    <SolidColorBrush x:Key="ConsoleAccentBlueAlpha80Brush" Color="#CC2D9CDB" />
    <SolidColorBrush x:Key="SuccessColorBrush"             Color="{StaticResource ConsoleAccentGreen}" />
    <SolidColorBrush x:Key="WarningColorBrush"             Color="{StaticResource ConsoleAccentOrange}" />
    <SolidColorBrush x:Key="ErrorColorBrush"               Color="{StaticResource ConsoleAccentRed}" />
    <SolidColorBrush x:Key="InfoColorBrush"                Color="{StaticResource ConsoleAccentBlue}" />
    <SolidColorBrush x:Key="ConsoleAccentBlueBrush"        Color="{StaticResource ConsoleAccentBlue}" />
    <SolidColorBrush x:Key="AccentCyanBrush"               Color="{StaticResource ConsoleAccentCyan}" />
    <SolidColorBrush x:Key="AccentPurpleBrush"             Color="{StaticResource ConsoleAccentPurple}" />
    <SolidColorBrush x:Key="ConsoleAccentGreenDimBrush"    Color="{StaticResource ConsoleAccentGreenDim}" />
    <SolidColorBrush x:Key="ConsoleAccentGreenLightBrush"  Color="{StaticResource ConsoleAccentGreenLight}" />
    <SolidColorBrush x:Key="ConsoleAccentGreenAlpha10Brush"  Color="{StaticResource ConsoleAccentGreenAlpha10}" />
    <SolidColorBrush x:Key="ConsoleAccentGreenAlpha20Brush"  Color="{StaticResource ConsoleAccentGreenAlpha20}" />
    <SolidColorBrush x:Key="SuccessColorAlpha20Brush"        Color="{StaticResource ConsoleAccentGreenAlpha20}" />
    <SolidColorBrush x:Key="ConsoleAccentBlueAlpha10Brush"   Color="{StaticResource ConsoleAccentBlueAlpha10}" />
    <SolidColorBrush x:Key="ConsoleAccentBlueAlpha20Brush"   Color="{StaticResource ConsoleAccentBlueAlpha20}" />
    <SolidColorBrush x:Key="ConsoleAccentRedAlpha10Brush"    Color="{StaticResource ConsoleAccentRedAlpha10}" />
    <SolidColorBrush x:Key="ConsoleAccentRedAlpha20Brush"    Color="{StaticResource ConsoleAccentRedAlpha20}" />
    <SolidColorBrush x:Key="ConsoleAccentOrangeAlpha10Brush" Color="{StaticResource ConsoleAccentOrangeAlpha10}" />
    <SolidColorBrush x:Key="ConsoleAccentOrangeAlpha20Brush" Color="{StaticResource ConsoleAccentOrangeAlpha20}" />
    <SolidColorBrush x:Key="ConsoleAccentPurpleAlpha10Brush" Color="{StaticResource ConsoleAccentPurpleAlpha10}" />

    <SolidColorBrush x:Key="ChartSurfaceBrush" Color="{StaticResource ChartSurfaceColor}" />
    <SolidColorBrush x:Key="ChartPlotAreaBrush" Color="{StaticResource ChartPlotAreaColor}" />
    <SolidColorBrush x:Key="ChartGridLineBrush" Color="{StaticResource ChartGridLineColor}" />
    <SolidColorBrush x:Key="ChartAxisLabelBrush" Color="{StaticResource ChartAxisLabelColor}" />
    <SolidColorBrush x:Key="ChartBorderBrush" Color="{StaticResource ChartBorderColor}" />
    <SolidColorBrush x:Key="ChartCrosshairBrush" Color="{StaticResource ChartCrosshairColor}" />
    <SolidColorBrush x:Key="ChartPrimaryLineBrush" Color="{StaticResource ChartPrimaryLineColor}" />
    <SolidColorBrush x:Key="ChartSecondaryLineBrush" Color="{StaticResource ChartSecondaryLineColor}" />
    <SolidColorBrush x:Key="ChartEquityBrush" Color="{StaticResource ChartEquityColor}" />
    <SolidColorBrush x:Key="ChartEquityAlpha20Brush" Color="{StaticResource ChartEquityAlpha20Color}" />
    <SolidColorBrush x:Key="ChartDrawdownBrush" Color="{StaticResource ChartDrawdownColor}" />
    <SolidColorBrush x:Key="ChartDrawdownAlpha20Brush" Color="{StaticResource ChartDrawdownAlpha20Color}" />
    <SolidColorBrush x:Key="ChartWarningLineBrush" Color="{StaticResource ChartWarningLineColor}" />
    <SolidColorBrush x:Key="ChartLoadingOverlayBrush" Color="#D9030A13" />

    <DrawingBrush x:Key="ChartCanvasGridBrush"
                  TileMode="Tile"
                  Viewbox="0,0,40,40"
                  ViewboxUnits="Absolute"
                  Viewport="0,0,40,40"
                  ViewportUnits="Absolute">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource ChartPlotAreaBrush}">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,40,40" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource ChartGridLineBrush}" Thickness="1" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0" EndPoint="40,0" />
                            <LineGeometry StartPoint="0,0" EndPoint="0,40" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <SolidColorBrush x:Key="ModeLiveBrush"     Color="{StaticResource ModeLiveColor}" />
    <SolidColorBrush x:Key="ModePaperBrush"    Color="{StaticResource ModePaperColor}" />
    <SolidColorBrush x:Key="ModeFixtureBrush"  Color="{StaticResource ModeFixtureColor}" />
    <SolidColorBrush x:Key="ModeHealthyBrush"  Color="{StaticResource ModeHealthyColor}" />
    <SolidColorBrush x:Key="ModeCriticalBrush" Color="{StaticResource ModeCriticalColor}" />

    <!-- Goldman blue-to-teal premium gradient (progress bars, accents) -->
    <LinearGradientBrush x:Key="GlowGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource ConsoleAccentBlue}" Offset="0" />
        <GradientStop Color="#20D3F7" Offset="0.5" />
        <GradientStop Color="{StaticResource ConsoleAccentGreen}" Offset="1" />
    </LinearGradientBrush>

    <!-- Premium top-bar gradient: deep navy with subtle cyan edge light -->
    <LinearGradientBrush x:Key="TopBarGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#020812" Offset="0" />
        <GradientStop Color="#071827" Offset="0.64" />
        <GradientStop Color="#04101D" Offset="1" />
    </LinearGradientBrush>

    <!-- Sidebar gradient: deep navy with subtle depth -->
    <LinearGradientBrush x:Key="SidebarGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#030B15" Offset="0" />
        <GradientStop Color="#081523" Offset="0.48" />
        <GradientStop Color="#06101B" Offset="1" />
    </LinearGradientBrush>

    <!-- Sidebar background is needed by shell surface brushes below, so declare it before use. -->
    <Color x:Key="SidebarBackground">#06101B</Color>

    <!-- Shell surfaces: clean, elevated canvas -->
    <SolidColorBrush x:Key="ShellWindowBackgroundBrush" Color="{StaticResource ConsoleBackgroundDark}" />
    <SolidColorBrush x:Key="ShellRailBackgroundBrush"   Color="{StaticResource SidebarBackground}" />

    <!-- Top bar: near-black, Marquee brand bar -->
    <SolidColorBrush x:Key="TopBarBackgroundBrush"      Color="{StaticResource TopBarBackground}" />
    <SolidColorBrush x:Key="TopBarTextBrush"            Color="{StaticResource TopBarText}" />
    <SolidColorBrush x:Key="TopBarBorderBrush"          Color="{StaticResource TopBarBorder}" />
    <SolidColorBrush x:Key="TopBarIconAccentBrush"      Color="{StaticResource TopBarIconAccent}" />

    <!-- HeaderBandBackgroundBrush retained for compatibility; maps to top bar gradient -->
    <SolidColorBrush x:Key="HeaderBandBackgroundBrush"  Color="#020812" />

    <!-- PremiumPanelBrush: primary dark panel surface -->
    <SolidColorBrush x:Key="PremiumPanelBrush"          Color="{StaticResource ConsoleBackgroundLight}" />

    <SolidColorBrush x:Key="ProgressSuccessBrush"       Color="{StaticResource ConsoleAccentGreen}" />
    <SolidColorBrush x:Key="ProgressWarningBrush"       Color="{StaticResource ConsoleAccentOrange}" />
    <SolidColorBrush x:Key="ProgressErrorBrush"         Color="{StaticResource ConsoleAccentRed}" />
    <SolidColorBrush x:Key="ProgressInfoBrush"          Color="{StaticResource ConsoleAccentBlue}" />
    <SolidColorBrush x:Key="SkeletonBackgroundBrush"    Color="{StaticResource ConsoleBackgroundHover}" />
    <SolidColorBrush x:Key="SkeletonHighlightBrush"     Color="{StaticResource ConsoleBorderColor}" />
    <SolidColorBrush x:Key="FocusVisualPrimaryBrush"    Color="{StaticResource ConsoleAccentBlue}" />
    <SolidColorBrush x:Key="FocusVisualSecondaryBrush"  Color="{StaticResource ConsoleBackgroundLight}" />

    <!-- Surface alias keys for components that use MD3-style resource names -->
    <SolidColorBrush x:Key="SurfaceBrush"          Color="{StaticResource ConsoleBackgroundLight}" />
    <SolidColorBrush x:Key="OnSurfaceBrush"        Color="{StaticResource ConsoleTextPrimary}" />
    <SolidColorBrush x:Key="SurfaceVariantBrush"   Color="{StaticResource ConsoleBackgroundHover}" />
    <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="{StaticResource ConsoleTextSecondary}" />
    <SolidColorBrush x:Key="OutlineDimBrush"       Color="{StaticResource ConsoleBorderColor}" />

    <!-- Nav active state: updated for dark sidebar -->
    <SolidColorBrush x:Key="NavActiveBackgroundBrush"   Color="#12304A" />
    <SolidColorBrush x:Key="NavActiveBorderBrush"       Color="#20D3F7" />

    <!-- ── Marquee dark sidebar palette ── -->
    <!-- Deep navy sidebar: premium trading terminal feel -->
    <Color x:Key="SidebarBorderColor">#142A3F</Color>
    <Color x:Key="SidebarHoverColor">#0E2134</Color>
    <Color x:Key="SidebarActiveColor">#122D45</Color>
    <Color x:Key="SidebarActiveIndicatorColor">#20D3F7</Color>
    <Color x:Key="SidebarTileColor">#0B1A2A</Color>
    <Color x:Key="SidebarTileHoverColor">#12304A</Color>
    <Color x:Key="NavItemText">#8DA9C4</Color>
    <Color x:Key="NavItemTextHover">#E6F4FF</Color>
    <Color x:Key="NavItemTextActive">#FFFFFF</Color>
    <Color x:Key="NavSectionLabel">#5D7893</Color>

    <SolidColorBrush x:Key="SidebarBackgroundBrush"          Color="{StaticResource SidebarBackground}" />
    <SolidColorBrush x:Key="SidebarBorderBrush"              Color="{StaticResource SidebarBorderColor}" />
    <SolidColorBrush x:Key="SidebarHoverBrush"               Color="{StaticResource SidebarHoverColor}" />
    <SolidColorBrush x:Key="SidebarActiveBrush"              Color="{StaticResource SidebarActiveColor}" />
    <SolidColorBrush x:Key="SidebarActiveIndicatorBrush"     Color="{StaticResource SidebarActiveIndicatorColor}" />
    <SolidColorBrush x:Key="SidebarTileBrush"                Color="{StaticResource SidebarTileColor}" />
    <SolidColorBrush x:Key="SidebarTileHoverBrush"           Color="{StaticResource SidebarTileHoverColor}" />
    <SolidColorBrush x:Key="NavItemForegroundBrush"          Color="{StaticResource NavItemText}" />
    <SolidColorBrush x:Key="NavItemForegroundHoverBrush"     Color="{StaticResource NavItemTextHover}" />
    <SolidColorBrush x:Key="NavItemForegroundActiveBrush"    Color="{StaticResource NavItemTextActive}" />
    <SolidColorBrush x:Key="NavSectionLabelBrush"            Color="{StaticResource NavSectionLabel}" />

    <!-- ── Dark terminal status bar palette ── -->
    <Color x:Key="StatusBarBackground">#020812</Color>
    <Color x:Key="StatusBarTextColor">#7893AE</Color>
    <Color x:Key="StatusBarBorderColor">#14283A</Color>

    <SolidColorBrush x:Key="StatusBarBackgroundBrush"  Color="{StaticResource StatusBarBackground}" />
    <SolidColorBrush x:Key="StatusBarTextBrush"        Color="{StaticResource StatusBarTextColor}" />
    <SolidColorBrush x:Key="StatusBarBorderBrush"      Color="{StaticResource StatusBarBorderColor}" />

    <!-- ── Command bar (split-pane toolbar) ── -->
    <SolidColorBrush x:Key="CommandBarBackground"    Color="#081523" />
    <SolidColorBrush x:Key="CommandBarBorderBrush"   Color="{StaticResource ConsoleBorderColor}" />

    <!-- ── Layout rhythm tokens ── -->
    <sys:Double x:Key="WorkspaceSectionGap">24</sys:Double>
    <sys:Double x:Key="WorkspaceCardInternalGap">16</sys:Double>
    <sys:Double x:Key="WorkspaceCompactGap">12</sys:Double>
    <sys:Double x:Key="WorkspaceTightGap">8</sys:Double>
    <Thickness x:Key="WorkspaceCardPaddingStandard">20</Thickness>
    <Thickness x:Key="WorkspaceCardPaddingCompact">16</Thickness>
    <Thickness x:Key="WorkspaceSectionCardMargin">0,0,0,24</Thickness>
    <Thickness x:Key="WorkspaceCardHeaderToBodyMargin">0,0,0,16</Thickness>
    <Thickness x:Key="WorkspaceCardBodyToFooterMargin">0,16,0,0</Thickness>
    <Thickness x:Key="WorkspaceSectionDividerMargin">0,16,0,14</Thickness>

    <!-- ── Semantic badge tokens ── -->
    <SolidColorBrush x:Key="BadgeInfoBackgroundBrush" Color="{StaticResource ConsoleAccentBlueAlpha10}" />
    <SolidColorBrush x:Key="BadgeInfoBorderBrush"     Color="{StaticResource ConsoleAccentBlue}" />
    <SolidColorBrush x:Key="BadgeInfoForegroundBrush" Color="{StaticResource ConsoleAccentBlue}" />
    <SolidColorBrush x:Key="BadgeSuccessBackgroundBrush" Color="{StaticResource ConsoleAccentGreenAlpha10}" />
    <SolidColorBrush x:Key="BadgeSuccessBorderBrush"     Color="{StaticResource ConsoleAccentGreen}" />
    <SolidColorBrush x:Key="BadgeSuccessForegroundBrush" Color="{StaticResource ConsoleAccentGreenDim}" />
    <SolidColorBrush x:Key="BadgeWarningBackgroundBrush" Color="{StaticResource ConsoleAccentOrangeAlpha10}" />
    <SolidColorBrush x:Key="BadgeWarningBorderBrush"     Color="{StaticResource ConsoleAccentOrange}" />
    <SolidColorBrush x:Key="BadgeWarningForegroundBrush" Color="{StaticResource ConsoleAccentOrangeDim}" />
    <SolidColorBrush x:Key="BadgeDangerBackgroundBrush" Color="{StaticResource ConsoleAccentRedAlpha10}" />
    <SolidColorBrush x:Key="BadgeDangerBorderBrush"     Color="{StaticResource ConsoleAccentRed}" />
    <SolidColorBrush x:Key="BadgeDangerForegroundBrush" Color="{StaticResource ConsoleAccentRedDim}" />

</ResourceDictionary>
