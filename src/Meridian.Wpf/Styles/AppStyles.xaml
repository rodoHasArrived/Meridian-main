<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ========================================== -->
    <!-- CONSOLE-INSPIRED COLOR PALETTE (GitHub Dark) -->
    <!-- ========================================== -->

    <!-- Background Colors -->
    <Color x:Key="ConsoleBackgroundDark">#0d1117</Color>
    <Color x:Key="ConsoleBackgroundMedium">#161b22</Color>
    <Color x:Key="ConsoleBackgroundLight">#21262d</Color>
    <Color x:Key="ConsoleBackgroundHover">#292e36</Color>
    <Color x:Key="ConsoleBackgroundActive">#33383f</Color>

    <!-- Border Colors -->
    <Color x:Key="ConsoleBorderColor">#30363d</Color>
    <Color x:Key="ConsoleBorderHover">#484f58</Color>
    <Color x:Key="ConsoleBorderFocus">#58a6ff</Color>

    <!-- Text Colors -->
    <Color x:Key="ConsoleTextPrimary">#e6edf3</Color>
    <Color x:Key="ConsoleTextSecondary">#8b949e</Color>
    <Color x:Key="ConsoleTextMuted">#6e7681</Color>
    <Color x:Key="ConsoleTextDisabled">#484f58</Color>

    <!-- Accent Colors -->
    <Color x:Key="ConsoleAccentGreen">#3fb950</Color>
    <Color x:Key="ConsoleAccentGreenDim">#238636</Color>
    <Color x:Key="ConsoleAccentGreenLight">#56d364</Color>
    <Color x:Key="ConsoleAccentBlue">#58a6ff</Color>
    <Color x:Key="ConsoleAccentBlueDim">#1f6feb</Color>
    <Color x:Key="ConsoleAccentPurple">#a371f7</Color>
    <Color x:Key="ConsoleAccentPurpleDim">#8957e5</Color>
    <Color x:Key="ConsoleAccentRed">#f85149</Color>
    <Color x:Key="ConsoleAccentRedDim">#da3633</Color>
    <Color x:Key="ConsoleAccentOrange">#d29922</Color>
    <Color x:Key="ConsoleAccentOrangeDim">#bb8009</Color>
    <Color x:Key="ConsoleAccentCyan">#39c5cf</Color>
    <Color x:Key="ConsoleAccentCyanDim">#2b959d</Color>
    <Color x:Key="ConsoleAccentPink">#db61a2</Color>
    <Color x:Key="ConsoleAccentYellow">#e3b341</Color>

    <!-- Semi-Transparent Accent Colors (for backgrounds) -->
    <Color x:Key="ConsoleAccentGreenAlpha10">#1A3fb950</Color>
    <Color x:Key="ConsoleAccentGreenAlpha20">#333fb950</Color>
    <Color x:Key="ConsoleAccentBlueAlpha10">#1A58a6ff</Color>
    <Color x:Key="ConsoleAccentBlueAlpha20">#3358a6ff</Color>
    <Color x:Key="ConsoleAccentRedAlpha10">#1Af85149</Color>
    <Color x:Key="ConsoleAccentRedAlpha20">#33f85149</Color>
    <Color x:Key="ConsoleAccentOrangeAlpha10">#1Ad29922</Color>
    <Color x:Key="ConsoleAccentOrangeAlpha20">#33d29922</Color>
    <Color x:Key="ConsoleAccentPurpleAlpha10">#1Aa371f7</Color>

    <!-- ========================================== -->
    <!-- SOLID COLOR BRUSHES -->
    <!-- ========================================== -->

    <!-- Background Brushes -->
    <SolidColorBrush x:Key="ConsoleBackgroundDarkBrush" Color="{StaticResource ConsoleBackgroundDark}" />
    <SolidColorBrush x:Key="ConsoleBackgroundMediumBrush" Color="{StaticResource ConsoleBackgroundMedium}" />
    <SolidColorBrush x:Key="ConsoleBackgroundLightBrush" Color="{StaticResource ConsoleBackgroundLight}" />
    <SolidColorBrush x:Key="ConsoleBackgroundHoverBrush" Color="{StaticResource ConsoleBackgroundHover}" />
    <SolidColorBrush x:Key="ConsoleBackgroundActiveBrush" Color="{StaticResource ConsoleBackgroundActive}" />

    <!-- Border Brushes -->
    <SolidColorBrush x:Key="ConsoleBorderBrush" Color="{StaticResource ConsoleBorderColor}" />
    <SolidColorBrush x:Key="ConsoleBorderHoverBrush" Color="{StaticResource ConsoleBorderHover}" />
    <SolidColorBrush x:Key="ConsoleBorderFocusBrush" Color="{StaticResource ConsoleBorderFocus}" />

    <!-- Text Brushes -->
    <SolidColorBrush x:Key="ConsoleTextPrimaryBrush" Color="{StaticResource ConsoleTextPrimary}" />
    <SolidColorBrush x:Key="ConsoleTextSecondaryBrush" Color="{StaticResource ConsoleTextSecondary}" />
    <SolidColorBrush x:Key="ConsoleTextMutedBrush" Color="{StaticResource ConsoleTextMuted}" />
    <SolidColorBrush x:Key="ConsoleTextDisabledBrush" Color="{StaticResource ConsoleTextDisabled}" />

    <!-- Status Colors -->
    <SolidColorBrush x:Key="SuccessColorBrush" Color="{StaticResource ConsoleAccentGreen}" />
    <SolidColorBrush x:Key="WarningColorBrush" Color="{StaticResource ConsoleAccentOrange}" />
    <SolidColorBrush x:Key="ErrorColorBrush" Color="{StaticResource ConsoleAccentRed}" />
    <SolidColorBrush x:Key="InfoColorBrush" Color="{StaticResource ConsoleAccentBlue}" />
    <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource ConsoleAccentCyan}" />
    <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource ConsoleAccentPurple}" />
    <SolidColorBrush x:Key="ConsoleAccentGreenDimBrush" Color="{StaticResource ConsoleAccentGreenDim}" />
    <SolidColorBrush x:Key="ConsoleAccentGreenLightBrush" Color="{StaticResource ConsoleAccentGreenLight}" />
    <SolidColorBrush x:Key="ConsoleAccentGreenAlpha10Brush" Color="{StaticResource ConsoleAccentGreenAlpha10}" />
    <SolidColorBrush x:Key="ConsoleAccentGreenAlpha20Brush" Color="{StaticResource ConsoleAccentGreenAlpha20}" />
    <SolidColorBrush x:Key="ConsoleAccentBlueAlpha10Brush" Color="{StaticResource ConsoleAccentBlueAlpha10}" />
    <SolidColorBrush x:Key="ConsoleAccentBlueAlpha20Brush" Color="{StaticResource ConsoleAccentBlueAlpha20}" />
    <SolidColorBrush x:Key="ConsoleAccentRedAlpha10Brush" Color="{StaticResource ConsoleAccentRedAlpha10}" />
    <SolidColorBrush x:Key="ConsoleAccentRedAlpha20Brush" Color="{StaticResource ConsoleAccentRedAlpha20}" />
    <SolidColorBrush x:Key="ConsoleAccentOrangeAlpha10Brush" Color="{StaticResource ConsoleAccentOrangeAlpha10}" />
    <SolidColorBrush x:Key="ConsoleAccentOrangeAlpha20Brush" Color="{StaticResource ConsoleAccentOrangeAlpha20}" />
    <SolidColorBrush x:Key="ConsoleAccentPurpleAlpha10Brush" Color="{StaticResource ConsoleAccentPurpleAlpha10}" />

    <!-- Glow Effect Brush -->
    <LinearGradientBrush x:Key="GlowGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource ConsoleAccentGreen}" Offset="0" />
        <GradientStop Color="{StaticResource ConsoleAccentCyan}" Offset="1" />
    </LinearGradientBrush>

    <!-- Progress Bar Accent Colors -->
    <SolidColorBrush x:Key="ProgressSuccessBrush" Color="{StaticResource ConsoleAccentGreen}" />
    <SolidColorBrush x:Key="ProgressWarningBrush" Color="{StaticResource ConsoleAccentOrange}" />
    <SolidColorBrush x:Key="ProgressErrorBrush" Color="{StaticResource ConsoleAccentRed}" />
    <SolidColorBrush x:Key="ProgressInfoBrush" Color="{StaticResource ConsoleAccentBlue}" />

    <!-- Skeleton Loading -->
    <SolidColorBrush x:Key="SkeletonBackgroundBrush" Color="{StaticResource ConsoleBackgroundLight}" />
    <SolidColorBrush x:Key="SkeletonHighlightBrush" Color="{StaticResource ConsoleBorderColor}" />

    <!-- Focus Visual -->
    <SolidColorBrush x:Key="FocusVisualPrimaryBrush" Color="{StaticResource ConsoleAccentBlue}" />
    <SolidColorBrush x:Key="FocusVisualSecondaryBrush" Color="{StaticResource ConsoleBackgroundDark}" />

    <!-- ========================================== -->
    <!-- CARD STYLES -->
    <!-- ========================================== -->

    <!-- Clickable Card Style (for navigation items) -->
    <Style x:Key="ClickableCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
    </Style>

    <!-- Elevated Card Style (with subtle shadow effect) -->
    <Style x:Key="ElevatedCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundLightBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Outlined Card Style (transparent background, visible border) -->
    <Style x:Key="OutlinedCardStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <!-- ========================================== -->
    <!-- STATUS INDICATOR STYLES -->
    <!-- ========================================== -->

    <!-- Status Dot Styles -->
    <Style x:Key="StatusDotSmallStyle" TargetType="Ellipse">
        <Setter Property="Width" Value="8" />
        <Setter Property="Height" Value="8" />
    </Style>

    <Style x:Key="StatusDotMediumStyle" TargetType="Ellipse">
        <Setter Property="Width" Value="12" />
        <Setter Property="Height" Value="12" />
    </Style>

    <Style x:Key="StatusDotLargeStyle" TargetType="Ellipse">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
    </Style>

    <Style x:Key="StatusConnectedStyle" TargetType="Ellipse" BasedOn="{StaticResource StatusDotMediumStyle}">
        <Setter Property="Fill" Value="{StaticResource SuccessColorBrush}" />
    </Style>

    <Style x:Key="StatusDisconnectedStyle" TargetType="Ellipse" BasedOn="{StaticResource StatusDotMediumStyle}">
        <Setter Property="Fill" Value="{StaticResource ErrorColorBrush}" />
    </Style>

    <Style x:Key="StatusWarningStyle" TargetType="Ellipse" BasedOn="{StaticResource StatusDotMediumStyle}">
        <Setter Property="Fill" Value="{StaticResource WarningColorBrush}" />
    </Style>

    <!-- Severity Bar (for alerts) -->
    <Style x:Key="SeverityBarStyle" TargetType="Border">
        <Setter Property="Width" Value="4" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>

    <!-- ========================================== -->
    <!-- BUTTON STYLES (WPF Compatible with Templates) -->
    <!-- ========================================== -->

    <!-- Secondary Button Style -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundLightBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ConsoleBackgroundHoverBrush}" />
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource ConsoleBorderHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ConsoleBackgroundActiveBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Danger Button Style -->
    <Style x:Key="DangerButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource ErrorColorBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ErrorColorBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ConsoleAccentRedAlpha10Brush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ConsoleAccentRedAlpha20Brush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Subtle Button (Low emphasis) -->
    <Style x:Key="SubtleButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundLightBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ConsoleBackgroundHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ConsoleBackgroundActiveBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========================================== -->
    <!-- TAG STYLES -->
    <!-- ========================================== -->

    <Style x:Key="TagStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,4" />
    </Style>

    <Style x:Key="TagIBStyle" TargetType="Border" BasedOn="{StaticResource TagStyle}">
        <Setter Property="Background" Value="{StaticResource ConsoleAccentBlueAlpha10Brush}" />
        <Setter Property="BorderBrush" Value="#4D58a6ff" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="TagAlpacaStyle" TargetType="Border" BasedOn="{StaticResource TagStyle}">
        <Setter Property="Background" Value="{StaticResource ConsoleAccentOrangeAlpha10Brush}" />
        <Setter Property="BorderBrush" Value="#4Dd29922" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="TagPolygonStyle" TargetType="Border" BasedOn="{StaticResource TagStyle}">
        <Setter Property="Background" Value="{StaticResource ConsoleAccentPurpleAlpha10Brush}" />
        <Setter Property="BorderBrush" Value="#4Da371f7" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- ========================================== -->
    <!-- BADGE STYLES -->
    <!-- ========================================== -->

    <!-- Count Badge -->
    <Style x:Key="CountBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundLightBrush}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Live Badge -->
    <Style x:Key="LiveBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SuccessColorBrush}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="10,4" />
    </Style>

    <!-- Stream Badges -->
    <Style x:Key="StreamBadgeActiveStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SuccessColorBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,6" />
    </Style>

    <Style x:Key="StreamBadgeInactiveStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ConsoleTextMutedBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,6" />
    </Style>

    <!-- Status Badges -->
    <Style x:Key="WarningBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ConsoleAccentOrangeAlpha10Brush}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style x:Key="ErrorBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ConsoleAccentRedAlpha10Brush}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style x:Key="InfoBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ConsoleAccentBlueAlpha10Brush}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <!-- ========================================== -->
    <!-- FORM INPUT STYLES -->
    <!-- ========================================== -->

    <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundDarkBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="FontFamily" Value="Consolas, Courier New" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer x:Name="PART_ContentHost" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource ConsoleBorderHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource ConsoleBorderFocusBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FormComboBoxStyle" TargetType="ComboBox">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundDarkBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
    </Style>

    <!-- Form Label -->
    <Style x:Key="FormLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <!-- Form Hint -->
    <Style x:Key="FormHintStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextMutedBrush}" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <!-- ========================================== -->
    <!-- TYPOGRAPHY STYLES -->
    <!-- ========================================== -->

    <!-- Page Subtitle -->
    <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,24" />
    </Style>

    <!-- Card Header -->
    <Style x:Key="CardHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
    </Style>

    <!-- Subtitle -->
    <Style x:Key="SubtitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
    </Style>

    <!-- Caption -->
    <Style x:Key="CaptionTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextMutedBrush}" />
    </Style>

    <!-- Body -->
    <Style x:Key="BodyTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
    </Style>

    <!-- Code/Mono Text Style -->
    <Style x:Key="MonoTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Code, JetBrains Mono, Consolas, Courier New, monospace" />
        <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}" />
    </Style>

    <!-- Stat Value (compact) -->
    <Style x:Key="StatValueCompactStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Code, JetBrains Mono, Consolas, monospace" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
    </Style>

    <!-- Stat Label (compact) -->
    <Style x:Key="StatLabelCompactStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextMutedBrush}" />
    </Style>

    <!-- ========================================== -->
    <!-- TERMINAL STYLES -->
    <!-- ========================================== -->

    <Style x:Key="TerminalHeaderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundLightBrush}" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="CornerRadius" Value="8,8,0,0" />
    </Style>

    <Style x:Key="TerminalBodyStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundDarkBrush}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="CornerRadius" Value="0,0,8,8" />
    </Style>

    <Style x:Key="TerminalPromptStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
        <Setter Property="Foreground" Value="{StaticResource SuccessColorBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="TerminalMessageStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- ========================================== -->
    <!-- TABLE STYLES -->
    <!-- ========================================== -->

    <Style x:Key="TableHeaderStyle" TargetType="Border" BasedOn="{StaticResource TerminalHeaderStyle}" />

    <Style x:Key="TableHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
    </Style>

    <Style x:Key="TableRowStyle" TargetType="ListViewItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- ========================================== -->
    <!-- DIVIDER STYLES -->
    <!-- ========================================== -->

    <Style x:Key="VerticalDividerStyle" TargetType="Rectangle">
        <Setter Property="Width" Value="1" />
        <Setter Property="Fill" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="Margin" Value="12,0" />
    </Style>

    <!-- ========================================== -->
    <!-- INLINE CODE STYLES -->
    <!-- ========================================== -->

    <Style x:Key="InlineCodeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundLightBrush}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="6,2" />
    </Style>

    <Style x:Key="InlineCodeTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Code, JetBrains Mono, Consolas, monospace" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}" />
    </Style>

    <!-- ========================================== -->
    <!-- KEYBOARD SHORTCUT STYLES -->
    <!-- ========================================== -->

    <Style x:Key="KeyboardKeyStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundLightBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderHoverBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="MinWidth" Value="24" />
    </Style>

    <Style x:Key="KeyboardKeyTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- ========================================== -->
    <!-- TOOLTIP STYLES -->
    <!-- ========================================== -->

    <Style x:Key="DarkTooltipStyle" TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundDarkBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,6" />
    </Style>

    <!-- ========================================== -->
    <!-- LOADING STYLES -->
    <!-- ========================================== -->

    <Style x:Key="LoadingOverlayStyle" TargetType="Grid">
        <Setter Property="Background" Value="#80000000" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="LoadingTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,12,0,0" />
    </Style>

    <!-- Skeleton Styles -->
    <Style x:Key="SkeletonTextStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SkeletonBackgroundBrush}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Height" Value="16" />
    </Style>

    <Style x:Key="SkeletonCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SkeletonBackgroundBrush}" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>

    <!-- ========================================== -->
    <!-- EMPTY STATE STYLES -->
    <!-- ========================================== -->

    <Style x:Key="EmptyStateContainerStyle" TargetType="StackPanel">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="40" />
    </Style>

    <Style x:Key="EmptyStateTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="EmptyStateDescriptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextMutedBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="MaxWidth" Value="400" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- ========================================== -->
    <!-- LAYOUT STYLES -->
    <!-- ========================================== -->

    <Style x:Key="PageContainerStyle" TargetType="ScrollViewer">
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundDarkBrush}" />
    </Style>

    <Style x:Key="ProgressRingContainerStyle" TargetType="Grid">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="StatContainerStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <!-- Top Border Accent -->
    <Style x:Key="AccentTopBorderStyle" TargetType="Border">
        <Setter Property="Height" Value="2" />
        <Setter Property="CornerRadius" Value="1" />
        <Setter Property="Background" Value="{StaticResource GlowGradientBrush}" />
    </Style>

    <!-- ========================================== -->
    <!-- SPACING CONSTANTS -->
    <!-- ========================================== -->

    <Thickness x:Key="PagePadding">24</Thickness>
    <Thickness x:Key="CardPadding">20</Thickness>
    <Thickness x:Key="CompactPadding">12</Thickness>
    <Thickness x:Key="SectionSpacing">0,0,0,24</Thickness>
    <Thickness x:Key="ItemSpacing">0,0,0,12</Thickness>
    <Thickness x:Key="FocusVisualPrimaryThickness">2</Thickness>
    <Thickness x:Key="FocusVisualSecondaryThickness">1</Thickness>
    <Thickness x:Key="NavigationViewContentMargin">0,0,0,0</Thickness>
    <Thickness x:Key="NavigationViewHeaderMargin">0,0,0,0</Thickness>

    <sys:Double x:Key="SmallSpacing">8</sys:Double>
    <sys:Double x:Key="MediumSpacing">12</sys:Double>
    <sys:Double x:Key="LargeSpacing">16</sys:Double>
    <sys:Double x:Key="XLargeSpacing">24</sys:Double>

    <!-- Responsive Layout Constants -->
    <sys:Double x:Key="CompactBreakpoint">640</sys:Double>
    <sys:Double x:Key="MediumBreakpoint">1007</sys:Double>
    <sys:Double x:Key="WideBreakpoint">1366</sys:Double>
    <sys:Double x:Key="SidebarWidthCompact">48</sys:Double>
    <sys:Double x:Key="SidebarWidthExpanded">280</sys:Double>
    <sys:Double x:Key="ContentMaxWidth">1400</sys:Double>
    <sys:Double x:Key="FormMaxWidth">600</sys:Double>

    <!-- Animation Durations (WPF uses Duration type) -->
    <Duration x:Key="QuickAnimationDuration">0:0:0.15</Duration>
    <Duration x:Key="NormalAnimationDuration">0:0:0.25</Duration>
    <Duration x:Key="SlowAnimationDuration">0:0:0.4</Duration>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- IMPLICIT DARK-THEME CONTROL STYLES                     -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <!-- DataGrid: Dark-themed with row hover, selection, and grid lines -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundDarkBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="RowBackground" Value="Transparent" />
        <Setter Property="AlternatingRowBackground" Value="{StaticResource ConsoleBackgroundLightBrush}" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="RowHeaderWidth" Value="0" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundLightBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="SeparatorBrush" Value="{StaticResource ConsoleBorderBrush}" />
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource ConsoleAccentBlueAlpha10Brush}" />
                <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource ConsoleBackgroundHoverBrush}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource ConsoleAccentBlueAlpha10Brush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ListView: Dark-themed -->
    <Style TargetType="ListView">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style TargetType="ListViewItem">
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ConsoleBackgroundHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ConsoleAccentBlueAlpha10Brush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ProgressBar: Dark-themed with rounded corners -->
    <Style TargetType="ProgressBar">
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundLightBrush}" />
        <Setter Property="Foreground" Value="{StaticResource SuccessColorBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Height" Value="6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <Border x:Name="PART_Track"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3" />
                        <Border x:Name="PART_Indicator"
                                Background="{TemplateBinding Foreground}"
                                CornerRadius="3"
                                HorizontalAlignment="Left" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ToolTip: Dark-themed -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundLightBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- Separator: Dark-themed -->
    <Style TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="0,8" />
    </Style>

    <!-- GridViewColumnHeader: Dark-themed for GridView inside ListView -->
    <Style TargetType="GridViewColumnHeader">
        <Setter Property="Background" Value="{StaticResource ConsoleBackgroundLightBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
    </Style>

</ResourceDictionary>
