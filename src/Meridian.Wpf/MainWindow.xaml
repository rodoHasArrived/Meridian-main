<Window x:Class="Meridian.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Meridian.Wpf"
        xmlns:views="clr-namespace:Meridian.Wpf.Views"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Meridian"
        Height="900" Width="1400"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ShellWindowBackgroundBrush}"
        Loaded="OnWindowLoaded"
        Closing="OnWindowClosing"
        KeyDown="OnWindowKeyDown"
        AutomationProperties.Name="Meridian">

    <Window.InputBindings>
        <!-- Navigation shortcuts -->
        <KeyBinding Key="D" Modifiers="Control" Command="{Binding NavigateCommand}" CommandParameter="Dashboard" />
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="{Binding StartCollectorCommand}" />
        <KeyBinding Key="Q" Modifiers="Control+Shift" Command="{Binding StopCollectorCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <!-- Fixture/Offline Mode Banner (P0: Hard visual distinction for non-live modes) -->
        <Border x:Name="FixtureModeBanner"
                Grid.Row="0"
                Visibility="{Binding FixtureModeBannerVisibility}"
                Padding="8,6"
                CornerRadius="0"
                Background="{Binding FixtureModeBannerBackground}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="&#xE7BA;"
                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                           FontSize="16"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBlock x:Name="FixtureModeText"
                           Grid.Column="1"
                           Text="{Binding FixtureModeText}"
                           Foreground="White"
                           FontWeight="SemiBold"
                           FontSize="12"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="2"
                           Text="&#xE8BB;"
                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                           FontSize="14"
                           Foreground="White"
                           Opacity="0.7"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
            </Grid>
        </Border>

        <Frame x:Name="RootFrame"
               Grid.Row="1"
               AllowDrop="True"
               Background="{DynamicResource ShellWindowBackgroundBrush}"
               NavigationUIVisibility="Hidden"
               Navigated="OnRootFrameNavigated"
               DragEnter="OnRootFrameDragEnter"
               DragOver="OnRootFrameDragOver"
               DragLeave="OnRootFrameDragLeave"
               Drop="OnRootFrameDrop" />

        <!-- Drop overlay: shown while a file drag is in progress over the window -->
        <Grid x:Name="DropOverlay"
              Grid.Row="0" Grid.RowSpan="2"
              Visibility="Collapsed"
              IsHitTestVisible="False"
              Panel.ZIndex="100">
            <Rectangle Fill="#AA1A3A5C" />
            <Border BorderBrush="#4499CC" BorderThickness="3" Margin="24" CornerRadius="8">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="DropOverlayIcon"
                               Text="&#xE896;"
                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                               FontSize="48" Foreground="White"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="DropOverlayTitle"
                               Text="Drop to Import"
                               FontSize="24" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" Margin="0,12,0,4" />
                    <TextBlock x:Name="DropOverlaySubtitle"
                               Text="CSV · JSON · JSONL · Parquet"
                               FontSize="14" Foreground="#AACCFF"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Clipboard symbol detection banner: floats at top of content area when symbols found -->
        <Border x:Name="ClipboardSymbolBanner"
                Grid.Row="1"
                VerticalAlignment="Top"
                Visibility="{Binding ClipboardBannerVisibility}"
                Padding="12,8"
                Panel.ZIndex="50"
                Background="#1A2A4A"
                BorderBrush="#4488CC" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="&#xE72D;"
                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                           Foreground="#66AAFF" FontSize="16"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="ClipboardBannerText"
                           Grid.Column="1"
                           Foreground="White" VerticalAlignment="Center" FontSize="13"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding ClipboardBannerText}"/>
                <Button x:Name="ClipboardAddButton"
                        Grid.Column="2"
                        Content="Add to Watchlist"
                        Margin="12,0,8,0" Padding="10,4"
                        Command="{Binding AddClipboardSymbolsCommand}"/>
                <Button x:Name="ClipboardDismissButton"
                        Grid.Column="3"
                        Content="Dismiss"
                        Padding="10,4"
                        Command="{Binding DismissClipboardBannerCommand}"/>
            </Grid>
        </Border>

        <!-- Persistent status bar: pinned to bottom, 32px height -->
        <views:StatusBarControl Grid.Row="2" DataContext="{Binding StatusBar}" />
    </Grid>
</Window>
