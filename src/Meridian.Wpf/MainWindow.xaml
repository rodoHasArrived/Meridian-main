<Window x:Class="Meridian.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Meridian.Wpf"
        xmlns:views="clr-namespace:Meridian.Wpf.Views"
        xmlns:converters="clr-namespace:Meridian.Wpf.Converters"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Meridian"
        Height="900" Width="1400"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ShellWindowBackgroundBrush}"
        Loaded="OnWindowLoaded"
        Closing="OnWindowClosing"
        KeyDown="OnWindowKeyDown"
        AutomationProperties.Name="Meridian">

    <Window.Resources>
        <converters:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
    </Window.Resources>

    <Window.InputBindings>
        <!-- Navigation shortcuts -->
        <KeyBinding Key="D" Modifiers="Control" Command="{Binding NavigateCommand}" CommandParameter="Dashboard" />
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="{Binding StartCollectorCommand}" />
        <KeyBinding Key="Q" Modifiers="Control+Shift" Command="{Binding StopCollectorCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
        <!-- Fixture mode: cycle scenario (only active when fixture mode is on) -->
        <KeyBinding Key="N" Modifiers="Control+Shift" Command="{Binding CycleFixtureScenarioCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <!-- Fixture/Offline Mode Banner (P0: Hard visual distinction for non-live modes) -->
        <Border x:Name="FixtureModeBanner"
                Grid.Row="0"
                Visibility="{Binding FixtureModeBannerVisibility}"
                Padding="8,6"
                CornerRadius="0"
                Background="{Binding FixtureModeBannerBackground}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="&#xE7BA;"
                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                           FontSize="16"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBlock x:Name="FixtureModeText"
                           Grid.Column="1"
                           Text="{Binding FixtureModeText}"
                           Foreground="White"
                           FontWeight="SemiBold"
                           FontSize="12"
                           VerticalAlignment="Center" />
                <!-- Scenario label: only visible in fixture mode (not offline-only mode) -->
                <Border Grid.Column="2"
                        Background="#33FFFFFF"
                        CornerRadius="3"
                        Padding="6,2"
                        Margin="8,0,4,0"
                        VerticalAlignment="Center"
                        Visibility="{Binding FixtureScenarioLabel, Converter={StaticResource NullToCollapsedConverter}}">
                    <TextBlock Text="{Binding FixtureScenarioLabel}"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="Medium" />
                </Border>
                <!-- Cycle scenario button: advances to next fixture scenario -->
                <Button Grid.Column="3"
                        Content="Next scenario  ·  Ctrl+⇧+N"
                        Command="{Binding CycleFixtureScenarioCommand}"
                        Padding="8,2"
                        Margin="4,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Background="#44FFFFFF"
                        Foreground="White"
                        BorderBrush="#66FFFFFF"
                        BorderThickness="1"
                        Cursor="Hand"
                        ToolTip="Cycle through fixture scenarios: Connected → Disconnected → Degraded → Error → Loading" />
                <TextBlock Grid.Column="4"
                           Text="&#xE8BB;"
                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                           FontSize="14"
                           Foreground="White"
                           Opacity="0.7"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
            </Grid>
        </Border>

        <Frame x:Name="RootFrame"
               Grid.Row="1"
               AllowDrop="True"
               Background="{DynamicResource ShellWindowBackgroundBrush}"
               NavigationUIVisibility="Hidden"
               Navigated="OnRootFrameNavigated"
               DragEnter="OnRootFrameDragEnter"
               DragOver="OnRootFrameDragOver"
               DragLeave="OnRootFrameDragLeave"
               Drop="OnRootFrameDrop" />

        <!-- Drop overlay: shown while a file drag is in progress over the window -->
        <Grid x:Name="DropOverlay"
              Grid.Row="0" Grid.RowSpan="2"
              Visibility="Collapsed"
              IsHitTestVisible="False"
              Panel.ZIndex="100">
            <Rectangle Fill="#AA1A3A5C" />
            <Border BorderBrush="#4499CC" BorderThickness="3" Margin="24" CornerRadius="8">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="DropOverlayIcon"
                               Text="&#xE896;"
                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                               FontSize="48" Foreground="White"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="DropOverlayTitle"
                               Text="Drop to Import"
                               FontSize="24" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" Margin="0,12,0,4" />
                    <TextBlock x:Name="DropOverlaySubtitle"
                               Text="CSV · JSON · JSONL · Parquet"
                               FontSize="14" Foreground="#AACCFF"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Clipboard symbol detection banner: light theme, Marquee-style -->
        <Border x:Name="ClipboardSymbolBanner"
                Grid.Row="1"
                VerticalAlignment="Top"
                Visibility="{Binding ClipboardBannerVisibility}"
                Padding="16,8"
                Panel.ZIndex="50"
                Background="{StaticResource ConsoleBackgroundLightBrush}"
                BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="&#xE72D;"
                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                           Foreground="{StaticResource InfoColorBrush}" FontSize="14"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="ClipboardBannerText"
                           Grid.Column="1"
                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" VerticalAlignment="Center" FontSize="13"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding ClipboardBannerText}"/>
                <Button x:Name="ClipboardAddButton"
                        Grid.Column="2"
                        Content="Add to Watchlist"
                        Margin="12,0,8,0" Padding="10,4"
                        Command="{Binding AddClipboardSymbolsCommand}"/>
                <Button x:Name="ClipboardDismissButton"
                        Grid.Column="3"
                        Content="Dismiss"
                        Padding="10,4"
                        Command="{Binding DismissClipboardBannerCommand}"/>
            </Grid>
        </Border>

        <!-- Persistent status bar: pinned to bottom, 32px height -->
        <views:StatusBarControl Grid.Row="2" DataContext="{Binding StatusBar}" />
    </Grid>
</Window>
