<Page x:Class="Meridian.Wpf.Views.RunMatPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      Unloaded="OnPageUnloaded"
      AutomationProperties.Name="RunMat Lab"
      AutomationProperties.AutomationId="RunMatPage">
    <Grid Margin="24"
          AutomationProperties.AutomationId="RunMatPageLayout"
          AutomationProperties.Name="RunMat Page Layout">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <TextBlock x:Name="RunMatAutomationStatusText"
                   Visibility="Collapsed"
                   Text="{Binding StatusText}"
                   AutomationProperties.AutomationId="RunMatAutomationStatus"
                   AutomationProperties.Name="RunMat Automation Status" />
        <TextBlock x:Name="RunMatAutomationLastRunText"
                   Visibility="Collapsed"
                   Text="{Binding LastRunSummary}"
                   AutomationProperties.AutomationId="RunMatAutomationLastRun"
                   AutomationProperties.Name="RunMat Automation Last Run" />
        <TextBlock x:Name="RunMatAutomationResolvedExecutableText"
                   Visibility="Collapsed"
                   Text="{Binding ResolvedExecutablePath}"
                   AutomationProperties.AutomationId="RunMatAutomationResolvedExecutable"
                   AutomationProperties.Name="RunMat Automation Resolved Executable" />

        <Border Grid.Row="0" Grid.ColumnSpan="5" Style="{StaticResource SectionCardStyle}"
                AutomationProperties.Name="RunMat Hero">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="14"
                        Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                        BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1">
                    <TextBlock Text="&#xE943;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                               FontSize="24" Foreground="{StaticResource InfoColorBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
                <StackPanel Margin="12,0,0,0">
                    <TextBlock Text="RunMat Lab" Style="{StaticResource PageTitleStyle}" />
                    <TextBlock Text="Research scripts, runtime settings, and saved MATLAB-style execution workflows."
                               Style="{StaticResource CardDescriptionStyle}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CardStyle}" Padding="16"
                AutomationProperties.AutomationId="RunMatSettingsPanel"
                AutomationProperties.Name="RunMat Settings Panel">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="RunMat Lab" Style="{StaticResource CardHeaderStyle}"
                               AutomationProperties.AutomationId="RunMatPageTitle"
                               AutomationProperties.Name="RunMat Lab Title" />
                    <TextBlock Text="Research scripts, runtime settings, and saved `.m` files."
                               Style="{StaticResource CardDescriptionStyle}" Margin="0,4,0,14" TextWrapping="Wrap" />

                    <TextBlock Text="Executable Path" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                    <TextBox x:Name="ExecutablePathTextBox"
                             Text="{Binding ExecutablePath, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}"
                             Margin="0,4,0,12"
                             AutomationProperties.AutomationId="RunMatExecutablePathInput"
                             AutomationProperties.Name="RunMat Executable Path" />

                    <TextBlock Text="Working Directory" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                    <TextBox x:Name="WorkingDirectoryTextBox"
                             Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}"
                             Margin="0,4,0,12"
                             AutomationProperties.AutomationId="RunMatWorkingDirectoryInput"
                             AutomationProperties.Name="RunMat Working Directory" />

                    <TextBlock Text="Additional Arguments" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                    <TextBox x:Name="AdditionalArgumentsTextBox"
                             Text="{Binding AdditionalArguments, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}"
                             Margin="0,4,0,12"
                             AutomationProperties.AutomationId="RunMatAdditionalArgumentsInput"
                             AutomationProperties.Name="RunMat Additional Arguments" />

                    <TextBlock Text="Saved Scripts" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,4,0,4" />
                    <Button x:Name="RefreshScriptsButton"
                            Content="Refresh Scripts"
                            Command="{Binding RefreshScriptsCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            HorizontalAlignment="Left"
                            AutomationProperties.AutomationId="RunMatRefreshScriptsButton"
                            AutomationProperties.Name="Refresh RunMat Scripts"
                            Margin="0,0,0,8" />
                </StackPanel>

                <ListBox x:Name="SavedScriptsListBox"
                         ItemsSource="{Binding Scripts}"
                         SelectedItem="{Binding SelectedScript, Mode=TwoWay}"
                         Background="{StaticResource ConsoleBackgroundLightBrush}"
                         BorderBrush="{StaticResource ConsoleBorderBrush}"
                         BorderThickness="1"
                         AutomationProperties.AutomationId="RunMatSavedScriptsList"
                         AutomationProperties.Name="RunMat Saved Scripts">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                    <TextBlock Text="{Binding LastWriteTimeUtc, StringFormat='Updated {0:yyyy-MM-dd HH:mm} UTC'}"
                                               FontSize="11"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource CardStyle}" Padding="16"
                AutomationProperties.AutomationId="RunMatEditorPanel"
                AutomationProperties.Name="RunMat Editor Panel">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Script Editor" Style="{StaticResource CardHeaderStyle}"
                                       AutomationProperties.AutomationId="RunMatEditorTitle"
                                       AutomationProperties.Name="RunMat Script Editor Title" />
                            <TextBlock Text="{Binding StatusText}" Style="{StaticResource CardDescriptionStyle}" Margin="0,4,0,0"
                                       AutomationProperties.AutomationId="RunMatStatusText"
                                       AutomationProperties.Name="RunMat Status Text" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="NewScriptButton" Content="New" Command="{Binding NewScriptCommand}" Style="{StaticResource GhostButtonStyle}" Margin="0,0,8,0"
                                    AutomationProperties.AutomationId="RunMatNewScriptButton"
                                    AutomationProperties.Name="New RunMat Script" />
                            <Button x:Name="LoadScriptButton" Content="Load" Command="{Binding LoadSelectedScriptCommand}" Style="{StaticResource GhostButtonStyle}" Margin="0,0,8,0"
                                    AutomationProperties.AutomationId="RunMatLoadScriptButton"
                                    AutomationProperties.Name="Load RunMat Script" />
                            <Button x:Name="SaveScriptButton" Content="Save" Command="{Binding SaveScriptCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"
                                    AutomationProperties.AutomationId="RunMatSaveScriptButton"
                                    AutomationProperties.Name="Save RunMat Script" />
                            <Button x:Name="RunScriptButton" Content="Run" Command="{Binding RunScriptCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"
                                    AutomationProperties.AutomationId="RunMatRunScriptButton"
                                    AutomationProperties.Name="Run RunMat Script" />
                            <Button x:Name="StopScriptButton" Content="Stop" Command="{Binding StopRunCommand}" Style="{StaticResource GhostButtonStyle}"
                                    AutomationProperties.AutomationId="RunMatStopScriptButton"
                                    AutomationProperties.Name="Stop RunMat Script" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Script Name" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                    <TextBox x:Name="ScriptNameTextBox"
                             Text="{Binding ScriptName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}"
                             Margin="0,4,0,12"
                             AutomationProperties.AutomationId="RunMatScriptNameInput"
                             AutomationProperties.Name="RunMat Script Name" />
                </StackPanel>

                <TextBox x:Name="ScriptSourceTextBox"
                         Text="{Binding ScriptSource, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         FontFamily="Cascadia Code, Consolas, monospace"
                         FontSize="13"
                         Background="{StaticResource PremiumPanelBrush}"
                         Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                         BorderBrush="{StaticResource ConsoleBorderBrush}"
                         BorderThickness="1"
                         AutomationProperties.AutomationId="RunMatScriptSourceEditor"
                         AutomationProperties.Name="RunMat Script Source Editor" />
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Grid.Column="4" Style="{StaticResource CardStyle}" Padding="16"
                AutomationProperties.AutomationId="RunMatOutputPanel"
                AutomationProperties.Name="RunMat Output Panel">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Run Output" Style="{StaticResource CardHeaderStyle}"
                               AutomationProperties.AutomationId="RunMatOutputTitle"
                               AutomationProperties.Name="RunMat Output Title" />
                    <TextBlock Text="{Binding ServiceStatus}" Style="{StaticResource CardDescriptionStyle}" Margin="0,4,0,12" TextWrapping="Wrap"
                               AutomationProperties.AutomationId="RunMatServiceStatus"
                               AutomationProperties.Name="RunMat Service Status" />

                    <Border Background="{StaticResource PremiumPanelBrush}" CornerRadius="12" Padding="10" Margin="0,0,0,12"
                            AutomationProperties.AutomationId="RunMatResolvedExecutablePanel"
                            AutomationProperties.Name="RunMat Resolved Executable Panel">
                        <StackPanel>
                            <TextBlock Text="Resolved Executable" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                            <TextBlock Text="{Binding ResolvedExecutablePath}" FontFamily="Cascadia Code, Consolas, monospace"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}" TextWrapping="Wrap"
                                       AutomationProperties.AutomationId="RunMatResolvedExecutablePath"
                                       AutomationProperties.Name="RunMat Resolved Executable Path" />
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource PremiumPanelBrush}" CornerRadius="12" Padding="10" Margin="0,0,0,12"
                            AutomationProperties.AutomationId="RunMatLastRunPanel"
                            AutomationProperties.Name="RunMat Last Run Panel">
                        <StackPanel>
                            <TextBlock Text="Last Run" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                            <TextBlock Text="{Binding LastRunSummary}" Foreground="{StaticResource ConsoleTextPrimaryBrush}" TextWrapping="Wrap"
                                       AutomationProperties.AutomationId="RunMatLastRunSummary"
                                       AutomationProperties.Name="RunMat Last Run Summary" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <ListBox x:Name="OutputLinesListBox"
                         ItemsSource="{Binding OutputLines}"
                         Background="{StaticResource PremiumPanelBrush}"
                         BorderBrush="{StaticResource ConsoleBorderBrush}"
                         BorderThickness="1"
                         AutomationProperties.AutomationId="RunMatOutputList"
                         AutomationProperties.Name="RunMat Output Lines">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6">
                                <TextBlock TextWrapping="Wrap">
                                    <Run Text="{Binding TimestampUtc, StringFormat='[{0:HH:mm:ss}] '}" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                    <Run Text="{Binding Text}" Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</Page>
