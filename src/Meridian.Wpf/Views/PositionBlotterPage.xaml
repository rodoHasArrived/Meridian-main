<Page x:Class="Meridian.Wpf.Views.PositionBlotterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="clr-namespace:Meridian.Wpf.Models"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      Unloaded="OnPageUnloaded"
      AutomationProperties.Name="Position Blotter"
      AutomationProperties.AutomationId="PositionBlotterPage">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="FilterChipStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ConsoleAccentBlueAlpha20Brush}" />
            <Setter Property="BorderBrush" Value="{StaticResource InfoColorBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="ContextChipStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ConsoleBackgroundLightBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="NumericCellTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Cascadia Code, JetBrains Mono, Consolas, monospace" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="NumericMetricTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource StatValueCompactStyle}">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="TextAlignment" Value="Right" />
        </Style>

        <Style x:Key="ExpandIconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource SymbolThemeFontFamily}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextMutedBrush}" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource EmbeddedShellCompactHeaderCardStyle}" Margin="24,20,24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Style="{StaticResource EmbeddedShellHeaderIdentityStackPanelStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="44"
                                Height="44"
                                CornerRadius="14"
                                Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                BorderBrush="{StaticResource InfoColorBrush}"
                                BorderThickness="1"
                                Margin="0,0,12,0">
                            <TextBlock Text="&#xE8EC;"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="22"
                                       Foreground="{StaticResource InfoColorBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Position Blotter" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="{Binding StatusText}"
                                       Style="{StaticResource CardDescriptionStyle}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0">
                    <TextBlock Text="{Binding SelectionSummaryText}"
                               Style="{StaticResource EmbeddedShellHostedOnlyTextBlockStyle}"
                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />
                    <Button Content="Upsize"
                            Command="{Binding UpsizeCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            ToolTip="Increase quantity on selected positions"
                            Margin="0,0,8,0" />
                    <Button Content="Terminate"
                            Command="{Binding TerminateCommand}"
                            Style="{StaticResource DangerButtonStyle}"
                            ToolTip="Close or flatten selected positions"
                            Margin="0,0,8,0" />
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource GhostButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource WorkspaceCommandBarSurfaceStyle}" Margin="24,12,24,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0"
                            Grid.ColumnSpan="3"
                            Orientation="Horizontal"
                            Margin="0,0,0,12">
                    <Border Style="{StaticResource ContextChipStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Entity"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       Margin="0,0,6,0" />
                            <TextBlock Text="Execution book"
                                       Style="{StaticResource MonoTextStyle}"
                                       FontSize="11"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ContextChipStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Period"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       Margin="0,0,6,0" />
                            <TextBlock Text="{Binding TradeTimeText}"
                                       Style="{StaticResource MonoTextStyle}"
                                       FontSize="11"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ContextChipStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Currency"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       Margin="0,0,6,0" />
                            <TextBlock Text="Instrument native"
                                       Style="{StaticResource MonoTextStyle}"
                                       FontSize="11"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ContextChipStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Source"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       Margin="0,0,6,0" />
                            <TextBlock Text="{Binding SnapshotSourceText}"
                                       Style="{StaticResource MonoTextStyle}"
                                       FontSize="11"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <ComboBox Grid.Row="1"
                          Grid.Column="0"
                          ItemsSource="{Binding Presets}"
                          SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0" />

                <ItemsControl Grid.Row="1"
                              Grid.Column="1"
                              ItemsSource="{Binding ActiveFilterChips}"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:BlotterFilterChip}">
                            <Border Style="{StaticResource FilterChipStyle}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Label}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InfoColorBrush}"
                                               Margin="0,0,4,0" />
                                    <TextBlock Text="{Binding Value}"
                                               FontSize="11"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                    <Button Content="&#xE711;"
                                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                                            FontSize="9"
                                            Command="{Binding DataContext.RemoveFilterChipCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Padding="2,0,0,0"
                                            Margin="4,0,0,0"
                                            ToolTip="Remove filter" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBox Grid.Row="1"
                         Grid.Column="2"
                         Text="{Binding FilterSearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FormTextBoxStyle}"
                         VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="24,12,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource WorkspaceWorkbenchCardStyle}"
                    AutomationProperties.AutomationId="PositionBlotterWorkbench">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Background="{StaticResource ConsoleBackgroundLightBrush}"
                          Margin="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="68" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding IsAllSelected, Mode=TwoWay}"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"
                                  Margin="6,6,4,6"
                                  ToolTip="Select or deselect all rows" />

                        <Border Grid.Column="1" />

                        <TextBlock Grid.Column="2" Text="Group" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" Margin="4,6,4,6" />
                        <TextBlock Grid.Column="3" Text="Product Description" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" Margin="4,6,4,6" />
                        <TextBlock Grid.Column="4" Text="Trade ID" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" Margin="4,6,4,6" />
                        <TextBlock Grid.Column="5" Text="Unit Price" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextMutedBrush}" FontFamily="Cascadia Code, JetBrains Mono, Consolas, monospace" TextAlignment="Right" VerticalAlignment="Center" Margin="8,6,8,6" />
                        <TextBlock Grid.Column="6" Text="Qty" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextMutedBrush}" FontFamily="Cascadia Code, JetBrains Mono, Consolas, monospace" TextAlignment="Right" VerticalAlignment="Center" Margin="8,6,8,6" />
                        <TextBlock Grid.Column="7" Text="Side" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" Margin="4,6,4,6" />
                        <TextBlock Grid.Column="8" Text="Unreal. PnL" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextMutedBrush}" FontFamily="Cascadia Code, JetBrains Mono, Consolas, monospace" TextAlignment="Right" VerticalAlignment="Center" Margin="8,6,8,6" />
                        <TextBlock Grid.Column="9" Text="Status" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" Margin="4,6,4,6" />
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Groups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:BlotterGroup}">
                                    <StackPanel>
                                        <Grid Background="{StaticResource ConsoleBackgroundLightBrush}" Margin="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36" />
                                                <ColumnDefinition Width="20" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="3*" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="96" />
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="68" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="90" />
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"
                                                      Margin="6,4,4,4" />

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding ExpandIcon}"
                                                       Style="{StaticResource ExpandIconStyle}"
                                                       ToolTip="Expand or collapse group">
                                                <TextBlock.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick"
                                                                  Command="{Binding DataContext.ToggleGroupCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                  CommandParameter="{Binding}" />
                                                </TextBlock.InputBindings>
                                            </TextBlock>

                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        Margin="4,4,4,4"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                                <TextBlock Text="{Binding Count, StringFormat= ({0})}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="4,0,0,0" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="3"
                                                       Text="Grouped underlying exposure"
                                                       FontSize="11"
                                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="4,4,4,4" />

                                            <TextBlock Grid.Column="6"
                                                       Text="{Binding NetQuantity, StringFormat={}{0:+#,0.####;-#,0.####;0}}"
                                                       Style="{StaticResource NumericCellTextStyle}"
                                                       FontWeight="SemiBold"
                                                       Margin="8,4,8,4" />

                                            <TextBlock Grid.Column="8"
                                                       Text="{Binding TotalPnlText}"
                                                       Style="{StaticResource NumericCellTextStyle}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding TotalPnlBrush}"
                                                       Margin="8,4,8,4" />
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding Entries}"
                                                      Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:BlotterEntry}">
                                                    <Grid Margin="0,0,0,1">
                                                        <Grid.Style>
                                                            <Style TargetType="Grid">
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Background" Value="{StaticResource ConsoleAccentBlueAlpha20Brush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Grid.Style>

                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="36" />
                                                            <ColumnDefinition Width="20" />
                                                            <ColumnDefinition Width="2*" />
                                                            <ColumnDefinition Width="3*" />
                                                            <ColumnDefinition Width="100" />
                                                            <ColumnDefinition Width="96" />
                                                            <ColumnDefinition Width="92" />
                                                            <ColumnDefinition Width="68" />
                                                            <ColumnDefinition Width="120" />
                                                            <ColumnDefinition Width="90" />
                                                        </Grid.ColumnDefinitions>

                                                        <CheckBox Grid.Column="0"
                                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Center"
                                                                  Margin="6,3,4,3" />

                                                        <Border Grid.Column="1" />

                                                        <TextBlock Grid.Column="2" Text="{Binding Group}" FontSize="12" Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" Margin="20,0,4,0" />
                                                        <TextBlock Grid.Column="3" Text="{Binding ProductDescription}" FontSize="12" Foreground="{StaticResource ConsoleTextPrimaryBrush}" VerticalAlignment="Center" Margin="4,5,4,5" />
                                                        <TextBlock Grid.Column="4" Text="{Binding TradeId}" FontSize="12" Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" Margin="4,5,4,5" />
                                                        <TextBlock Grid.Column="5" Text="{Binding UnitPriceText}" Style="{StaticResource NumericCellTextStyle}" Margin="8,5,8,5" />
                                                        <TextBlock Grid.Column="6" Text="{Binding QuantityText}" Style="{StaticResource NumericCellTextStyle}" Margin="8,5,8,5" />
                                                        <TextBlock Grid.Column="7" Text="{Binding Side}" FontSize="12" Foreground="{StaticResource ConsoleTextPrimaryBrush}" VerticalAlignment="Center" Margin="4,5,4,5" />
                                                        <TextBlock Grid.Column="8" Text="{Binding UnrealisedPnlText}" Style="{StaticResource NumericCellTextStyle}" Foreground="{Binding PnlBrush}" Margin="8,5,8,5" />
                                                        <TextBlock Grid.Column="9" Text="{Binding Status}" FontSize="12" Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" Margin="4,5,4,5" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource WorkspaceInspectorCardStyle}"
                        AutomationProperties.AutomationId="PositionBlotterActionInspector">
                    <StackPanel>
                        <TextBlock Text="Batch Action Readiness" Style="{StaticResource CardHeaderStyle}" />
                        <TextBlock Text="{Binding SelectionActionStateText}" Style="{StaticResource CardDescriptionStyle}" Margin="0,8,0,14" TextWrapping="Wrap" />

                        <Button Content="Increase Selected Size"
                                Command="{Binding UpsizeCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,8" />
                        <Button Content="Flatten Selected Positions"
                                Command="{Binding TerminateCommand}"
                                Style="{StaticResource DangerButtonStyle}"
                                HorizontalAlignment="Stretch" />

                        <TextBlock Text="Provider-aware execution actions stay available only for supported rows, and the grouped workbench keeps your place after review."
                                   FontSize="11"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource WorkspaceInspectorCardStyle}"
                        AutomationProperties.AutomationId="PositionBlotterSelectionInspector">
                    <StackPanel>
                        <TextBlock Text="Selection Posture" Style="{StaticResource CardHeaderStyle}" />
                        <TextBlock Text="{Binding SelectionSummaryText}" Style="{StaticResource CardDescriptionStyle}" Margin="0,8,0,14" TextWrapping="Wrap" />

                        <UniformGrid Columns="2" Margin="0,0,0,8">
                            <Border Style="{StaticResource WorkspaceQueueCardStyle}" Margin="0,0,8,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedPositionCount}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                    <TextBlock Text="Selected positions" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource WorkspaceQueueCardStyle}" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedGroupCount}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                    <TextBlock Text="Selected groups" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource WorkspaceQueueCardStyle}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedNetQuantityText}" Style="{StaticResource NumericMetricTextStyle}" />
                                    <TextBlock Text="Net quantity" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource WorkspaceQueueCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedUnrealisedPnlText}" Style="{StaticResource NumericMetricTextStyle}" Foreground="{Binding SelectedUnrealisedPnlBrush}" />
                                    <TextBlock Text="Unrealised PnL" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource WorkspaceInspectorCardStyle}"
                        AutomationProperties.AutomationId="PositionBlotterFilterInspector">
                    <Expander Header="Filter &amp; Freshness"
                              IsExpanded="False"
                              Foreground="{StaticResource ConsoleTextPrimaryBrush}">
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="{Binding FilterSummaryText}" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SnapshotSourceText}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,0,0,14" TextWrapping="Wrap" />

                            <UniformGrid Columns="3">
                                <Border Style="{StaticResource WorkspaceQueueCardStyle}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding MinMktTimeText}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                        <TextBlock Text="Min mkt time" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource WorkspaceQueueCardStyle}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding MaxMktTimeText}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                        <TextBlock Text="Max mkt time" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource WorkspaceQueueCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TradeTimeText}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                        <TextBlock Text="Trade time" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Expander>
                </Border>
            </StackPanel>
        </Grid>

        <Border Grid.Row="3"
                Background="{StaticResource ConsoleBackgroundLightBrush}"
                BorderBrush="{StaticResource ConsoleBorderBrush}"
                BorderThickness="0,1,0,0"
                Margin="24,4,24,16"
                Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}">
                    <Run Text="{Binding RowCount, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                    <Run Text=" rows" />
                    <Run Text=" • " />
                    <Run Text="{Binding GroupCount, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                    <Run Text=" groups" />
                    <Run Text=" • Min Mkt Time " />
                    <Run Text="{Binding MinMktTimeText, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                    <Run Text=" • Max Mkt Time " />
                    <Run Text="{Binding MaxMktTimeText, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                    <Run Text=" • Trade Time " />
                    <Run Text="{Binding TradeTimeText, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Page>
