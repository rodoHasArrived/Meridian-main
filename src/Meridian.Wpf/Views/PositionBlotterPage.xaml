<Page x:Class="Meridian.Wpf.Views.PositionBlotterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="clr-namespace:Meridian.Wpf.Models"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      Unloaded="OnPageUnloaded"
      AutomationProperties.Name="Position Blotter">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <!-- Style for a filter chip pill -->
        <Style x:Key="FilterChipStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ConsoleAccentBlueAlpha20Brush}" />
            <Setter Property="BorderBrush" Value="{StaticResource InfoColorBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <!-- Style for the expand/collapse icon inside group rows -->
        <Style x:Key="ExpandIconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource SymbolThemeFontFamily}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextMutedBrush}" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Page header card -->
            <RowDefinition Height="Auto" />
            <!-- Filter bar card -->
            <RowDefinition Height="Auto" />
            <!-- Main data grid (takes remaining space) -->
            <RowDefinition Height="*" />
            <!-- Status bar -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════════
             Row 0 · Page Header
             ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}" Margin="24,20,24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="44" Height="44" CornerRadius="14"
                                Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1"
                                Margin="0,0,12,0">
                            <TextBlock Text="&#xE8EC;"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="22"
                                       Foreground="{StaticResource InfoColorBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Position Blotter" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="{Binding StatusText}"
                                       Style="{StaticResource CardDescriptionStyle}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                    <Button Content="Upsize"
                            Command="{Binding UpsizeCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            ToolTip="Increase quantity on selected positions"
                            Margin="0,0,8,0" />
                    <Button Content="Terminate"
                            Command="{Binding TerminateCommand}"
                            Style="{StaticResource DangerButtonStyle}"
                            ToolTip="Close / flatten selected positions"
                            Margin="0,0,8,0" />
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource GhostButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════
             Row 1 · Filter Bar
             ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="24,12,24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Preset dropdown -->
                    <ColumnDefinition Width="180" />
                    <!-- Filter chips area -->
                    <ColumnDefinition Width="*" />
                    <!-- Search box -->
                    <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>

                <!-- Preset dropdown -->
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding Presets}"
                          SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0" />

                <!-- Active filter chips -->
                <ItemsControl Grid.Column="1"
                              ItemsSource="{Binding ActiveFilterChips}"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:BlotterFilterChip}">
                            <Border Style="{StaticResource FilterChipStyle}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Label}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource InfoColorBrush}"
                                               Margin="0,0,4,0" />
                                    <TextBlock Text="{Binding Value}"
                                               FontSize="11"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                    <Button Content="&#xE711;"
                                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                                            FontSize="9"
                                            Command="{Binding DataContext.RemoveFilterChipCommand,
                                                              RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Padding="2,0,0,0"
                                            Margin="4,0,0,0"
                                            ToolTip="Remove filter" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Symbol / description search -->
                <TextBox Grid.Column="2"
                         Text="{Binding FilterSearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FormTextBoxStyle}"
                         VerticalAlignment="Center">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource FormTextBoxStyle}">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Tag" Value="Enter filter parameters" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════
             Row 2 · Main Blotter Grid
             ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="24,12,24,0">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Column header row -->
                    <RowDefinition Height="Auto" />
                    <!-- Scrollable data rows -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- ── Column header ── -->
                <Grid Grid.Row="0"
                      Background="{StaticResource ConsoleBackgroundLightBrush}"
                      Margin="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <!-- Checkbox column -->
                        <ColumnDefinition Width="36" />
                        <!-- Expand/collapse column -->
                        <ColumnDefinition Width="20" />
                        <!-- Group -->
                        <ColumnDefinition Width="2*" />
                        <!-- Product Description -->
                        <ColumnDefinition Width="3*" />
                        <!-- Trade ID -->
                        <ColumnDefinition Width="100" />
                        <!-- Unit Price -->
                        <ColumnDefinition Width="90" />
                        <!-- Qty -->
                        <ColumnDefinition Width="80" />
                        <!-- Side -->
                        <ColumnDefinition Width="60" />
                        <!-- Unrealised PnL -->
                        <ColumnDefinition Width="110" />
                        <!-- Status -->
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>

                    <!-- Master select-all checkbox -->
                    <CheckBox Grid.Column="0"
                              IsChecked="{Binding IsAllSelected, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              Margin="6,6,4,6"
                              ToolTip="Select / deselect all rows" />

                    <!-- Spacer for expand column -->
                    <Border Grid.Column="1" />

                    <TextBlock Grid.Column="2"  Text="Group"               FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" Margin="4,6,4,6" />
                    <TextBlock Grid.Column="3"  Text="Product Description" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" Margin="4,6,4,6" />
                    <TextBlock Grid.Column="4"  Text="Trade ID"            FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" Margin="4,6,4,6" />
                    <TextBlock Grid.Column="5"  Text="Unit Price"          FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" Margin="4,6,4,6" />
                    <TextBlock Grid.Column="6"  Text="Qty"                 FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" Margin="4,6,4,6" />
                    <TextBlock Grid.Column="7"  Text="Side"                FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" Margin="4,6,4,6" />
                    <TextBlock Grid.Column="8"  Text="Unreal. PnL"        FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" Margin="4,6,4,6" />
                    <TextBlock Grid.Column="9"  Text="Status"              FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" Margin="4,6,4,6" />
                </Grid>

                <!-- ── Scrollable rows ── -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Groups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:BlotterGroup}">
                                <StackPanel>

                                    <!-- Group header row -->
                                    <Grid Background="{StaticResource ConsoleBackgroundLightBrush}"
                                          Margin="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="20" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="3*" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Group checkbox -->
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"
                                                  Margin="6,4,4,4" />

                                        <!-- Expand / collapse toggle -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ExpandIcon}"
                                                   Style="{StaticResource ExpandIconStyle}"
                                                   ToolTip="Expand/collapse group">
                                            <TextBlock.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.ToggleGroupCommand,
                                                                                RelativeSource={RelativeSource AncestorType=Page}}"
                                                              CommandParameter="{Binding}" />
                                            </TextBlock.InputBindings>
                                        </TextBlock>

                                        <!-- Group name + count -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="4,4,4,4" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"
                                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                            <TextBlock Text="{Binding Count, StringFormat= ({0})}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                                       Margin="4,0,0,0" />
                                        </StackPanel>

                                        <!-- Total PnL for group -->
                                        <TextBlock Grid.Column="8"
                                                   Text="{Binding TotalPnlText}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding TotalPnlBrush}"
                                                   Margin="4,4,4,4" />
                                    </Grid>

                                    <!-- Child entry rows (collapsed when IsExpanded=false) -->
                                    <ItemsControl ItemsSource="{Binding Entries}"
                                                  Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:BlotterEntry}">
                                                <Grid Margin="0,0,0,1">
                                                    <Grid.Style>
                                                        <Style TargetType="Grid">
                                                            <Setter Property="Background" Value="Transparent" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource ConsoleAccentBlueAlpha20Brush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Grid.Style>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="36" />
                                                        <ColumnDefinition Width="20" />
                                                        <ColumnDefinition Width="2*" />
                                                        <ColumnDefinition Width="3*" />
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="90" />
                                                        <ColumnDefinition Width="80" />
                                                        <ColumnDefinition Width="60" />
                                                        <ColumnDefinition Width="110" />
                                                        <ColumnDefinition Width="80" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Row checkbox -->
                                                    <CheckBox Grid.Column="0"
                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Center"
                                                              Margin="6,3,4,3" />

                                                    <!-- Indent spacer -->
                                                    <Border Grid.Column="1" />

                                                    <!-- Group (symbol) -->
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding Group}"
                                                               FontSize="12" Foreground="{StaticResource ConsoleTextPrimaryBrush}" VerticalAlignment="Center" Margin="4,5,4,5"
                                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                                               Margin="20,0,4,0" />

                                                    <!-- Product Description -->
                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding ProductDescription}"
                                                               FontSize="12" Foreground="{StaticResource ConsoleTextPrimaryBrush}" VerticalAlignment="Center" Margin="4,5,4,5" />

                                                    <!-- Trade ID -->
                                                    <TextBlock Grid.Column="4"
                                                               Text="{Binding TradeId}"
                                                               FontSize="12" Foreground="{StaticResource ConsoleTextPrimaryBrush}" VerticalAlignment="Center" Margin="4,5,4,5"
                                                               Foreground="{StaticResource ConsoleTextMutedBrush}" />

                                                    <!-- Unit Price -->
                                                    <TextBlock Grid.Column="5"
                                                               Text="{Binding UnitPriceText}"
                                                               FontSize="12" Foreground="{StaticResource ConsoleTextPrimaryBrush}" VerticalAlignment="Center" Margin="4,5,4,5" />

                                                    <!-- Quantity -->
                                                    <TextBlock Grid.Column="6"
                                                               Text="{Binding QuantityText}"
                                                               FontSize="12" Foreground="{StaticResource ConsoleTextPrimaryBrush}" VerticalAlignment="Center" Margin="4,5,4,5" />

                                                    <!-- Side -->
                                                    <TextBlock Grid.Column="7"
                                                               Text="{Binding Side}"
                                                               FontSize="12" Foreground="{StaticResource ConsoleTextPrimaryBrush}" VerticalAlignment="Center" Margin="4,5,4,5" />

                                                    <!-- Unrealised PnL -->
                                                    <TextBlock Grid.Column="8"
                                                               Text="{Binding UnrealisedPnlText}"
                                                               FontSize="12" Foreground="{StaticResource ConsoleTextPrimaryBrush}" VerticalAlignment="Center" Margin="4,5,4,5"
                                                               Foreground="{Binding PnlBrush}" />

                                                    <!-- Status -->
                                                    <TextBlock Grid.Column="9"
                                                               Text="{Binding Status}"
                                                               FontSize="12" Foreground="{StaticResource ConsoleTextPrimaryBrush}" VerticalAlignment="Center" Margin="4,5,4,5"
                                                               Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════
             Row 3 · Status Bar
             ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="{StaticResource ConsoleBackgroundLightBrush}"
                BorderBrush="{StaticResource ConsoleBorderBrush}"
                BorderThickness="0,1,0,0"
                Margin="24,4,24,16"
                Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}">
                    <Run Text="{Binding RowCount, Mode=OneWay}" FontWeight="SemiBold"
                         Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                    <Run Text=" rows" />
                    <Run Text=" &#x2022; " />
                    <Run Text="Min Mkt Time " />
                    <Run Text="{Binding MinMktTimeText, Mode=OneWay}" FontWeight="SemiBold"
                         Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                    <Run Text=" &#x2022; " />
                    <Run Text="Max Mkt Time " />
                    <Run Text="{Binding MaxMktTimeText, Mode=OneWay}" FontWeight="SemiBold"
                         Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                    <Run Text=" &#x2022; " />
                    <Run Text="Trade Time " />
                    <Run Text="{Binding TradeTimeText, Mode=OneWay}" FontWeight="SemiBold"
                         Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                </TextBlock>
            </StackPanel>
        </Border>

    </Grid>
</Page>
