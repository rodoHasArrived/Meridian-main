<Page x:Class="Meridian.Wpf.Views.GovernanceWorkspaceShellPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:models="clr-namespace:Meridian.Wpf.Models"
      xmlns:views="clr-namespace:Meridian.Wpf.Views"
      mc:Ignorable="d"
      d:DesignHeight="900"
      d:DesignWidth="1400"
      Background="{DynamicResource ConsoleBackgroundDarkBrush}"
      Loaded="OnPageLoaded"
      Unloaded="OnPageUnloaded"
      AutomationProperties.Name="Governance Workspace"
      AutomationProperties.AutomationId="GovernanceWorkspaceShellPage">

    <Page.Resources>
        <DataTemplate x:Key="QueueItemTemplate" DataType="{x:Type models:WorkspaceQueueItem}">
            <Border Style="{StaticResource WorkspaceQueueCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Text="{Binding Title}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                            <Border Style="{StaticResource NeutralBadgeStyle}" Margin="10,0,8,0">
                                <TextBlock Text="{Binding StatusLabel}"
                                           FontSize="10"
                                           Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                            </Border>
                            <Border Style="{StaticResource InfoBadgeInlineStyle}">
                                <TextBlock Text="{Binding CountLabel}"
                                           FontSize="10"
                                           Foreground="{StaticResource InfoColorBrush}" />
                            </Border>
                        </WrapPanel>

                        <TextBlock Text="{Binding Detail}"
                                   FontSize="12"
                                   Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Tag="{Binding}"
                                Content="{Binding PrimaryActionLabel}"
                                Click="OnQueuePrimaryActionClick"
                                Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Tag="{Binding}"
                                Content="{Binding SecondaryActionLabel}"
                                Click="OnQueueSecondaryActionClick">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SecondaryActionLabel}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="RecentItemTemplate" DataType="{x:Type models:WorkspaceRecentItem}">
            <Border Style="{StaticResource WorkspaceInspectorCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                    <TextBlock Text="{Binding Detail}"
                               Margin="0,6,0,0"
                               FontSize="11"
                               Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Meta}"
                               Margin="0,6,0,0"
                               FontSize="10"
                               Foreground="{StaticResource ConsoleTextMutedBrush}" />
                    <Button Tag="{Binding ActionId}"
                            Content="{Binding ActionLabel}"
                            Click="OnRecentActionClick"
                            HorizontalAlignment="Left"
                            Margin="0,12,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActionLabel}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <views:WorkspaceShellContextStripControl x:Name="ContextStrip" />

        <views:WorkspaceCommandBarControl x:Name="CommandBar"
                                          Grid.Row="1"
                                          CommandInvoked="OnCommandBarCommandInvoked" />

        <Border Grid.Row="2"
                Background="{StaticResource ConsoleBackgroundMediumBrush}"
                BorderBrush="{StaticResource ConsoleBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14"
                Margin="0,0,0,16">
            <WrapPanel>
                <Button x:Name="OperationsLaneButton"
                        Content="Operations"
                        Click="OpenOperationsLane_Click"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0" />
                <Button x:Name="AccountingLaneButton"
                        Content="Accounting"
                        Click="OpenAccountingLane_Click"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="0,0,8,0" />
                <Button x:Name="ReconciliationLaneButton"
                        Content="Reconciliation"
                        Click="OpenReconciliationLane_Click"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="0,0,8,0" />
                <Button x:Name="ReportingLaneButton"
                        Content="Reporting"
                        Click="OpenReportingLane_Click"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="0,0,8,0" />
                <Button x:Name="AuditLaneButton"
                        Content="Audit"
                        Click="OpenAuditLane_Click"
                        Style="{StaticResource GhostButtonStyle}" />
            </WrapPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.15*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource WorkspaceWorkbenchCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Needs Attention"
                                       Style="{StaticResource CardHeaderStyle}" />
                            <TextBlock x:Name="QueueSummaryText"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                       Text="Governance work queues for operations, accounting, reconciliation, reporting, and audit review." />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Style="{StaticResource NeutralBadgeStyle}"
                                Margin="12,0,0,0"
                                VerticalAlignment="Top">
                            <TextBlock x:Name="QueueScopeBadgeText"
                                       FontSize="11"
                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                       Text="Awaiting fund scope" />
                        </Border>
                    </Grid>

                    <Border x:Name="NoFundEmptyState"
                            Grid.Row="1"
                            Style="{StaticResource WorkspaceEmptyStateCardStyle}"
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MaxWidth="520">
                            <Border Width="64"
                                    Height="64"
                                    CornerRadius="20"
                                    Background="{StaticResource ConsoleAccentOrangeAlpha10Brush}"
                                    BorderBrush="{StaticResource WarningColorBrush}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="&#xE8B7;"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="28"
                                           Foreground="{StaticResource WarningColorBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Governance is locked until a fund-linked context is selected."
                                       Margin="0,18,0,0"
                                       FontFamily="{StaticResource MeridianDisplayFontFamily}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                       TextAlignment="Center" />
                            <TextBlock Text="Switch context to unlock operations, accounting, reconciliation, reporting, and audit-first governance queues."
                                       Margin="0,12,0,0"
                                       FontSize="13"
                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center" />
                            <WrapPanel HorizontalAlignment="Center" Margin="0,20,0,0">
                                <Button Content="Switch Context"
                                        Click="SwitchContext_Click"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="0,0,10,0" />
                                <Button Content="Open Diagnostics"
                                        Click="OpenDiagnosticsFromEmptyState_Click"
                                        Style="{StaticResource GhostButtonStyle}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <ScrollViewer x:Name="AttentionQueueScrollViewer"
                                  Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="Operations"
                                       Style="{StaticResource ShellSectionLabelStyle}"
                                       Margin="0,0,0,8" />
                            <ItemsControl x:Name="OperationsQueueList"
                                          ItemTemplate="{StaticResource QueueItemTemplate}" />

                            <TextBlock Text="Accounting"
                                       Style="{StaticResource ShellSectionLabelStyle}"
                                       Margin="0,12,0,8" />
                            <ItemsControl x:Name="AccountingQueueList"
                                          ItemTemplate="{StaticResource QueueItemTemplate}" />

                            <TextBlock Text="Reconciliation"
                                       Style="{StaticResource ShellSectionLabelStyle}"
                                       Margin="0,12,0,8" />
                            <ItemsControl x:Name="ReconciliationQueueList"
                                          ItemTemplate="{StaticResource QueueItemTemplate}" />

                            <TextBlock Text="Reporting"
                                       Style="{StaticResource ShellSectionLabelStyle}"
                                       Margin="0,12,0,8" />
                            <ItemsControl x:Name="ReportingQueueList"
                                          ItemTemplate="{StaticResource QueueItemTemplate}" />

                            <TextBlock Text="Audit"
                                       Style="{StaticResource ShellSectionLabelStyle}"
                                       Margin="0,12,0,8" />
                            <ItemsControl x:Name="AuditQueueList"
                                          ItemTemplate="{StaticResource QueueItemTemplate}" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource WorkspaceInspectorCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Active Governance Context"
                                       Style="{StaticResource CardHeaderStyle}" />
                            <TextBlock x:Name="FundSummaryTitleText"
                                       Margin="0,10,0,0"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                       Text="No fund selected" />
                            <TextBlock x:Name="FundSummaryDetailText"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                       Text="Switch to a fund-linked context to unlock governance review." />
                            <TextBlock x:Name="FundSummaryMetaText"
                                       Margin="0,6,0,0"
                                       FontSize="11"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       Text="No current fund context." />

                            <UniformGrid Columns="3" Margin="0,14,0,0">
                                <Border Style="{StaticResource WorkspaceQueueCardStyle}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Cash"
                                                   FontSize="10"
                                                   Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                        <TextBlock x:Name="SummaryCashText"
                                                   Margin="0,6,0,0"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                                   Text="—" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource WorkspaceQueueCardStyle}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Open Breaks"
                                                   FontSize="10"
                                                   Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                        <TextBlock x:Name="SummaryBreaksText"
                                                   Margin="0,6,0,0"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource WarningColorBrush}"
                                                   Text="—" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource WorkspaceQueueCardStyle}" Margin="0">
                                    <StackPanel>
                                        <TextBlock Text="Journal"
                                                   FontSize="10"
                                                   Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                        <TextBlock x:Name="SummaryJournalText"
                                                   Margin="0,6,0,0"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                                   Text="—" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkspaceInspectorCardStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Recent Governance Work"
                                           Style="{StaticResource CardHeaderStyle}" />
                                <Button Grid.Column="1"
                                        Content="Notifications"
                                        Click="OpenNotifications_Click"
                                        Style="{StaticResource LinkButtonStyle}" />
                            </Grid>
                            <ItemsControl x:Name="RecentWorkList"
                                          ItemTemplate="{StaticResource RecentItemTemplate}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkspaceInspectorCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Audit Access"
                                       Style="{StaticResource CardHeaderStyle}" />
                            <TextBlock Text="Use the rail below to jump into the audit trail, provider posture, or system readiness without losing the governance shell."
                                       Margin="0,8,0,0"
                                       FontSize="11"
                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                            <WrapPanel Margin="0,14,0,0">
                                <Button Content="Audit Trail"
                                        Click="OpenAuditTrail_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8" />
                                <Button Content="Provider Health"
                                        Click="OpenProviderHealth_Click"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Margin="0,0,8,8" />
                                <Button Content="System Health"
                                        Click="OpenSystemHealth_Click"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Margin="0,0,8,8" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="4"
                Margin="0,12,0,0"
                Style="{StaticResource WorkspaceDockHostStyle}">
            <StackPanel>
                <TextBlock Text="Inspector Dock"
                           Style="{StaticResource CardHeaderStyle}"
                           Margin="4,0,0,10" />
                <views:MeridianDockingManager x:Name="GovernanceDockManager"
                                              Height="320"
                                              PaneDropRequested="OnPaneDropRequested"
                                              AutomationProperties.Name="Governance Dock Manager" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
