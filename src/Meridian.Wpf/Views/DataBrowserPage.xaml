<Page x:Class="Meridian.Wpf.Views.DataBrowserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="clr-namespace:Meridian.Wpf.Converters"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      AutomationProperties.Name="Data Browser">

    <Page.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!-- Column header template with ↕ sort indicator -->
        <DataTemplate x:Key="SortableHeaderTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding}" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" />
                <TextBlock Text=" ↕" FontSize="10"
                           Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" />
            </StackPanel>
        </DataTemplate>

        <!-- Active sort column header (cyan, ascending arrow) -->
        <DataTemplate x:Key="ActiveSortAscHeaderTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding}" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center" />
                <TextBlock Text=" ↑" FontSize="10"
                           Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center" />
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <DockPanel>

        <!-- ═══ TOP FILTER TOOLBAR ═══ -->
        <Border DockPanel.Dock="Top"
                Height="52"
                Background="{DynamicResource ConsoleBackgroundMediumBrush}"
                BorderBrush="{DynamicResource ConsoleBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,0">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Border Grid.Column="0"
                        Background="{DynamicResource ConsoleBackgroundLightBrush}"
                        BorderBrush="{DynamicResource ConsoleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,0">
                    <Grid>
                        <TextBlock Text="&#xE721;"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="12"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left" />
                        <TextBox Text="{Binding SymbolFilter, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource ConsoleTextPrimaryBrush}"
                                 CaretBrush="{DynamicResource ConsoleTextPrimaryBrush}"
                                 FontSize="13"
                                 Padding="22,0,0,0"
                                 VerticalAlignment="Center"
                                 VerticalContentAlignment="Center" />
                        <TextBlock Text="Search datasets, strategies, or metrics..."
                                   FontSize="12"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Padding="22,0,0,0"
                                   Visibility="{Binding SymbolFilter, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Invert}" />
                    </Grid>
                </Border>

                <!-- Data Type selector -->
                <Border Grid.Column="1"
                        Background="{DynamicResource ConsoleBackgroundLightBrush}"
                        BorderBrush="{DynamicResource ConsoleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Margin="10,0,0,0"
                        Padding="2,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                        <TextBlock Text="&#xE8EC;"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="12"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0" />
                        <ComboBox ItemsSource="{Binding DataTypes}"
                                  SelectedItem="{Binding SelectedDataType}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="{DynamicResource ConsoleTextPrimaryBrush}"
                                  FontSize="13"
                                  MinWidth="140"
                                  VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Time Period selector -->
                <Border Grid.Column="2"
                        Background="{DynamicResource ConsoleBackgroundLightBrush}"
                        BorderBrush="{DynamicResource ConsoleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Margin="10,0,0,0"
                        Padding="2,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                        <TextBlock Text="&#xE787;"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="12"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0" />
                        <ComboBox x:Name="TimePeriodCombo"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="{DynamicResource ConsoleTextPrimaryBrush}"
                                  FontSize="13"
                                  MinWidth="100"
                                  VerticalAlignment="Center">
                            <ComboBoxItem Content="1 Day" IsSelected="True" />
                            <ComboBoxItem Content="1 Week" />
                            <ComboBoxItem Content="1 Month" />
                            <ComboBoxItem Content="3 Months" />
                            <ComboBoxItem Content="1 Year" />
                            <ComboBoxItem Content="All Time" />
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Venue / Region selector -->
                <Border Grid.Column="3"
                        Background="{DynamicResource ConsoleBackgroundLightBrush}"
                        BorderBrush="{DynamicResource ConsoleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Margin="10,0,0,0"
                        Padding="2,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                        <TextBlock Text="&#xE909;"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="12"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0" />
                        <ComboBox ItemsSource="{Binding Venues}"
                                  SelectedItem="{Binding SelectedVenue}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="{DynamicResource ConsoleTextPrimaryBrush}"
                                  FontSize="13"
                                  MinWidth="110"
                                  VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- spacer -->

                <!-- Active Filters badge -->
                <Border Grid.Column="5"
                        Background="{DynamicResource ConsoleBackgroundLightBrush}"
                        BorderBrush="{DynamicResource ConsoleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,6"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Active Filters:"
                                   FontSize="12"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0" />
                        <Border Background="{StaticResource InfoColorBrush}"
                                CornerRadius="999"
                                Padding="6,1">
                            <TextBlock Text="{Binding ActiveFilterCount}" FontSize="11" FontWeight="Bold" Foreground="White" />
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Export button -->
                <Button Grid.Column="6"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="ExportCsv_Click"
                        Margin="0,0,8,0"
                        Padding="14,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xEDE1;"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0" />
                        <TextBlock Text="Export" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Advanced Filters button -->
                <Button Grid.Column="7"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="ApplyFilters_Click"
                        Padding="14,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE71C;"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0" />
                        <TextBlock Text="Advanced Filters" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <ScrollViewer DockPanel.Dock="Bottom"
                      VerticalScrollBarVisibility="Auto"
                      Padding="28,20,28,32">
            <StackPanel>

                <!-- Blue left-border page title -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0" Fill="{StaticResource InfoColorBrush}" RadiusX="2" RadiusY="2" />
                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                        <TextBlock Text="Data Explorer"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                        <TextBlock Text="Browse and analyze market data with advanced filtering and sorting capabilities"
                                   FontSize="13"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>

                <!-- Advanced filter panel (collapsible) -->
                <Border x:Name="AdvancedFilterPanel"
                        Style="{StaticResource CardStyle}"
                        Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="From Date" Style="{StaticResource FormLabelStyle}" />
                            <DatePicker SelectedDate="{Binding FromDate, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="To Date" Style="{StaticResource FormLabelStyle}" />
                            <DatePicker SelectedDate="{Binding ToDate, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="16,0,0,0">
                            <TextBlock Text="Result Size" Style="{StaticResource FormLabelStyle}" />
                            <ComboBox Style="{StaticResource FormComboBoxStyle}"
                                      ItemsSource="{Binding PageSizes}"
                                      SelectedItem="{Binding PageSize}" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" VerticalAlignment="Bottom" Margin="16,0,0,0">
                            <Button Content="Reset"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Click="ResetFilters_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Market Data Explorer card -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>

                        <!-- Card header: title + row count + sort + Export Selected -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Market Data Explorer"
                                       Style="{StaticResource CardHeaderStyle}"
                                       VerticalAlignment="Center" />

                            <TextBlock Grid.Column="1"
                                       Text="{Binding FilteredCountText}"
                                       FontSize="12"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0" />

                            <!-- Sort selector -->
                            <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,12,0">
                                <TextBlock Text="Sort"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"
                                           FontSize="12" />
                                <ComboBox x:Name="SortCombo"
                                          Width="130"
                                          Style="{StaticResource FormComboBoxStyle}"
                                          SelectionChanged="SortChanged_SelectionChanged">
                                    <ComboBoxItem Content="Newest First" Tag="TimestampDesc" IsSelected="True" />
                                    <ComboBoxItem Content="Oldest First" Tag="TimestampAsc" />
                                    <ComboBoxItem Content="Symbol A-Z" Tag="SymbolAsc" />
                                    <ComboBoxItem Content="Symbol Z-A" Tag="SymbolDesc" />
                                    <ComboBoxItem Content="Price High" Tag="PriceDesc" />
                                    <ComboBoxItem Content="Price Low" Tag="PriceAsc" />
                                    <ComboBoxItem Content="Size High" Tag="SizeDesc" />
                                </ComboBox>
                            </StackPanel>

                            <!-- Export Selected button -->
                            <Button Grid.Column="4"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="ExportCsv_Click"
                                    Padding="12,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xEDE1;"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0" />
                                    <TextBlock Text="Export Selected" VerticalAlignment="Center" FontSize="13" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Separator -->
                        <Border Height="1"
                                Background="{StaticResource ConsoleBorderBrush}"
                                Margin="0,0,0,0" />

                        <!-- DataGrid -->
                        <DataGrid x:Name="ResultsGrid"
                                  ItemsSource="{Binding PagedRecords}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  HeadersVisibility="Column"
                                  MinHeight="300"
                                  Margin="0,0,0,8"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{StaticResource ConsoleBorderBrush}"
                                  Background="Transparent"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="{StaticResource ConsoleBackgroundLightBrush}"
                                  BorderThickness="0"
                                  SelectionChanged="ResultsGrid_SelectionChanged">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="{StaticResource ConsoleTextMutedBrush}" />
                                    <Setter Property="FontSize" Value="12" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Padding" Value="10,10" />
                                    <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource ConsoleBackgroundHoverBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{StaticResource ConsoleAccentBlueAlpha10Brush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource InfoColorBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="10,10" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <!-- Checkbox column -->
                                <DataGridTemplateColumn Width="40" CanUserSort="False" CanUserResize="False">
                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding DataContext.AllRowsSelected,
                                                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                      VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Type column with dot + pill -->
                                <DataGridTemplateColumn Width="100" SortMemberPath="DataType" CanUserSort="True">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Type" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center" />
                                            <TextBlock Text=" ↑" FontSize="10"
                                                       Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="2,0">
                                                <Border Background="{Binding DataTypeColor}"
                                                        CornerRadius="999"
                                                        Padding="8,3">
                                                    <TextBlock Text="{Binding DataType}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="White" />
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Timestamp column -->
                                <DataGridTextColumn Width="190"
                                                    Binding="{Binding Timestamp, StringFormat='{}{0:M/d/yyyy, h:mm:ss tt}'}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Timestamp" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" />
                                                <TextBlock Text=" ↕" FontSize="10"
                                                           Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="Consolas" />
                                            <Setter Property="FontSize" Value="12" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Symbol column (active sort, cyan) -->
                                <DataGridTextColumn Width="*"
                                                    Binding="{Binding Symbol}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Symbol" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center" />
                                                <TextBlock Text=" ↑" FontSize="10"
                                                           Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="FontSize" Value="13" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Venue column -->
                                <DataGridTextColumn Width="90"
                                                    Binding="{Binding Venue}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Venue" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" />
                                                <TextBlock Text=" ↕" FontSize="10"
                                                           Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontSize" Value="13" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Price column -->
                                <DataGridTextColumn Width="100"
                                                    Binding="{Binding Price, StringFormat='{}{0:N4}'}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Price" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" />
                                                <TextBlock Text=" ↕" FontSize="10"
                                                           Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="Consolas" />
                                            <Setter Property="FontSize" Value="13" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Size column -->
                                <DataGridTextColumn Width="80"
                                                    Binding="{Binding Size, StringFormat='{}{0:N0}'}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Size" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" />
                                                <TextBlock Text=" ↕" FontSize="10"
                                                           Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="Consolas" />
                                            <Setter Property="FontSize" Value="13" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Row Detail Panel -->
                        <Border x:Name="DetailPanel" Visibility="Collapsed"
                                Background="{StaticResource ConsoleBackgroundLightBrush}"
                                BorderBrush="{StaticResource InfoColorBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,4,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="SYMBOL"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock x:Name="DetailSymbol"
                                               FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                    <TextBlock Text="VENUE"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                               FontSize="10" FontWeight="SemiBold" Margin="0,12,0,4" />
                                    <TextBlock x:Name="DetailVenue"
                                               Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="DATA TYPE"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock x:Name="DetailDataType"
                                               Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                    <TextBlock Text="TIMESTAMP"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                               FontSize="10" FontWeight="SemiBold" Margin="0,12,0,4" />
                                    <TextBlock x:Name="DetailTimestamp"
                                               Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                               FontFamily="Consolas" FontSize="13" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="PRICE"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock x:Name="DetailPrice"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource SuccessColorBrush}"
                                               FontFamily="Consolas" />
                                    <TextBlock Text="SIZE"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                               FontSize="10" FontWeight="SemiBold" Margin="0,12,0,4" />
                                    <TextBlock x:Name="DetailSize"
                                               Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                               FontFamily="Consolas" />
                                </StackPanel>
                                <Button Grid.Column="3"
                                        Style="{StaticResource GhostButtonStyle}"
                                        VerticalAlignment="Top"
                                        Click="CopyJson_Click"
                                        Padding="10,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8C8;"
                                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0" />
                                        <TextBlock Text="Copy JSON" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Pagination footer -->
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding PageSummary}"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="← Previous"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="PreviousPage_Click"
                                        IsEnabled="{Binding CanGoPrevious}"
                                        Margin="0,0,8,0" />
                                <Button Content="Next →"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="NextPage_Click"
                                        IsEnabled="{Binding CanGoNext}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Validation message -->
                <TextBlock Text="{Binding ValidationSummary}"
                           Foreground="{StaticResource ErrorColorBrush}"
                           Margin="0,12,0,0"
                           Visibility="{Binding ValidationSummary, Converter={StaticResource StringToVisibilityConverter}}" />

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
