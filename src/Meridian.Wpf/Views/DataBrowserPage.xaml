<Page x:Class="Meridian.Wpf.Views.DataBrowserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource ConsoleBackgroundDarkBrush}"
      Loaded="OnPageLoaded"
      AutomationProperties.Name="Data Browser">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel MaxWidth="1200">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="&#xE8A5;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                           FontSize="28" Foreground="{StaticResource InfoColorBrush}" VerticalAlignment="Center" />
                <TextBlock Text="Data Browser" Style="{StaticResource PageTitleStyle}" Margin="12,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="Search historical and live data sets with symbol filters and paging."
                       Style="{StaticResource PageSubtitleStyle}" Margin="0,0,0,20" />

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="Symbol" Style="{StaticResource FormLabelStyle}" />
                        <TextBox Style="{StaticResource FormTextBoxStyle}"
                                 Text="{Binding SymbolFilter, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1">
                        <TextBlock Text="Data Type" Style="{StaticResource FormLabelStyle}" />
                        <ComboBox Style="{StaticResource FormComboBoxStyle}"
                                  ItemsSource="{Binding DataTypes}"
                                  SelectedItem="{Binding SelectedDataType}" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="Venue" Style="{StaticResource FormLabelStyle}" />
                        <ComboBox Style="{StaticResource FormComboBoxStyle}"
                                  ItemsSource="{Binding Venues}"
                                  SelectedItem="{Binding SelectedVenue}" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="3" VerticalAlignment="Bottom">
                        <Button Content="Apply Filters"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="ApplyFilters_Click" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0">
                        <TextBlock Text="From" Style="{StaticResource FormLabelStyle}" />
                        <DatePicker SelectedDate="{Binding FromDate, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1">
                        <TextBlock Text="To" Style="{StaticResource FormLabelStyle}" />
                        <DatePicker SelectedDate="{Binding ToDate, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2">
                        <TextBlock Text="Result Size" Style="{StaticResource FormLabelStyle}" />
                        <ComboBox Style="{StaticResource FormComboBoxStyle}"
                                  ItemsSource="{Binding PageSizes}"
                                  SelectedItem="{Binding PageSize}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="3" VerticalAlignment="Bottom">
                        <Button Content="Reset"
                                Style="{StaticResource GhostButtonStyle}"
                                Click="ResetFilters_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="{StaticResource IconList}"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="16"
                                       Foreground="{StaticResource InfoColorBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Results" Style="{StaticResource CardHeaderStyle}" Margin="8,0,0,0" />
                        </StackPanel>

                        <Border Grid.Column="1" Background="{StaticResource InfoColorBrush}"
                                CornerRadius="8" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding FilteredCountText}"
                                       Foreground="White" FontSize="11" FontWeight="SemiBold" />
                        </Border>

                        <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,8,0">
                            <TextBlock Text="Sort by" Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12" />
                            <ComboBox x:Name="SortCombo" Width="130"
                                      Style="{StaticResource FormComboBoxStyle}"
                                      SelectionChanged="SortChanged_SelectionChanged">
                                <ComboBoxItem Content="Newest First" Tag="TimestampDesc" IsSelected="True" />
                                <ComboBoxItem Content="Oldest First" Tag="TimestampAsc" />
                                <ComboBoxItem Content="Symbol A-Z" Tag="SymbolAsc" />
                                <ComboBoxItem Content="Symbol Z-A" Tag="SymbolDesc" />
                                <ComboBoxItem Content="Price High" Tag="PriceDesc" />
                                <ComboBoxItem Content="Price Low" Tag="PriceAsc" />
                                <ComboBoxItem Content="Size High" Tag="SizeDesc" />
                            </ComboBox>
                        </StackPanel>

                        <Button Grid.Column="4" Content="&#xEDE1; Export CSV"
                                FontFamily="{StaticResource SymbolThemeFontFamily}"
                                Style="{StaticResource GhostButtonStyle}"
                                Click="ExportCsv_Click" />
                    </Grid>

                    <DataGrid x:Name="ResultsGrid"
                              ItemsSource="{Binding PagedRecords}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserSortColumns="True"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              MinHeight="300"
                              Margin="0,0,0,8"
                              SelectionChanged="ResultsGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Type" Width="80" SortMemberPath="DataType">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Ellipse Width="8" Height="8"
                                                     Fill="{Binding DataTypeColor}"
                                                     Margin="0,0,6,0" />
                                            <TextBlock Text="{Binding DataType}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Timestamp"
                                                Binding="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss.fff}'}"
                                                Width="190" />
                            <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="*" />
                            <DataGridTextColumn Header="Venue" Binding="{Binding Venue}" Width="100" />
                            <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat='{}{0:N2}'}" Width="100" />
                            <DataGridTextColumn Header="Size" Binding="{Binding Size, StringFormat='{}{0:N0}'}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Row Detail Panel -->
                    <Border x:Name="DetailPanel" Visibility="Collapsed"
                            Background="{StaticResource ConsoleBackgroundLightBrush}"
                            BorderBrush="{StaticResource ConsoleAccentBlueBrush}"
                            BorderThickness="0,0,0,2" CornerRadius="6" Padding="20,16" Margin="0,4,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="SYMBOL" Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBlock x:Name="DetailSymbol" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                <TextBlock Text="VENUE" Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           FontSize="10" FontWeight="SemiBold" Margin="0,12,0,4" />
                                <TextBlock x:Name="DetailVenue" Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="DATA TYPE" Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBlock x:Name="DetailDataType" Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                <TextBlock Text="TIMESTAMP" Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           FontSize="10" FontWeight="SemiBold" Margin="0,12,0,4" />
                                <TextBlock x:Name="DetailTimestamp" Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                           FontFamily="Consolas" FontSize="13" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="PRICE" Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBlock x:Name="DetailPrice" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource SuccessColorBrush}"
                                           FontFamily="Consolas" />
                                <TextBlock Text="SIZE" Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           FontSize="10" FontWeight="SemiBold" Margin="0,12,0,4" />
                                <TextBlock x:Name="DetailSize" Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                           FontFamily="Consolas" />
                            </StackPanel>
                            <Button Grid.Column="3" Content="&#xE8C8; Copy JSON"
                                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                                    Style="{StaticResource GhostButtonStyle}"
                                    VerticalAlignment="Top"
                                    Click="CopyJson_Click" />
                        </Grid>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding PageSummary}"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   VerticalAlignment="Center" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Previous"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="PreviousPage_Click"
                                    IsEnabled="{Binding CanGoPrevious}"
                                    Margin="0,0,8,0" />
                            <Button Content="Next"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="NextPage_Click"
                                    IsEnabled="{Binding CanGoNext}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding ValidationSummary}"
                       Foreground="{StaticResource ErrorColorBrush}"
                       Margin="0,12,0,0"
                       Visibility="{Binding ValidationSummary, Converter={StaticResource StringToVisibilityConverter}}" />
        </StackPanel>
    </ScrollViewer>
</Page>
