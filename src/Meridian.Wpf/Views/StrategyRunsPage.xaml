<Page x:Class="Meridian.Wpf.Views.StrategyRunsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      AutomationProperties.Name="Strategy Runs">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource EmbeddedShellHeroCardStyle}" Margin="0,0,0,20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="14"
                            Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                            BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1" Margin="0,0,12,0">
                        <TextBlock Text="&#xE8B0;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="24" Foreground="{StaticResource InfoColorBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Strategy Run Browser" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="{Binding StatusText}" Style="{StaticResource CardDescriptionStyle}" Margin="0,6,0,0" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0" />
                <Button Content="Open Detail"
                        Command="{Binding OpenDetailCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" />
            </StackPanel>
        </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Search" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}"
                             AutomationProperties.AutomationId="StrategyRunsSearchBox" />
                    <TextBlock Text="{Binding RunScopeText}"
                               FontSize="11"
                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                               Margin="0,6,0,0"
                               AutomationProperties.AutomationId="StrategyRunsScopeText" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Mode" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding ModeFilters}"
                              SelectedItem="{Binding SelectedModeFilter, Mode=TwoWay}"
                              AutomationProperties.AutomationId="StrategyRunsModeFilter" />
                </StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="Portfolio"
                            Command="{Binding OpenPortfolioCommand}"
                            Style="{StaticResource GhostButtonStyle}"
                            Margin="0,0,8,0" />
                    <Button Content="Ledger"
                            Command="{Binding OpenLedgerCommand}"
                            Style="{StaticResource GhostButtonStyle}"
                            Margin="0,0,8,0" />
                    <Button Content="Reset Filters"
                            Command="{Binding ClearRunFiltersCommand}"
                            Style="{StaticResource GhostButtonStyle}"
                            Visibility="{Binding HasActiveFilters, Converter={StaticResource BoolToVisibilityConverter}}"
                            AutomationProperties.AutomationId="StrategyRunsResetFiltersButton"
                            Margin="0,0,8,0" />
                    <Button Content="Compare"
                            Command="{Binding CompareRunsCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            ToolTip="Select a Comparison Run then click Compare to diff the two runs"
                            Margin="0,0,8,0" />
                    <Button Content="Clear"
                            Command="{Binding ClearComparisonCommand}"
                            Style="{StaticResource GhostButtonStyle}"
                            Visibility="{Binding IsComparisonVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DataGrid Grid.Row="0"
                              ItemsSource="{Binding Runs}"
                              SelectedItem="{Binding SelectedRun, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserSortColumns="True"
                              HeadersVisibility="Column"
                              Background="{StaticResource ConsoleBackgroundLightBrush}"
                              BorderThickness="0"
                              AutomationProperties.AutomationId="StrategyRunsGrid">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Started" Binding="{Binding StartedAt, StringFormat={}{0:g}}" Width="140" />
                            <DataGridTextColumn Header="Strategy" Binding="{Binding StrategyName}" Width="180" />
                            <DataGridTextColumn Header="Mode" Binding="{Binding Mode}" Width="90" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                            <DataGridTextColumn Header="Equity" Binding="{Binding FinalEquity, StringFormat={}{0:C2}}" Width="110" />
                            <DataGridTextColumn Header="Net PnL" Binding="{Binding NetPnl, StringFormat={}{0:C2}}" Width="110" />
                            <DataGridTextColumn Header="Fills" Binding="{Binding FillCount}" Width="70" />
                            <DataGridTextColumn Header="Run Id" Binding="{Binding RunId}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="460"
                                Visibility="{Binding IsEmptyStateVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                AutomationProperties.AutomationId="StrategyRunsEmptyStatePanel"
                                AutomationProperties.Name="{Binding EmptyStateTitle}">
                        <TextBlock Text="&#xE8B0;"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="40"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,14" />
                        <TextBlock Text="{Binding EmptyStateTitle}"
                                   Style="{StaticResource EmptyStateTitleStyle}"
                                   Margin="0,0,0,8"
                                   AutomationProperties.AutomationId="StrategyRunsEmptyStateTitle" />
                        <TextBlock Text="{Binding EmptyStateDetail}"
                                   Style="{StaticResource EmptyStateDescriptionStyle}"
                                   TextWrapping="Wrap"
                                   AutomationProperties.AutomationId="StrategyRunsEmptyStateDetail" />
                        <Button Content="Reset Filters"
                                Command="{Binding ClearRunFiltersCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Visibility="{Binding HasFilterRecoveryAction, Converter={StaticResource BoolToVisibilityConverter}}"
                                Margin="0,16,0,0"
                                HorizontalAlignment="Center"
                                AutomationProperties.AutomationId="StrategyRunsEmptyStateResetFiltersButton" />
                    </StackPanel>

                    <!-- Comparison run picker -->
                    <Border Grid.Row="1" Margin="0,12,0,0" Padding="10,8"
                            Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                            CornerRadius="6"
                            BorderBrush="{StaticResource InfoColorBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Compare with:" FontSize="11"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Runs}"
                                      SelectedItem="{Binding ComparisonRun, Mode=TwoWay}"
                                      ToolTip="Select a second run to diff against the primary selection">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <Run Text="{Binding StrategyName}" />
                                            <Run Text=" (" /><Run Text="{Binding Mode}" /><Run Text=")" />
                                            <Run Text=" " />
                                            <Run Text="{Binding StartedAt, StringFormat={}{0:yyyy-MM-dd}}" Foreground="{DynamicResource ConsoleTextMutedBrush}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Grid.Column="2" FontSize="11"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                       Text="{Binding ComparisonRun.Mode, StringFormat='({0})'}" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Side-by-side comparison diff panel -->
            <Border Grid.Column="1"
                    Width="380"
                    Margin="16,0,0,0"
                    Style="{StaticResource CardStyle}"
                    Visibility="{Binding IsComparisonVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0">
                        <TextBlock Text="Run Comparison" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,14" />

                        <!-- Column headers -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Metric" FontSize="11"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource InfoColorBrush}"
                                       Text="{Binding ComparisonResult[0].Mode, StringFormat='A ({0})'}" />
                            <TextBlock Grid.Column="2" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource SuccessColorBrush}"
                                       Text="{Binding ComparisonResult[1].Mode, StringFormat='B ({0})'}" />
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource ConsoleTextMutedBrush}" Margin="0,0,0,8" Opacity="0.2" />

                        <ItemsControl ItemsSource="{Binding ComparisonRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="11"
                                                   Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding ValueA}" FontSize="11" />
                                        <TextBlock Grid.Column="2" Text="{Binding ValueB}" FontSize="11" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
