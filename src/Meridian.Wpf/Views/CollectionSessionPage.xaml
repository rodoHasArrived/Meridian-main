<Page x:Class="Meridian.Wpf.Views.CollectionSessionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="clr-namespace:Meridian.Wpf.Converters"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      AutomationProperties.Name="Collection Session">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20,28,32">
        <StackPanel MaxWidth="1200">
            <!-- Page Header -->
            <Border Style="{StaticResource EmbeddedShellHeroCardStyle}" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="14"
                            Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                            BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1">
                        <TextBlock Text="&#xE768;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="24" Foreground="{StaticResource InfoColorBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Collection Sessions" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="Monitor active capture sessions, rate posture, and completed collection history."
                                   Style="{StaticResource CardDescriptionStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Session Action Readiness -->
            <Border Style="{StaticResource CardStyle}"
                    Margin="0,0,0,16"
                    AutomationProperties.AutomationId="CollectionSessionReadinessCard"
                    AutomationProperties.Name="Collection session lifecycle readiness">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding SessionActionTitle}"
                                   Style="{StaticResource CardHeaderStyle}" />
                        <TextBlock Text="{Binding SessionActionDetail}"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"
                                   AutomationProperties.AutomationId="CollectionSessionActionDetail" />
                        <TextBlock Text="{Binding SessionActionScope}"
                                   Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                   FontSize="11"
                                   Margin="0,8,0,0"
                                   AutomationProperties.AutomationId="CollectionSessionActionScope" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="Loading"
                               Foreground="{StaticResource InfoColorBrush}"
                               FontSize="12"
                               VerticalAlignment="Top"
                               Visibility="{Binding LoadingVisibility}"
                               AutomationProperties.AutomationId="CollectionSessionLoadingIndicator" />
                </Grid>
            </Border>

            <!-- Active Session -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Active Session" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12" />
                    <Border Visibility="{Binding HasActiveSession, Converter={StaticResource BoolToVisibilityConverter}}"
                            BorderBrush="{StaticResource SuccessColorBrush}" BorderThickness="1"
                            Background="{StaticResource PremiumPanelBrush}" CornerRadius="12" Padding="12" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding ActiveSessionName}" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessColorBrush}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ActiveSessionStatus}" Margin="6,0,0,0"
                                               Foreground="{StaticResource SuccessColorBrush}" FontSize="12" />
                                    <TextBlock Text="{Binding ActiveSessionDuration}" Margin="16,0,0,0"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="12" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="Events: " Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                                    <TextBlock Text="{Binding ActiveSessionEvents}"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" FontSize="11" />
                                    <TextBlock Text="  |  Rate: " Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" Margin="8,0,0,0" />
                                    <TextBlock Text="{Binding ActiveSessionRate}"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" FontSize="11" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Pause" Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding PauseSessionCommand}"
                                        Padding="12,6" Margin="0,0,8,0"
                                        AutomationProperties.AutomationId="CollectionSessionPauseButton" />
                                <Button Content="Stop" Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding StopSessionCommand}"
                                        Padding="12,6"
                                        AutomationProperties.AutomationId="CollectionSessionStopButton" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="No active collection session."
                               Visibility="{Binding HasActiveSession, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                               Foreground="{StaticResource ConsoleTextMutedBrush}" />
                </StackPanel>
            </Border>

            <!-- Quick Actions -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Quick Actions" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Create Daily Session" Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding CreateDailySessionCommand}"
                                Padding="16,8" Margin="0,0,8,0"
                                AutomationProperties.AutomationId="CollectionSessionCreateDailyButton" />
                        <Button Content="Refresh" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding RefreshSessionsCommand}"
                                Padding="16,8"
                                AutomationProperties.AutomationId="CollectionSessionRefreshButton" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Session History -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Session History" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12" />
                    <TextBlock Text="{Binding SessionHistoryStatus}" Margin="0,0,0,8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource ConsoleTextMutedBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSessionHistoryError}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource ErrorColorBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Border Visibility="{Binding EmptySessionHistoryVisibility}"
                            BorderBrush="{StaticResource ConsoleBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,0,0,8"
                            AutomationProperties.AutomationId="CollectionSessionEmptyState">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="No captured sessions yet"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                <TextBlock Text="{Binding SessionActionDetail}"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Create Daily Session"
                                    Command="{Binding CreateDailySessionCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center"
                                    AutomationProperties.AutomationId="CollectionSessionEmptyCreateButton" />
                        </Grid>
                    </Border>
                    <ItemsControl ItemsSource="{Binding Sessions}"
                                  Visibility="{Binding SessionHistoryVisibility}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource ConsoleTextMutedBrush}" BorderThickness="0,0,0,1"
                                        Padding="0,8" Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                            <TextBlock Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11">
                                                <Run Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" />
                                                <Run Text=" | " />
                                                <Run Text="{Binding Symbols.Length, StringFormat='{}{0} symbols'}" />
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Status}" Margin="12,0"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource ConsoleTextMutedBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessColorBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Active">
                                                            <Setter Property="Foreground" Value="{StaticResource InfoColorBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                            <Setter Property="Foreground" Value="{StaticResource WarningColorBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Column="2" Text="{Binding QualityScore, StringFormat='{}{0:F1}%'}"
                                                   Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="12,0"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{Binding Statistics.TotalEvents, StringFormat='{}{0:N0} events'}"
                                                   Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="12,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Session Summary -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Session Summary" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12" />
                    <TextBlock Text="{Binding SessionSummaryText}"
                               Foreground="{StaticResource ConsoleTextMutedBrush}" TextWrapping="Wrap"
                               FontFamily="Consolas" FontSize="11" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
