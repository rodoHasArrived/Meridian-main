<Page x:Class="Meridian.Wpf.Views.ActivityLogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      AutomationProperties.Name="Activity Log">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}" Margin="24,24,24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="14"
                            Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                            BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1">
                        <TextBlock Text="&#xE7BC;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="24" Foreground="{StaticResource InfoColorBrush}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Activity Log" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="Operational events, exportable traces, and filtered runtime messages for support workflows."
                                   Style="{StaticResource CardDescriptionStyle}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <CheckBox x:Name="AutoScrollCheck" Content="Auto-scroll"
                              IsChecked="{Binding IsAutoScrollEnabled, Mode=TwoWay}"
                              Foreground="{StaticResource ConsoleTextMutedBrush}"
                              VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button Content="Export" Click="Export_Click" Margin="0,0,8,0"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                    <Button Content="Clear" Click="Clear_Click"
                            Style="{StaticResource GhostButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filters -->
        <Border Grid.Row="1" Background="{StaticResource PremiumPanelBrush}"
                BorderBrush="{StaticResource ConsoleBorderBrush}"
                BorderThickness="1"
                Margin="24,0,24,16" Padding="18,14" CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Level Filter -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Level:" Foreground="{StaticResource ConsoleTextMutedBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="LevelFilterCombo" Width="120" SelectionChanged="Filter_Changed"
                              Background="{DynamicResource ConsoleBackgroundDarkBrush}"
                              Foreground="{DynamicResource ConsoleTextBrush}"
                              BorderThickness="1" Padding="8,4">
                        <ComboBoxItem Content="All" IsSelected="True"/>
                        <ComboBoxItem Content="Info"/>
                        <ComboBoxItem Content="Warning"/>
                        <ComboBoxItem Content="Error"/>
                        <ComboBoxItem Content="Debug"/>
                    </ComboBox>
                </StackPanel>

                <!-- Category Filter -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="Category:" Foreground="{StaticResource ConsoleTextMutedBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="CategoryFilterCombo" Width="140" SelectionChanged="Filter_Changed"
                              Background="{DynamicResource ConsoleBackgroundDarkBrush}"
                              Foreground="{DynamicResource ConsoleTextBrush}"
                              BorderThickness="1" Padding="8,4">
                        <ComboBoxItem Content="All" IsSelected="True"/>
                        <ComboBoxItem Content="Connection"/>
                        <ComboBoxItem Content="Data"/>
                        <ComboBoxItem Content="Backfill"/>
                        <ComboBoxItem Content="Storage"/>
                        <ComboBoxItem Content="System"/>
                    </ComboBox>
                </StackPanel>

                <!-- Search -->
                <TextBox x:Name="SearchBox" Grid.Column="4" TextChanged="Search_Changed"
                         Background="{DynamicResource ConsoleBackgroundDarkBrush}"
                         Foreground="{DynamicResource ConsoleTextBrush}"
                         BorderThickness="1" Padding="8,6">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Tag" Value="Search logs..."/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Stats -->
                <StackPanel Grid.Column="5" Orientation="Horizontal">
                    <TextBlock Text="{Binding LogCount}"
                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Log Entries -->
        <Border Grid.Row="2" Margin="24,0,24,24" Style="{StaticResource CardStyle}">
            <Grid>
                <ListBox x:Name="LogList" Background="Transparent" BorderThickness="0"
                         ItemsSource="{Binding FilteredLogs}"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Timestamp}"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           FontSize="11" FontFamily="Consolas"
                                           VerticalAlignment="Top"/>

                                <Border Grid.Column="1" CornerRadius="999" Padding="8,3"
                                        Background="{Binding LevelBackground}"
                                        HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding Level}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{Binding LevelForeground}"/>
                                </Border>

                                <TextBlock Grid.Column="2" Text="{Binding Category}"
                                           Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                           FontSize="11" VerticalAlignment="Top"/>

                                <TextBlock Grid.Column="3" Text="{Binding Message}"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                           TextWrapping="Wrap" FontSize="12"
                                           VerticalAlignment="Top"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="No log entries to display."
                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding NoLogsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</Page>
