<Window x:Class="Meridian.Wpf.Views.TickerStripWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        MouseLeave="OnMouseLeave"
        MouseEnter="OnMouseEnter"
        Loaded="OnLoaded"
        d:DesignHeight="28" d:DesignWidth="1920"
        AutomationProperties.Name="Ticker Strip">

    <Grid>
        <!-- Full strip (28px) — visible while mouse is over the bar -->
        <Border x:Name="FullStrip"
                Height="28"
                VerticalAlignment="Bottom"
                Background="#EE0A0A0F"
                BorderBrush="#FF1A2A4A"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Scrolling ticker items -->
                <ItemsControl Grid.Column="0"
                              ItemsSource="{Binding Items}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,0"
                                    Margin="0,0,1,0"
                                    Background="#0A0A1A"
                                    VerticalAlignment="Stretch">
                                <!-- Flash highlight: semi-transparent white overlay appears on IsFlashing -->
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFlashing}" Value="True">
                                                <Setter Property="Background" Value="#1AFFFFFF" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Symbol}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Foreground="Gray"
                                               Margin="0,0,4,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding LastText}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Foreground="{Binding PriceColor}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text=" "
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding BidText}"
                                               FontFamily="Consolas"
                                               FontSize="10"
                                               Foreground="#44AA44"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="/"
                                               FontFamily="Consolas"
                                               FontSize="10"
                                               Foreground="Gray"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding AskText}"
                                               FontFamily="Consolas"
                                               FontSize="10"
                                               Foreground="#AA4444"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Right-side controls: context menu hint -->
                <Border Grid.Column="1"
                        Padding="8,0"
                        Background="#0A0A1A"
                        Cursor="Hand"
                        MouseRightButtonUp="OnRightClick"
                        ToolTip="Right-click for options">
                    <TextBlock Text="⋮"
                               FontSize="14"
                               Foreground="#44667799"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                </Border>
            </Grid>
        </Border>

        <!-- Hairline (4px) — shown when mouse has left the bar -->
        <Border x:Name="HairlineStrip"
                Height="4"
                VerticalAlignment="Bottom"
                Background="#661A2A4A"
                Visibility="Collapsed" />
    </Grid>
</Window>
