<Page x:Class="Meridian.Wpf.Views.CredentialManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:converters="clr-namespace:Meridian.Wpf.Converters"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="1200"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      Unloaded="OnPageUnloaded"
      AutomationProperties.Name="Credential Management">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>

        <!-- ── Left column: provider list ──────────────────────────────── -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="28,20,12,32">
            <StackPanel MaxWidth="800">

                <!-- Header -->
                <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource GhostButtonStyle}"
                                Click="BackButton_Click"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                ToolTip="Back to Settings">
                            <TextBlock Text="{StaticResource IconBack}"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="16" />
                        </Button>
                        <Border Width="44" Height="44" CornerRadius="14"
                                Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1">
                            <TextBlock Text="{StaticResource IconLock}"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="24"
                                       Foreground="{StaticResource InfoColorBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Credential Management"
                                       Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="Configure API keys and account credentials for all data providers."
                                       Style="{StaticResource PageSubtitleStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Status bar + bulk actions -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource CardHeaderStyle}" Text="Provider Credentials" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       FontSize="12"
                                       Foreground="{DynamicResource ConsoleTextMutedBrush}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding TestAllCredentialsCommand}"
                                Padding="14,8"
                                ToolTip="Test all configured credentials">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{StaticResource IconCheckmark}"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Test All" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Provider credential list -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Select a provider to configure its API credentials."
                                   FontSize="12"
                                   Foreground="{DynamicResource ConsoleTextMutedBrush}"
                                   Margin="0,0,0,16" />

                        <ListView x:Name="CredentialsList"
                                  ItemsSource="{Binding Credentials}"
                                  SelectedItem="{Binding SelectedCredential, Mode=TwoWay}"
                                  SelectionMode="Single"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  HorizontalContentAlignment="Stretch"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,4" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <Border x:Name="ItemBorder"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{DynamicResource OutlineVariantBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        Padding="14,10">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background"
                                                                Value="{DynamicResource ConsoleAccentBlueAlpha10Brush}" />
                                                        <Setter TargetName="ItemBorder" Property="BorderBrush"
                                                                Value="{DynamicResource InfoColorBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background"
                                                                Value="{DynamicResource SurfaceVariantBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Status dot -->
                                        <Ellipse Grid.Column="0" Width="10" Height="10"
                                                 VerticalAlignment="Center" Margin="0,0,12,0">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{Binding StatusColor}" />
                                            </Ellipse.Fill>
                                        </Ellipse>

                                        <!-- Provider name + status -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="13" FontWeight="Medium"
                                                       Foreground="{DynamicResource ConsoleTextPrimaryBrush}" />
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource ConsoleTextMutedBrush}"
                                                       Margin="0,2,0,0">
                                                <Run Text="{Binding CredentialType}" />
                                                <Run Text="  ·  " />
                                                <Run Text="{Binding StatusText}" />
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Testing indicator -->
                                        <TextBlock Grid.Column="2" Text="Testing…"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource ConsoleTextMutedBrush}"
                                                   VerticalAlignment="Center" Margin="8,0"
                                                   Visibility="{Binding IsTesting, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <!-- Configured / Not configured badge -->
                                        <Border Grid.Column="3" Padding="8,3" CornerRadius="4"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding RequiresCredentials, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasCredentials}" Value="True">
                                                            <Setter Property="Background"
                                                                    Value="{StaticResource ConsoleAccentGreenAlpha10Brush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding HasCredentials}" Value="False">
                                                            <Setter Property="Background"
                                                                    Value="{StaticResource ConsoleAccentRedAlpha10Brush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="11" FontWeight="Medium">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasCredentials}" Value="True">
                                                                <Setter Property="Text" Value="Configured" />
                                                                <Setter Property="Foreground"
                                                                        Value="{StaticResource SuccessColorBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding HasCredentials}" Value="False">
                                                                <Setter Property="Text" Value="Not configured" />
                                                                <Setter Property="Foreground"
                                                                        Value="{StaticResource ErrorColorBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- Security notice -->
                <Border Style="{StaticResource CardStyle}" Margin="0,16,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{StaticResource IconInfo}"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="16" Foreground="{DynamicResource InfoColorBrush}"
                                   VerticalAlignment="Top" Margin="0,2,10,0" />
                        <StackPanel>
                            <TextBlock Text="Credential Storage"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ConsoleTextPrimaryBrush}"
                                       Margin="0,0,0,4" />
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource ConsoleTextMutedBrush}"
                                       MaxWidth="600">
                                Credentials are encrypted with Windows DPAPI and stored locally.
                                They are also written as user-scoped environment variables so that
                                all Meridian processes share them automatically.
                                Secrets never leave your machine.
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Right column: action / edit panel ───────────────────────── -->
        <Grid Grid.Column="1">

            <!-- Empty-selection placeholder -->
            <Border Margin="0,20,24,0" Padding="20">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedCredential}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20">
                    <TextBlock Text="{StaticResource IconLock}"
                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                               FontSize="36"
                               Foreground="{DynamicResource ConsoleTextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,12" />
                    <TextBlock Text="Select a provider"
                               FontSize="14" FontWeight="Medium"
                               Foreground="{DynamicResource ConsoleTextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Choose a provider from the list to view and manage its credentials."
                               FontSize="11" Foreground="{DynamicResource ConsoleTextMutedBrush}"
                               TextWrapping="Wrap" TextAlignment="Center"
                               MaxWidth="260" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <!-- Provider action panel -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,20,24,0">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedCredential}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel>

                    <!-- Provider summary + actions -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedCredential.DisplayName}"
                                       Style="{StaticResource CardHeaderStyle}"
                                       Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{Binding SelectedCredential.StatusColor}" />
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="{Binding SelectedCredential.StatusText}"
                                           FontSize="12"
                                           Foreground="{DynamicResource ConsoleTextSecondaryBrush}" />
                            </StackPanel>
                            <TextBlock Text="{Binding SelectedCredential.CredentialType}"
                                       FontSize="11"
                                       Foreground="{DynamicResource ConsoleTextMutedBrush}" />

                            <WrapPanel Margin="0,14,0,0">
                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding EditCredentialCommand}"
                                        Padding="14,8" Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconEdit}"
                                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                   FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Add Credentials" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedCredential.HasCredentials}" Value="True">
                                                            <Setter Property="Text" Value="Edit Credentials" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding TestCredentialCommand}"
                                        Padding="14,8" Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconCheckmark}"
                                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                   FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Text="Test" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource DangerButtonStyle}"
                                        Command="{Binding RemoveCredentialCommand}"
                                        Padding="14,8" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconDelete}"
                                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                   FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Text="Remove" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Test result banner -->
                    <Border Margin="0,0,0,12" Padding="14,10" CornerRadius="6"
                            Background="#0D58A6FA"
                            Visibility="{Binding IsTestResultVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding TestResultText}"
                                   FontSize="12" TextWrapping="Wrap"
                                   Foreground="{DynamicResource ConsoleTextSecondaryBrush}" />
                    </Border>

                    <!-- Edit / Add credential form -->
                    <Border Style="{StaticResource CardStyle}"
                            Visibility="{Binding IsEditPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding EditPanelTitle}"
                                       Style="{StaticResource CardHeaderStyle}"
                                       Margin="0,0,0,16" />

                            <ItemsControl ItemsSource="{Binding EditFields}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,14">
                                            <TextBlock Text="{Binding Label}"
                                                       Style="{StaticResource FormLabelStyle}" />
                                            <!-- Secret field (PasswordBox; value sync via code-behind) -->
                                            <PasswordBox Style="{StaticResource FormTextBoxStyle}"
                                                         FontFamily="Consolas"
                                                         PasswordChanged="CredentialField_PasswordChanged"
                                                         Tag="{Binding EnvVarName}"
                                                         Visibility="{Binding IsSecret, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <!-- Plain text field -->
                                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="Consolas">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSecret}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                            <TextBlock Text="{Binding EnvVarName, StringFormat='Environment variable: {0}'}"
                                                       Style="{StaticResource FormHintStyle}"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding SaveCredentialCommand}"
                                        Padding="16,8" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconSave}"
                                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                   FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Text="Save" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding CancelEditCommand}"
                                        Padding="16,8">
                                    <TextBlock Text="Cancel" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Busy overlay -->
            <Border Background="#80000000"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="Working…" Foreground="White" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
        </Grid>
    </Grid>
</Page>
