<Window x:Class="Meridian.Wpf.Views.EditScheduledJobDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Edit Scheduled Job"
        Width="450" Height="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF1E1E2E"
        ShowInTaskbar="False">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Job Name -->
        <TextBlock Grid.Row="0" Text="Job Name:" Foreground="White" Margin="0,0,0,4" />
        <TextBox x:Name="NameBox"
                 Grid.Row="1"
                 Background="#FF2A2A3E"
                 Foreground="White"
                 BorderBrush="#FF3A3A4E"
                 Padding="10,6"
                 Margin="0,4,0,12" />

        <!-- Frequency -->
        <TextBlock Grid.Row="2" Text="Frequency:" Foreground="White" Margin="0,0,0,4" />
        <ComboBox x:Name="FrequencyCombo"
                  Grid.Row="3"
                  Background="#FF2A2A3E"
                  Foreground="White"
                  Margin="0,4,0,12"
                  SelectionChanged="FrequencyCombo_SelectionChanged">
            <ComboBoxItem Content="Daily" IsSelected="True" />
            <ComboBoxItem Content="Weekly" />
            <ComboBoxItem Content="Monthly" />
        </ComboBox>

        <!-- Time -->
        <TextBlock Grid.Row="4" Text="Time:" Foreground="White" Margin="0,0,0,4" />
        <ComboBox x:Name="TimeCombo"
                  Grid.Row="5"
                  Background="#FF2A2A3E"
                  Foreground="White"
                  Margin="0,4,0,12" />

        <!-- Day of week (weekly only) -->
        <ComboBox x:Name="DayCombo"
                  Grid.Row="6"
                  Background="#FF2A2A3E"
                  Foreground="White"
                  Margin="0,4,0,12"
                  Visibility="Collapsed">
            <ComboBoxItem Content="Monday" />
            <ComboBoxItem Content="Tuesday" />
            <ComboBoxItem Content="Wednesday" />
            <ComboBoxItem Content="Thursday" />
            <ComboBoxItem Content="Friday" />
            <ComboBoxItem Content="Saturday" />
            <ComboBoxItem Content="Sunday" IsSelected="True" />
        </ComboBox>

        <!-- Buttons -->
        <Grid Grid.Row="7" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Delete"
                    Width="100"
                    Background="#FFF44336"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="12,8"
                    Click="Delete_Click" />

            <Button Grid.Column="2"
                    Content="Cancel"
                    Width="100"
                    Background="#FF3A3A4E"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="12,8"
                    Click="Cancel_Click" />

            <Button Grid.Column="3"
                    Content="Save"
                    Width="100"
                    Margin="8,0,0,0"
                    Background="#FF4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="12,8"
                    Click="Save_Click"
                    IsDefault="True" />
        </Grid>
    </Grid>
</Window>
