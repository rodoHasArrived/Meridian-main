<Page x:Class="Meridian.Wpf.Views.TradingWorkspaceShellPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:views="clr-namespace:Meridian.Wpf.Views"
      mc:Ignorable="d"
      d:DesignHeight="900"
      d:DesignWidth="1440"
      Background="{DynamicResource ConsoleBackgroundDarkBrush}"
      Loaded="OnPageLoaded"
      Unloaded="OnPageUnloaded"
      AutomationProperties.Name="Trading Workspace"
      AutomationProperties.AutomationId="TradingWorkspaceShellPage">

    <Page.Resources>
        <Style x:Key="CockpitPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ConsoleCardSurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,16,16" />
        </Style>
        <Style x:Key="CockpitPanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
        </Style>
        <Style x:Key="CockpitValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <views:WorkspaceShellContextStripControl x:Name="ContextStrip"
                                                 Grid.Row="0" />

        <Border Grid.Row="1"
                Background="#08160F"
                BorderBrush="#214433"
                BorderThickness="1"
                CornerRadius="18"
                Padding="22"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="42"
                                Height="42"
                                CornerRadius="12"
                                Background="{StaticResource ConsoleAccentGreenAlpha20Brush}"
                                BorderBrush="{StaticResource SuccessColorBrush}"
                                BorderThickness="1">
                            <TextBlock Text="&#xE9F5;"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="22"
                                       Foreground="{StaticResource SuccessColorBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Trading Cockpit"
                                       FontFamily="{StaticResource MeridianDisplayFontFamily}"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="White" />
                            <TextBlock Text="Monitor live posture, manage positions, and keep blotter, risk, and alerts one split away."
                                       Margin="0,6,0,0"
                                       FontSize="13"
                                       Foreground="#B5D7C0"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="ActiveFundText"
                                       Margin="0,12,0,0"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Text="No fund selected" />
                            <TextBlock x:Name="ActiveFundDetailText"
                                       Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="#B5D7C0"
                                       Text="Runs and KPIs scope to the active fund profile." />
                        </StackPanel>
                    </StackPanel>

                    <Border Margin="0,18,0,0"
                            Padding="14,12"
                            CornerRadius="12"
                            Background="#10271B"
                            BorderBrush="#25563F"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Selected Run"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#8CC6A0" />
                            <TextBlock x:Name="TradingActiveRunText"
                                       Margin="0,6,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Text="No active trading run" />
                            <TextBlock x:Name="TradingActiveRunMetaText"
                                       Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="#B5D7C0"
                                       Text="Use Research to promote a run, or open a live/paper panel below." />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <Border Style="{StaticResource WorkspaceKpiTileStyle}"
                            Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock x:Name="PaperRunsText"
                                       Text="—"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InfoColorBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Paper"
                                       FontSize="11"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WorkspaceKpiTileStyle}"
                            Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock x:Name="LiveRunsText"
                                       Text="—"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource SuccessColorBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Live"
                                       FontSize="11"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WorkspaceKpiTileStyle}">
                        <StackPanel>
                            <TextBlock x:Name="TotalEquityText"
                                       Text="—"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Equity"
                                       FontSize="11"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="Transparent"
                BorderThickness="0"
                Padding="0"
                Margin="0,0,0,16">
            <StackPanel>
                <views:WorkspaceCommandBarControl x:Name="CommandBar"
                                                  CommandInvoked="OnCommandBarCommandInvoked" />
                <Border Background="{StaticResource ConsoleBackgroundMediumBrush}"
                        BorderBrush="{StaticResource ConsoleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14"
                        Margin="0,4,0,0">
                    <TextBlock x:Name="DeskActionStatusText"
                               FontSize="12"
                               Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                               Text="Trading desk status appears here after a staged command or review action." />
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="1.1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CockpitPanelStyle}">
                <StackPanel>
                    <TextBlock Text="Strategies &amp; Watchlists" Style="{StaticResource CockpitPanelTitleStyle}" />
                    <TextBlock x:Name="WatchlistStatusText"
                               Margin="0,10,0,0"
                               Style="{StaticResource CockpitValueStyle}"
                               Text="Watchlists and active strategies populate once paper or live runs are started." />
                    <Button Content="Open Portfolio"
                            Click="OpenPortfolio_Click"
                            Style="{StaticResource GhostButtonStyle}"
                            Margin="0,14,0,0"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CockpitPanelStyle}">
                <StackPanel>
                    <TextBlock Text="Market Core &amp; Accounting" Style="{StaticResource CockpitPanelTitleStyle}" />
                    <TextBlock x:Name="MarketCoreText"
                               Margin="0,10,0,0"
                               Style="{StaticResource CockpitValueStyle}"
                               Text="Live data, order book, and portfolio inspectors are ready to dock below." />
                    <WrapPanel Margin="0,14,0,0">
                        <Button Content="Live Data"
                                Click="OpenLiveData_Click"
                                Style="{StaticResource GhostButtonStyle}"
                                Margin="0,0,10,0" />
                        <Button Content="Order Book"
                                Click="OpenOrderBook_Click"
                                Style="{StaticResource GhostButtonStyle}" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource CockpitPanelStyle}"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Blotter, Alerts, Risk, Audit" Style="{StaticResource CockpitPanelTitleStyle}" />
                    <TextBlock x:Name="RiskRailText"
                               Margin="0,10,0,0"
                               Style="{StaticResource CockpitValueStyle}"
                               Text="Risk rail becomes specific once an active run is selected." />
                    <WrapPanel Margin="0,14,0,0">
                        <Button Content="Blotter"
                                Click="OpenBlotter_Click"
                                Style="{StaticResource GhostButtonStyle}"
                                Margin="0,0,10,0" />
                        <Button Content="Risk Rail"
                                Click="OpenRiskRail_Click"
                                Style="{StaticResource GhostButtonStyle}"
                                Margin="0,0,10,0" />
                        <Button Content="Accounting"
                                Click="OpenAccountingConsequences_Click"
                                Style="{StaticResource GhostButtonStyle}"
                                Margin="0,0,10,0" />
                        <Button Content="Audit"
                                Click="OpenAuditTrail_Click"
                                Style="{StaticResource GhostButtonStyle}"
                                Margin="0,0,10,0" />
                        <Button Content="Alerts"
                                Click="OpenAlerts_Click"
                                Style="{StaticResource GhostButtonStyle}" />
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.6*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CockpitPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="Active Positions" Style="{StaticResource CockpitPanelTitleStyle}" />
                        <ItemsControl x:Name="ActivePositionsList"
                                      Margin="0,12,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource WorkspaceQueueItemCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Symbol}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                                <TextBlock Text="{Binding StrategyName}"
                                                           Margin="0,4,0,0"
                                                           FontSize="11"
                                                           Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding QuantityLabel}"
                                                       FontSize="12"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding UnrealizedPnlFormatted}"
                                                       FontSize="12"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Foreground="{Binding UnrealizedPnlBrush}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="NoPositionsText"
                                   Margin="0,8,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   Text="No active positions. Start a paper or live run to see positions here."
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource CockpitPanelStyle}"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Capital &amp; Controls" Style="{StaticResource CockpitPanelTitleStyle}" />
                        <UniformGrid Columns="2" Margin="0,12,0,0">
                            <Border Style="{StaticResource WorkspaceQueueItemCardStyle}" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="Cash" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                    <TextBlock x:Name="CapitalCashText"
                                               Margin="0,6,0,0"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource WorkspaceQueueItemCardStyle}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Gross" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                    <TextBlock x:Name="CapitalGrossExposureText"
                                               Margin="0,6,0,0"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource WorkspaceQueueItemCardStyle}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Net" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                    <TextBlock x:Name="CapitalNetExposureText"
                                               Margin="0,6,0,0"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource WorkspaceQueueItemCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Financing" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                    <TextBlock x:Name="CapitalFinancingText"
                                               Margin="0,6,0,0"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource WarningColorBrush}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <TextBlock x:Name="CapitalControlsDetailText"
                                   Margin="0,14,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Text="Select a fund to unlock capital, financing, and reconciliation posture." />

                        <Rectangle Margin="0,14,0,14"
                                   Height="1"
                                   Fill="{StaticResource ConsoleBorderBrush}" />

                        <TextBlock Text="Risk Snapshot" Style="{StaticResource CockpitPanelTitleStyle}" />
                        <TextBlock x:Name="DrawdownText"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource CockpitValueStyle}"
                                   Text="—" />
                        <TextBlock x:Name="PositionLimitText"
                                   Margin="0,8,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                   Text="—" />
                        <TextBlock x:Name="OrderRateText"
                                   Margin="0,8,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                   Text="—" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Background="{StaticResource ConsoleBackgroundMediumBrush}"
                    BorderBrush="{StaticResource ConsoleBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="12">
                <views:MeridianDockingManager x:Name="TradingDockManager"
                                              PaneDropRequested="OnPaneDropRequested"
                                              AutomationProperties.Name="Trading Dock Manager" />
            </Border>
        </Grid>
    </Grid>
</Page>
