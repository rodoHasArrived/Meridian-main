<Page x:Class="Meridian.Wpf.Views.ScatterAnalysisPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      AutomationProperties.Name="Scatter Analysis">

  <Page.Resources>
    <!-- Time-range RadioButton style (mutual exclusion via GroupName) -->
    <Style x:Key="TimeRangeButtonStyle" TargetType="RadioButton">
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="10,0" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontFamily" Value="{DynamicResource ContentControlThemeFontFamily}" />
      <Setter Property="Foreground" Value="{DynamicResource ConsoleTextBrush}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="Border" Background="{TemplateBinding Background}"
                    CornerRadius="4" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <!-- Checked — accent fill -->
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentButtonBackground}" />
                <Setter Property="Foreground" Value="White" />
              </Trigger>
              <!-- Hover only when NOT already selected, so the accent fill is never overridden -->
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsMouseOver" Value="True" />
                  <Condition Property="IsChecked" Value="False" />
                </MultiTrigger.Conditions>
                <Setter TargetName="Border" Property="Background" Value="{DynamicResource SubtleBackgroundBrush}" />
              </MultiTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Expression line number prefix style -->
    <Style x:Key="LineNumberStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource ChartAxisLabelBrush}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontFamily" Value="{StaticResource MeridianDataFontFamily}" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Width" Value="24" />
      <Setter Property="TextAlignment" Value="Right" />
      <Setter Property="Margin" Value="0,0,10,0" />
    </Style>

    <!-- Expression text box style -->
    <Style x:Key="ExpressionTextBoxStyle" TargetType="TextBox">
      <Setter Property="FontFamily" Value="{StaticResource MeridianDataFontFamily}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="{StaticResource ChartPrimaryLineBrush}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="CaretBrush" Value="White" />
      <Setter Property="SelectionBrush" Value="{StaticResource ChartSecondaryLineBrush}" />
    </Style>

    <!-- Stats label style -->
    <Style x:Key="StatLabelStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Stats value style -->
    <Style x:Key="StatValueStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource ConsoleTextBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Tab header RadioButton style (bottom underline accent) -->
    <Style x:Key="AnalysisTabButtonStyle" TargetType="RadioButton">
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0,0,0,2" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="Border" Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <!-- Active tab — accent underline + accent text -->
              <Trigger Property="IsChecked" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentTextBrush}" />
              </Trigger>
              <!-- Hover only when NOT already selected -->
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsMouseOver" Value="True" />
                  <Condition Property="IsChecked" Value="False" />
                </MultiTrigger.Conditions>
                <Setter Property="Foreground" Value="{DynamicResource ConsoleTextBrush}" />
              </MultiTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <!-- Quickstart sidebar item button style -->
    <Style x:Key="QuickstartItemStyle" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ItemBorder"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ChartPlotAreaBrush}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ChartPrimaryLineBrush}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Page.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />  <!-- Header (full width) -->
      <RowDefinition Height="*" />     <!-- Sidebar + chart content -->
    </Grid.RowDefinitions>

    <!-- ══ Header ══════════════════════════════════════════════════════════ -->
    <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}" Margin="24,24,24,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Page title + icon -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,24,0">
          <Border Width="40" Height="40" CornerRadius="12"
                  Background="{StaticResource ConsoleAccentBlueAlpha20Brush}" BorderBrush="{DynamicResource InfoColorBrush}" BorderThickness="1">
            <TextBlock Text="⠿" FontSize="20" Foreground="{DynamicResource InfoColorBrush}"
                       VerticalAlignment="Center" HorizontalAlignment="Center" />
          </Border>
          <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
            <TextBlock Text="Scatter Analysis" Style="{StaticResource PageTitleStyle}" />
            <TextBlock Text="Plot the relationship between two data series with regression and statistics."
                       Style="{StaticResource CardDescriptionStyle}" />
          </StackPanel>
        </StackPanel>

        <!-- Symbol inputs -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="X" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center"
                     Margin="0,0,6,0" FontWeight="SemiBold" />
          <TextBox x:Name="XSymbolBox" MinWidth="90"
                   Text="{Binding XSymbol, UpdateSourceTrigger=PropertyChanged}"
                   Style="{StaticResource SearchBoxStyle}"
                   ToolTip="X-axis symbol (e.g. SPY)" />
          <TextBlock Text="vs" Style="{StaticResource FormLabelStyle}" Margin="10,0" VerticalAlignment="Center" />
          <TextBlock Text="Y" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center"
                     Margin="0,0,6,0" FontWeight="SemiBold" />
          <TextBox x:Name="YSymbolBox" MinWidth="90"
                   Text="{Binding YSymbol, UpdateSourceTrigger=PropertyChanged}"
                   Style="{StaticResource SearchBoxStyle}"
                   ToolTip="Y-axis symbol (e.g. QQQ)" />
          <Button Content="Plot" Margin="12,0,0,0"
                  Command="{Binding PlotCommand}"
                  Style="{StaticResource PrimaryButtonStyle}" />
        </StackPanel>

        <!-- Time-range RadioButtons (GroupName provides mutual exclusion natively) -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <RadioButton Content="1M"  Tag="1M"  GroupName="TimeRange" Style="{StaticResource TimeRangeButtonStyle}" Checked="TimeRange_Checked" />
          <RadioButton Content="3M"  Tag="3M"  GroupName="TimeRange" Style="{StaticResource TimeRangeButtonStyle}" Checked="TimeRange_Checked" />
          <RadioButton Content="6M"  Tag="6M"  GroupName="TimeRange" Style="{StaticResource TimeRangeButtonStyle}" Checked="TimeRange_Checked" />
          <RadioButton Content="1Y"  Tag="1Y"  GroupName="TimeRange" Style="{StaticResource TimeRangeButtonStyle}" Checked="TimeRange_Checked" IsChecked="True" />
          <RadioButton Content="3Y"  Tag="3Y"  GroupName="TimeRange" Style="{StaticResource TimeRangeButtonStyle}" Checked="TimeRange_Checked" />
          <RadioButton Content="MAX" Tag="MAX" GroupName="TimeRange" Style="{StaticResource TimeRangeButtonStyle}" Checked="TimeRange_Checked" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- ══ Body: Quickstart sidebar + chart area ════════════════════════════ -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="220" />   <!-- Quickstart sidebar -->
        <ColumnDefinition Width="*" />     <!-- Chart + bottom panel -->
      </Grid.ColumnDefinitions>

      <!-- ── Quickstart sidebar ─────────────────────────────────────────── -->
      <Border Grid.Column="0"
              Margin="24,12,0,24"
              Background="{StaticResource ChartSurfaceBrush}"
              BorderBrush="{StaticResource ChartBorderBrush}"
              BorderThickness="1" CornerRadius="8"
              ClipToBounds="True">
        <DockPanel>

          <!-- "EXPLORE PLOTTOOL" section label -->
          <Border DockPanel.Dock="Top"
                  Padding="12,10"
                  BorderBrush="{StaticResource ChartBorderBrush}"
                  BorderThickness="0,0,0,1">
            <TextBlock Text="EXPLORE PLOTTOOL"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource ChartAxisLabelBrush}" />
          </Border>

          <!-- "Quickstart" group header -->
          <Border DockPanel.Dock="Top"
                  Padding="12,8"
                  Background="{StaticResource ChartPlotAreaBrush}"
                  BorderBrush="{StaticResource ChartBorderBrush}"
                  BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="▾" FontSize="11" VerticalAlignment="Center"
                         Foreground="{StaticResource ChartAxisLabelBrush}" Margin="0,0,5,0" />
              <TextBlock Text="Quickstart"
                         FontSize="12" FontWeight="SemiBold"
                         Foreground="{StaticResource TopBarTextBrush}" />
            </StackPanel>
          </Border>

          <!-- Template list -->
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding QuickstartTemplates}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Style="{StaticResource QuickstartItemStyle}"
                          Command="{Binding DataContext.ApplyTemplateCommand,
                                            RelativeSource={RelativeSource AncestorType=Page}}"
                          CommandParameter="{Binding}"
                          HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="›" FontSize="12" VerticalAlignment="Center"
                                 Foreground="{StaticResource ChartAxisLabelBrush}" Margin="0,0,4,0" />
                      <TextBlock Text="📁" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0" />
                      <TextBlock Text="{Binding Name}" FontSize="12"
                                 Foreground="{StaticResource TopBarTextBrush}"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

        </DockPanel>
      </Border>

      <!-- ── Chart + bottom panel ────────────────────────────────────────── -->
      <Grid Grid.Column="1" Margin="8,12,24,24">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" MinHeight="300" />   <!-- Chart -->
        <RowDefinition Height="5" />                   <!-- Splitter -->
        <RowDefinition Height="220" MinHeight="140" /> <!-- Bottom panel -->
      </Grid.RowDefinitions>

      <!-- ── Chart area ───────────────────────────────────────────────────── -->
      <Border Grid.Row="0"
              Style="{StaticResource ChartCardStyle}"
              Padding="0">
        <Grid>
          <!-- Chart title -->
          <TextBlock x:Name="ChartTitleBlock"
                     Text="{Binding ChartTitle}"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="{StaticResource TopBarTextBrush}"
                     Margin="16,12,16,0"
                     VerticalAlignment="Top" Panel.ZIndex="1" />

          <!-- ScottPlot chart control -->
          <scottplot:WpfPlot x:Name="ScatterPlot"
                             Margin="0,38,0,0"
                             Visibility="{Binding ChartVisible}" />

          <!-- No-data / loading overlay -->
          <Border Visibility="{Binding NoDataVisible}"
                  VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock Text="📊" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8" />
              <TextBlock Text="{Binding StatusMessage}"
                         Style="{StaticResource CardDescriptionStyle}"
                         Foreground="{StaticResource ChartAxisLabelBrush}"
                         HorizontalAlignment="Center" FontSize="13" />
            </StackPanel>
          </Border>

          <!-- Loading spinner text -->
          <Border Visibility="{Binding LoadingVisible}" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Loading data…" Style="{StaticResource CardDescriptionStyle}" Foreground="{StaticResource ChartAxisLabelBrush}" FontSize="13" />
          </Border>

          <!-- Legend strip (bottom left) -->
          <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Left"
                      Margin="16,0,0,12"
                      Visibility="{Binding ChartVisible}">
            <Ellipse Width="10" Height="10" Fill="{StaticResource ChartSecondaryLineBrush}" Margin="0,0,4,0" VerticalAlignment="Center" />
            <TextBlock Text="History" FontSize="11" Foreground="{StaticResource ChartAxisLabelBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />
            <Ellipse Width="10" Height="10" Fill="{StaticResource ChartDrawdownBrush}" Margin="0,0,4,0" VerticalAlignment="Center" />
            <TextBlock Text="Current" FontSize="11" Foreground="{StaticResource ChartAxisLabelBrush}" VerticalAlignment="Center" />
          </StackPanel>

          <!-- Status bar -->
          <TextBlock Text="{Binding StatusMessage}"
                     FontSize="11"
                     Foreground="{StaticResource ChartAxisLabelBrush}"
                     VerticalAlignment="Bottom" HorizontalAlignment="Right"
                     Margin="0,0,12,8"
                     Visibility="{Binding ChartVisible}" />
        </Grid>
      </Border>

      <!-- ── Grid splitter ────────────────────────────────────────────────── -->
      <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                    Background="{StaticResource ChartBorderBrush}" Cursor="SizeNS" />

      <!-- ── Bottom analysis panel ────────────────────────────────────────── -->
      <Border Grid.Row="2"
              Style="{StaticResource ChartCardStyle}"
              Padding="0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Tab headers -->
            <RowDefinition Height="*" />     <!-- Tab content -->
          </Grid.RowDefinitions>

          <!-- Tab header strip -->
          <Border Grid.Row="0"
                  BorderBrush="{StaticResource ChartBorderBrush}" BorderThickness="0,0,0,1"
                  Background="{StaticResource ChartPlotAreaBrush}">
            <StackPanel Orientation="Horizontal" Height="32">
              <RadioButton x:Name="TabExpressionEditor" Content="Expression Editor"
                           Style="{StaticResource AnalysisTabButtonStyle}"
                           IsChecked="True" GroupName="AnalysisTabs"
                           Checked="Tab_Checked" Tag="0" />
              <RadioButton x:Name="TabDataSheet" Content="Data Sheet"
                           Style="{StaticResource AnalysisTabButtonStyle}"
                           GroupName="AnalysisTabs"
                           Checked="Tab_Checked" Tag="1" />
              <RadioButton x:Name="TabStatistics" Content="Statistics"
                           Style="{StaticResource AnalysisTabButtonStyle}"
                           GroupName="AnalysisTabs"
                           Checked="Tab_Checked" Tag="2" />
            </StackPanel>
          </Border>

          <!-- Tab content -->
          <Grid Grid.Row="1">

            <!-- ─ Expression Editor tab ─ -->
            <Grid x:Name="PanelExpressionEditor" Margin="12,8">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <!-- Expression 1 (X) -->
              <Border Grid.Row="0"
                      Background="{StaticResource ChartPlotAreaBrush}" BorderBrush="{StaticResource ChartBorderBrush}" BorderThickness="1" CornerRadius="4"
                      Padding="8,6" Margin="0,0,0,4">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="1" Style="{StaticResource LineNumberStyle}" />
                  <TextBox Style="{StaticResource ExpressionTextBoxStyle}"
                           Text="{Binding XExpression, UpdateSourceTrigger=PropertyChanged}"
                           MinWidth="400"
                           ToolTip="X-axis expression — edit and press Plot" />
                </StackPanel>
              </Border>

              <!-- Expression 2 (Y) -->
              <Border Grid.Row="1"
                      Background="{StaticResource ChartPlotAreaBrush}" BorderBrush="{StaticResource ChartBorderBrush}" BorderThickness="1" CornerRadius="4"
                      Padding="8,6">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="2" Style="{StaticResource LineNumberStyle}" />
                  <TextBox Style="{StaticResource ExpressionTextBoxStyle}"
                           Text="{Binding YExpression, UpdateSourceTrigger=PropertyChanged}"
                           MinWidth="400"
                           ToolTip="Y-axis expression — edit and press Plot" />
                </StackPanel>
              </Border>
            </Grid>

            <!-- ─ Data Sheet tab ─ -->
            <Grid x:Name="PanelDataSheet" Visibility="Collapsed" Margin="0">
              <DataGrid x:Name="DataSheetGrid"
                        ItemsSource="{Binding DataSheetRows}"
                        AutoGenerateColumns="False"
                        IsReadOnly="True"
                        GridLinesVisibility="Horizontal"
                        HeadersVisibility="Column"
                        SelectionMode="Single"
                        BorderThickness="0"
                        Background="Transparent"
                        RowBackground="Transparent"
                        AlternatingRowBackground="{StaticResource ChartPlotAreaBrush}"
                        Foreground="{StaticResource TopBarTextBrush}"
                        FontSize="12"
                        ColumnHeaderHeight="28">
                <DataGrid.ColumnHeaderStyle>
                  <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource ChartPlotAreaBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource ChartAxisLabelBrush}" />
                    <Setter Property="FontSize" Value="11" />
                    <Setter Property="Padding" Value="10,0" />
                    <Setter Property="BorderThickness" Value="0" />
                  </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Date"    Binding="{Binding Date}"   Width="120" />
                  <DataGridTextColumn Header="X Value" Binding="{Binding XValue}" Width="*" />
                  <DataGridTextColumn Header="Y Value" Binding="{Binding YValue}" Width="*" />
                </DataGrid.Columns>
              </DataGrid>
            </Grid>

            <!-- ─ Statistics tab ─ -->
            <ScrollViewer x:Name="PanelStatistics" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto" Margin="12,8">
              <WrapPanel>
                <!-- Correlation card -->
                <Border Style="{StaticResource SectionCardStyle}" Width="170" Margin="0,0,10,8">
                  <StackPanel>
                    <TextBlock Text="CORRELATION" Style="{StaticResource StatLabelStyle}" />
                    <TextBlock Text="{Binding CorrelationText}" Style="{StaticResource StatValueStyle}"
                               FontSize="18" Margin="0,4,0,0" />
                  </StackPanel>
                </Border>

                <!-- R² card -->
                <Border Style="{StaticResource SectionCardStyle}" Width="130" Margin="0,0,10,8">
                  <StackPanel>
                    <TextBlock Text="R²" Style="{StaticResource StatLabelStyle}" />
                    <TextBlock Text="{Binding RSquaredText}" Style="{StaticResource StatValueStyle}"
                               FontSize="18" Margin="0,4,0,0" />
                  </StackPanel>
                </Border>

                <!-- Slope card -->
                <Border Style="{StaticResource SectionCardStyle}" Width="130" Margin="0,0,10,8">
                  <StackPanel>
                    <TextBlock Text="SLOPE" Style="{StaticResource StatLabelStyle}" />
                    <TextBlock Text="{Binding SlopeText}" Style="{StaticResource StatValueStyle}"
                               FontSize="18" Margin="0,4,0,0" />
                  </StackPanel>
                </Border>

                <!-- Intercept card -->
                <Border Style="{StaticResource SectionCardStyle}" Width="130" Margin="0,0,10,8">
                  <StackPanel>
                    <TextBlock Text="INTERCEPT" Style="{StaticResource StatLabelStyle}" />
                    <TextBlock Text="{Binding InterceptText}" Style="{StaticResource StatValueStyle}"
                               FontSize="18" Margin="0,4,0,0" />
                  </StackPanel>
                </Border>

                <!-- Count card -->
                <Border Style="{StaticResource SectionCardStyle}" Width="100" Margin="0,0,10,8">
                  <StackPanel>
                    <TextBlock Text="N POINTS" Style="{StaticResource StatLabelStyle}" />
                    <TextBlock Text="{Binding CountText}" Style="{StaticResource StatValueStyle}"
                               FontSize="18" Margin="0,4,0,0" />
                  </StackPanel>
                </Border>

                <!-- X Mean -->
                <Border Style="{StaticResource SectionCardStyle}" Width="130" Margin="0,0,10,8">
                  <StackPanel>
                    <TextBlock Text="X MEAN" Style="{StaticResource StatLabelStyle}" />
                    <TextBlock Text="{Binding XMeanText}" Style="{StaticResource StatValueStyle}"
                               FontSize="16" Margin="0,4,0,0" />
                  </StackPanel>
                </Border>

                <!-- Y Mean -->
                <Border Style="{StaticResource SectionCardStyle}" Width="130" Margin="0,0,10,8">
                  <StackPanel>
                    <TextBlock Text="Y MEAN" Style="{StaticResource StatLabelStyle}" />
                    <TextBlock Text="{Binding YMeanText}" Style="{StaticResource StatValueStyle}"
                               FontSize="16" Margin="0,4,0,0" />
                  </StackPanel>
                </Border>

                <!-- X Std Dev -->
                <Border Style="{StaticResource SectionCardStyle}" Width="130" Margin="0,0,10,8">
                  <StackPanel>
                    <TextBlock Text="X STD DEV" Style="{StaticResource StatLabelStyle}" />
                    <TextBlock Text="{Binding XStdDevText}" Style="{StaticResource StatValueStyle}"
                               FontSize="16" Margin="0,4,0,0" />
                  </StackPanel>
                </Border>

                <!-- Y Std Dev -->
                <Border Style="{StaticResource SectionCardStyle}" Width="130" Margin="0,0,10,8">
                  <StackPanel>
                    <TextBlock Text="Y STD DEV" Style="{StaticResource StatLabelStyle}" />
                    <TextBlock Text="{Binding YStdDevText}" Style="{StaticResource StatValueStyle}"
                               FontSize="16" Margin="0,4,0,0" />
                  </StackPanel>
                </Border>
              </WrapPanel>
            </ScrollViewer>

          </Grid>
        </Grid>
      </Border>
      </Grid>  <!-- ── end Chart + bottom panel ── -->

    </Grid>  <!-- ── end Body grid ── -->
  </Grid>
</Page>
