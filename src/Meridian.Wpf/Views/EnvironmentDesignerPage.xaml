<Page x:Class="Meridian.Wpf.Views.EnvironmentDesignerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="960"
      d:DesignWidth="1440"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Environment Designer" Style="{StaticResource PageTitleStyle}" />
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource CardDescriptionStyle}" Margin="0,6,0,0" />
                </StackPanel>

                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <Button Content="Refresh"
                            Click="OnRefreshClick"
                            Style="{StaticResource GhostButtonStyle}"
                            Margin="0,0,8,0" />
                    <Button Content="New Blank Draft"
                            Click="OnCreateBlankDraftClick"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,0" />
                    <Button Content="New Advisory Starter"
                            Click="OnCreateAdvisoryStarterClick"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Drafts" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12" />
                        <ListBox ItemsSource="{Binding Drafts}"
                                 SelectedItem="{Binding SelectedDraft, Mode=TwoWay}"
                                 SelectionChanged="OnDraftSelectionChanged"
                                 BorderThickness="0"
                                 Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource ConsoleBackgroundLightBrush}"
                                            BorderBrush="{StaticResource ConsoleBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12"
                                            Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding UpdatedAt}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="Published Versions" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12" />
                        <ListBox ItemsSource="{Binding Versions}"
                                 SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                                 SelectionChanged="OnVersionSelectionChanged"
                                 BorderThickness="0"
                                 Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource ConsoleBackgroundLightBrush}"
                                            BorderBrush="{StaticResource ConsoleBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12"
                                            Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding VersionLabel}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding PublishedAt}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                            <TextBlock Text="{Binding OrganizationName}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="Save Draft"
                                Click="OnSaveDraftClick"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,0,8,0" />
                        <Button Content="Validate"
                                Click="OnValidateDraftClick"
                                Style="{StaticResource GhostButtonStyle}"
                                Margin="0,0,8,0" />
                        <Button Content="Preview Publish"
                                Click="OnPreviewPublishClick"
                                Style="{StaticResource GhostButtonStyle}"
                                Margin="0,0,8,0" />
                        <Button Content="Publish"
                                Click="OnPublishClick"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Text="{Binding DraftJson, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="13"
                             TextWrapping="NoWrap"
                             Padding="12" />

                    <TextBlock Grid.Row="2"
                               Text="Edit the full draft JSON to add lanes, nodes, relationships, and shell defaults."
                               Style="{StaticResource CardDescriptionStyle}"
                               Margin="0,12,0,0" />
                </Grid>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Inspector" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12" />

                    <StackPanel Grid.Row="1">
                        <TextBlock Text="Draft Summary" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                        <TextBox Text="{Binding DraftSummaryText, Mode=OneWay}"
                                 Margin="0,4,0,12"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="180" />
                    </StackPanel>

                    <TextBox Grid.Row="2"
                             Text="{Binding ValidationAndDiffText, Mode=OneWay}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Padding="8" />

                    <Button Grid.Row="3"
                            Content="Rollback Selected Version"
                            Click="OnRollbackClick"
                            Style="{StaticResource GhostButtonStyle}"
                            Margin="0,12,0,0" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
