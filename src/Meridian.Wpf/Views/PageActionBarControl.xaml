<UserControl x:Class="Meridian.Wpf.Views.PageActionBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:Meridian.Wpf.Models"
             mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <CollectionViewSource x:Key="ActionsSource" Source="{Binding Actions}" />
    </UserControl.Resources>

    <Border Height="40" 
            Background="{StaticResource ConsoleBackgroundMediumBrush}"
            BorderBrush="{StaticResource ConsoleBorderBrush}" 
            BorderThickness="0,0,0,1"
            Padding="12,0">
        <DockPanel VerticalAlignment="Center">
            <!-- Page title on left -->
            <TextBlock DockPanel.Dock="Left" 
                       Text="{Binding PageTitle}" 
                       FontSize="13" 
                       FontWeight="SemiBold" 
                       VerticalAlignment="Center"
                       Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                       Margin="0,0,16,0"
                       Visibility="{Binding PageTitle, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Separator line if title is present -->
            <Border DockPanel.Dock="Left"
                    Width="1"
                    Background="{StaticResource ConsoleBorderBrush}"
                    Margin="0,4,16,4"
                    Visibility="{Binding PageTitle, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Action buttons on left -->
            <ItemsControl ItemsSource="{Binding Actions}" 
                          DockPanel.Dock="Left">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ActionEntry}">
                        <Button Command="{Binding Command}"
                                ToolTip="{Binding Tooltip}"
                                Margin="0,0,4,0"
                                Padding="8,6,8,6"
                                Background="{StaticResource ConsoleBackgroundLightBrush}"
                                Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                BorderBrush="{StaticResource ConsoleBorderBrush}"
                                BorderThickness="1"
                                Cursor="Hand"
                                FontSize="12">
                            <StackPanel Orientation="Horizontal">
                                <!-- Icon (if present) -->
                                <TextBlock Text="{Binding Icon}"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="14"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding Icon, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <!-- Label -->
                                <TextBlock Text="{Binding Label}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <!-- Trigger style change for primary actions -->
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{StaticResource ConsoleBackgroundLightBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPrimary}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource ConsoleAccentGreenDimBrush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource ConsoleAccentGreen}"/>
                                            <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource ConsoleBackgroundHoverBrush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderHoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="{StaticResource ConsoleBackgroundActiveBrush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderFocusBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Stretch area to push actions left -->
            <Border DockPanel.Dock="Left" />
        </DockPanel>
    </Border>
</UserControl>
