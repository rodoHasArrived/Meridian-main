<Page x:Class="Meridian.Wpf.Views.WorkflowLibraryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      AutomationProperties.Name="Workflow library">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20,28,32">
        <StackPanel MaxWidth="1180">
            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Width="44"
                                Height="44"
                                CornerRadius="14"
                                Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                BorderBrush="{StaticResource InfoColorBrush}"
                                BorderThickness="1">
                            <TextBlock Text="&#xE8FD;"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="24"
                                       Foreground="{StaticResource InfoColorBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Workflow Library" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="{Binding SummaryText}" Style="{StaticResource CardDescriptionStyle}" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource GhostButtonStyle}"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             MinWidth="320"
                             Style="{StaticResource FormTextBoxStyle}"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.Name="Workflow library search" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SummaryText}"
                               Margin="16,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                               FontSize="12" />
                </Grid>
            </Border>

            <TextBlock Text="{Binding EmptyStateText}"
                       Visibility="{Binding HasWorkflows, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                       Margin="0,0,0,20" />

            <ItemsControl ItemsSource="{Binding Workflows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Title}"
                                                   Style="{StaticResource CardHeaderStyle}" />
                                        <Border Margin="10,0,0,0"
                                                Padding="8,2"
                                                CornerRadius="999"
                                                Background="{StaticResource ConsoleAccentBlueAlpha10Brush}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding WorkspaceTitle}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource InfoColorBrush}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Summary}"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource CardDescriptionStyle}"
                                               Margin="0,4,0,0" />
                                </StackPanel>

                                <Button Grid.Row="0"
                                        Grid.Column="1"
                                        Content="Open"
                                        Command="{Binding DataContext.OpenWorkflowCommand, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                        CommandParameter="{Binding EntryPageTag}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        VerticalAlignment="Top"
                                        Margin="16,0,0,0" />

                                <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="{StaticResource ConsoleBackgroundMediumBrush}"
                                            CornerRadius="8"
                                            Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Evidence" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                            <TextBlock Text="{Binding EvidenceText}"
                                                       TextWrapping="Wrap"
                                                       FontSize="12"
                                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2"
                                            Background="{StaticResource ConsoleBackgroundMediumBrush}"
                                            CornerRadius="8"
                                            Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Market Patterns" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                            <TextBlock Text="{Binding MarketPatternText}"
                                                       TextWrapping="Wrap"
                                                       FontSize="12"
                                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <ItemsControl Grid.Row="2"
                                              Grid.ColumnSpan="2"
                                              ItemsSource="{Binding Actions}"
                                              Margin="0,16,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource ConsoleBackgroundLightBrush}"
                                                    BorderBrush="{StaticResource ConsoleBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="12"
                                                    Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Label}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                                        <TextBlock Text="{Binding Detail}"
                                                                   TextWrapping="Wrap"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                                                   Margin="0,3,0,0" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Content="{Binding TargetText}"
                                                            Command="{Binding DataContext.OpenWorkflowCommand, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                            CommandParameter="{Binding TargetPageTag}"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Margin="16,0,0,0"
                                                            VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Grid.Row="3"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding WorkflowId}"
                                           FontSize="11"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           Margin="0,4,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
