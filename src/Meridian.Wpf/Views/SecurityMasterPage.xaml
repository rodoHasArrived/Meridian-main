<Page x:Class="Meridian.Wpf.Views.SecurityMasterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:converters="clr-namespace:Meridian.Wpf.Converters"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1200"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      AutomationProperties.Name="Security Master">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InvertBoolConverter x:Key="InvertBoolConverter" />
        <converters:BoolToStringConverter x:Key="BoolToStringConverter" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20,28,32">
        <StackPanel MaxWidth="1400">

            <!-- Header -->
            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Width="44" Height="44" CornerRadius="14"
                                Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1">
                            <TextBlock Text="&#xE8D7;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="24" Foreground="{StaticResource InfoColorBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Security Master" Style="{StaticResource PageTitleStyle}"/>
                            <TextBlock Text="Search, inspect, review, and manage securities registered in the Security Master."
                                       Style="{StaticResource CardDescriptionStyle}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   VerticalAlignment="Center" Margin="0,0,16,0" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Toolbar: Create/Edit/Deactivate buttons -->
            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <Button Content="+ New Security"
                            Command="{Binding CreateNewCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,8,0"/>

                    <Button Content="✏ Edit"
                            Command="{Binding EditSelectedCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,8,0"/>

                    <Button Content="✕ Deactivate"
                            Command="{Binding DeactivateSelectedCommand}"
                            Style="{StaticResource DangerButtonStyle}"/>
                </StackPanel>
            </Border>

            <!-- Search bar -->
            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="SearchBox"
                             Grid.Column="0"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}"
                             Margin="0,0,12,0"
                             KeyDown="SearchBox_KeyDown"
                             VerticalAlignment="Center"/>

                    <CheckBox Grid.Column="1"
                              Content="Active only"
                              IsChecked="{Binding ActiveOnly}"
                              VerticalAlignment="Center"
                              Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                              Margin="0,0,12,0"/>

                    <Button Grid.Column="2"
                            Content="Search"
                            Click="Search_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,8,0"/>
                </Grid>
            </Border>

            <!-- Edit panel -->
            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,24"
                    Visibility="{Binding IsEditPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="500">
                    <StackPanel>
                        <TextBlock Text="{Binding EditVm.IsEditMode, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Edit Security|Create Security'}"
                                   Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,16"/>

                        <!-- Display Name -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Display Name" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditVm.DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBoxStyle}"
                                     IsReadOnly="{Binding EditVm.IsBusy}"/>
                        </StackPanel>

                        <!-- Asset Class -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Asset Class" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding EditVm.AssetClasses}"
                                      SelectedItem="{Binding EditVm.AssetClass, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EditVm.IsBusy, Converter={StaticResource InvertBoolConverter}}"/>
                        </StackPanel>

                        <!-- Currency -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Currency" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditVm.Currency, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBoxStyle}"
                                     IsReadOnly="{Binding EditVm.IsBusy}"/>
                        </StackPanel>

                        <!-- Primary Identifier Kind -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Identifier Kind" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding EditVm.IdentifierKinds}"
                                      SelectedItem="{Binding EditVm.PrimaryIdentifierKind, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EditVm.IsBusy, Converter={StaticResource InvertBoolConverter}}"/>
                        </StackPanel>

                        <!-- Primary Identifier Value -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Identifier Value" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditVm.PrimaryIdentifierValue, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBoxStyle}"
                                     IsReadOnly="{Binding EditVm.IsBusy}"/>
                        </StackPanel>

                        <!-- Exchange (optional) -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Exchange (Optional)" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditVm.Exchange, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBoxStyle}"
                                     IsReadOnly="{Binding EditVm.IsBusy}"/>
                        </StackPanel>

                        <!-- Issuer Name (optional) -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Issuer Name (Optional)" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditVm.IssuerName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBoxStyle}"
                                     IsReadOnly="{Binding EditVm.IsBusy}"/>
                        </StackPanel>

                        <!-- Validation Errors -->
                        <ItemsControl ItemsSource="{Binding EditVm.ValidationErrors}"
                                      Visibility="{Binding EditVm.HasErrors, Converter={StaticResource BoolToVisibilityConverter}}"
                                      Margin="0,0,0,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Foreground="{StaticResource ErrorBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,4"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Status text -->
                        <TextBlock Text="{Binding EditVm.StatusText}"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   FontSize="11" Margin="0,0,0,12"/>

                        <!-- Save + Cancel buttons -->
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Save"
                                    Command="{Binding EditVm.SaveCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    IsEnabled="{Binding EditVm.IsBusy, Converter={StaticResource InvertBoolConverter}}"
                                    Margin="0,0,8,0"/>
                            <Button Content="Cancel"
                                    Command="{Binding EditVm.CancelCommand}"
                                    Style="{StaticResource GhostButtonStyle}"
                                    IsEnabled="{Binding EditVm.IsBusy, Converter={StaticResource InvertBoolConverter}}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Deactivate panel -->
            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,24"
                    Visibility="{Binding IsDeactivatePanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Deactivate Security" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,16"/>

                    <TextBlock Text="{Binding DeactivateVm.SecurityName, StringFormat='Are you sure you want to deactivate &quot;{0}&quot;? This action cannot be undone.'}"
                               TextWrapping="Wrap" Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                               Margin="0,0,0,12"/>

                    <!-- Reason (optional) -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Reason (Optional)" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding DeactivateVm.Reason, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 IsReadOnly="{Binding DeactivateVm.IsBusy}"
                                 TextWrapping="Wrap" MaxHeight="80"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>

                    <!-- Status text -->
                    <TextBlock Text="{Binding DeactivateVm.StatusText}"
                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                               FontSize="11" Margin="0,0,0,12"/>

                    <!-- Confirm + Cancel buttons -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Confirm Deactivation"
                                Command="{Binding DeactivateVm.ConfirmCommand}"
                                Style="{StaticResource DangerButtonStyle}"
                                IsEnabled="{Binding DeactivateVm.IsBusy, Converter={StaticResource InvertBoolConverter}}"
                                Margin="0,0,8,0"/>
                        <Button Content="Cancel"
                                Command="{Binding DeactivateVm.CancelCommand}"
                                Style="{StaticResource GhostButtonStyle}"
                                IsEnabled="{Binding DeactivateVm.IsBusy, Converter={StaticResource InvertBoolConverter}}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Results + detail split -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <!-- Results list -->
                <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Results" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="Loading…"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   Margin="0,0,0,8"/>

                        <ListBox x:Name="ResultsList"
                                 ItemsSource="{Binding Results}"
                                 SelectedItem="{Binding SelectedSecurity, Mode=TwoWay}"
                                 SelectionChanged="ResultsList_SelectionChanged"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 MaxHeight="520"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4,6">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Classification.AssetClass}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource ConsoleTextMutedBrush}"/>
                                            <TextBlock Text=" · "
                                                       FontSize="11"
                                                       Foreground="{StaticResource ConsoleTextMutedBrush}"/>
                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource ConsoleTextMutedBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Detail panel -->
                <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}"
                        Visibility="{Binding HasSelectedSecurity, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Security Detail" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,16"/>

                            <!-- Name + status -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="{Binding SelectedSecurity.DisplayName}"
                                           FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Border Background="{StaticResource InfoColorBrush}"
                                        CornerRadius="999" Padding="10,3"
                                        Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedStatusBadge}"
                                               FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>

                            <TextBlock Text="{Binding SelectedIdentifier}"
                                       FontSize="12"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       Margin="0,0,0,16"/>

                            <!-- Classification grid -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Asset Class"
                                           Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding SelectedAssetClass}"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,0,0,4"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Currency"
                                           Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{Binding SelectedCurrency}"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,0,0,4"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Version"
                                           Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{Binding SelectedSecurity.EconomicDefinition.Version}"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,0,0,4"/>
                            </Grid>

                            <!-- Event history -->
                            <TextBlock Text="Event History" Style="{StaticResource CardHeaderStyle}" Margin="0,8,0,8"/>
                            <TextBox Text="{Binding HistoryText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                     TextWrapping="Wrap"
                                     MaxHeight="200"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Placeholder when nothing selected -->
                <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}"
                        Visibility="{Binding HasSelectedSecurity, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40">
                        <TextBlock Text="&#xE8D7;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="40" HorizontalAlignment="Center"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,0,0,12"/>
                        <TextBlock Text="Select a security to view details."
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
