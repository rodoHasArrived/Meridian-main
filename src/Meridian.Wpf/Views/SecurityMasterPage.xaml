<Page x:Class="Meridian.Wpf.Views.SecurityMasterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:converters="clr-namespace:Meridian.Wpf.Converters"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1200"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      AutomationProperties.Name="Security Master">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20,28,32">
        <StackPanel MaxWidth="1400">

            <!-- Header -->
            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Width="44" Height="44" CornerRadius="14"
                                Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1">
                            <TextBlock Text="&#xE8D7;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="24" Foreground="{StaticResource InfoColorBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Security Master" Style="{StaticResource PageTitleStyle}"/>
                            <TextBlock Text="Search, inspect, and review securities registered in the Security Master."
                                       Style="{StaticResource CardDescriptionStyle}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   VerticalAlignment="Center" Margin="0,0,16,0" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Search bar -->
            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="SearchBox"
                             Grid.Column="0"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}"
                             Margin="0,0,12,0"
                             KeyDown="SearchBox_KeyDown"
                             VerticalAlignment="Center"/>

                    <CheckBox Grid.Column="1"
                              Content="Active only"
                              IsChecked="{Binding ActiveOnly}"
                              VerticalAlignment="Center"
                              Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                              Margin="0,0,12,0"/>

                    <Button Grid.Column="2"
                            Content="Search"
                            Click="Search_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,8,0"/>
                </Grid>
            </Border>

            <!-- Results + detail split -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <!-- Results list -->
                <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Results" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="Loading…"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   Margin="0,0,0,8"/>

                        <ListBox x:Name="ResultsList"
                                 ItemsSource="{Binding Results}"
                                 SelectedItem="{Binding SelectedSecurity, Mode=TwoWay}"
                                 SelectionChanged="ResultsList_SelectionChanged"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 MaxHeight="520"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4,6">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Classification.AssetClass}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource ConsoleTextMutedBrush}"/>
                                            <TextBlock Text=" · "
                                                       FontSize="11"
                                                       Foreground="{StaticResource ConsoleTextMutedBrush}"/>
                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource ConsoleTextMutedBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Detail panel -->
                <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}"
                        Visibility="{Binding HasSelectedSecurity, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Security Detail" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,16"/>

                            <!-- Name + status -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="{Binding SelectedSecurity.DisplayName}"
                                           FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Border Background="{StaticResource InfoColorBrush}"
                                        CornerRadius="999" Padding="10,3"
                                        Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedStatusBadge}"
                                               FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>

                            <TextBlock Text="{Binding SelectedIdentifier}"
                                       FontSize="12"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       Margin="0,0,0,16"/>

                            <!-- Classification grid -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Asset Class"
                                           Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding SelectedAssetClass}"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,0,0,4"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Currency"
                                           Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{Binding SelectedCurrency}"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,0,0,4"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Version"
                                           Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{Binding SelectedSecurity.EconomicDefinition.Version}"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,0,0,4"/>
                            </Grid>

                            <!-- Event history -->
                            <TextBlock Text="Event History" Style="{StaticResource CardHeaderStyle}" Margin="0,8,0,8"/>
                            <TextBox Text="{Binding HistoryText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                     TextWrapping="Wrap"
                                     MaxHeight="200"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Placeholder when nothing selected -->
                <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}"
                        Visibility="{Binding HasSelectedSecurity, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40">
                        <TextBlock Text="&#xE8D7;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="40" HorizontalAlignment="Center"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,0,0,12"/>
                        <TextBlock Text="Select a security to view details."
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
