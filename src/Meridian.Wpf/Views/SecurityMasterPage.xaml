<Page x:Class="Meridian.Wpf.Views.SecurityMasterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:converters="clr-namespace:Meridian.Wpf.Converters"
      mc:Ignorable="d"
      d:DesignHeight="800"
      d:DesignWidth="1200"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      AutomationProperties.Name="Security Master"
      AutomationProperties.AutomationId="SecurityMasterPage">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InvertBoolConverter x:Key="InvertBoolConverter" />
        <converters:BoolToStringConverter x:Key="BoolToStringConverter" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20,28,32">
        <StackPanel MaxWidth="1500">
            <Border Style="{StaticResource EmbeddedShellCompactHeaderCardStyle}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Style="{StaticResource EmbeddedShellHeaderIdentityStackPanelStyle}">
                        <Border Width="44"
                                Height="44"
                                CornerRadius="14"
                                Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                BorderBrush="{StaticResource InfoColorBrush}"
                                BorderThickness="1">
                            <TextBlock Text="&#xE8D7;"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="24"
                                       Foreground="{StaticResource InfoColorBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Security Master" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="Search, inspect, enrich, and govern the workstation security universe from a single review surface."
                                       Style="{StaticResource CardDescriptionStyle}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0"
                                   FontSize="12" />
                        <Border Background="{StaticResource WarningColorBrush}"
                                CornerRadius="10"
                                Padding="8,2"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasOpenConflicts, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTip="Open identifier conflicts detected. Review and resolve them."
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding RefreshConflictCountCommand}" />
                            </Border.InputBindings>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠ "
                                           Foreground="#333"
                                           FontWeight="Bold"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding OpenConflictCount}"
                                           Foreground="#333"
                                           FontWeight="Bold"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <TextBlock Text=" conflicts"
                                           Foreground="#333"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource WorkspaceContextStripStyle}" Margin="0,0,0,20">
                <UniformGrid Columns="4">
                    <Border Style="{StaticResource WorkspaceContextBadgeStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Search Scope" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                            <TextBlock Text="{Binding SearchScopeText}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WorkspaceContextBadgeStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Runtime" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                            <TextBlock Text="{Binding RuntimeStatusLabel}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                            <TextBlock Text="{Binding RuntimeStatusDetail}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WorkspaceContextBadgeStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Conflicts" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                            <TextBlock Text="{Binding ConflictSummaryText}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WorkspaceContextBadgeStyle}">
                        <StackPanel>
                            <TextBlock Text="Import Session" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                            <TextBlock Text="{Binding ImportSessionText}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </Border>

            <Border Style="{StaticResource WorkspaceCommandBarSurfaceStyle}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <WrapPanel Grid.Column="0">
                        <Button Content="+ New Security"
                                Command="{Binding CreateNewCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,0,8,8" />
                        <Button Content="Edit Selected"
                                Command="{Binding EditSelectedCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,8" />
                        <Button Content="Deactivate Selected"
                                Command="{Binding DeactivateSelectedCommand}"
                                Style="{StaticResource DangerButtonStyle}"
                                Margin="0,0,8,8" />
                        <Button Content="Import Universe"
                                Command="{Binding ImportFromFileCommand}"
                                IsEnabled="{Binding IsImporting, Converter={StaticResource InvertBoolConverter}}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,8" />
                    </WrapPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button Content="Refresh Workflow"
                                Command="{Binding RefreshWorkflowCommand}"
                                Style="{StaticResource GhostButtonStyle}"
                                Margin="0,0,8,8" />
                        <Button Content="Backfill Trading Parameters"
                                Command="{Binding BackfillTradingParamsCommand}"
                                IsEnabled="{Binding IsBackfillingTradingParams, Converter={StaticResource InvertBoolConverter}}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,8" />
                        <TextBlock Text="{Binding BackfillStatus}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   MaxWidth="260" />
                    </StackPanel>
                </Grid>
            </Border>
            <Border Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,20"
                    Visibility="{Binding IsImporting, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Importing securities from file..."
                               Style="{StaticResource CardHeaderStyle}"
                               Margin="0,0,0,12" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="240" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding ImportStatus}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                        <ProgressBar Grid.Column="1"
                                     Value="{Binding ImportProcessed, Mode=OneWay}"
                                     Maximum="{Binding ImportTotal, Mode=OneWay}"
                                     Height="16"
                                     Margin="16,0,0,0" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,20"
                    Visibility="{Binding IsImportResultVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="{StaticResource ConsoleBackgroundDarkBrush}">
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Content="×"
                            Command="{Binding CloseImportResultCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="32"
                            Height="32"
                            Margin="12,0,0,0" />
                    <TextBlock Text="{Binding ImportResultSummary}"
                               Style="{StaticResource CardDescriptionStyle}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                </DockPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="SearchBox"
                             Grid.Column="0"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}"
                             Margin="0,0,12,0"
                             VerticalAlignment="Center"
                             AutomationProperties.AutomationId="SecurityMasterSearchBox">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter"
                                        Command="{Binding SearchCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>

                    <CheckBox Grid.Column="1"
                              Content="Active only"
                              IsChecked="{Binding ActiveOnly}"
                              VerticalAlignment="Center"
                              Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                              Margin="0,0,12,0" />

                    <TextBlock Grid.Column="2"
                               Text="{Binding ResultCount, StringFormat=Results {0}}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                               Margin="0,0,12,0" />

                    <Button Grid.Column="3"
                            Content="Search"
                            Command="{Binding SearchCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,8,0"
                            AutomationProperties.AutomationId="SecurityMasterSearchButton" />

                    <Button Grid.Column="4"
                            Content="Clear Search"
                            Command="{Binding ClearSearchCommand}"
                            Style="{StaticResource GhostButtonStyle}"
                            AutomationProperties.AutomationId="SecurityMasterClearSearchButton" />
                </Grid>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,20"
                    Visibility="{Binding IsEditPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="500">
                    <StackPanel>
                        <TextBlock Text="{Binding EditVm.IsEditMode, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Edit Security|Create Security'}"
                                   Style="{StaticResource CardHeaderStyle}"
                                   Margin="0,0,0,16" />

                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Display Name" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding EditVm.DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FormTextBoxStyle}"
                                         IsReadOnly="{Binding EditVm.IsBusy}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Asset Class" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding EditVm.AssetClasses}"
                                          SelectedItem="{Binding EditVm.AssetClass, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding EditVm.IsBusy, Converter={StaticResource InvertBoolConverter}}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Currency" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding EditVm.Currency, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FormTextBoxStyle}"
                                         IsReadOnly="{Binding EditVm.IsBusy}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Identifier Kind" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding EditVm.IdentifierKinds}"
                                          SelectedItem="{Binding EditVm.PrimaryIdentifierKind, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding EditVm.IsBusy, Converter={StaticResource InvertBoolConverter}}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock Text="Identifier Value" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding EditVm.PrimaryIdentifierValue, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FormTextBoxStyle}"
                                         IsReadOnly="{Binding EditVm.IsBusy}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Exchange (Optional)" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding EditVm.Exchange, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FormTextBoxStyle}"
                                         IsReadOnly="{Binding EditVm.IsBusy}" />
                            </StackPanel>
                        </UniformGrid>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Issuer Name (Optional)" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding EditVm.IssuerName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBoxStyle}"
                                     IsReadOnly="{Binding EditVm.IsBusy}" />
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding EditVm.ValidationErrors}"
                                      Visibility="{Binding EditVm.HasErrors, Converter={StaticResource BoolToVisibilityConverter}}"
                                      Margin="0,0,0,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Foreground="{StaticResource ErrorBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding EditVm.StatusText}"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   FontSize="11"
                                   Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Save"
                                    Command="{Binding EditVm.SaveCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    IsEnabled="{Binding EditVm.IsBusy, Converter={StaticResource InvertBoolConverter}}"
                                    Margin="0,0,8,0" />
                            <Button Content="Cancel"
                                    Command="{Binding EditVm.CancelCommand}"
                                    Style="{StaticResource GhostButtonStyle}"
                                    IsEnabled="{Binding EditVm.IsBusy, Converter={StaticResource InvertBoolConverter}}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,20"
                    Visibility="{Binding IsDeactivatePanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Deactivate Security" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,16" />
                    <TextBlock Text="{Binding DeactivateVm.SecurityName, StringFormat='Are you sure you want to deactivate &quot;{0}&quot;? This action cannot be undone.'}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                               Margin="0,0,0,12" />
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Reason (Optional)" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding DeactivateVm.Reason, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 IsReadOnly="{Binding DeactivateVm.IsBusy}"
                                 TextWrapping="Wrap"
                                 MaxHeight="80"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                    <TextBlock Text="{Binding DeactivateVm.StatusText}"
                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                               FontSize="11"
                               Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Confirm Deactivation"
                                Command="{Binding DeactivateVm.ConfirmCommand}"
                                Style="{StaticResource DangerButtonStyle}"
                                IsEnabled="{Binding DeactivateVm.IsBusy, Converter={StaticResource InvertBoolConverter}}"
                                Margin="0,0,8,0" />
                        <Button Content="Cancel"
                                Command="{Binding DeactivateVm.CancelCommand}"
                                Style="{StaticResource GhostButtonStyle}"
                                IsEnabled="{Binding DeactivateVm.IsBusy, Converter={StaticResource InvertBoolConverter}}" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.3*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="3.2*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="1.7*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource WorkspaceWorkbenchCardStyle}"
                        AutomationProperties.AutomationId="SecurityMasterResultsWorkbench">
                    <StackPanel>
                        <TextBlock Text="Search Results" Style="{StaticResource CardHeaderStyle}" />
                        <TextBlock Text="{Binding StatusText}"
                                   Style="{StaticResource CardDescriptionStyle}"
                                   Margin="0,6,0,12"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Loading…"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   Margin="0,0,0,8" />
                        <Border Style="{StaticResource WorkspaceEmptyStateCardStyle}"
                                Margin="0,0,0,12"
                                Visibility="{Binding IsSearchRecoveryVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                AutomationProperties.AutomationId="SecurityMasterSearchRecoveryCard">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,18">
                                <TextBlock Text="&#xE721;"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="28"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           Margin="0,0,0,10" />
                                <TextBlock Text="{Binding SearchRecoveryTitle}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center" />
                                <TextBlock Text="{Binding SearchRecoveryDetail}"
                                           Style="{StaticResource CardDescriptionStyle}"
                                           Margin="0,6,0,12"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           MaxWidth="420" />
                                <Button Content="Clear Search"
                                        Command="{Binding ClearSearchCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        AutomationProperties.AutomationId="SecurityMasterSearchRecoveryClearButton" />
                            </StackPanel>
                        </Border>
                        <ListBox x:Name="ResultsList"
                                 ItemsSource="{Binding Results}"
                                 SelectedItem="{Binding SelectedSecurity, Mode=TwoWay}"
                                 SelectionChanged="ResultsList_SelectionChanged"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 MaxHeight="620"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 AutomationProperties.AutomationId="SecurityMasterResultsList">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource WorkspaceQueueItemCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                                <TextBlock Text="{Binding Classification.PrimaryIdentifierValue, StringFormat=Identifier {0}}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,4,0,0" />
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <TextBlock Text="{Binding Classification.AssetClass}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                                    <TextBlock Text=" • " FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                                    <TextBlock Text="{Binding EconomicDefinition.Currency}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                                </StackPanel>
                                            </StackPanel>
                                            <Border Grid.Column="1" Style="{StaticResource InfoBadgeInlineStyle}" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource InfoColorBrush}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource WorkspaceWorkbenchCardStyle}"
                        AutomationProperties.AutomationId="SecurityMasterDetailWorkbench"
                        Visibility="{Binding HasSelectedSecurity, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="{Binding SelectedSecurity.DisplayName}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                           VerticalAlignment="Center" />
                                <Border Style="{StaticResource InfoBadgeInlineStyle}" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedStatusBadge}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource InfoColorBrush}" />
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{Binding SelectedIdentifier}"
                                       FontSize="12"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       Margin="0,0,0,16" />
                            <TabControl SelectedIndex="{Binding SelectedDetailTab}">
                                <TabItem Header="Overview">
                                    <StackPanel Margin="12">
                                        <UniformGrid Columns="2" Margin="0,0,0,16">
                                            <Border Style="{StaticResource WorkspaceQueueCardStyle}" Margin="0,0,8,8">
                                                <StackPanel>
                                                    <TextBlock Text="Asset Class" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                                    <TextBlock Text="{Binding SelectedAssetClass}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource WorkspaceQueueCardStyle}" Margin="0,0,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="Currency" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                                    <TextBlock Text="{Binding SelectedCurrency}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource WorkspaceQueueCardStyle}" Margin="0,0,8,0">
                                                <StackPanel>
                                                    <TextBlock Text="Version" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                                    <TextBlock Text="{Binding SelectedSecurity.EconomicDefinition.Version}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource WorkspaceQueueCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Primary Identifier" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                                    <TextBlock Text="{Binding SelectedIdentifier}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>

                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Style="{StaticResource WorkspaceQueueCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Trust Summary" Style="{StaticResource CardHeaderStyle}" />
                                                    <TextBlock Text="{Binding TrustScoreText}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,8,0,4" />
                                                    <TextBlock Text="{Binding TrustSummaryText}" Style="{StaticResource CardDescriptionStyle}" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding GoldenCopySourceText}" FontSize="12" Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,12,0,0" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding TradingParametersStatusText}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,8,0,0" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding CorporateActionReadinessText}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,8,0,0" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="2" Style="{StaticResource WorkspaceQueueCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Downstream Impact" Style="{StaticResource CardHeaderStyle}" />
                                                    <TextBlock Text="{Binding DownstreamImpactSummaryText}" Style="{StaticResource CardDescriptionStyle}" Margin="0,8,0,10" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding SelectedTrustSnapshot.DownstreamImpact.MatchedRunCount, StringFormat='Scoped runs checked: {0}'}" FontSize="12" Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                                    <TextBlock Text="{Binding SelectedTrustSnapshot.DownstreamImpact.PortfolioExposureSummary}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,8,0,0" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding SelectedTrustSnapshot.DownstreamImpact.LedgerExposureSummary}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding SelectedTrustSnapshot.DownstreamImpact.ReconciliationExposureSummary}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding SelectedTrustSnapshot.DownstreamImpact.ReportPackExposureSummary}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Border Style="{StaticResource WorkspaceQueueCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Recommended Actions" Style="{StaticResource CardHeaderStyle}" />
                                                <ItemsControl ItemsSource="{Binding RecommendedActions}" Margin="0,10,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{StaticResource WorkspaceQueueItemCardStyle}" Margin="0,0,0,8">
                                                                <StackPanel>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" TextWrapping="Wrap" />
                                                                        <Border Margin="8,0,0,0"
                                                                                Style="{StaticResource InfoBadgeInlineStyle}"
                                                                                Visibility="{Binding IsPrimary, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                            <TextBlock Text="Primary" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource InfoColorBrush}" />
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding Detail}" Style="{StaticResource CardDescriptionStyle}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </TabItem>

                                <TabItem Header="Identity &amp; Provenance"
                                         AutomationProperties.AutomationId="SecurityMasterIdentityProvenanceTab">
                                    <StackPanel Margin="12">
                                        <UniformGrid Columns="2" Margin="0,0,0,16">
                                            <Border Style="{StaticResource WorkspaceQueueCardStyle}" Margin="0,0,8,8">
                                                <StackPanel>
                                                    <TextBlock Text="Classification" Style="{StaticResource CardHeaderStyle}" />
                                                    <TextBlock Text="{Binding SelectedSecurity.Classification.AssetClass}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,8,0,0" />
                                                    <TextBlock Text="{Binding SelectedTrustSnapshot.EconomicDefinition.AssetFamily, StringFormat='Asset family: {0}'}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,6,0,0" />
                                                    <TextBlock Text="{Binding SelectedTrustSnapshot.EconomicDefinition.SubType, StringFormat='Subtype: {0}'}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,4,0,0" />
                                                    <TextBlock Text="{Binding SelectedTrustSnapshot.EconomicDefinition.IssuerType, StringFormat='Issuer type: {0}'}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource WorkspaceQueueCardStyle}" Margin="0,0,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="Winning Source" Style="{StaticResource CardHeaderStyle}" />
                                                    <TextBlock Text="{Binding GoldenCopySourceText}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,8,0,0" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding GoldenCopyRuleText}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding SelectedTrustSnapshot.EconomicDefinition.WinningSourceReason}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource WorkspaceQueueCardStyle}" Margin="0,0,8,0">
                                                <StackPanel>
                                                    <TextBlock Text="Identifiers" Style="{StaticResource CardHeaderStyle}" />
                                                    <ItemsControl ItemsSource="{Binding SelectedTrustSnapshot.Identity.Identifiers}" Margin="0,8,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Margin="0,0,0,6">
                                                                    <TextBlock Text="{Binding Kind}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                                                    <TextBlock Text="{Binding Value}" FontSize="12" Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource WorkspaceQueueCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Aliases" Style="{StaticResource CardHeaderStyle}" />
                                                    <ItemsControl ItemsSource="{Binding SelectedTrustSnapshot.Identity.Aliases}" Margin="0,8,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Margin="0,0,0,6">
                                                                    <TextBlock Text="{Binding AliasKind}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                                                    <TextBlock Text="{Binding AliasValue}" FontSize="12" Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>

                                        <Border Style="{StaticResource WorkspaceQueueCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Source Candidates" Style="{StaticResource CardHeaderStyle}" />
                                                <DataGrid ItemsSource="{Binding ProvenanceCandidates}"
                                                          AutoGenerateColumns="False"
                                                          IsReadOnly="True"
                                                          CanUserAddRows="False"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Margin="0,10,0,0">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Field Path" Binding="{Binding FieldPath}" Width="*" />
                                                        <DataGridTextColumn Header="Source System" Binding="{Binding SourceSystem}" Width="120" />
                                                        <DataGridTextColumn Header="Display Value" Binding="{Binding DisplayValue}" Width="180" />
                                                        <DataGridCheckBoxColumn Header="Winning" Binding="{Binding IsWinningSource}" Width="80" />
                                                        <DataGridTextColumn Header="As Of" Binding="{Binding AsOf, StringFormat='{}{0:g}'}" Width="120" />
                                                        <DataGridTextColumn Header="Updated By" Binding="{Binding UpdatedBy}" Width="120" />
                                                        <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="2*" />
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </TabItem>

                                <TabItem Header="History">
                                    <StackPanel Margin="12">
                                        <TextBlock Text="{Binding LatestHistoryEventText}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,0,0,10" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding HistoryText}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource ConsoleTextSecondaryBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </TabItem>

                                <TabItem Header="Conflict Queue">
                                    <Grid Margin="12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <WrapPanel>
                                            <CheckBox Content="Selected security only"
                                                      IsChecked="{Binding ShowOnlySelectedSecurityConflicts}"
                                                      Margin="0,0,12,8"
                                                      Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                            <CheckBox Content="High impact only"
                                                      IsChecked="{Binding ShowHighImpactConflictsOnly}"
                                                      Margin="0,0,12,8"
                                                      Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                            <CheckBox Content="Bulk eligible only"
                                                      IsChecked="{Binding ShowBulkEligibleConflictsOnly}"
                                                      Margin="0,0,12,8"
                                                      Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                            <Button Content="Reset Filters"
                                                    Command="{Binding ResetConflictFiltersCommand}"
                                                    Style="{StaticResource GhostButtonStyle}"
                                                    Margin="0,0,0,8" />
                                        </WrapPanel>

                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding ConflictFilterSummaryText}"
                                                   Style="{StaticResource CardDescriptionStyle}"
                                                   Margin="0,0,0,12"
                                                   TextWrapping="Wrap" />

                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Style="{StaticResource WorkspaceQueueCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Filtered Conflicts" Style="{StaticResource CardHeaderStyle}" />
                                                    <DataGrid ItemsSource="{Binding FilteredConflicts}"
                                                              SelectedItem="{Binding SelectedConflict, Mode=TwoWay}"
                                                              AutoGenerateColumns="False"
                                                              IsReadOnly="True"
                                                              CanUserAddRows="False"
                                                              Background="Transparent"
                                                              BorderThickness="0"
                                                              Margin="0,10,0,0">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Field" Binding="{Binding FieldPath}" Width="*" />
                                                            <DataGridTextColumn Header="Provider A" Binding="{Binding ProviderA}" Width="120" />
                                                            <DataGridTextColumn Header="Provider B" Binding="{Binding ProviderB}" Width="120" />
                                                            <DataGridTextColumn Header="Detected" Binding="{Binding DetectedAt, StringFormat='{}{0:g}'}" Width="120" />
                                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </StackPanel>
                                            </Border>

                                            <StackPanel Grid.Column="2">
                                                <Border Style="{StaticResource WorkspaceQueueCardStyle}"
                                                        AutomationProperties.AutomationId="SecurityMasterConflictTriagePanel">
                                                    <StackPanel>
                                                        <TextBlock Text="Conflict Triage" Style="{StaticResource CardHeaderStyle}" />
                                                        <TextBlock Text="{Binding SelectedConflictSummaryText}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,8,0,4" TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding SelectedConflictDetectedText}" Style="{StaticResource CardDescriptionStyle}" TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding SelectedConflictRecommendedActionText}" FontSize="12" Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,10,0,0" TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding SelectedConflictWinnerText}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding SelectedConflictImpactText}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,6,0,12" TextWrapping="Wrap" />

                                                        <Grid Margin="0,0,0,12">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="12" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <Border Grid.Column="0" Style="{StaticResource WorkspaceQueueItemCardStyle}">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding SelectedConflict.ProviderA, TargetNullValue='Provider A'}" Style="{StaticResource CardDescriptionStyle}" />
                                                                    <TextBlock Text="{Binding SelectedConflict.ValueA}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </Border>

                                                            <Border Grid.Column="2" Style="{StaticResource WorkspaceQueueItemCardStyle}">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding SelectedConflict.ProviderB, TargetNullValue='Provider B'}" Style="{StaticResource CardDescriptionStyle}" />
                                                                    <TextBlock Text="{Binding SelectedConflict.ValueB}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </Border>
                                                        </Grid>

                                                        <TextBlock Text="Resolved By" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4" />
                                                        <TextBox Text="{Binding ConflictOperatorText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" Margin="0,0,0,10" />
                                                        <TextBlock Text="Resolution Note" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,0,4" />
                                                        <TextBox Text="{Binding ConflictNoteText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" Margin="0,0,0,12" />

                                                        <WrapPanel>
                                                            <Button Content="Apply Recommended"
                                                                    Command="{Binding ApplyRecommendedConflictResolutionCommand}"
                                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                                    Margin="0,0,8,8" />
                                                            <Button Content="Accept A"
                                                                    Command="{Binding AcceptPrimaryConflictCommand}"
                                                                    Style="{StaticResource GhostButtonStyle}"
                                                                    Margin="0,0,8,8" />
                                                            <Button Content="Accept B"
                                                                    Command="{Binding AcceptSecondaryConflictCommand}"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Margin="0,0,8,8" />
                                                            <Button Content="Dismiss"
                                                                    Command="{Binding DismissConflictCommand}"
                                                                    Style="{StaticResource DangerButtonStyle}"
                                                                    Margin="0,0,0,8" />
                                                        </WrapPanel>
                                                    </StackPanel>
                                                </Border>

                                                <Border Style="{StaticResource WorkspaceQueueCardStyle}" Margin="0,12,0,0">
                                                    <StackPanel>
                                                        <TextBlock Text="Low-Risk Bulk Assist" Style="{StaticResource CardHeaderStyle}" />
                                                        <TextBlock Text="{Binding BulkPreviewSummaryText}" Style="{StaticResource CardDescriptionStyle}" Margin="0,8,0,12" TextWrapping="Wrap" />
                                                        <WrapPanel>
                                                            <Button Content="Preview Bulk Low-Risk"
                                                                    Command="{Binding PreviewBulkRecommendedResolutionsCommand}"
                                                                    Style="{StaticResource GhostButtonStyle}"
                                                                    Margin="0,0,8,0" />
                                                            <Button Content="Apply Bulk Low-Risk"
                                                                    Command="{Binding ApplyBulkRecommendedResolutionsCommand}"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    AutomationProperties.AutomationId="SecurityMasterBulkResolveButton" />
                                                        </WrapPanel>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </TabItem>

                                <TabItem Header="Corporate Actions">
                                    <DockPanel Margin="12">
                                        <Border DockPanel.Dock="Top"
                                                Style="{StaticResource WorkspaceQueueCardStyle}"
                                                Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="Corporate-Action Readiness" Style="{StaticResource CardHeaderStyle}" />
                                                <TextBlock Text="{Binding CorporateActionReadinessText}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,8,0,4" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding CorporateActionImpactSummaryText}" Style="{StaticResource CardDescriptionStyle}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>

                                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                                            <Button Content="+ Record"
                                                    Command="{Binding ShowRecordCorpActionCommand}"
                                                    IsEnabled="{Binding HasSelectedSecurity}"
                                                    Style="{StaticResource PrimaryButtonStyle}" />
                                        </StackPanel>

                                        <Border DockPanel.Dock="Top"
                                                Style="{StaticResource WorkspaceQueueCardStyle}"
                                                Margin="0,0,0,12"
                                                Visibility="{Binding IsRecordCorpActionVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel>
                                                <TextBlock Text="Record Corporate Action" Style="{StaticResource CardHeaderStyle}" />
                                                <TextBlock Text="Switches the entry form between dividend and stock-split mode without leaving the selected security."
                                                           Style="{StaticResource CardDescriptionStyle}"
                                                           Margin="0,8,0,12"
                                                           TextWrapping="Wrap" />

                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="180" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="180" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Type" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,8,4" VerticalAlignment="Center" />
                                                    <ComboBox Grid.Column="1" ItemsSource="{Binding CorpActTypes}" SelectedItem="{Binding CorpActType, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0" />
                                                    <TextBlock Grid.Column="2" Text="Ex-Date" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,8,4" VerticalAlignment="Center" />
                                                    <TextBox Grid.Column="3" Text="{Binding CorpActExDate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                                                </Grid>

                                                <StackPanel x:Name="DividendForm">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CorpActType}" Value="Dividend">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="180" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="180" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Dividend Amount" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,8,4" VerticalAlignment="Center" />
                                                        <TextBox Grid.Column="1" Text="{Binding CorpActAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" Margin="0,0,12,0" />
                                                        <TextBlock Grid.Column="2" Text="Currency" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,8,4" VerticalAlignment="Center" />
                                                        <TextBox Grid.Column="3" Text="{Binding CorpActCurrency, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                                                    </Grid>
                                                </StackPanel>

                                                <StackPanel x:Name="StockSplitForm">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CorpActType}" Value="StockSplit">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="180" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Split Ratio" Style="{StaticResource CardDescriptionStyle}" Margin="0,0,8,4" VerticalAlignment="Center" />
                                                        <TextBox Grid.Column="1" Text="{Binding CorpActAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                                                    </Grid>
                                                </StackPanel>

                                                <WrapPanel>
                                                    <Button Content="Save" Command="{Binding RecordCorpActionCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" />
                                                    <Button Content="Cancel" Command="{Binding CancelRecordCorpActionCommand}" Style="{StaticResource GhostButtonStyle}" />
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock DockPanel.Dock="Top" Text="Timeline" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,6" />
                                        <Border DockPanel.Dock="Top" Margin="0,0,0,12" Height="80" Background="{StaticResource ConsoleBackgroundDarkBrush}" CornerRadius="4">
                                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Padding="8,0">
                                                <ItemsControl ItemsSource="{Binding CorporateActions}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                                                                <Border x:Name="EventBadge" CornerRadius="4" Padding="7,5" Background="{StaticResource SuccessColorBrush}" ToolTip="{Binding EventType}">
                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding EventType}" FontSize="10" FontWeight="SemiBold" Foreground="White" />
                                                                        <TextBlock Text="{Binding ExDate, StringFormat='{}{0:yyyy-MM-dd}'}" FontSize="9" Foreground="White" Opacity="0.85" />
                                                                        <TextBlock x:Name="DividendAmountBadge" Text="{Binding DividendPerShare, StringFormat='${0:F2}'}" FontSize="9" Foreground="White" Opacity="0.85" />
                                                                        <TextBlock x:Name="SplitRatioBadge" Text="{Binding SplitRatio, StringFormat='×{0:G}'}" FontSize="9" Foreground="White" Opacity="0.85" Visibility="Collapsed" />
                                                                    </StackPanel>
                                                                </Border>
                                                                <TextBlock Text="›" FontSize="14" VerticalAlignment="Center" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="3,0" />
                                                            </StackPanel>
                                                            <DataTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding EventType}" Value="StockSplit">
                                                                    <Setter TargetName="EventBadge" Property="Background" Value="{StaticResource WarningColorBrush}" />
                                                                    <Setter TargetName="DividendAmountBadge" Property="Visibility" Value="Collapsed" />
                                                                    <Setter TargetName="SplitRatioBadge" Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </DataTemplate.Triggers>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Border>

                                        <DataGrid ItemsSource="{Binding CorporateActions}"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  CanUserAddRows="False"
                                                  Background="Transparent"
                                                  BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Type" Binding="{Binding EventType}" Width="100" />
                                                <DataGridTextColumn Header="Ex-Date" Binding="{Binding ExDate, StringFormat='{}{0:yyyy-MM-dd}'}" Width="110" />
                                                <DataGridTemplateColumn Header="Amount/Ratio" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Grid>
                                                                <TextBlock x:Name="DividendAmount" Text="{Binding DividendPerShare}" />
                                                                <TextBlock x:Name="SplitRatio" Text="{Binding SplitRatio}" Visibility="Collapsed" />
                                                            </Grid>
                                                            <DataTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding EventType}" Value="StockSplit">
                                                                    <Setter TargetName="DividendAmount" Property="Visibility" Value="Collapsed" />
                                                                    <Setter TargetName="SplitRatio" Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </DataTemplate.Triggers>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Currency" Binding="{Binding Currency}" Width="90" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </DockPanel>
                                </TabItem>
                            </TabControl>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource WorkspaceEmptyStateCardStyle}"
                        Visibility="{Binding HasSelectedSecurity, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40">
                        <TextBlock Text="&#xE8D7;"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="40"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   Margin="0,0,0,12" />
                        <TextBlock Text="Select a security to inspect identifiers, history, and corporate actions."
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="4">
                    <Border Style="{StaticResource WorkspaceInspectorCardStyle}"
                            AutomationProperties.AutomationId="SecurityMasterTrustPostureInspector">
                        <StackPanel>
                            <TextBlock Text="Trust Posture" Style="{StaticResource CardHeaderStyle}" />
                            <TextBlock Text="{Binding TrustScoreText}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,8,0,4" />
                            <TextBlock Text="{Binding TrustSummaryText}" Style="{StaticResource CardDescriptionStyle}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding GoldenCopySourceText}" FontSize="12" Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,10,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding TradingParametersStatusText}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding CorporateActionReadinessText}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding WorkflowRetrievedAtText}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,8,0,0" />
                            <Rectangle Style="{StaticResource HorizontalDividerStyle}" Margin="0,14,0,14" />
                            <TextBlock Text="{Binding RuntimeStatusDetail}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ImportSessionText}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkspaceInspectorCardStyle}"
                            AutomationProperties.AutomationId="SecurityMasterSelectionInspector">
                        <StackPanel>
                            <TextBlock Text="Selected Security" Style="{StaticResource CardHeaderStyle}" />
                            <TextBlock Text="{Binding SelectionSummaryText}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,8,0,4" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectionLifecycleText}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,0,0,10" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedTrustPostureText}" FontSize="11" Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,0,0,10" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedProvenanceText}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,0,0,12" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedIdentifier}" FontSize="12" Foreground="{StaticResource ConsoleTextPrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />
                            <WrapPanel Margin="0,0,0,12">
                                <Button Content="Copy Identifier"
                                        Command="{Binding CopySelectedIdentifierCommand}"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Margin="0,0,8,8" />
                                <Button Content="Refresh Snapshot"
                                        Command="{Binding RefreshSelectedTrustSnapshotCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>
                            <TextBlock Text="Latest History Event" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                            <TextBlock Text="{Binding LatestHistoryEventText}" FontSize="12" Foreground="{StaticResource ConsoleTextPrimaryBrush}" TextWrapping="Wrap" Margin="0,4,0,12" />
                            <TextBlock Text="{Binding SelectedTradingParameterCoverageText}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,0,0,12" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding CorporateActionSummaryText}" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkspaceInspectorCardStyle}"
                            AutomationProperties.AutomationId="SecurityMasterActionInspector">
                        <StackPanel>
                            <TextBlock Text="Next Best Actions" Style="{StaticResource CardHeaderStyle}" />
                            <ItemsControl ItemsSource="{Binding RecommendedActions}"
                                          Margin="0,10,0,12"
                                          AutomationProperties.AutomationId="SecurityMasterRecommendedActionsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource WorkspaceQueueItemCardStyle}" Margin="0,0,0,8">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" TextWrapping="Wrap" />
                                                    <Border Margin="8,0,0,0"
                                                            Style="{StaticResource InfoBadgeInlineStyle}"
                                                            Visibility="{Binding IsPrimary, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <TextBlock Text="Primary" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource InfoColorBrush}" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Detail}" Style="{StaticResource CardDescriptionStyle}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="Open Portfolio Impact"
                                    Command="{Binding OpenSelectedSecurityPortfolioImpactCommand}"
                                    Style="{StaticResource GhostButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding HasPortfolioImpactLink, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <Button Content="Open Ledger Impact"
                                    Command="{Binding OpenSelectedSecurityLedgerImpactCommand}"
                                    Style="{StaticResource GhostButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding HasLedgerImpactLink, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <Button Content="Open Reconciliation Impact"
                                    Command="{Binding OpenSelectedSecurityReconciliationImpactCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding HasReconciliationImpactLink, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <Button Content="Open Report Pack Impact"
                                    Command="{Binding OpenSelectedSecurityReportPackImpactCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding HasReportPackImpactLink, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <Button Content="Edit Selected Security"
                                    Command="{Binding EditSelectedCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding HasSelectedSecurity, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <Button Content="Backfill Trading Parameters"
                                    Command="{Binding BackfillTradingParamsCommand}"
                                    Style="{StaticResource GhostButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Visibility="{Binding ShowBackfillTradingParamsAction, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
