<Page x:Class="Meridian.Wpf.Views.AdvancedAnalyticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="clr-namespace:Meridian.Wpf.Converters"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      AutomationProperties.Name="Advanced Analytics">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:InvertBoolConverter x:Key="InvertBool" />
    </Page.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20,28,32">
        <StackPanel MaxWidth="1400">
            <!-- Header -->
            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="14"
                            Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                            BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1">
                        <TextBlock Text="&#xE9F9;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="24" Foreground="{StaticResource InfoColorBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Advanced Analytics" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="Gap analysis, anomaly detection, and cross-provider quality diagnostics for archive intelligence."
                                   Style="{StaticResource CardDescriptionStyle}" />
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" Command="{Binding RefreshAllCommand}" Style="{StaticResource SecondaryButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="Refresh All" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
            </Border>

            <!-- Status InfoBar -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16"
                    Visibility="{Binding IsStatusVisible, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding StatusIcon}" FontFamily="{StaticResource SymbolThemeFontFamily}"
                               FontSize="20" Foreground="{Binding StatusBrush}" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusTitle}" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextBrush}" />
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource ConsoleTextMutedBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="2" Content="&#xE711;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                            Command="{Binding DismissStatusCommand}" Background="Transparent" BorderThickness="0" Padding="8"
                            Foreground="{StaticResource ConsoleTextMutedBrush}" />
                </Grid>
            </Border>

            <!-- Quality Summary Cards -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding OverallScoreText}" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource InfoColorBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="Overall Quality" Foreground="{StaticResource ConsoleTextMutedBrush}" HorizontalAlignment="Center" Margin="0,4,0,8" />
                        <Border Background="{Binding GradeBadgeBackground}" CornerRadius="999" Padding="12,4" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding GradeText}" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextBrush}" />
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding CompletenessText}" FontSize="32" FontWeight="Bold"
                                   Foreground="#48BB78" HorizontalAlignment="Center" />
                        <TextBlock Text="Completeness" Foreground="{StaticResource ConsoleTextMutedBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding TotalGapsText}" FontSize="32" FontWeight="Bold"
                                   Foreground="#ED8936" HorizontalAlignment="Center" />
                        <TextBlock Text="Data Gaps" Foreground="{StaticResource ConsoleTextMutedBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Style="{StaticResource CardStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="--" FontSize="32" FontWeight="Bold"
                                   Foreground="#F56565" HorizontalAlignment="Center" />
                        <TextBlock Text="Anomalies" Foreground="{StaticResource ConsoleTextMutedBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Gap Analysis Section -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7BA;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       Foreground="{StaticResource InfoColorBrush}" FontSize="20" VerticalAlignment="Center" />
                            <TextBlock Text="Gap Analysis" Style="{StaticResource CardHeaderStyle}" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <ComboBox Width="120" Margin="0,0,8,0"
                                      ItemsSource="{Binding AvailableSymbols}"
                                      SelectedItem="{Binding GapSymbol, Mode=TwoWay}"
                                      Background="{StaticResource ConsoleBackgroundBrush}" Foreground="{StaticResource ConsoleTextBrush}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="">
                                                            <Setter Property="Text" Value="All Symbols" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Content="Analyze Gaps" Command="{Binding AnalyzeGapsCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" />
                            <Button Content="Repair Gaps" Command="{Binding RequestRepairGapsCommand}"
                                    Style="{StaticResource GhostButtonStyle}" />
                        </StackPanel>
                    </Grid>

                    <ProgressBar IsIndeterminate="True" Margin="0,0,0,16"
                                 Visibility="{Binding IsGapAnalysisBusy, Converter={StaticResource BoolToVisibility}}" />

                    <Border AutomationProperties.Name="Advanced analytics repair confirmation"
                            Background="{StaticResource PremiumPanelBrush}"
                            BorderBrush="{StaticResource WarningColorBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="16" Margin="0,0,0,16"
                            Visibility="{Binding IsRepairConfirmationVisible, Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE7BA;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="20" Foreground="{StaticResource WarningColorBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding RepairConfirmationTitle}"
                                           FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextBrush}" />
                                <TextBlock Text="{Binding RepairConfirmationDetail}"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                                <Button Content="Cancel" Command="{Binding CancelRepairGapsCommand}"
                                        Style="{StaticResource GhostButtonStyle}" Margin="0,0,8,0" />
                                <Button Content="Run Repair" Command="{Binding ConfirmRepairGapsCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="{StaticResource PremiumPanelBrush}"
                            BorderBrush="{StaticResource ConsoleBorderBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="16" Margin="0,0,0,16"
                            Visibility="{Binding IsGapSummaryVisible, Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="{Binding TotalGapsText}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource ConsoleTextBrush}" />
                                <TextBlock Text="Total Gaps" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,32,0">
                                <TextBlock Text="{Binding TotalGapDurationText}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource ConsoleTextBrush}" />
                                <TextBlock Text="Total Duration" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding RepairableGapsText}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource ConsoleTextBrush}" />
                                <TextBlock Text="Repairable" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ListView ItemsSource="{Binding GapItems}" MaxHeight="250" Background="Transparent" BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,2" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource PremiumPanelBrush}" BorderBrush="{StaticResource ConsoleBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Symbol}" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding EventType}" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                        <TextBlock Grid.Column="2" Text="{Binding TimeRange}" Foreground="{StaticResource ConsoleTextBrush}" />
                                        <TextBlock Grid.Column="3" Text="{Binding DurationText}" Foreground="{StaticResource InfoColorBrush}" />
                                        <Border Grid.Column="4" Background="{Binding RepairableBackground}" CornerRadius="999" Padding="8,3">
                                            <TextBlock Text="{Binding RepairableText}" FontSize="11" Foreground="{StaticResource ConsoleTextBrush}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- Cross-Provider Comparison -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8AB;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       Foreground="{StaticResource InfoColorBrush}" FontSize="20" VerticalAlignment="Center" />
                            <TextBlock Text="Cross-Provider Comparison" Style="{StaticResource CardHeaderStyle}" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBox Width="100" Margin="0,0,8,0"
                                     Text="{Binding CompareSymbol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{StaticResource ConsoleBackgroundBrush}" Foreground="{StaticResource ConsoleTextBrush}" />
                            <DatePicker Margin="0,0,8,0"
                                        SelectedDate="{Binding CompareDate, Mode=TwoWay}" />
                            <Button Content="Compare" Command="{Binding CompareProvidersCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock AutomationProperties.Name="Advanced analytics comparison guidance"
                               Text="{Binding CompareGuidanceText}"
                               Foreground="{StaticResource ConsoleTextMutedBrush}" TextWrapping="Wrap"
                               Margin="0,0,0,12" />

                    <ProgressBar IsIndeterminate="True" Margin="0,0,0,16"
                                 Visibility="{Binding IsComparisonBusy, Converter={StaticResource BoolToVisibility}}" />

                    <Border Background="{StaticResource PremiumPanelBrush}"
                            BorderBrush="{StaticResource ConsoleBorderBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="16"
                            Visibility="{Binding IsComparisonResultsVisible, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,32,0">
                                    <TextBlock Text="{Binding ConsistencyScoreText}" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource InfoColorBrush}" />
                                    <TextBlock Text="Consistency Score" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding DiscrepancyCountText}" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource ConsoleTextBrush}" />
                                    <TextBlock Text="Discrepancies" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                                </StackPanel>
                            </Grid>

                            <ListView ItemsSource="{Binding DiscrepancyItems}" MaxHeight="150" Background="Transparent" BorderThickness="0">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="8,4" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Background" Value="Transparent" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="100" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding TimestampText}" Foreground="{StaticResource ConsoleTextBrush}" />
                                            <TextBlock Grid.Column="1" Text="{Binding DiscrepancyType}" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                            <TextBlock Grid.Column="2" Text="{Binding Values}" Foreground="{StaticResource ConsoleTextBrush}" />
                                            <TextBlock Grid.Column="3" Text="{Binding DifferenceText}" Foreground="{StaticResource InfoColorBrush}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Provider Latency -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="&#xE916;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   Foreground="{StaticResource InfoColorBrush}" FontSize="20" VerticalAlignment="Center" />
                        <TextBlock Text="Provider Latency" Style="{StaticResource CardHeaderStyle}" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>

                    <ListView ItemsSource="{Binding LatencyItems}" Background="Transparent" BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,4" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource ConsoleBackgroundBrush}" CornerRadius="4" Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Provider}" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextBrush}" VerticalAlignment="Center" />
                                        <ProgressBar Grid.Column="1" Value="{Binding LatencyPercent}" Maximum="100" Height="8" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding P50Text}" Foreground="{StaticResource ConsoleTextBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{Binding P95Text}" Foreground="#ED8936" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="4" Text="{Binding P99Text}" Foreground="#F56565" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="2" Text="P50" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="3" Text="P95" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="4" Text="P99" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" HorizontalAlignment="Right" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Rate Limits -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="&#xE8CB;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   Foreground="{StaticResource InfoColorBrush}" FontSize="20" VerticalAlignment="Center" />
                        <TextBlock Text="Provider Rate Limits" Style="{StaticResource CardHeaderStyle}" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>

                    <ListView ItemsSource="{Binding RateLimitItems}" Background="Transparent" BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,4" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource ConsoleBackgroundBrush}" CornerRadius="4" Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Provider}" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextBrush}" VerticalAlignment="Center" />
                                        <ProgressBar Grid.Column="1" Value="{Binding UsagePercent}" Maximum="100" Height="8"
                                                     VerticalAlignment="Center" Margin="12,0" Foreground="{Binding UsageColor}" />
                                        <TextBlock Grid.Column="2" Text="{Binding UsageText}" Foreground="{StaticResource ConsoleTextBrush}" VerticalAlignment="Center" Margin="12,0" />
                                        <Border Grid.Column="3" Background="{Binding StatusBackground}" CornerRadius="4" Padding="8,4">
                                            <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="{StaticResource ConsoleTextBrush}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- Symbol Quality Report -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9F5;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       Foreground="{StaticResource InfoColorBrush}" FontSize="20" VerticalAlignment="Center" />
                            <TextBlock Text="Symbol Quality Report" Style="{StaticResource CardHeaderStyle}" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>

                        <Button Grid.Column="1" Content="Generate Full Report" Command="{Binding GenerateReportCommand}" Style="{StaticResource ConsoleButtonStyle}" />
                    </Grid>

                    <ListView ItemsSource="{Binding SymbolQualityItems}" MaxHeight="300" Background="Transparent" BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,4" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource ConsoleBackgroundBrush}" CornerRadius="4" Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="60" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Symbol}" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextBrush}" VerticalAlignment="Center" />
                                        <Border Grid.Column="1" Background="{Binding GradeBackground}" CornerRadius="4" Padding="8,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Grade}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource ConsoleTextBrush}" />
                                        </Border>
                                        <ProgressBar Grid.Column="2" Value="{Binding OverallScore}" Maximum="100" Height="6" Margin="12,0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{Binding CompletenessText}" Foreground="{StaticResource ConsoleTextBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="4" Text="{Binding IntegrityText}" Foreground="{StaticResource ConsoleTextBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="5" Text="{Binding IssueCount}" Foreground="#F56565" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Symbol" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                        <TextBlock Grid.Column="1" Text="Grade" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                        <TextBlock Grid.Column="2" Text="Quality Score" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" Margin="12,0" />
                        <TextBlock Grid.Column="3" Text="Complete" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="4" Text="Integrity" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="5" Text="Issues" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" HorizontalAlignment="Right" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Recommendations -->
            <Border Style="{StaticResource CardStyle}"
                    Visibility="{Binding IsRecommendationsVisible, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="&#xE946;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   Foreground="#ED8936" FontSize="20" VerticalAlignment="Center" />
                        <TextBlock Text="Recommendations" Style="{StaticResource CardHeaderStyle}" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>

                    <ListView ItemsSource="{Binding Recommendations}" Background="Transparent" BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="8,4" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE946;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="14" Foreground="#ED8936" Margin="0,0,12,0" VerticalAlignment="Top" />
                                    <TextBlock Grid.Column="1" Text="{Binding}" TextWrapping="Wrap" Foreground="{StaticResource ConsoleTextBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
