<Page x:Class="Meridian.Wpf.Views.DirectLendingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      AutomationProperties.Name="Direct Lending">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header card -->
        <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="44" Height="44" CornerRadius="14"
                                Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1" Margin="0,0,12,0">
                            <TextBlock Text="&#xE8C1;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="24" Foreground="{StaticResource InfoColorBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel>
                            <TextBlock Text="Direct Lending" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="{Binding StatusText}" Style="{StaticResource CardDescriptionStyle}" Margin="0,6,0,0" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Post Accrual"
                            Command="{Binding PostAccrualCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,0" />
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filter bar -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="180" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Search" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Status" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding StatusFilters}"
                              SelectedItem="{Binding SelectedStatusFilter, Mode=TwoWay}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content: split list / detail -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="300" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="3*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <!-- Loan list -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <DataGrid x:Name="LoanGrid"
                          ItemsSource="{Binding Loans}"
                          SelectedItem="{Binding SelectedLoan, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          HeadersVisibility="Column"
                          Background="{StaticResource ConsoleBackgroundLightBrush}"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Facility" Binding="{Binding FacilityName}" Width="*" />
                        <DataGridTextColumn Header="Borrower" Binding="{Binding BorrowerName}" Width="130" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80" />
                        <DataGridTextColumn Header="Principal" Binding="{Binding PrincipalOutstanding, StringFormat={}{0:N0}}" Width="90" />
                        <DataGridTextColumn Header="Maturity" Binding="{Binding MaturityDate, StringFormat={}{0:d}}" Width="90" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Detail panel -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <!-- Placeholder when no loan is selected -->
                    <TextBlock Text="Select a loan to view details"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CardDescriptionStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelectedLoan}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Loading indicator -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDetailLoading}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Loading…" Style="{StaticResource CardDescriptionStyle}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Detail content -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding HasSelectedLoan}" Value="True" />
                                            <Condition Binding="{Binding IsDetailLoading}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <StackPanel Margin="8">
                            <!-- Contract summary -->
                            <TextBlock Text="Contract" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Facility" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding SelectedContract.FacilityName}" FontSize="12" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Borrower" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding SelectedContract.Borrower.BorrowerName}" FontSize="12" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Status" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding SelectedContract.Status}" FontSize="12" />
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Commitment" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                <TextBlock Grid.Row="6" Grid.Column="2" Text="{Binding SelectedContract.CurrentTerms.CommitmentAmount, StringFormat={}{0:N0}}" FontSize="12" />
                            </Grid>

                            <!-- Servicing balances -->
                            <TextBlock Text="Balances" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Principal" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding SelectedServicing.Balances.PrincipalOutstanding, StringFormat={}{0:N2}}" FontSize="12" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Accrued Interest" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding SelectedServicing.Balances.InterestAccruedUnpaid, StringFormat={}{0:N2}}" FontSize="12" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Commitment Fee" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding SelectedServicing.Balances.CommitmentFeeAccruedUnpaid, StringFormat={}{0:N2}}" FontSize="12" />
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Available" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                <TextBlock Grid.Row="6" Grid.Column="2" Text="{Binding SelectedServicing.AvailableToDraw, StringFormat={}{0:N2}}" FontSize="12" />
                                <TextBlock Grid.Row="8" Grid.Column="0" Text="Last Accrual" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                <TextBlock Grid.Row="8" Grid.Column="2" Text="{Binding SelectedServicing.LastAccrualDate, StringFormat={}{0:d}}" FontSize="12" />
                            </Grid>

                            <!-- Accrual result feedback -->
                            <Border Visibility="{Binding AccrualResultVisibility}"
                                    Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                    BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1"
                                    CornerRadius="4" Padding="8" Margin="0,0,0,16">
                                <TextBlock Text="{Binding AccrualResultText}"
                                           FontSize="11" Foreground="{StaticResource InfoColorBrush}"
                                           TextWrapping="Wrap" />
                            </Border>

                            <!-- Recent accruals -->
                            <TextBlock Text="Recent Accruals" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,8" />
                            <DataGrid ItemsSource="{Binding Accruals}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      MaxHeight="180"
                                      Background="{StaticResource ConsoleBackgroundLightBrush}"
                                      BorderThickness="0"
                                      Margin="0,0,0,16">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding AccrualDate, StringFormat={}{0:d}}" Width="90" />
                                    <DataGridTextColumn Header="Interest" Binding="{Binding InterestAmount, StringFormat={}{0:N2}}" Width="90" />
                                    <DataGridTextColumn Header="Commit. Fee" Binding="{Binding CommitmentFeeAmount, StringFormat={}{0:N2}}" Width="90" />
                                    <DataGridTextColumn Header="Rate" Binding="{Binding AnnualRateApplied, StringFormat={}{0:P3}}" Width="80" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Recent cash transactions -->
                            <TextBlock Text="Cash Transactions" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,8" />
                            <DataGrid ItemsSource="{Binding CashTransactions}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      MaxHeight="180"
                                      Background="{StaticResource ConsoleBackgroundLightBrush}"
                                      BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding EffectiveDate, StringFormat={}{0:d}}" Width="90" />
                                    <DataGridTextColumn Header="Type" Binding="{Binding TransactionType}" Width="110" />
                                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:N2}}" Width="100" />
                                    <DataGridTextColumn Header="Ref" Binding="{Binding ExternalRef}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
