<views:DataOperationsWorkspaceShellPageBase x:Class="Meridian.Wpf.Views.DataOperationsWorkspaceShellPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:models="clr-namespace:Meridian.Wpf.Models"
      xmlns:views="clr-namespace:Meridian.Wpf.Views"
      xmlns:services="clr-namespace:Meridian.Wpf.Services"
      xmlns:copy="clr-namespace:Meridian.Wpf.Copy"
      mc:Ignorable="d"
      d:DesignHeight="900"
      d:DesignWidth="1400"
      Background="{DynamicResource ConsoleBackgroundDarkBrush}"
      Loaded="OnPageLoaded"
      Unloaded="OnPageUnloaded"
      AutomationProperties.Name="{x:Static copy:WorkspaceCopyCatalog.DataOperationsShellTitle}"
      AutomationProperties.AutomationId="DataOperationsWorkspaceShellPage">

    <Page.Resources>
        <DataTemplate x:Key="QueueItemTemplate" DataType="{x:Type models:WorkspaceQueueItem}">
            <Border Style="{StaticResource WorkspaceToneQueueCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Text="{Binding Title}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                            <Border Style="{StaticResource WorkspaceToneBadgeStyle}" Margin="10,0,8,0">
                                <TextBlock Text="{Binding StatusLabel}"
                                           FontSize="10"
                                           Style="{StaticResource WorkspaceToneBadgeTextStyle}" />
                            </Border>
                            <Border Style="{StaticResource NeutralBadgeStyle}">
                                <TextBlock Text="{Binding CountLabel}"
                                           FontSize="10"
                                           Style="{StaticResource WorkspaceToneBadgeTextStyle}" />
                            </Border>
                        </WrapPanel>

                        <TextBlock Text="{Binding Detail}"
                                   FontSize="12"
                                   Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Tag="{Binding PrimaryActionId}"
                                Content="{Binding PrimaryActionLabel}"
                                Click="OnQueuePrimaryActionClick"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,0" />
                        <Button Tag="{Binding SecondaryActionId}"
                                Content="{Binding SecondaryActionLabel}"
                                Click="OnQueueSecondaryActionClick">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SecondaryActionLabel}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>


        <DataTemplate x:Key="QueueRegionStateTemplate" DataType="{x:Type models:WorkspaceQueueRegionState}">
            <Border Style="{StaticResource WorkspaceQueueStateCardStyle}">
                <StackPanel>
                    <Border Style="{StaticResource WorkspaceQueueStateIconContainerStyle}">
                        <TextBlock Text="{Binding IconGlyph}"
                                   Style="{StaticResource WorkspaceQueueStateIconTextStyle}" />
                    </Border>
                    <TextBlock Text="{Binding Title}" Style="{StaticResource WorkspaceQueueStateTitleTextStyle}" />
                    <TextBlock Text="{Binding Description}" Style="{StaticResource WorkspaceQueueStateDescriptionTextStyle}" />
                    <WrapPanel Margin="0,12,0,0">
                        <Button Tag="{Binding PrimaryActionId}"
                                Content="{Binding PrimaryActionLabel}"
                                Click="OnQueueStateActionClick"
                                Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PrimaryActionLabel}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Tag="{Binding SecondaryActionId}"
                                Content="{Binding SecondaryActionLabel}"
                                Click="OnQueueStateActionClick">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SecondaryActionLabel}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="RecentItemTemplate" DataType="{x:Type models:WorkspaceRecentItem}">
            <Border Style="{StaticResource WorkspaceToneInspectorCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                    <TextBlock Text="{Binding Detail}"
                               Margin="0,6,0,0"
                               FontSize="11"
                               Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Meta}"
                               Margin="0,6,0,0"
                               FontSize="10"
                               Style="{StaticResource WorkspaceToneBadgeTextStyle}" />
                    <Button Tag="{Binding ActionId}"
                            Content="{Binding ActionLabel}"
                            Click="OnRecentActionClick"
                            HorizontalAlignment="Left"
                            Margin="0,12,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActionLabel}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="HeroMetricTemplate" DataType="{x:Type services:DataOperationsHeroMetric}">
            <Border Style="{StaticResource WorkspaceToneBadgeStyle}"
                    MinWidth="112"
                    Margin="0,0,8,8"
                    Padding="10,8"
                    ToolTip="{Binding Detail}"
                    AutomationProperties.Name="{Binding AutomationName}">
                <StackPanel>
                    <TextBlock Text="{Binding Label}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ConsoleTextMutedBrush}" />
                    <TextBlock Text="{Binding Value}"
                               Margin="0,4,0,0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Style="{StaticResource WorkspaceToneBadgeTextStyle}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <views:WorkspaceShellContextStripControl x:Name="ContextStrip" />

        <Border Grid.Row="1"
                Style="{StaticResource SectionCardStyle}"
                Margin="0,16,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.6*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="44"
                                Height="44"
                                CornerRadius="14"
                                Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                BorderBrush="{StaticResource InfoColorBrush}"
                                BorderThickness="1">
                            <TextBlock Text="&#xEE94;"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="24"
                                       Foreground="{StaticResource InfoColorBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Data Operations"
                                       Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="Provider readiness, queue pressure, storage posture, and export delivery from one operator shell."
                                       Style="{StaticResource CardDescriptionStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>

                    <Border Margin="0,18,0,0"
                            Padding="14,12"
                            CornerRadius="12"
                            Background="#10263A"
                            BorderBrush="#22486B"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Active Scope"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#7EA3C5" />
                            <TextBlock x:Name="OperationsHeroScopeText"
                                       Margin="0,6,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Text="Provider and storage health" />
                            <TextBlock x:Name="OperationsHeroSummaryText"
                                       Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="#A8BED7"
                                       TextWrapping="Wrap"
                                       Text="Provider health, backfill priority, storage follow-up, and export delivery stay in one fixed shell." />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Column="1"
                        Margin="16,0,0,0"
                        Padding="16,14"
                        CornerRadius="12"
                        Background="{StaticResource ConsoleBackgroundMediumBrush}"
                        BorderBrush="{StaticResource ConsoleBorderBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="Next Handoff"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}" />
                            <Border x:Name="OperationsHeroBadgeBorder"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource NeutralBadgeStyle}">
                                <TextBlock x:Name="OperationsHeroBadgeText"
                                           FontSize="10"
                                           Foreground="{StaticResource InfoColorBrush}"
                                           Text="Loading"
                                           AutomationProperties.AutomationId="OperationsHeroBadgeText" />
                            </Border>
                        </DockPanel>
                        <TextBlock x:Name="OperationsHeroFocusText"
                                   Margin="0,10,0,0"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                   Text="Operational posture"
                                   AutomationProperties.AutomationId="OperationsHeroFocusText" />
                        <TextBlock x:Name="OperationsHeroActionSummaryText"
                                   Margin="0,6,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Text="Refreshing provider, backfill, storage, and export posture."
                                   AutomationProperties.AutomationId="OperationsHeroActionSummaryText" />
                        <ItemsControl x:Name="OperationsHeroMetricsList"
                                      Margin="0,12,0,0"
                                      ItemTemplate="{StaticResource HeroMetricTemplate}"
                                      AutomationProperties.AutomationId="OperationsHeroMetricsList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <TextBlock x:Name="OperationsHeroHandoffTitleText"
                                   Margin="0,12,0,0"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                   Text="Telemetry refresh in progress"
                                   AutomationProperties.AutomationId="OperationsHeroHandoffTitleText" />
                        <TextBlock x:Name="OperationsHeroHandoffDetailText"
                                   Margin="0,6,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Text="The Data Operations shell is collecting current readiness signals."
                                   AutomationProperties.AutomationId="OperationsHeroHandoffDetailText" />
                        <WrapPanel Margin="0,12,0,0">
                            <Button x:Name="OperationsHeroPrimaryActionButton"
                                    Click="OnOperationsHeroPrimaryActionClick"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,8,8"
                                    Visibility="Collapsed"
                                    AutomationProperties.AutomationId="OperationsHeroPrimaryActionButton" />
                            <Button x:Name="OperationsHeroSecondaryActionButton"
                                    Click="OnOperationsHeroSecondaryActionClick"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Margin="0,0,8,8"
                                    Visibility="Collapsed"
                                    AutomationProperties.AutomationId="OperationsHeroSecondaryActionButton" />
                        </WrapPanel>
                        <TextBlock x:Name="OperationsHeroTargetText"
                                   Margin="0,10,0,0"
                                   FontSize="10"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   Text="Target: Current shell"
                                   AutomationProperties.AutomationId="OperationsHeroTargetText" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <views:WorkspaceCommandBarControl x:Name="CommandBar"
                                          Grid.Row="2"
                                          CommandInvoked="OnCommandBarCommandInvoked" />

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.15*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource WorkspaceWorkbenchCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Style="{StaticResource WorkspaceCardHeaderGridStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Operational Queues"
                                       Style="{StaticResource CardHeaderStyle}" />
                            <TextBlock x:Name="QueueSummaryText"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                       Text="Provider posture, backfill priority, and storage follow-up stay in one fixed shell." />
                        </StackPanel>
                        <Border Grid.Column="1"
                                Style="{StaticResource NeutralBadgeStyle}"
                                Margin="12,0,0,0"
                                VerticalAlignment="Top">
                            <TextBlock x:Name="QueueScopeBadgeText"
                                       FontSize="11"
                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                       Text="Provider posture" />
                        </Border>
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="Providers"
                                       Style="{StaticResource ShellSectionLabelStyle}"
                                       Margin="0,0,0,8" />
                            <Grid>
                                <ItemsControl x:Name="ProviderQueueList"
                                              ItemTemplate="{StaticResource QueueItemTemplate}" />
                                <ContentControl x:Name="ProviderQueueStateContainer"
                                                ContentTemplate="{StaticResource QueueRegionStateTemplate}"
                                                Visibility="Collapsed" />
                            </Grid>

                            <TextBlock Text="Backfill"
                                       Style="{StaticResource ShellSectionLabelStyle}"
                                       Margin="0,12,0,8" />
                            <Grid>
                                <ItemsControl x:Name="BackfillQueueList"
                                              ItemTemplate="{StaticResource QueueItemTemplate}" />
                                <ContentControl x:Name="BackfillQueueStateContainer"
                                                ContentTemplate="{StaticResource QueueRegionStateTemplate}"
                                                Visibility="Collapsed" />
                            </Grid>

                            <TextBlock Text="Storage"
                                       Style="{StaticResource ShellSectionLabelStyle}"
                                       Margin="0,12,0,8" />
                            <Grid>
                                <ItemsControl x:Name="StorageQueueList"
                                              ItemTemplate="{StaticResource QueueItemTemplate}" />
                                <ContentControl x:Name="StorageQueueStateContainer"
                                                ContentTemplate="{StaticResource QueueRegionStateTemplate}"
                                                Visibility="Collapsed" />
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource WorkspaceInspectorCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Operations Summary"
                                       Style="{StaticResource CardHeaderStyle}" />
                            <TextBlock x:Name="OperationsSummaryTitleText"
                                       Margin="0,10,0,0"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                       Text="Data Operations" />
                            <TextBlock x:Name="OperationsSummaryDetailText"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                       Text="Provider readiness, historical coverage, and storage posture live in the same operator shell." />
                            <UniformGrid Columns="3" Margin="0,14,0,0">
                                <Border Style="{StaticResource WorkspaceQueueCardStyle}" Margin="0,0,8,0">
                                    <StackPanel Style="{StaticResource WorkspaceSummaryTileContentStyle}">
                                        <TextBlock Text="Providers"
                                                   FontSize="10"
                                                   Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                        <TextBlock x:Name="SummaryProvidersText"
                                                   Margin="0,6,0,0"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                                   Text="3" />
                                        <TextBlock Text="Connectivity posture"
                                                   Margin="0,4,0,0"
                                                   FontSize="10"
                                                   Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource WorkspaceQueueCardStyle}" Margin="0,0,8,0">
                                    <StackPanel Style="{StaticResource WorkspaceSummaryTileContentStyle}">
                                        <TextBlock Text="Backfill"
                                                   FontSize="10"
                                                   Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                        <TextBlock x:Name="SummaryBackfillText"
                                                   Margin="0,6,0,0"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource WarningColorBrush}"
                                                   Text="Queue" />
                                        <TextBlock Text="Historical coverage"
                                                   Margin="0,4,0,0"
                                                   FontSize="10"
                                                   Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource WorkspaceQueueCardStyle}">
                                    <StackPanel Style="{StaticResource WorkspaceSummaryTileContentStyle}">
                                        <TextBlock Text="Storage"
                                                   FontSize="10"
                                                   Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                        <TextBlock x:Name="SummaryStorageText"
                                                   Margin="0,6,0,0"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                                   Text="Watch" />
                                        <TextBlock Text="Durability health"
                                                   Margin="0,4,0,0"
                                                   FontSize="10"
                                                   Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkspaceInspectorCardStyle}">
                        <StackPanel>
                            <Grid Style="{StaticResource WorkspaceCardHeaderGridStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Recent Operations"
                                           Style="{StaticResource CardHeaderStyle}" />
                                <Button Grid.Column="1"
                                        Content="All Sessions"
                                        Click="OpenCollectionSessions_Click"
                                        Style="{StaticResource LinkButtonStyle}" />
                            </Grid>
                            <ItemsControl x:Name="RecentOperationsList"
                                          ItemTemplate="{StaticResource RecentItemTemplate}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WorkspaceInspectorCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Support Surfaces"
                                       Style="{StaticResource CardHeaderStyle}" />
                            <TextBlock Text="Jump into storage, packages, or collection sessions without leaving the shell."
                                       Margin="0,8,0,0"
                                       FontSize="11"
                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                            <WrapPanel Style="{StaticResource WorkspaceCardFooterPanelStyle}">
                                <Button Content="Storage"
                                        Click="OpenStorage_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8" />
                                <Button Content="Sessions"
                                        Click="OpenCollectionSessions_Click"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Margin="0,0,8,8" />
                                <Button Content="Data Export"
                                        Click="OpenDataExport_Click"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Margin="0,0,8,8" />
                                <Button Content="Schedules"
                                        Click="OpenSchedules_Click"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Margin="0,0,8,8" />
                                <Button Content="Packages"
                                        Click="OpenPackageManager_Click"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Margin="0,0,8,8" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="4"
                Margin="0,12,0,0"
                Style="{StaticResource WorkspaceDockHostStyle}">
            <StackPanel>
                <TextBlock Text="Operations Dock"
                           Style="{StaticResource CardHeaderStyle}"
                           Margin="4,0,0,10" />
                <views:MeridianDockingManager x:Name="DataOperationsDockManager"
                                              Height="320"
                                              PaneDropRequested="OnPaneDropRequested"
                                              AutomationProperties.Name="Data Operations Dock Manager" />
            </StackPanel>
        </Border>
    </Grid>
</views:DataOperationsWorkspaceShellPageBase>
