<Page x:Class="Meridian.Wpf.Views.WelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="900"
      d:DesignWidth="1200"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      AutomationProperties.Name="Welcome">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20,28,32">
        <StackPanel MaxWidth="1240">

            <Border Style="{StaticResource EmbeddedShellHeroCardStyle}" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.7*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="48"
                                    Height="48"
                                    CornerRadius="16"
                                    Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                    BorderBrush="{StaticResource InfoColorBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="{StaticResource IconHome}"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="26"
                                           Foreground="{StaticResource InfoColorBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </Border>

                            <StackPanel Margin="14,0,0,0">
                                <TextBlock Text="Meridian Workstation"
                                           Style="{StaticResource PageTitleStyle}" />
                                <TextBlock Text="Choose the right operator lane first, then move into Research, Trading, Data Operations, or Governance without leaving the desktop shell."
                                           Style="{StaticResource CardDescriptionStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>

                        <WrapPanel Margin="0,18,0,0">
                            <Border Background="{StaticResource ConsoleBackgroundMediumBrush}"
                                    BorderBrush="{StaticResource ConsoleBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Padding="10,4"
                                    Margin="0,0,8,8">
                                <TextBlock Text="4 operator workspaces"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                            </Border>

                            <Border Background="{StaticResource ConsoleAccentGreenAlpha10Brush}"
                                    BorderBrush="{StaticResource SuccessColorBrush}"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Padding="10,4"
                                    Margin="0,0,8,8">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8"
                                             Height="8"
                                             Fill="{Binding ConnectionStatusDotFill}"
                                             Margin="0,0,6,0"
                                             VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ConnectionStatusText}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource ConsoleAccentBlueAlpha10Brush}"
                                    BorderBrush="{StaticResource InfoColorBrush}"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Padding="10,4"
                                    Margin="0,0,8,8">
                                <TextBlock Text="{Binding SymbolsCountText, StringFormat={}{0} symbols configured}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <Border Grid.Column="2"
                            Background="{StaticResource ConsoleBackgroundMediumBrush}"
                            BorderBrush="{StaticResource ConsoleBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="18,16">
                        <StackPanel>
                            <TextBlock Text="Landing Page Focus"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}" />
                            <TextBlock Text="The welcome surface now mirrors the workstation model: pick a shell, then use page-level jumps only when you need a specific operation."
                                       Margin="0,10,0,0"
                                       Style="{StaticResource CardDescriptionStyle}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Collection onboarding still lives below, but it is explicitly scoped to Data Operations instead of acting like the entire product home."
                                       Margin="0,10,0,0"
                                       Style="{StaticResource CardDescriptionStyle}"
                                       TextWrapping="Wrap" />

                            <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                <Button Content="Open Documentation"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="OpenDocumentation_Click"
                                        Margin="0,0,8,0" />
                                <Button Content="Open Data Operations"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding NavigateToDataOperationsWorkspaceCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="{StaticResource IconDashboard}"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="18"
                                       Foreground="{StaticResource InfoColorBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Choose A Workspace"
                                       Style="{StaticResource CardHeaderStyle}"
                                       Margin="8,0,0,0" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Open Research"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding NavigateToWorkspaceCommand}"
                                CommandParameter="ResearchShell" />
                    </Grid>

                    <TextBlock Text="Each shell owns a distinct part of the operator journey while keeping the same top-level navigation model across the desktop."
                               TextWrapping="Wrap"
                               Foreground="{StaticResource ConsoleTextSecondaryBrush}" />

                    <ItemsControl ItemsSource="{Binding WorkspaceCards}" Margin="0,18,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Margin" Value="0,0,16,16" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="280"
                                        Padding="16"
                                        Background="{StaticResource ConsoleBackgroundMediumBrush}"
                                        BorderBrush="{Binding AccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Width="42"
                                                    Height="42"
                                                    CornerRadius="14"
                                                    Background="{Binding AccentBackgroundBrush}"
                                                    BorderBrush="{Binding AccentBrush}"
                                                    BorderThickness="1">
                                                <TextBlock Text="{Binding IconGlyph}"
                                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                           FontSize="22"
                                                           Foreground="{Binding AccentBrush}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                <TextBlock Text="{Binding Title}"
                                                           FontFamily="{StaticResource MeridianDisplayFontFamily}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                                <TextBlock Text="{Binding ShellDisplayName}"
                                                           Margin="0,4,0,0"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding AccentBrush}" />
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Grid.Row="1"
                                                   Margin="0,14,0,0"
                                                   Text="{Binding Description}"
                                                   Style="{StaticResource CardDescriptionStyle}" />

                                        <Grid Grid.Row="2" Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Button Content="{Binding ActionLabel}"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Command="{Binding DataContext.NavigateToWorkspaceCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding PageTag}" />

                                            <Border Grid.Column="1"
                                                    Margin="10,0,0,0"
                                                    Background="{Binding AccentBackgroundBrush}"
                                                    BorderBrush="{Binding AccentBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="999"
                                                    Padding="10,4"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TileSummary}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding AccentBrush}" />
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="{StaticResource IconDataOps}"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="18"
                                       Foreground="{StaticResource WarningColorBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Data Operations Quick Start"
                                       Style="{StaticResource CardHeaderStyle}"
                                       Margin="8,0,0,0" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Open Data Operations Workspace"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding NavigateToDataOperationsWorkspaceCommand}" />
                    </Grid>

                    <TextBlock Text="Use this route when you are onboarding provider collection, validating symbol coverage, or checking storage and freshness from a clean workstation."
                               TextWrapping="Wrap"
                               Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                               Margin="0,0,0,16" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{StaticResource PremiumPanelBrush}"
                                BorderBrush="{StaticResource ConsoleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14"
                                Cursor="Hand"
                                MouseLeftButtonUp="StepProvider_CardClick">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{StaticResource IconProvider}"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="24"
                                           Foreground="{StaticResource InfoColorBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="1. Provider"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                           Margin="0,8,0,4" />
                                <TextBlock Text="Configure data source"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           FontSize="11" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{StaticResource PremiumPanelBrush}"
                                BorderBrush="{StaticResource ConsoleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14"
                                Cursor="Hand"
                                MouseLeftButtonUp="StepSymbols_CardClick">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{StaticResource IconList}"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="24"
                                           Foreground="{StaticResource InfoColorBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="2. Symbols"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                           Margin="0,8,0,4" />
                                <TextBlock Text="Add subscriptions"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           FontSize="11" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4"
                                Background="{StaticResource PremiumPanelBrush}"
                                BorderBrush="{StaticResource ConsoleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14"
                                Cursor="Hand"
                                MouseLeftButtonUp="StepStorage_CardClick">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{StaticResource IconDatabase}"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="24"
                                           Foreground="{StaticResource InfoColorBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="3. Storage"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                           Margin="0,8,0,4" />
                                <TextBlock Text="Set output location"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           FontSize="11" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="6"
                                Background="{StaticResource PremiumPanelBrush}"
                                BorderBrush="{StaticResource ConsoleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14"
                                Cursor="Hand"
                                MouseLeftButtonUp="StepOperations_CardClick">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{StaticResource IconDataOps}"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="24"
                                           Foreground="{StaticResource WarningColorBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="4. Operate"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                           Margin="0,8,0,4" />
                                <TextBlock Text="Open queue shell"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           FontSize="11" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="8"
                                Background="{StaticResource PremiumPanelBrush}"
                                BorderBrush="{StaticResource ConsoleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14"
                                Cursor="Hand"
                                MouseLeftButtonUp="StepDataQuality_CardClick">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{StaticResource IconDataQuality}"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="24"
                                           Foreground="{StaticResource SuccessColorBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="5. Quality"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                           Margin="0,8,0,4" />
                                <TextBlock Text="Monitor freshness"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           FontSize="11" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="{StaticResource IconDashboard}"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="18"
                                       Foreground="{StaticResource InfoColorBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="System Overview"
                                       Style="{StaticResource CardHeaderStyle}"
                                       Margin="8,0,0,0" />
                        </StackPanel>

                        <Border Background="{StaticResource PremiumPanelBrush}"
                                BorderBrush="{StaticResource ConsoleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12"
                                Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{StaticResource IconNetwork}"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="18"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Connection"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                    <TextBlock Text="{Binding ConnectionProviderText}"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                               FontSize="11" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="8"
                                             Height="8"
                                             Fill="{Binding ConnectionStatusDotFill}"
                                             Margin="0,0,6,0" />
                                    <TextBlock Text="{Binding ConnectionStatusText}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Background="{StaticResource ConsoleBackgroundMediumBrush}"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{StaticResource IconList}"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="18"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Monitored Symbols"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                    <TextBlock Text="Configured subscriptions"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                               FontSize="11" />
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding SymbolsCountText}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Border Background="{StaticResource ConsoleBackgroundMediumBrush}"
                                CornerRadius="8"
                                Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{StaticResource IconDatabase}"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="18"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Storage Path"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                    <TextBlock Text="{Binding StoragePathText}"
                                               FontFamily="{StaticResource MeridianDataFontFamily}"
                                               FontSize="11"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Button Content="Open Data Operations Workspace"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Left"
                                Margin="0,16,0,0"
                                Command="{Binding NavigateToDataOperationsWorkspaceCommand}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="{StaticResource IconStar}"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="18"
                                           Foreground="{StaticResource InfoColorBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Next Best Action"
                                           Style="{StaticResource CardHeaderStyle}"
                                           Margin="8,0,0,0" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="{Binding NextAction.AccentBackgroundBrush}"
                                    BorderBrush="{Binding NextAction.AccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Padding="10,4">
                                <TextBlock Text="{Binding NextAction.ToneLabel}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding NextAction.AccentBrush}" />
                            </Border>
                        </Grid>

                        <Border Background="{Binding NextAction.AccentBackgroundBrush}"
                                BorderBrush="{Binding NextAction.AccentBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="{Binding NextAction.Title}"
                                           FontFamily="{StaticResource MeridianDisplayFontFamily}"
                                           FontSize="19"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                <TextBlock Text="{Binding NextAction.Summary}"
                                           Margin="0,10,0,0"
                                           Style="{StaticResource CardDescriptionStyle}"
                                           TextWrapping="Wrap" />

                                <WrapPanel Margin="0,16,0,0">
                                    <Button Content="{Binding NextAction.PrimaryActionLabel}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding NavigateToPageCommand}"
                                            CommandParameter="{Binding NextAction.PrimaryActionPageTag}"
                                            Margin="0,0,8,8" />
                                    <Button Content="{Binding NextAction.SecondaryActionLabel}"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Command="{Binding NavigateToPageCommand}"
                                            CommandParameter="{Binding NextAction.SecondaryActionPageTag}"
                                            Margin="0,0,0,8" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Readiness checks"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                   Margin="0,0,0,10" />

                        <ItemsControl ItemsSource="{Binding ReadinessItems}">
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Margin" Value="0,0,0,8" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource ConsoleBackgroundMediumBrush}"
                                            BorderBrush="{StaticResource ConsoleBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Width="38"
                                                    Height="38"
                                                    CornerRadius="12"
                                                    Background="{Binding AccentBackgroundBrush}"
                                                    BorderBrush="{Binding AccentBrush}"
                                                    BorderThickness="1"
                                                    VerticalAlignment="Top">
                                                <TextBlock Text="{Binding IconGlyph}"
                                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                           FontSize="18"
                                                           Foreground="{Binding AccentBrush}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="12,0,16,0">
                                                <WrapPanel Margin="0,0,0,6">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                                               Margin="0,0,8,0" />
                                                    <Border Background="{Binding AccentBackgroundBrush}"
                                                            BorderBrush="{Binding AccentBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="999"
                                                            Padding="8,2">
                                                        <TextBlock Text="{Binding StatusLabel}"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{Binding AccentBrush}" />
                                                    </Border>
                                                </WrapPanel>
                                                <TextBlock Text="{Binding Detail}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <Button Grid.Column="2"
                                                    Content="{Binding ActionLabel}"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding DataContext.NavigateToPageCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding ActionPageTag}"
                                                    VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Background="{StaticResource ConsoleBackgroundMediumBrush}"
                                CornerRadius="10"
                                Padding="12"
                                Margin="0,8,0,0">
                            <TextBlock Text="Routing rule: keep provider, symbol, storage, and freshness blockers inside Data Operations. Move into Research, Trading, or Governance only after setup stops being the limiting factor."
                                       FontSize="11"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
