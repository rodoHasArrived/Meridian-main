<Page x:Class="Meridian.Wpf.Views.PortfolioImportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="clr-namespace:Meridian.Wpf.Converters"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      AutomationProperties.Name="Portfolio Import">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InvertBoolConverter x:Key="InvertBoolConverter" />
    </Page.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20,28,32">
        <StackPanel MaxWidth="1200">
            <Border Style="{StaticResource EmbeddedShellHeroCardStyle}" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="14"
                            Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                            BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1">
                        <TextBlock Text="&#xE896;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="24" Foreground="{StaticResource InfoColorBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Portfolio Import" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="Import monitored symbols from files, portfolios, and major index universes."
                                   Style="{StaticResource CardDescriptionStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- File Import -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,16">
                    <StackPanel>
                        <TextBlock Text="Import from File" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,4" />
                        <TextBlock Text="CSV, Excel, or text files with symbol lists." Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="12" Margin="0,0,0,16" />

                        <Border AutomationProperties.AutomationId="PortfolioImportFileReadiness"
                                Background="{StaticResource PremiumPanelBrush}"
                                BorderBrush="{StaticResource ConsoleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock AutomationProperties.AutomationId="PortfolioImportFileReadinessTitle"
                                           Text="{Binding FileImportGuidanceTitle}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextBrush}" />
                                <TextBlock AutomationProperties.AutomationId="PortfolioImportFileReadinessText"
                                           Text="{Binding FileImportGuidanceText}"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="File Format" Style="{StaticResource FormLabelStyle}" />
                        <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding SelectedFileFormat}"
                                  Style="{StaticResource FormComboBoxStyle}" Margin="0,0,0,8">
                            <ComboBoxItem Content="CSV (Symbol per row)" Tag="csv" />
                            <ComboBoxItem Content="CSV with headers" Tag="csv-header" />
                            <ComboBoxItem Content="Text (one symbol per line)" Tag="text" />
                            <ComboBoxItem Content="Excel (.xlsx)" Tag="excel" />
                        </ComboBox>

                        <TextBlock Text="Symbol Column (for CSV with headers)" Style="{StaticResource FormLabelStyle}" />
                        <TextBox x:Name="SymbolColumnBox" Style="{StaticResource FormTextBoxStyle}" Text="Symbol" Margin="0,0,0,8" />

                        <TextBlock Text="Selected File" Style="{StaticResource FormLabelStyle}" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding FilePath}" Style="{StaticResource FormTextBoxStyle}" IsReadOnly="True" />
                            <Button Grid.Column="1"
                                    Content="Browse..."
                                    Command="{Binding BrowseFileCommand}"
                                    Style="{StaticResource FormButtonStyle}"
                                    Margin="8,0,0,0" />
                        </Grid>

                        <CheckBox x:Name="ValidateSymbolsCheck" Content="Validate symbols before import" IsChecked="True"
                                  Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,0,0,8" />
                        <CheckBox x:Name="SkipExistingCheck" Content="Skip symbols already monitored" IsChecked="True"
                                  Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Import"
                                    Command="{Binding ImportFileCommand}"
                                    Style="{StaticResource FormButtonStyle}"
                                    AutomationProperties.AutomationId="PortfolioImportFileButton" />
                            <TextBlock Text="{Binding ImportStatus}" VerticalAlignment="Center" Margin="12,0,0,0"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Quick Index Import -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Quick Index Import" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,4" />
                        <TextBlock Text="Add all constituents of a major index." Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="12" Margin="0,0,0,16" />

                        <Button Content="S&amp;P 500 (SPY constituents)"
                                Command="{Binding ImportIndexCommand}"
                                CommandParameter="sp500"
                                Style="{StaticResource FormButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,8"
                                AutomationProperties.AutomationId="PortfolioImportSp500Button" />
                        <Button Content="NASDAQ-100 (QQQ constituents)"
                                Command="{Binding ImportIndexCommand}"
                                CommandParameter="nasdaq100"
                                Style="{StaticResource FormButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,8"
                                AutomationProperties.AutomationId="PortfolioImportNasdaq100Button" />
                        <Button Content="Dow Jones 30 (DIA constituents)"
                                Command="{Binding ImportIndexCommand}"
                                CommandParameter="djia"
                                Style="{StaticResource FormButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,8"
                                AutomationProperties.AutomationId="PortfolioImportDjiaButton" />
                        <Button Content="Russell 2000 (IWM constituents)"
                                Command="{Binding ImportIndexCommand}"
                                CommandParameter="russell2000"
                                Style="{StaticResource FormButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,8"
                                AutomationProperties.AutomationId="PortfolioImportRussell2000Button" />
                        <Button Content="S&amp;P MidCap 400"
                                Command="{Binding ImportIndexCommand}"
                                CommandParameter="sp400"
                                Style="{StaticResource FormButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,8"
                                AutomationProperties.AutomationId="PortfolioImportSp400Button" />

                        <TextBlock Text="{Binding IndexImportStatus}" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="12" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Manual Entry -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Manual Entry" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,4" />
                    <TextBlock Text="Paste or type symbols separated by commas, spaces, or newlines." Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="12" Margin="0,0,0,16" />

                    <TextBox Text="{Binding ManualSymbols, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBoxStyle}" Height="80"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12" />

                    <Border AutomationProperties.AutomationId="PortfolioImportManualReadiness"
                            Background="{StaticResource PremiumPanelBrush}"
                            BorderBrush="{StaticResource ConsoleBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock AutomationProperties.AutomationId="PortfolioImportManualCount"
                                       Text="{Binding ManualSymbolCountText}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ConsoleTextBrush}" />
                            <TextBlock AutomationProperties.AutomationId="PortfolioImportManualGuidance"
                                       Text="{Binding ManualEntryGuidanceText}"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Add Symbols"
                                Command="{Binding AddManualSymbolsCommand}"
                                Style="{StaticResource FormButtonStyle}"
                                AutomationProperties.AutomationId="PortfolioImportManualAddButton" />
                        <TextBlock Text="{Binding ManualImportStatus}" VerticalAlignment="Center" Margin="12,0,0,0"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="12" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Import History -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Import History" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding ImportHistory}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,0,0,4" BorderBrush="{DynamicResource ConsoleBackgroundBrush}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Source}" Foreground="{DynamicResource ConsoleTextBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding CountText}" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="16,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding DateText}" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="No imports yet." Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="12"
                               Visibility="{Binding HasImportHistory, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
