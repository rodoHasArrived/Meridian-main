<Page x:Class="Meridian.Wpf.Views.AnalysisExportWizardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      AutomationProperties.Name="Analysis Export Wizard">
    <Page.Resources>
        <Style x:Key="StepPanelStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentStep}" Value="1">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StepPanelStyleTwo" TargetType="StackPanel" BasedOn="{StaticResource StepPanelStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StepPanelStyleThree" TargetType="StackPanel" BasedOn="{StaticResource StepPanelStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentStep}" Value="3">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20,28,32">
        <StackPanel MaxWidth="1200">
            <Border Style="{StaticResource EmbeddedShellHeroCardStyle}" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="14"
                            Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                            BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1">
                        <TextBlock Text="&#xF2F1;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="24" Foreground="{StaticResource InfoColorBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Analysis Export Wizard" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="Build export packages step by step for downstream analysis and review."
                                   Style="{StaticResource CardDescriptionStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="Step" Style="{StaticResource CardHeaderStyle}" />
                        <TextBlock Text="{Binding CurrentStep}" Style="{StaticResource CardHeaderStyle}" Margin="8,0,0,0" />
                        <TextBlock Text="of 3" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="6,6,0,0" />
                    </StackPanel>

                    <Border AutomationProperties.AutomationId="AnalysisExportWizardReadinessCard"
                            Background="{StaticResource ConsoleBackgroundLightBrush}"
                            BorderBrush="{StaticResource ConsoleBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,0,0,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentStepTitle}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                <TextBlock Text="{Binding CurrentStepDetail}"
                                           Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                                <TextBlock AutomationProperties.AutomationId="AnalysisExportWizardScopeText"
                                           Text="{Binding WizardScopeText}"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           FontSize="12"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Width="300"
                                        Margin="20,0,0,0">
                                <TextBlock Text="{Binding ActionReadinessTitle}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InfoColorBrush}" />
                                <TextBlock Text="{Binding ActionReadinessDetail}"
                                           Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Style="{StaticResource StepPanelStyle}">
                        <TextBlock Text="1. Select symbols and date range" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Symbols" Style="{StaticResource FormLabelStyle}" />
                                <TextBox Style="{StaticResource FormTextBoxStyle}"
                                         Text="{Binding SymbolInput, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Content="Add Symbol"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding AddSymbolCommand}"
                                        AutomationProperties.AutomationId="AnalysisExportWizardAddSymbolButton"
                                        Margin="0,8,0,0" />
                                <ListBox ItemsSource="{Binding SelectedSymbols}" Height="100" Margin="0,8,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="From" Style="{StaticResource FormLabelStyle}" />
                                <DatePicker SelectedDate="{Binding FromDate, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="To" Style="{StaticResource FormLabelStyle}" />
                                <DatePicker SelectedDate="{Binding ToDate, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel Style="{StaticResource StepPanelStyleTwo}">
                        <TextBlock Text="2. Choose metrics and output format" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Metrics" Style="{StaticResource FormLabelStyle}" />
                                <ItemsControl ItemsSource="{Binding Metrics}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="0,0,16,6" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Format" Style="{StaticResource FormLabelStyle}" />
                                <ComboBox Style="{StaticResource FormComboBoxStyle}"
                                          ItemsSource="{Binding Formats}"
                                          SelectedItem="{Binding SelectedFormat}" />
                                <TextBlock Text="Output Destination" Style="{StaticResource FormLabelStyle}" Margin="0,12,0,0" />
                                <TextBox Style="{StaticResource FormTextBoxStyle}"
                                         Text="{Binding Destination, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel Style="{StaticResource StepPanelStyleThree}">
                        <TextBlock Text="3. Review and confirm" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,12" />
                        <StackPanel>
                            <TextBlock Text="{Binding ReviewSummary}" Foreground="{StaticResource ConsoleTextMutedBrush}" TextWrapping="Wrap" />
                            <CheckBox Content="Include charts in export package" IsChecked="{Binding IncludeCharts}" Margin="0,12,0,0" />
                            <CheckBox Content="Attach summary PDF" IsChecked="{Binding IncludeSummary}" />
                        </StackPanel>

                        <!-- Pre-Export Validation Report -->
                        <Border Background="{StaticResource ConsoleBackgroundLightBrush}"
                                CornerRadius="12"
                                Padding="16"
                                Margin="0,16,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="&#xE9D5;"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="16"
                                               Foreground="{StaticResource InfoColorBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="Pre-Export Validation"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                    <TextBlock Text="{Binding EstimatedSize, StringFormat='  |  Estimated: {0}'}"
                                               FontSize="12"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0" />
                                </StackPanel>
                                <TextBlock Text="{Binding PreExportReport}"
                                           FontFamily="Cascadia Code, Consolas"
                                           FontSize="12"
                                           Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <Button Content="Back"
                                Style="{StaticResource GhostButtonStyle}"
                                Command="{Binding BackCommand}"
                                AutomationProperties.AutomationId="AnalysisExportWizardBackButton"
                                Margin="0,0,8,0" />
                        <Button Content="{Binding PrimaryActionLabel}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding PrimaryActionCommand}"
                                AutomationProperties.AutomationId="AnalysisExportWizardPrimaryActionButton"
                                Margin="0,0,8,0" />
                        <Button Content="Cancel"
                                Style="{StaticResource GhostButtonStyle}"
                                Command="{Binding CancelCommand}"
                                AutomationProperties.AutomationId="AnalysisExportWizardCancelButton" />
                    </StackPanel>

                    <TextBlock AutomationProperties.AutomationId="AnalysisExportWizardStatusText"
                               Text="{Binding StatusMessage}"
                               Foreground="{StaticResource InfoColorBrush}"
                               Margin="0,12,0,0"
                               Visibility="{Binding StatusVisibility}" />
                </StackPanel>
            </Border>

            <TextBlock AutomationProperties.AutomationId="AnalysisExportWizardValidationText"
                       Text="{Binding ValidationSummary}"
                       Foreground="{StaticResource ErrorColorBrush}"
                       Margin="0,12,0,0"
                       Visibility="{Binding ValidationVisibility}" />
        </StackPanel>
    </ScrollViewer>
</Page>
