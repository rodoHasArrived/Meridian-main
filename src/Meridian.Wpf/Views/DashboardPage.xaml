<Page x:Class="Meridian.Wpf.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:views="clr-namespace:Meridian.Wpf.Views"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="1400"
      Background="{DynamicResource ConsoleBackgroundDarkBrush}"
      Loaded="OnPageLoaded"
      Unloaded="OnPageUnloaded"
      AutomationProperties.Name="Portfolio Operations Dashboard">

    <Page.Resources>
        <Style x:Key="DashboardMetricItemBorderStyle" TargetType="Border" BasedOn="{StaticResource MetricCardStyle}">
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="MinHeight" Value="126" />
            <Setter Property="Padding" Value="18,16" />
        </Style>

        <Style x:Key="DashboardMonoCellTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MeridianDataFontFamily}" />
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="DashboardTextCellStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MeridianBodyFontFamily}" />
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="DashboardMutedCellStyle" TargetType="TextBlock" BasedOn="{StaticResource DashboardTextCellStyle}">
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
        </Style>
    </Page.Resources>

    <DockPanel>
        <views:PageActionBarControl DockPanel.Dock="Top" DataContext="{Binding}" />

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20,28,32">
            <StackPanel MaxWidth="1400">
                <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Portfolio Operations" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="Holdings oversight, valuation readiness, and data-quality controls."
                                       Style="{StaticResource CardDescriptionStyle}"
                                       Margin="0,6,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                            <Button Command="{Binding RefreshStatusCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{StaticResource IconRefresh}"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="14"
                                               Margin="0,0,6,0" />
                                    <TextBlock Text="Refresh" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ViewAllIntegrityEventsCommand}"
                                    Style="{StaticResource GhostButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{StaticResource IconWarning}"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="14"
                                               Margin="0,0,6,0" />
                                    <TextBlock Text="Quality Worklist" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <ItemsControl ItemsSource="{Binding OperationsMetrics}" Margin="0,0,0,12">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource DashboardMetricItemBorderStyle}"
                                    BorderBrush="{Binding AccentBrush}"
                                    BorderThickness="3,1,1,1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="{Binding Label}"
                                               Style="{StaticResource MetricLabelStyle}"
                                               Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Value}"
                                               Style="{StaticResource MetricValueStyle}"
                                               Foreground="{Binding AccentBrush}"
                                               Margin="0,10,0,6" />
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding Detail}"
                                               Style="{StaticResource CardDescriptionStyle}"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Quality Exceptions by Category" Style="{StaticResource SectionHeaderStyle}" />
                            <TextBlock Text="Open exceptions affecting valuation, security master, and ledger export readiness."
                                       Style="{StaticResource CardDescriptionStyle}"
                                       Margin="0,4,0,18" />

                            <ItemsControl ItemsSource="{Binding DataQualityCategories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,14">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Row="0" Grid.Column="0">
                                                <TextBlock Text="{Binding Category}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                                <TextBlock Text="{Binding Detail}"
                                                           Style="{StaticResource CardDescriptionStyle}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,2,16,0" />
                                            </StackPanel>
                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="1"
                                                       Text="{Binding Count}"
                                                       FontFamily="{StaticResource MeridianDataFontFamily}"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding StatusBrush}"
                                                       VerticalAlignment="Top" />
                                            <ProgressBar Grid.Row="1"
                                                         Grid.ColumnSpan="2"
                                                         Height="6"
                                                         Maximum="100"
                                                         Value="{Binding Completion}"
                                                         Foreground="{Binding StatusBrush}"
                                                         Background="{StaticResource ConsoleBackgroundMediumBrush}"
                                                         Margin="0,10,0,0" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Upcoming Maturities" Style="{StaticResource SectionHeaderStyle}" />
                            <TextBlock Text="Cash-facing maturities and term-data readiness over the next 90 days."
                                       Style="{StaticResource CardDescriptionStyle}"
                                       Margin="0,4,0,18" />

                            <ItemsControl ItemsSource="{Binding UpcomingMaturities}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource ConsoleBorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,0,0,12"
                                                Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="92" />
                                                    <ColumnDefinition Width="96" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Issuer}"
                                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding MaturityDate}"
                                                           FontFamily="{StaticResource MeridianDataFontFamily}"
                                                           Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding ParValue}"
                                                           FontFamily="{StaticResource MeridianDataFontFamily}"
                                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding Status}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding StatusBrush}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="20,18,20,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Holdings Snapshot" Style="{StaticResource SectionHeaderStyle}" />
                                <Border Style="{StaticResource NeutralBadgeStyle}" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding HoldingsSnapshotCountText}"
                                               FontSize="12"
                                               Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                </Border>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="Holdings, valuation basis, and data-quality workflow status"
                                       Style="{StaticResource CardDescriptionStyle}"
                                       VerticalAlignment="Center" />
                        </Grid>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding HoldingsSnapshotItems}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserSortColumns="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  RowHeight="36"
                                  ColumnHeaderHeight="34"
                                  MinHeight="326"
                                  Background="{StaticResource PremiumPanelBrush}"
                                  Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                  BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="CUSIP" Binding="{Binding Cusip}" Width="98" ElementStyle="{StaticResource DashboardMonoCellTextStyle}" />
                                <DataGridTextColumn Header="Issuer" Binding="{Binding Issuer}" Width="160" ElementStyle="{StaticResource DashboardTextCellStyle}" />
                                <DataGridTextColumn Header="Instrument" Binding="{Binding Description}" Width="185" ElementStyle="{StaticResource DashboardMutedCellStyle}" />
                                <DataGridTextColumn Header="Asset Class" Binding="{Binding AssetClass}" Width="104" ElementStyle="{StaticResource DashboardTextCellStyle}" />
                                <DataGridTextColumn Header="Rating" Binding="{Binding Rating}" Width="92" ElementStyle="{StaticResource DashboardMonoCellTextStyle}" />
                                <DataGridTextColumn Header="Coupon" Binding="{Binding Coupon}" Width="78" ElementStyle="{StaticResource DashboardMonoCellTextStyle}" />
                                <DataGridTextColumn Header="Maturity" Binding="{Binding Maturity}" Width="96" ElementStyle="{StaticResource DashboardMonoCellTextStyle}" />
                                <DataGridTextColumn Header="Par / Qty" Binding="{Binding ParValue}" Width="100" ElementStyle="{StaticResource DashboardMonoCellTextStyle}" />
                                <DataGridTextColumn Header="Book Basis" Binding="{Binding BookValue}" Width="100" ElementStyle="{StaticResource DashboardMonoCellTextStyle}" />
                                <DataGridTextColumn Header="Valuation" Binding="{Binding MarketValue}" Width="104" ElementStyle="{StaticResource DashboardMonoCellTextStyle}" />
                                <DataGridTemplateColumn Header="Valuation Delta" Width="118">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ValuationDelta}"
                                                       FontFamily="{StaticResource MeridianDataFontFamily}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding ValuationDeltaBrush}"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Right" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Data Quality" Width="118">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding DataStatusBackground}"
                                                    BorderBrush="{Binding DataStatusBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="8,3"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DataStatus}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{Binding DataStatusForeground}" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="9" Height="9" Fill="{StaticResource SuccessColorBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="Holdings and data-quality controls current"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                           Margin="8,0,0,0" />
                            </StackPanel>
                            <TextBlock Text="Pricing coverage current · Security master checks clear · Ledger export ready · Reference data synchronized"
                                       FontFamily="{StaticResource MeridianDataFontFamily}"
                                       FontSize="12"
                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                       Margin="17,6,0,0" />
                        </StackPanel>

                        <ItemsControl Grid.Column="1" ItemsSource="{Binding PortfolioDataServiceStatuses}" VerticalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource NeutralBadgeStyle}" Margin="8,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6" Fill="{Binding StatusBrush}" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding ServiceName}" Margin="6,0,4,0" FontSize="12" />
                                            <TextBlock Text="{Binding State}"
                                                       FontFamily="{StaticResource MeridianDataFontFamily}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
