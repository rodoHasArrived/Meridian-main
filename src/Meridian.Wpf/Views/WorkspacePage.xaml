<Page x:Class="Meridian.Wpf.Views.WorkspacePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="clr-namespace:Meridian.Wpf.Converters"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      AutomationProperties.Name="Workspace">
    <Page.Resources>
        <converters:InvertBoolConverter x:Key="InvertBoolConverter" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20,28,32">
        <StackPanel MaxWidth="1200">

            <!-- Header -->
            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Width="44" Height="44" CornerRadius="14"
                                    Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                    BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1">
                                <TextBlock Text="&#xE8A1;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="24" Foreground="{StaticResource InfoColorBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                            <StackPanel Margin="12,0,0,0">
                                <TextBlock Text="Workspaces" Style="{StaticResource PageTitleStyle}" VerticalAlignment="Center" />
                                <TextBlock Text="Manage workstation templates and restore workflow-focused session layouts"
                                           Style="{StaticResource CardDescriptionStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Import"
                                Click="ImportWorkspace_Click"
                                Style="{StaticResource GhostButtonStyle}"
                                Margin="0,0,8,0"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />
                        <Button Content="Capture Current"
                                Command="{Binding CaptureWorkspaceCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{Binding StatusMessageColor}"
                       Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}"
                       Margin="0,0,0,24"
                       FontSize="12" />

            <!-- Active Workspace -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="&#xE8A7;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="16" Foreground="{StaticResource SuccessColorBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Active Workspace" Style="{StaticResource CardHeaderStyle}" />
                    </StackPanel>
                    <Border Background="{StaticResource ConsoleBackgroundLightBrush}" CornerRadius="12" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding ActiveWorkspaceName}" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                <TextBlock Text="{Binding ActiveWorkspaceDescription}"
                                            FontSize="12" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding ActiveWorkspacePagesText}" FontSize="12"
                                            Foreground="{StaticResource ConsoleTextSecondaryBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    CornerRadius="999"
                                    Padding="10,4"
                                    Background="{StaticResource ConsoleAccentBlueAlpha10Brush}"
                                    VerticalAlignment="Top"
                                    Visibility="{Binding HasActiveWorkspace, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding ActiveWorkspaceCategoryText}" FontSize="11" FontWeight="SemiBold"
                                            Foreground="{StaticResource InfoColorBrush}" />
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Session Restore -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Last Session" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12" />
                    <TextBlock Text="{Binding LastSessionText}" FontSize="13"
                               Foreground="{StaticResource ConsoleTextMutedBrush}" />
                    <Button Content="Restore Session"
                            Command="{Binding RestoreSessionCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Left" Margin="0,8,0,0"
                            IsEnabled="{Binding CanRestoreSession}" />
                </StackPanel>
            </Border>

            <!-- Create Workspace -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Create Workspace" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,16" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Name" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource FormTextBoxStyle}"
                                     Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding NewNameError}"
                                       Foreground="#F85149"
                                       FontSize="11"
                                       Margin="0,4,0,0"
                                       Visibility="{Binding HasNewNameError, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Description" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource FormTextBoxStyle}"
                                     Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Category" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,0,0,4" />
                            <ComboBox SelectedIndex="{Binding NewCategoryIndex}" Width="150">
                                <ComboBoxItem Content="Research" />
                                <ComboBoxItem Content="Trading" />
                                <ComboBoxItem Content="Data Operations" />
                                <ComboBoxItem Content="Governance" />
                                <ComboBoxItem Content="Custom" />
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                    <Button Content="Create Workspace"
                            Command="{Binding CreateWorkspaceCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Left"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />
                </StackPanel>
            </Border>

            <!-- Workspace List -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="All Workspaces" Style="{StaticResource CardHeaderStyle}" />
                        <TextBlock Grid.Column="1" Text="{Binding WorkspaceCountText}" FontSize="12"
                                    Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Text="No workspaces yet."
                               Margin="0,0,0,12"
                               FontSize="12"
                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                               Visibility="{Binding HasWorkspaces, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}" />
                    <ListView ItemsSource="{Binding Workspaces}"
                              SelectionMode="Single"
                              MaxHeight="400"
                              Background="Transparent"
                              BorderThickness="0"
                              Visibility="{Binding HasWorkspaces, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,4" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource ConsoleBackgroundLightBrush}"
                                        CornerRadius="12" Padding="12,10"
                                        BorderBrush="{StaticResource ConsoleBorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Bold"
                                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                                <Border Margin="8,0,0,0"
                                                        Padding="8,2"
                                                        CornerRadius="999"
                                                        Background="{StaticResource ConsoleAccentBlueAlpha10Brush}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding BadgeText}" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{StaticResource InfoColorBrush}"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <Border Margin="6,0,0,0"
                                                        Padding="8,2"
                                                        CornerRadius="999"
                                                        Background="{StaticResource ConsoleAccentGreenAlpha10Brush}"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock Text="ACTIVE"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource SuccessColorBrush}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding PagesText}" FontSize="12"
                                                   Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                                   VerticalAlignment="Center" Margin="12,0" />
                                        <Button Grid.Column="2"
                                                Content="Activate"
                                                Command="{Binding DataContext.ActivateWorkspaceCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding Id}"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Margin="0,0,4,0" />
                                        <Button Grid.Column="3"
                                                Content="Export"
                                                Click="ExportWorkspace_Click"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Tag="{Binding Id}"
                                                IsEnabled="{Binding DataContext.IsBusy, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource InvertBoolConverter}}"
                                                Margin="0,0,4,0" />
                                        <Button Grid.Column="4"
                                                Content="Delete"
                                                Command="{Binding DataContext.DeleteWorkspaceCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding Id}"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Visibility="{Binding CanDelete, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
