<UserControl x:Class="Meridian.Wpf.Views.SplitPaneHostControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="800"
             AllowDrop="True"
             Background="Transparent"
             DragLeave="OnDragLeave"
             DragOver="OnDragOver"
             Drop="OnDrop">
    <Grid>
        <Grid x:Name="ContentGrid"/>

        <Grid x:Name="DropOverlay"
              Visibility="Collapsed"
              IsHitTestVisible="False"
              Background="#66050B14">
            <Border Width="280"
                    Height="220"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#F20E1726"
                    BorderBrush="#5F7DB3"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="16">
                <Grid x:Name="DropTargetGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="OpenTabTarget"
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="6"
                            Padding="10,8"
                            CornerRadius="10"
                            Background="#10263D"
                            BorderBrush="#365A84"
                            BorderThickness="1">
                        <TextBlock Text="Open Tab"
                                   Foreground="White"
                                   FontSize="12"
                                   HorizontalAlignment="Center" />
                    </Border>

                    <Border x:Name="FloatTarget"
                            Grid.Row="0"
                            Grid.Column="2"
                            Margin="6"
                            Padding="10,8"
                            CornerRadius="10"
                            Background="#10263D"
                            BorderBrush="#365A84"
                            BorderThickness="1">
                        <TextBlock Text="Float"
                                   Foreground="White"
                                   FontSize="12"
                                   HorizontalAlignment="Center" />
                    </Border>

                    <Border x:Name="SplitLeftTarget"
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="6"
                            Padding="12"
                            CornerRadius="10"
                            Background="#10263D"
                            BorderBrush="#365A84"
                            BorderThickness="1">
                        <TextBlock Text="Split Left"
                                   Foreground="White"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <Border x:Name="ReplaceTarget"
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="6"
                            Padding="12"
                            CornerRadius="10"
                            Background="#153157"
                            BorderBrush="#4B8CDB"
                            BorderThickness="1">
                        <TextBlock Text="Replace"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <Border x:Name="SplitRightTarget"
                            Grid.Row="1"
                            Grid.Column="2"
                            Margin="6"
                            Padding="12"
                            CornerRadius="10"
                            Background="#10263D"
                            BorderBrush="#365A84"
                            BorderThickness="1">
                        <TextBlock Text="Split Right"
                                   Foreground="White"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <Border x:Name="SplitBelowTarget"
                            Grid.Row="2"
                            Grid.Column="1"
                            Margin="6"
                            Padding="12"
                            CornerRadius="10"
                            Background="#10263D"
                            BorderBrush="#365A84"
                            BorderThickness="1">
                        <TextBlock Text="Split Below"
                                   Foreground="White"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
