<Page x:Class="Meridian.Wpf.Views.AddProviderWizardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      AutomationProperties.Name="Add Provider Wizard">

    <Grid Background="{DynamicResource ShellWindowBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="28,20,12,32">
            <StackPanel MaxWidth="880">
                <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource GhostButtonStyle}" Click="BackButton_Click" Margin="0,0,8,0">
                            <TextBlock Text="{StaticResource IconBack}" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="16" />
                        </Button>
                        <Border Width="44" Height="44" CornerRadius="14" Background="{StaticResource ConsoleAccentBlueAlpha20Brush}" BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1">
                            <TextBlock Text="{StaticResource IconPlugin}" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="24" Foreground="{StaticResource InfoColorBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Add Provider Relationship" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="Scope a broker, bank, custodian, exchange, or data vendor with capability bindings and certification." Style="{StaticResource CardDescriptionStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="1. Choose Relationship" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Connection Type" Style="{StaticResource FormLabelStyle}" />
                                <ComboBox x:Name="ConnectionTypeCombo" Style="{StaticResource FormComboBoxStyle}" SelectionChanged="ConnectionType_SelectionChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Preset" Style="{StaticResource FormLabelStyle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="PresetCombo" Style="{StaticResource FormComboBoxStyle}" DisplayMemberPath="Name" SelectionChanged="PresetCombo_SelectionChanged" />
                                    <Button Grid.Column="1" Content="Apply" Style="{StaticResource SecondaryButtonStyle}" Click="PresetApply_Click" Margin="8,0,0,0" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Connection Label" Style="{StaticResource FormLabelStyle}" />
                                <TextBox x:Name="ConnectionNameBox" Style="{StaticResource FormTextBoxStyle}" TextChanged="TextInput_Changed" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Provider Family ID" Style="{StaticResource FormLabelStyle}" />
                                <TextBox x:Name="ProviderFamilyIdBox" Style="{StaticResource FormTextBoxStyle}" TextChanged="TextInput_Changed" />
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Institution ID" Style="{StaticResource FormLabelStyle}" />
                                <TextBox x:Name="InstitutionIdBox" Style="{StaticResource FormTextBoxStyle}" TextChanged="TextInput_Changed" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="External Account ID" Style="{StaticResource FormLabelStyle}" />
                                <TextBox x:Name="ExternalAccountIdBox" Style="{StaticResource FormTextBoxStyle}" TextChanged="TextInput_Changed" />
                            </StackPanel>
                        </Grid>
                        <ItemsControl x:Name="ProviderCatalogList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,8,8" Click="ProviderCard_Click" Tag="{Binding Id}" HorizontalContentAlignment="Stretch">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Setter Property="Padding" Value="14,10" />
                                            </Style>
                                        </Button.Style>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <Ellipse Width="10" Height="10" Fill="{Binding CredentialStatusBrush}" Margin="0,0,8,0" />
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="2. Credentials And Scope" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Connection Mode" Style="{StaticResource FormLabelStyle}" />
                                <ComboBox x:Name="OperatingModeCombo" Style="{StaticResource FormComboBoxStyle}" SelectionChanged="OperatingMode_SelectionChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Credential Reference" Style="{StaticResource FormLabelStyle}" />
                                <TextBox x:Name="CredentialReferenceBox" Style="{StaticResource FormTextBoxStyle}" TextChanged="TextInput_Changed" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="{Binding CredentialsInfoText}" Foreground="{StaticResource ConsoleTextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />
                        <StackPanel x:Name="CredentialFieldsPanel" />
                        <TextBlock Text="No catalog-defined environment fields are required." Visibility="{Binding NoCredentialsVisibility}" Foreground="{StaticResource SuccessColorBrush}" Margin="0,0,0,12" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Workspace" Style="{StaticResource FormLabelStyle}" />
                                <TextBox x:Name="WorkspaceBox" Style="{StaticResource FormTextBoxStyle}" TextChanged="TextInput_Changed" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Fund Profile ID" Style="{StaticResource FormLabelStyle}" />
                                <TextBox x:Name="FundProfileIdBox" Style="{StaticResource FormTextBoxStyle}" TextChanged="TextInput_Changed" />
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Entity ID" Style="{StaticResource FormLabelStyle}" />
                                <TextBox x:Name="EntityIdBox" Style="{StaticResource FormTextBoxStyle}" TextChanged="TextInput_Changed" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Sleeve ID" Style="{StaticResource FormLabelStyle}" />
                                <TextBox x:Name="SleeveIdBox" Style="{StaticResource FormTextBoxStyle}" TextChanged="TextInput_Changed" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Vehicle ID" Style="{StaticResource FormLabelStyle}" />
                                <TextBox x:Name="VehicleIdBox" Style="{StaticResource FormTextBoxStyle}" TextChanged="TextInput_Changed" />
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Account ID" Style="{StaticResource FormLabelStyle}" />
                                <TextBox x:Name="AccountIdBox" Style="{StaticResource FormTextBoxStyle}" TextChanged="TextInput_Changed" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Relationship Notes" Style="{StaticResource FormLabelStyle}" />
                                <TextBox x:Name="DescriptionBox" Style="{StaticResource FormTextBoxStyle}" TextChanged="TextInput_Changed" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="3. Capabilities And Policy" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Safety Mode" Style="{StaticResource FormLabelStyle}" />
                                <ComboBox x:Name="SafetyModeCombo" Style="{StaticResource FormComboBoxStyle}" SelectionChanged="SafetyMode_SelectionChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Failover IDs (comma)" Style="{StaticResource FormLabelStyle}" />
                                <TextBox x:Name="FailoverConnectionIdsBox" Style="{StaticResource FormTextBoxStyle}" TextChanged="TextInput_Changed" />
                            </StackPanel>
                        </Grid>
                        <CheckBox x:Name="EnabledCheck" Content="Enable immediately" IsChecked="True" Margin="0,0,0,6" Checked="StateOption_Changed" Unchecked="StateOption_Changed" />
                        <CheckBox x:Name="ProductionReadyCheck" Content="Require certification before live use" Margin="0,0,0,12" Checked="StateOption_Changed" Unchecked="StateOption_Changed" />
                        <WrapPanel x:Name="CapabilityOptionsPanel" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="4. Save, Preview, And Certify" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Ellipse Width="12" Height="12" Fill="{Binding ConnectionTestDotBrush}" Margin="0,0,10,0" />
                            <TextBlock Text="{Binding ConnectionTestStatusText}" Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                        </StackPanel>
                        <WrapPanel Margin="0,0,0,12">
                            <Button Content="Validate Draft" Style="{StaticResource SecondaryButtonStyle}" Click="TestProviderConnection_Click" Margin="0,0,8,8" />
                            <Button Content="Save Relationship" Style="{StaticResource PrimaryButtonStyle}" Click="SaveProvider_Click" Margin="0,0,8,8" />
                            <Button Content="Preview Route" Style="{StaticResource GhostButtonStyle}" Click="PreviewRoute_Click" Margin="0,0,8,8" />
                            <Button Content="Run Certification" Style="{StaticResource GhostButtonStyle}" Click="RunCertification_Click" Margin="0,0,8,8" />
                        </WrapPanel>
                        <TextBlock Text="{Binding SaveStatusText}" Foreground="{Binding SaveStatusBrush}" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding RoutePreviewText}" Foreground="{Binding RoutePreviewBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding CertificationStatusText}" Foreground="{Binding CertificationStatusBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Column="1" Margin="12,20,28,32">
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Summary" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,0,0,12" />
                    <TextBlock Text="{Binding SelectedProviderName}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource InfoColorBrush}" />
                    <TextBlock Text="{Binding SelectedProviderDescription}" Foreground="{StaticResource ConsoleTextSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,12" />
                    <TextBlock Text="{Binding SummaryConnectionTypeText}" Margin="0,2,0,0" />
                    <TextBlock Text="{Binding SummaryOperatingModeText}" Margin="0,2,0,0" />
                    <TextBlock Text="{Binding SummaryScopeText}" Margin="0,2,0,0" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SummaryCapabilitiesText}" Margin="0,2,0,0" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SummaryCredentialText}" Margin="0,2,0,0" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SummaryPresetText}" Margin="0,2,0,0" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SummaryCertificationText}" Margin="0,2,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Progress" FontWeight="SemiBold" Foreground="{StaticResource ConsoleTextPrimaryBrush}" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Margin="0,4"><Ellipse Width="10" Height="10" Fill="{Binding Step1Fill}" Margin="0,0,8,0" /><TextBlock Text="Choose relationship" /></StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4"><Ellipse Width="10" Height="10" Fill="{Binding Step2Fill}" Margin="0,0,8,0" /><TextBlock Text="Set credentials and scope" /></StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4"><Ellipse Width="10" Height="10" Fill="{Binding Step3Fill}" Margin="0,0,8,0" /><TextBlock Text="Assign capabilities and policy" /></StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4"><Ellipse Width="10" Height="10" Fill="{Binding Step4Fill}" Margin="0,0,8,0" /><TextBlock Text="Save, preview, and certify" /></StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
