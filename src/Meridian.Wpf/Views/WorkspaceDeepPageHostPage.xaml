<Page x:Class="Meridian.Wpf.Views.WorkspaceDeepPageHostPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:views="clr-namespace:Meridian.Wpf.Views"
      mc:Ignorable="d"
      d:DesignHeight="900"
      d:DesignWidth="1400"
      Background="{DynamicResource ConsoleBackgroundDarkBrush}"
      Loaded="OnPageLoaded"
      Unloaded="OnPageUnloaded"
      AutomationProperties.Name="Workspace Deep Page Host"
      AutomationProperties.AutomationId="WorkspaceDeepPageHostPage">

    <Page.Resources>
        <Style x:Key="MetaBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ConsoleBackgroundLightBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,6,6" />
        </Style>

        <Style x:Key="MetaBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
        </Style>
    </Page.Resources>

    <Grid Margin="18,12,18,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <views:WorkspaceShellContextStripControl x:Name="ContextStrip"
                                                 Grid.Row="0"
                                                 Margin="0,0,0,10"
                                                 Visibility="Collapsed" />

        <views:WorkspaceCommandBarControl x:Name="CommandBar"
                                          Grid.Row="1"
                                          Margin="0,0,0,8"
                                          IsCompactSurface="True"
                                          Visibility="Collapsed"
                                          CommandInvoked="OnCommandBarCommandInvoked" />

        <Border x:Name="SummaryCard"
                Grid.Row="2"
                Style="{StaticResource SectionCardStyle}"
                Padding="14"
                Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Width="36"
                                Height="36"
                                CornerRadius="12"
                                Background="{StaticResource ConsoleAccentBlueAlpha10Brush}"
                                BorderBrush="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                BorderThickness="1">
                            <TextBlock x:Name="PageGlyphText"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="19"
                                       Foreground="{StaticResource InfoColorBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Text="&#xE8A5;" />
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Margin="12,0,0,0">
                            <TextBlock x:Name="PageTitleText"
                                       Style="{StaticResource PageTitleStyle}"
                                       TextWrapping="Wrap"
                                       AutomationProperties.AutomationId="WorkspaceDeepPageHostTitle"
                                       Text="Workflow" />
                            <TextBlock x:Name="PageSubtitleText"
                                       Margin="0,4,0,0"
                                       Style="{StaticResource CardDescriptionStyle}"
                                       TextWrapping="Wrap"
                                       Text="Shared workspace shell host" />
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="ShellHintText"
                               Margin="0,14,0,0"
                               Visibility="Collapsed"
                               FontSize="12"
                               Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Text="This workflow is being hosted inside the shared workstation shell so context and related routes stay nearby." />
                </StackPanel>

                <WrapPanel Grid.Row="1"
                           Margin="48,8,0,0"
                           VerticalAlignment="Top"
                           HorizontalAlignment="Left">
                    <Border Style="{StaticResource MetaBadgeStyle}">
                        <TextBlock x:Name="WorkspaceBadgeText"
                                   Style="{StaticResource MetaBadgeTextStyle}"
                                   Text="Workspace" />
                    </Border>
                    <Border Style="{StaticResource MetaBadgeStyle}">
                        <TextBlock x:Name="SectionBadgeText"
                                   Style="{StaticResource MetaBadgeTextStyle}"
                                   Text="Section" />
                    </Border>
                    <Border Style="{StaticResource MetaBadgeStyle}">
                        <TextBlock x:Name="ReachabilityBadgeText"
                                   Style="{StaticResource MetaBadgeTextStyle}"
                                   Text="Reachability" />
                    </Border>
                    <Border Style="{StaticResource MetaBadgeStyle}">
                        <TextBlock x:Name="RelatedBadgeText"
                                   Style="{StaticResource MetaBadgeTextStyle}"
                                   Text="Related" />
                    </Border>
                    <Border x:Name="SelectionBadge"
                            Style="{StaticResource MetaBadgeStyle}"
                            Visibility="Collapsed">
                        <TextBlock x:Name="SelectionBadgeText"
                                   Style="{StaticResource MetaBadgeTextStyle}"
                                   Text="Selection" />
                    </Border>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="{StaticResource ConsoleBackgroundDarkBrush}"
                BorderBrush="{StaticResource ConsoleBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                SnapsToDevicePixels="True">
            <Frame x:Name="HostedFrame"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent"
                   AutomationProperties.Name="Hosted Workflow Frame"
                   AutomationProperties.AutomationId="WorkspaceDeepPageHostFrame" />
        </Border>
    </Grid>
</Page>
