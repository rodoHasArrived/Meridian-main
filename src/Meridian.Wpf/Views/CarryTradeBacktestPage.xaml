<Page x:Class="Meridian.Wpf.Views.CarryTradeBacktestPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Carry Trade Backtest"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      AutomationProperties.Name="CarryTradeBacktest">

    <Page.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextMutedBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,2,0,4" />
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InfoColorBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="ChipButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="FontSize" Value="11" />
        </Style>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Carry Trade Backtest"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                    <TextBlock Text="Select securities, configure carry parameters, and assess strategy viability."
                               Style="{StaticResource LabelStyle}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Padding="12,8" Margin="0,0,8,0" MinWidth="90"
                            Command="{Binding RunBacktestCommand}"
                            Content="Run Backtest" />
                    <Button Padding="12,8" MinWidth="80"
                            Command="{Binding CancelBacktestCommand}"
                            Content="Cancel" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main 3-column layout -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="200" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="260" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: Security selector + carry parameters -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Security selection -->
                    <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="SECURITIES" Style="{StaticResource SectionHeaderStyle}" />

                            <!-- Add symbol row -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding NewSymbol, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="Ticker…">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Return" Command="{Binding AddSymbolCommand}" />
                                    </TextBox.InputBindings>
                                </TextBox>
                                <Button Grid.Column="2" Content="Add"
                                        Padding="10,6"
                                        Command="{Binding AddSymbolCommand}" />
                            </Grid>

                            <!-- Preset buttons -->
                            <TextBlock Text="Presets:" Style="{StaticResource LabelStyle}" />
                            <WrapPanel Margin="0,0,0,8">
                                <Button Style="{StaticResource ChipButtonStyle}"
                                        Content="FAANG" Command="{Binding AddPresetFaangCommand}" />
                                <Button Style="{StaticResource ChipButtonStyle}"
                                        Content="Mag-7" Command="{Binding AddPresetMagnificentSevenCommand}" />
                                <Button Style="{StaticResource ChipButtonStyle}"
                                        Content="ETFs" Command="{Binding AddPresetEtfsCommand}" />
                                <Button Style="{StaticResource ChipButtonStyle}"
                                        Content="Div ETFs" Command="{Binding AddPresetDividendEtfsCommand}"
                                        ToolTip="High-yield dividend ETFs (VYM, SCHD, HDV, DVY, JEPI)" />
                                <Button Style="{StaticResource ChipButtonStyle}"
                                        Content="Bond Carry" Command="{Binding AddPresetBondCarryCommand}"
                                        ToolTip="Bond carry pairs (TLT, HYG, LQD, EMB, SHY)" />
                                <Button Style="{StaticResource ChipButtonStyle}"
                                        Content="Clear" Command="{Binding ClearSymbolsCommand}" />
                            </WrapPanel>

                            <!-- Symbol chips list -->
                            <ItemsControl ItemsSource="{Binding SelectedSymbols}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4"
                                                Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                                Margin="0,0,4,4" Padding="6,3">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                                           VerticalAlignment="Center" />
                                                <Button Content="×"
                                                        FontSize="11"
                                                        Padding="4,0" Margin="4,0,0,0"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Command="{Binding DataContext.RemoveSymbolCommand,
                                                            RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Date / cash parameters -->
                    <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="BACKTEST PARAMETERS" Style="{StaticResource SectionHeaderStyle}" />

                            <TextBlock Text="From" Style="{StaticResource LabelStyle}" />
                            <DatePicker SelectedDate="{Binding FromDate}" Margin="0,0,0,8" />

                            <TextBlock Text="To" Style="{StaticResource LabelStyle}" />
                            <DatePicker SelectedDate="{Binding ToDate}" Margin="0,0,0,8" />

                            <TextBlock Text="Initial Capital ($)" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding InitialCash}" Margin="0,0,0,8" />

                            <TextBlock Text="Data Root" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding DataRoot}" Margin="0,0,0,8" />

                            <TextBlock Text="Rebalance Frequency (days)" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding RebalanceFrequencyDays}" Margin="0,0,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Yield carry mode -->
                    <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="YIELD CARRY MODE" Style="{StaticResource SectionHeaderStyle}" />

                            <TextBlock Text="Carry Signal Mode" Style="{StaticResource LabelStyle}" />
                            <ComboBox ItemsSource="{Binding YieldCarryModes}"
                                      SelectedItem="{Binding YieldCarryMode}"
                                      Margin="0,0,0,4" />
                            <!-- Mode descriptions -->
                            <TextBlock FontSize="10" Opacity="0.65" TextWrapping="Wrap"
                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                       Margin="0,0,0,8">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"
                                                Value="Classic carry: price-momentum + assumed yield." />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding YieldCarryMode}"
                                                         Value="YieldSpread">
                                                <Setter Property="Text"
                                                        Value="Yield spread: long assets where yield − risk-free rate ≥ threshold." />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding YieldCarryMode}"
                                                         Value="YieldRotation">
                                                <Setter Property="Text"
                                                        Value="Yield rotation: rotate into top-50 % yielders; tilt when yield rises above 20-day MA." />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Text="Min Yield Spread (decimal, e.g. 0.005 = 50 bps)"
                                       Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding MinYieldSpread}" Margin="0,0,0,8"
                                     ToolTip="Assets with (assetYield − riskFreeRate) below this value are excluded in YieldSpread mode." />

                            <TextBlock Text="Risk-Free Rate" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding RiskFreeRate}" Margin="0,0,0,0"
                                     ToolTip="Annual risk-free rate used to compute yield spread (e.g. 0.04 for 4 %)." />
                        </StackPanel>
                    </Border>

                    <!-- Per-symbol yield overrides -->
                    <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="YIELD OVERRIDES" Style="{StaticResource SectionHeaderStyle}" />
                            <TextBlock FontSize="10" Opacity="0.65" TextWrapping="Wrap"
                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                       Margin="0,0,0,8"
                                       Text="Optional: enter known annual yields (dividend yield, bond coupon, FX carry). Leave blank to estimate from price history." />

                            <!-- Add override row -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding NewYieldSymbol, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="TICKER" Padding="8,6" />
                                <TextBox Grid.Column="2" Text="{Binding NewYieldValue, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="0.035" Padding="8,6"
                                         ToolTip="Annual yield as decimal (e.g. 0.035 = 3.5 %)" />
                                <Button Grid.Column="4" Content="Add"
                                        Padding="10,6"
                                        Command="{Binding AddYieldOverrideCommand}" />
                            </Grid>

                            <!-- Yield table -->
                            <ItemsControl ItemsSource="{Binding SymbolYields}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Symbol}"
                                                       FontWeight="SemiBold" FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding YieldDisplay}"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource ConsoleAccentGreenBrush}" />
                                            <Button Grid.Column="2"
                                                    Content="×" FontSize="11" Padding="4,0"
                                                    Background="Transparent" BorderThickness="0"
                                                    Command="{Binding DataContext.RemoveYieldOverrideCommand,
                                                        RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Carry optimisation parameters -->
                    <Border Style="{StaticResource SectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="OPTIMISATION PARAMETERS" Style="{StaticResource SectionHeaderStyle}" />

                            <TextBlock Text="Optimisation Method" Style="{StaticResource LabelStyle}" />
                            <ComboBox ItemsSource="{Binding OptimizationMethods}"
                                      SelectedItem="{Binding OptimizationMethod}"
                                      Margin="0,0,0,8" />

                            <TextBlock Text="Risk Aversion (λ)" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding RiskAversion}" Margin="0,0,0,8" />

                            <TextBlock Text="Max Single Position" Style="{StaticResource LabelStyle}" />
                            <TextBox Text="{Binding MaxSinglePosition}" Margin="0,0,0,8" />

                            <CheckBox IsChecked="{Binding UseTargetVolatility}"
                                      Content="Use Target Volatility"
                                      Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                      Margin="0,0,0,4" />
                            <TextBox Text="{Binding TargetVolatility}"
                                     IsEnabled="{Binding UseTargetVolatility}"
                                     Margin="0,0,0,0" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- CENTRE: equity curve + progress -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" MinHeight="200" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Status + progress -->
                <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                   FontSize="12" Margin="0,0,0,6" />
                        <ProgressBar Height="6" Minimum="0" Maximum="1"
                                     Value="{Binding ProgressFraction}"
                                     Foreground="{StaticResource ConsoleAccentBlueAlpha80Brush}"
                                     Background="{StaticResource ConsoleWindowBackgroundBrush}" />
                    </StackPanel>
                </Border>

                <!-- Equity curve canvas -->
                <Border Grid.Row="2" Style="{StaticResource SectionCardStyle}">
                    <Grid>
                        <TextBlock Text="Equity Curve"
                                   Style="{StaticResource LabelStyle}"
                                   VerticalAlignment="Top" HorizontalAlignment="Left" />
                        <Canvas x:Name="EquityCanvas" Margin="0,20,0,0">
                            <Polyline x:Name="EquityPolyline"
                                      Stroke="{StaticResource ConsoleAccentBlueAlpha80Brush}"
                                      StrokeThickness="2"
                                      StrokeLineJoin="Round" />
                        </Canvas>
                    </Grid>
                </Border>

                <!-- Attribution table -->
                <Border Grid.Row="4" Style="{StaticResource SectionCardStyle}" MaxHeight="200">
                    <DataGrid ItemsSource="{Binding Attribution}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              ColumnHeaderHeight="28"
                              RowHeight="22"
                              BorderThickness="0"
                              Background="{StaticResource ShellWindowBackgroundBrush}"
                              Foreground="{StaticResource ConsoleTextPrimaryBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="80" />
                            <DataGridTextColumn Header="Net P&amp;L" Binding="{Binding NetPnl}" Width="90" />
                            <DataGridTextColumn Header="Return" Binding="{Binding TotalReturn}" Width="80" />
                            <DataGridTextColumn Header="Trades" Binding="{Binding TotalTrades}" Width="60" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- RIGHT: metrics + viability assessment -->
            <ScrollViewer Grid.Column="4" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Viability assessment badge -->
                    <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="VIABILITY ASSESSMENT" Style="{StaticResource SectionHeaderStyle}" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border CornerRadius="8"
                                        Width="56" Height="56"
                                        Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource ShellWindowBackgroundColor}" />
                                    </Border.Background>
                                    <TextBlock x:Name="GradeTextBlock"
                                               Text="{Binding ViabilityGrade}"
                                               FontSize="28" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Score" Style="{StaticResource LabelStyle}" />
                                    <TextBlock Text="{Binding ViabilityScore}" Style="{StaticResource ValueStyle}" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="{Binding ViabilitySummary}"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                       FontSize="12"
                                       LineHeight="18" />
                        </StackPanel>
                    </Border>

                    <!-- Performance metrics -->
                    <Border Style="{StaticResource SectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="PERFORMANCE METRICS" Style="{StaticResource SectionHeaderStyle}" />

                            <TextBlock Text="Total Return" Style="{StaticResource LabelStyle}" />
                            <TextBlock Text="{Binding TotalReturn}" Style="{StaticResource ValueStyle}" />

                            <TextBlock Text="Annualised Return" Style="{StaticResource LabelStyle}" />
                            <TextBlock Text="{Binding AnnualisedReturn}" Style="{StaticResource ValueStyle}" />

                            <TextBlock Text="Sharpe Ratio" Style="{StaticResource LabelStyle}" />
                            <TextBlock Text="{Binding SharpeRatio}" Style="{StaticResource ValueStyle}" />

                            <TextBlock Text="Sortino Ratio" Style="{StaticResource LabelStyle}" />
                            <TextBlock Text="{Binding SortinoRatio}" Style="{StaticResource ValueStyle}" />

                            <TextBlock Text="Calmar Ratio" Style="{StaticResource LabelStyle}" />
                            <TextBlock Text="{Binding CalmarRatio}" Style="{StaticResource ValueStyle}" />

                            <TextBlock Text="Max Drawdown" Style="{StaticResource LabelStyle}" />
                            <TextBlock Text="{Binding MaxDrawdown}" Style="{StaticResource ValueStyle}" />

                            <TextBlock Text="Win Rate" Style="{StaticResource LabelStyle}" />
                            <TextBlock Text="{Binding WinRate}" Style="{StaticResource ValueStyle}" />

                            <TextBlock Text="Total Trades" Style="{StaticResource LabelStyle}" />
                            <TextBlock Text="{Binding TotalTrades}" Style="{StaticResource ValueStyle}" />

                            <TextBlock Text="Net P&amp;L" Style="{StaticResource LabelStyle}" />
                            <TextBlock Text="{Binding NetPnl}" Style="{StaticResource ValueStyle}" />

                            <TextBlock Text="Commissions" Style="{StaticResource LabelStyle}" />
                            <TextBlock Text="{Binding TotalCommissions}" Style="{StaticResource ValueStyle}" />

                            <TextBlock Text="XIRR" Style="{StaticResource LabelStyle}" />
                            <TextBlock Text="{Binding Xirr}" Style="{StaticResource ValueStyle}" />

                            <TextBlock Text="Events Processed" Style="{StaticResource LabelStyle}" />
                            <TextBlock Text="{Binding EventsProcessed}" Style="{StaticResource ValueStyle}" />

                            <TextBlock Text="Elapsed Time" Style="{StaticResource LabelStyle}" />
                            <TextBlock Text="{Binding ElapsedTime}" Style="{StaticResource ValueStyle}" />

                            <Separator Margin="0,4,0,8" />

                            <StackPanel Orientation="Horizontal">
                                <Button Content="View Runs" Padding="10,6" Margin="0,0,6,0"
                                        Command="{Binding OpenRunBrowserCommand}" />
                                <Button Content="Run Detail" Padding="10,6"
                                        Command="{Binding OpenRunDetailCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
