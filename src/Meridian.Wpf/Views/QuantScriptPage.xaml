<Page x:Class="Meridian.Wpf.Views.QuantScriptPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
      xmlns:behaviors="clr-namespace:Meridian.Wpf.Behaviors"
      xmlns:models="clr-namespace:Meridian.Wpf.Models"
      xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
      Loaded="OnPageLoaded"
      Unloaded="OnPageUnloaded">

  <Page.Resources>
    <BooleanToVisibilityConverter x:Key="BoolVis" />

    <behaviors:ParameterTemplateSelector x:Key="ParamSelector">
      <behaviors:ParameterTemplateSelector.NumericTemplate>
        <DataTemplate DataType="{x:Type models:ParameterViewModel}">
          <DockPanel Margin="0,3">
            <TextBlock DockPanel.Dock="Left"
                       Width="100"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="#8FA3BF"
                       Text="{Binding Name}" />
            <TextBox Padding="6,4"
                     FontSize="11"
                     Background="#111B2D"
                     BorderBrush="#233044"
                     Foreground="#F5F7FA"
                     Text="{Binding RawValue, UpdateSourceTrigger=PropertyChanged}" />
          </DockPanel>
        </DataTemplate>
      </behaviors:ParameterTemplateSelector.NumericTemplate>
      <behaviors:ParameterTemplateSelector.TextTemplate>
        <DataTemplate DataType="{x:Type models:ParameterViewModel}">
          <DockPanel Margin="0,3">
            <TextBlock DockPanel.Dock="Left"
                       Width="100"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="#8FA3BF"
                       Text="{Binding Name}" />
            <TextBox Padding="6,4"
                     FontSize="11"
                     Background="#111B2D"
                     BorderBrush="#233044"
                     Foreground="#F5F7FA"
                     Text="{Binding RawValue, UpdateSourceTrigger=PropertyChanged}" />
          </DockPanel>
        </DataTemplate>
      </behaviors:ParameterTemplateSelector.TextTemplate>
      <behaviors:ParameterTemplateSelector.BoolTemplate>
        <DataTemplate DataType="{x:Type models:ParameterViewModel}">
          <DockPanel Margin="0,3">
            <TextBlock DockPanel.Dock="Left"
                       Width="100"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="#8FA3BF"
                       Text="{Binding Name}" />
            <CheckBox VerticalAlignment="Center"
                      IsChecked="{Binding RawValue}" />
          </DockPanel>
        </DataTemplate>
      </behaviors:ParameterTemplateSelector.BoolTemplate>
    </behaviors:ParameterTemplateSelector>

    <Style x:Key="CellCardStyle" TargetType="Border">
      <Setter Property="Background" Value="#101826" />
      <Setter Property="BorderBrush" Value="#233044" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="10" />
      <Setter Property="Margin" Value="0,0,0,12" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsSelected}" Value="True">
          <Setter Property="BorderBrush" Value="#4C8DFF" />
          <Setter Property="BorderThickness" Value="2" />
        </DataTrigger>
      </Style.Triggers>
    </Style>
  </Page.Resources>

  <Grid Background="#0B1220">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Padding="10,8"
            Background="#111B2D"
            BorderBrush="#233044"
            BorderThickness="0,0,0,1">
      <DockPanel LastChildFill="False">
        <TextBlock DockPanel.Dock="Left"
                   Margin="0,0,12,0"
                   VerticalAlignment="Center"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#F5F7FA"
                   Text="QuantScript Notebook" />

        <TextBox DockPanel.Dock="Left"
                 Width="240"
                 Margin="0,0,12,0"
                 VerticalAlignment="Center"
                 Padding="8,4"
                 Background="#0E1727"
                 BorderBrush="#233044"
                 Foreground="#F5F7FA"
                 Text="{Binding NotebookTitle, UpdateSourceTrigger=PropertyChanged}" />

        <Button DockPanel.Dock="Left"
                Margin="0,0,6,0"
                Command="{Binding RunAllCommand}"
                Content="Run All" />
        <Button DockPanel.Dock="Left"
                Margin="0,0,6,0"
                Command="{Binding StopCommand}"
                Content="Stop" />
        <Button DockPanel.Dock="Left"
                Margin="0,0,6,0"
                Command="{Binding NewNotebookCommand}"
                Content="New Notebook" />
        <Button DockPanel.Dock="Left"
                Margin="0,0,6,0"
                Command="{Binding SaveNotebookCommand}"
                Content="Save" />
        <Button DockPanel.Dock="Left"
                Margin="0,0,6,0"
                Command="{Binding RefreshDocumentsCommand}"
                Content="Refresh" />
        <Button DockPanel.Dock="Left"
                Command="{Binding ClearConsoleCommand}"
                Content="Clear Console" />

        <ProgressBar DockPanel.Dock="Right"
                     Width="120"
                     Height="8"
                     Margin="10,0,0,0"
                     VerticalAlignment="Center"
                     IsIndeterminate="{Binding IsRunning}"
                     Maximum="1"
                     Minimum="0"
                     Value="{Binding ProgressFraction, Mode=OneWay}" />
        <TextBlock DockPanel.Dock="Right"
                   Margin="10,0,0,0"
                   VerticalAlignment="Center"
                   Foreground="#8FA3BF"
                   Text="{Binding MemoryText}" />
        <TextBlock DockPanel.Dock="Right"
                   Margin="10,0,0,0"
                   VerticalAlignment="Center"
                   Foreground="#8FA3BF"
                   Text="{Binding ElapsedText}" />
        <TextBlock DockPanel.Dock="Right"
                   Margin="10,0,0,0"
                   VerticalAlignment="Center"
                   Foreground="#D7E3F4"
                   Text="{Binding StatusText}" />
      </DockPanel>
    </Border>

    <Grid Grid.Row="1">
      <Grid.RowDefinitions>
        <RowDefinition x:Name="ChartRow"
                       Height="300*"
                       MinHeight="120" />
        <RowDefinition Height="5" />
        <RowDefinition x:Name="EditorRow"
                       Height="280*"
                       MinHeight="200" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0"
              Margin="8,8,8,0"
              Padding="12"
              Background="#101826"
              BorderBrush="#233044"
              BorderThickness="1"
              CornerRadius="8">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="#F5F7FA"
                     Text="{Binding PrimaryChartTitle}" />

          <Grid Grid.Row="1"
                Margin="0,10,0,0">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{Binding HasNoChart, Converter={StaticResource BoolVis}}">
              <TextBlock HorizontalAlignment="Center"
                         FontSize="28"
                         Foreground="#506580"
                         Text="Chart" />
              <TextBlock Margin="0,8,0,0"
                         HorizontalAlignment="Center"
                         FontSize="12"
                         Foreground="#8FA3BF"
                         Text="Run notebook cells to populate the primary chart preview." />
            </StackPanel>

            <scottplot:WpfPlot behaviors:PlotRenderBehavior.Request="{Binding PrimaryChartRequest}"
                               Visibility="{Binding HasChart, Converter={StaticResource BoolVis}}" />
          </Grid>

          <Border Grid.Row="2"
                  Margin="0,10,0,0"
                  Padding="0,8,0,0"
                  BorderBrush="#233044"
                  BorderThickness="0,1,0,0"
                  Visibility="{Binding HasLegend, Converter={StaticResource BoolVis}}">
            <ItemsControl ItemsSource="{Binding LegendEntries}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type models:ChartLegendEntry}">
                  <StackPanel Margin="0,0,16,0"
                              Orientation="Horizontal">
                    <Rectangle Width="12"
                               Height="12"
                               Margin="0,0,6,0"
                               VerticalAlignment="Center"
                               Fill="{Binding SeriesColorBrush}" />
                    <TextBlock VerticalAlignment="Center"
                               Foreground="#D7E3F4"
                               Text="{Binding Label}" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>
        </Grid>
      </Border>

      <GridSplitter Grid.Row="1"
                    Margin="8,0"
                    Background="#233044"
                    ResizeDirection="Rows"
                    HorizontalAlignment="Stretch" />

      <Grid Grid.Row="2"
            Margin="8,8,8,8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="260" />
          <ColumnDefinition Width="6" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="6" />
          <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="10"
                Background="#101826"
                BorderBrush="#233044"
                BorderThickness="1"
                CornerRadius="8">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="220" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Margin="0,0,0,6"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#E7EEF8"
                       Text="Documents" />

            <ListBox Grid.Row="1"
                     Background="#0E1727"
                     BorderBrush="#233044"
                     Foreground="#F5F7FA"
                     ItemsSource="{Binding Documents}"
                     SelectedItem="{Binding SelectedDocument}">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:QuantScriptDocumentEntry}">
                  <StackPanel Margin="0,3">
                    <TextBlock Foreground="#F5F7FA"
                               Text="{Binding Name}" />
                    <TextBlock FontSize="11"
                               Foreground="#8FA3BF"
                               Text="{Binding Kind}" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Grid.Row="2"
                       Margin="0,10,0,6"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#E7EEF8"
                       Text="Parameters" />

            <DockPanel Grid.Row="3">
              <TextBlock DockPanel.Dock="Top"
                         Margin="0,0,0,8"
                         Foreground="#F6C460"
                         Text="{Binding DocumentWarningText}"
                         TextWrapping="Wrap" />
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Parameters}"
                              ItemTemplateSelector="{StaticResource ParamSelector}" />
              </ScrollViewer>
            </DockPanel>
          </Grid>
        </Border>

        <GridSplitter Grid.Column="1"
                      Background="#233044"
                      HorizontalAlignment="Stretch"
                      ResizeDirection="Columns" />

        <Border Grid.Column="2"
                Padding="10"
                Background="#101826"
                BorderBrush="#233044"
                BorderThickness="1"
                CornerRadius="8">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Cells}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type models:QuantScriptCellViewModel}">
                  <Border Style="{StaticResource CellCardStyle}">
                    <StackPanel>
                      <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left"
                                    Orientation="Horizontal">
                          <TextBlock Margin="0,0,10,0"
                                     FontWeight="SemiBold"
                                     Foreground="#F5F7FA"
                                     Text="{Binding StatusText}" />
                          <TextBlock Foreground="#8FA3BF"
                                     Text="{Binding ElapsedTime, StringFormat={}{0:g}}" />
                        </StackPanel>

                        <Button Margin="0,0,6,0"
                                Command="{Binding DataContext.RunCellCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                CommandParameter="{Binding}"
                                Content="Run" />
                        <Button Margin="0,0,6,0"
                                Command="{Binding DataContext.AddCellBelowCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                CommandParameter="{Binding}"
                                Content="+ Cell" />
                        <Button Command="{Binding DataContext.DeleteCellCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                CommandParameter="{Binding}"
                                Content="Delete" />
                      </DockPanel>

                      <avalonEdit:TextEditor Margin="0,10,0,0"
                                             Background="#09111F"
                                             FontFamily="Cascadia Code, Consolas, Courier New"
                                             FontSize="13"
                                             Foreground="#F5F7FA"
                                             GotKeyboardFocus="OnCellEditorGotKeyboardFocus"
                                             Loaded="OnCellEditorLoaded"
                                             ShowLineNumbers="True"
                                             SyntaxHighlighting="C#"
                                             Unloaded="OnCellEditorUnloaded"
                                             WordWrap="False"
                                             behaviors:AvalonEditNotebookBehavior.CommandParameter="{Binding}"
                                             behaviors:AvalonEditNotebookBehavior.RunAndAdvanceCommand="{Binding DataContext.RunCellAndAdvanceCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                             behaviors:AvalonEditNotebookBehavior.RunCommand="{Binding DataContext.RunCellCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                             behaviors:AvalonEditNotebookBehavior.Text="{Binding SourceCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                      <Border Margin="0,10,0,0"
                              Padding="8"
                              Background="#0E1727"
                              BorderBrush="#1D2A3F"
                              BorderThickness="1"
                              CornerRadius="6">
                        <StackPanel>
                          <TextBlock Foreground="#D7E3F4"
                                     Text="{Binding OutputText}"
                                     TextWrapping="Wrap" />
                          <TextBlock Margin="0,8,0,0"
                                     Foreground="#FF8A8A"
                                     Text="{Binding RuntimeError}"
                                     TextWrapping="Wrap" />

                          <ItemsControl Margin="0,8,0,0"
                                        ItemsSource="{Binding OutputPlots}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate DataType="{x:Type models:CellPlotViewModel}">
                                <StackPanel Margin="0,0,0,8">
                                  <TextBlock Margin="0,0,0,4"
                                             FontWeight="SemiBold"
                                             Foreground="#F5F7FA"
                                             Text="{Binding Title}" />
                                  <scottplot:WpfPlot Height="220"
                                                     behaviors:PlotRenderBehavior.Request="{Binding Request}" />
                                </StackPanel>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>

                          <ItemsControl Margin="0,8,0,0"
                                        ItemsSource="{Binding OutputMetrics}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate DataType="{x:Type models:MetricEntry}">
                                <DockPanel Margin="0,2">
                                  <TextBlock Width="180"
                                             Foreground="#8FA3BF"
                                             Text="{Binding Label}" />
                                  <TextBlock Foreground="#F5F7FA"
                                             Text="{Binding Value}" />
                                </DockPanel>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <GridSplitter Grid.Column="3"
                      Background="#233044"
                      HorizontalAlignment="Stretch"
                      ResizeDirection="Columns" />

        <Border Grid.Column="4"
                Padding="10"
                Background="#101826"
                BorderBrush="#233044"
                BorderThickness="1"
                CornerRadius="8">
          <TabControl SelectedIndex="{Binding ActiveResultsTab}">
            <TabItem Header="{Binding ConsoleTabHeader}">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ConsoleOutput}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ConsoleEntry}">
                      <TextBlock FontFamily="Cascadia Code, Consolas"
                                 FontSize="11"
                                 Foreground="#D7E3F4"
                                 Text="{Binding Text}"
                                 TextWrapping="Wrap" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </TabItem>

            <TabItem Header="{Binding ChartsTabHeader}">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Charts}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:PlotViewModel}">
                      <StackPanel Margin="0,4,0,8">
                        <TextBlock Margin="4,0,0,2"
                                   FontWeight="SemiBold"
                                   Foreground="#F5F7FA"
                                   Text="{Binding Title}" />
                        <scottplot:WpfPlot Height="220"
                                           behaviors:PlotRenderBehavior.Request="{Binding Request}" />
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </TabItem>

            <TabItem Header="{Binding MetricsTabHeader}">
              <DataGrid AutoGenerateColumns="False"
                        GridLinesVisibility="None"
                        HeadersVisibility="Column"
                        IsReadOnly="True"
                        ItemsSource="{Binding Metrics}">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Metric"
                                      Binding="{Binding Label}"
                                      Width="180" />
                  <DataGridTextColumn Header="Value"
                                      Binding="{Binding Value}"
                                      Width="*" />
                </DataGrid.Columns>
              </DataGrid>
            </TabItem>

            <TabItem Header="{Binding DiagnosticsTabHeader}">
              <DataGrid AutoGenerateColumns="False"
                        GridLinesVisibility="None"
                        HeadersVisibility="Column"
                        IsReadOnly="True"
                        ItemsSource="{Binding Diagnostics}">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Key"
                                      Binding="{Binding Key}"
                                      Width="180" />
                  <DataGridTextColumn Header="Value"
                                      Binding="{Binding Value}"
                                      Width="*" />
                </DataGrid.Columns>
              </DataGrid>
            </TabItem>

            <TabItem Header="{Binding TradesTabHeader}">
              <DataGrid AutoGenerateColumns="False"
                        GridLinesVisibility="None"
                        HeadersVisibility="Column"
                        IsReadOnly="True"
                        ItemsSource="{Binding Trades}">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Filled At"
                                      Binding="{Binding FilledAt}"
                                      Width="140" />
                  <DataGridTextColumn Header="Symbol"
                                      Binding="{Binding Symbol}"
                                      Width="90" />
                  <DataGridTextColumn Header="Qty"
                                      Binding="{Binding FilledQuantity}"
                                      Width="90" />
                  <DataGridTextColumn Header="Price"
                                      Binding="{Binding FillPrice}"
                                      Width="100" />
                  <DataGridTextColumn Header="Commission"
                                      Binding="{Binding Commission}"
                                      Width="100" />
                  <DataGridTextColumn Header="Side"
                                      Binding="{Binding Side}"
                                      Width="80" />
                </DataGrid.Columns>
              </DataGrid>
            </TabItem>
          </TabControl>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Page>
