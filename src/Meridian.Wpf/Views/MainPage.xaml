<Page x:Class="Meridian.Wpf.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:views="clr-namespace:Meridian.Wpf.Views"
      mc:Ignorable="d"
      d:DesignHeight="900"
      d:DesignWidth="1400"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      Unloaded="OnPageUnloaded"
      AutomationProperties.Name="Main"
      AutomationProperties.AutomationId="MainPage">

    <Page.Resources>
        <!-- Marquee-inspired nav item: left-bar indicator on active, flat hover -->
        <Style x:Key="ShellNavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,1,0,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="{StaticResource NavItemForegroundBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid x:Name="ItemGrid" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!-- Left indicator bar: visible only when selected -->
                            <Rectangle x:Name="ActiveIndicator"
                                       Grid.Column="0"
                                       Fill="{StaticResource SidebarActiveIndicatorBrush}"
                                       Visibility="Collapsed" />
                            <Border x:Name="ItemContent"
                                    Grid.Column="1"
                                    Background="Transparent"
                                    Padding="12,9">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemContent" Property="Background" Value="{StaticResource SidebarHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource NavItemForegroundHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemContent" Property="Background" Value="{StaticResource SidebarActiveBrush}" />
                                <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible" />
                                <Setter Property="Foreground" Value="{StaticResource NavItemForegroundActiveBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShellNavIconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource SymbolThemeFontFamily}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Width" Value="18" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ShellNavLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MeridianBodyFontFamily}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="10,0,0,0" />
        </Style>

        <!-- Marquee: uppercase muted section labels — light text on dark sidebar -->
        <Style x:Key="ShellSectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MeridianBodyFontFamily}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource NavSectionLabelBrush}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Typography.Capitals" Value="AllSmallCaps" />
        </Style>

        <!-- Marquee-style workspace tiles on dark sidebar background -->
        <Style x:Key="WorkspaceTileStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SidebarTileBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SidebarBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource NavItemForegroundBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="MinHeight" Value="52" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template" Value="{StaticResource SidebarButtonTemplate}" />
        </Style>

        <Style x:Key="ActiveWorkspaceTileStyle" TargetType="Button" BasedOn="{StaticResource WorkspaceTileStyle}">
            <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SidebarActiveIndicatorBrush}" />
            <Setter Property="Foreground" Value="{StaticResource NavItemForegroundActiveBrush}" />
        </Style>

        <Style x:Key="RecentPageButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource SidebarBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource NavItemForegroundBrush}" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template" Value="{StaticResource SidebarButtonTemplate}" />
        </Style>

        <!-- Shared style for the sidebar footer action buttons -->
        <Style x:Key="FooterNavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource NavItemForegroundBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template" Value="{StaticResource SidebarButtonTemplate}" />
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>

    <Page.InputBindings>
        <KeyBinding Key="K" Modifiers="Control" Command="{Binding ShowCommandPaletteCommand}" />
    </Page.InputBindings>

    <Grid Background="{DynamicResource ShellWindowBackgroundBrush}">
        <TextBlock x:Name="ShellAutomationStateText"
                   Text="{Binding CurrentPageTag}"
                   Visibility="Collapsed"
                   AutomationProperties.AutomationId="ShellAutomationState"
                   AutomationProperties.Name="Shell Automation State" />

        <Grid x:Name="CommandPaletteOverlay"
              Visibility="{Binding CommandPaletteVisibility}"
              Panel.ZIndex="100"
              Background="#80000000"
              AutomationProperties.AutomationId="CommandPaletteOverlay"
              AutomationProperties.Name="Command Palette Overlay"
              MouseDown="CommandPaletteOverlay_MouseDown">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,80,0,0"
                    Width="620"
                    Background="{StaticResource SidebarBackgroundBrush}"
                    CornerRadius="3"
                    BorderBrush="{StaticResource SidebarBorderBrush}"
                    BorderThickness="1"
                    Padding="0"
                    MouseDown="CommandPaletteBorder_MouseDown">
                <StackPanel>
                    <TextBox x:Name="CommandPaletteTextBox"
                             Margin="16,16,16,6"
                             Padding="12,10"
                             FontSize="14"
                             Background="{StaticResource SidebarTileBrush}"
                             Foreground="{StaticResource NavItemForegroundHoverBrush}"
                             BorderBrush="{StaticResource SidebarBorderBrush}"
                             BorderThickness="1"
                             AutomationProperties.AutomationId="CommandPaletteInput"
                             AutomationProperties.Name="Command Palette Input"
                             Text="{Binding CommandPaletteQuery, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Escape" Command="{Binding HideCommandPaletteCommand}" />
                            <KeyBinding Key="Enter" Command="{Binding OpenSelectedCommandPalettePageCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                    <ListBox x:Name="CommandPaletteResults"
                             MaxHeight="360"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource ShellNavItemStyle}"
                             SelectionChanged="CommandPaletteResults_SelectionChanged"
                             ItemsSource="{Binding CommandPalettePages}"
                             SelectedItem="{Binding SelectedCommandPalettePage, Mode=TwoWay}"
                             AutomationProperties.AutomationId="CommandPaletteResults"
                             AutomationProperties.Name="Command Palette Results"
                             Margin="10,0,10,8" />
                    <TextBlock Text="Ctrl+K to open - Esc to close - Enter to open selection"
                               FontSize="11"
                               Opacity="0.7"
                               Foreground="{StaticResource NavSectionLabelBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14" />
                </StackPanel>
            </Border>
        </Grid>

        <DockPanel LastChildFill="True">
            <!-- ── Marquee-style dark top header bar ── -->
            <Border DockPanel.Dock="Top"
                    Height="44"
                    Background="{StaticResource TopBarBackgroundBrush}"
                    BorderBrush="{StaticResource TopBarBorderBrush}"
                    BorderThickness="0,0,0,1">
                <DockPanel Margin="16,0" LastChildFill="False">
                    <!-- Brand -->
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{StaticResource IconChart}"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="16"
                                   Foreground="{StaticResource TopBarIconAccentBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="Meridian"
                                   FontFamily="{StaticResource MeridianDisplayFontFamily}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TopBarTextBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Operator Workstation"
                                   FontFamily="{StaticResource MeridianBodyFontFamily}"
                                   FontSize="12"
                                   Foreground="#6B7280"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0" />
                    </StackPanel>
                    <!-- Mode badge + search icon -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource TopBarBorderBrush}"
                                CornerRadius="3"
                                Padding="8,3"
                                Margin="0,0,12,0">
                            <TextBlock Text="{Binding CurrentModeName}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#60A5FA" />
                        </Border>
                        <Button Style="{StaticResource IconButtonStyle}"
                                Click="OnOpenCommandPaletteClick"
                                ToolTip="Search (Ctrl+K)"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource TopBarTextBrush}"
                                Width="28" Height="28" Padding="4"
                                AutomationProperties.Name="Search">
                            <TextBlock Text="{StaticResource IconSearch}"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="14"
                                       Foreground="#9CA3AF" />
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ── Marquee-style dark navy sidebar ── -->
            <Border DockPanel.Dock="Left"
                    Width="220"
                    Background="{StaticResource SidebarBackgroundBrush}"
                    BorderBrush="{StaticResource SidebarBorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Compact workspace selector -->
                    <Border Grid.Row="0"
                            Padding="12,10"
                            BorderBrush="{StaticResource SidebarBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="Workspaces"
                                       Style="{StaticResource ShellSectionLabelStyle}"
                                       Margin="4,0,0,4"/>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button x:Name="ResearchWorkspaceButton"
                                        Grid.Row="0" Grid.Column="0"
                                        Command="{Binding SelectWorkspaceCommand}"
                                        CommandParameter="research"
                                        Margin="0,0,4,4">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource WorkspaceTileStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsResearchWorkspaceActive}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource SidebarActiveIndicatorBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="Foreground" Value="{StaticResource NavItemForegroundActiveBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel>
                                        <TextBlock Text="Research" FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="Runs · Charts"
                                                   Margin="0,2,0,0" FontSize="10"
                                                   Opacity="0.75" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button>

                                <Button x:Name="TradingWorkspaceButton"
                                        Grid.Row="0" Grid.Column="1"
                                        Command="{Binding SelectWorkspaceCommand}"
                                        CommandParameter="trading"
                                        Margin="4,0,0,4">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource WorkspaceTileStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTradingWorkspaceActive}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource SidebarActiveIndicatorBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="Foreground" Value="{StaticResource NavItemForegroundActiveBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel>
                                        <TextBlock Text="Trading" FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="Live · Orders"
                                                   Margin="0,2,0,0" FontSize="10"
                                                   Opacity="0.75" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button>

                                <Button x:Name="DataOperationsWorkspaceButton"
                                        Grid.Row="1" Grid.Column="0"
                                        Command="{Binding SelectWorkspaceCommand}"
                                        CommandParameter="data-operations"
                                        Margin="0,0,4,0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource WorkspaceTileStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDataOperationsWorkspaceActive}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource SidebarActiveIndicatorBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="Foreground" Value="{StaticResource NavItemForegroundActiveBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel>
                                        <TextBlock Text="Data Ops" FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="Providers · Storage"
                                                   Margin="0,2,0,0" FontSize="10"
                                                   Opacity="0.75" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button>

                                <Button x:Name="GovernanceWorkspaceButton"
                                        Grid.Row="1" Grid.Column="1"
                                        Command="{Binding SelectWorkspaceCommand}"
                                        CommandParameter="governance"
                                        Margin="4,0,0,0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource WorkspaceTileStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGovernanceWorkspaceActive}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource SidebarActiveIndicatorBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="Foreground" Value="{StaticResource NavItemForegroundActiveBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel>
                                        <TextBlock Text="Governance" FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="Quality · Policy"
                                                   Margin="0,2,0,0" FontSize="10"
                                                   Opacity="0.75" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Current workspace label -->
                    <Border Grid.Row="1"
                            Padding="16,8"
                            BorderBrush="{StaticResource SidebarBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="{Binding ActiveNavigationLabel}"
                                       Style="{StaticResource ShellSectionLabelStyle}" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,6,0,12">
                        <StackPanel>
                            <StackPanel Visibility="{Binding IsResearchWorkspaceActive, Converter={StaticResource BoolToVisibility}}">
                                <ListBox x:Name="ResearchNavList"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ItemContainerStyle="{StaticResource ShellNavItemStyle}"
                                         SelectedValuePath="Tag"
                                         SelectedValue="{Binding CurrentPageTag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.AutomationId="ResearchNavList"
                                         AutomationProperties.Name="Research Navigation">
                                    <ListBoxItem Tag="Dashboard"
                                                 AutomationProperties.AutomationId="ResearchNavDashboard"
                                                 AutomationProperties.Name="Dashboard Navigation">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconDashboard}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Dashboard" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="LiveData"
                                                 AutomationProperties.AutomationId="ResearchNavLiveData"
                                                 AutomationProperties.Name="Live Data Navigation">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconChart}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Live Data" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="Charts"
                                                 AutomationProperties.AutomationId="ResearchNavCharts"
                                                 AutomationProperties.Name="Charts Navigation">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconChartLine}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Charts" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="QuantScript"
                                                 AutomationProperties.AutomationId="ResearchNavQuantScript"
                                                 AutomationProperties.Name="QuantScript Navigation">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconCode}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="QuantScript" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="RunMat"
                                                 AutomationProperties.AutomationId="ResearchNavRunMat"
                                                 AutomationProperties.Name="RunMat Lab Navigation">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconCode}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="RunMat Lab" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="StrategyRuns"
                                                 AutomationProperties.AutomationId="ResearchNavStrategyRuns"
                                                 AutomationProperties.Name="Strategy Runs Navigation">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconList}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Strategy Runs" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="OrderBook"
                                                 AutomationProperties.AutomationId="ResearchNavOrderBook"
                                                 AutomationProperties.Name="Order Book Navigation">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconTable}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Order Book" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="Watchlist"
                                                 AutomationProperties.AutomationId="ResearchNavWatchlist"
                                                 AutomationProperties.Name="Watchlist Navigation">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconFavorite}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Watchlist" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                </ListBox>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsTradingWorkspaceActive, Converter={StaticResource BoolToVisibility}}">
                                <ListBox x:Name="TradingNavList"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ItemContainerStyle="{StaticResource ShellNavItemStyle}"
                                         SelectedValuePath="Tag"
                                         SelectedValue="{Binding CurrentPageTag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ListBoxItem Tag="Backtest">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconPlay}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Backtest" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="StrategyRuns">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconList}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Strategy Runs" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="LeanIntegration">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconCode}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Lean Engine" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="PortfolioImport">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconImport}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Portfolio Import" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="TradingHours">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconClock}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Trading Hours" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="PositionBlotter"
                                                 AutomationProperties.AutomationId="TradingNavPositionBlotter"
                                                 AutomationProperties.Name="Position Blotter Navigation">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconList}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Position Blotter" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="DirectLending"
                                                 AutomationProperties.AutomationId="TradingNavDirectLending">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconList}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Direct Lending" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                </ListBox>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsDataOperationsWorkspaceActive, Converter={StaticResource BoolToVisibility}}">
                                <ListBox x:Name="DataOpsNavList"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ItemContainerStyle="{StaticResource ShellNavItemStyle}"
                                         SelectedValuePath="Tag"
                                         SelectedValue="{Binding CurrentPageTag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ListBoxItem Tag="Provider">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconNetwork}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Provider" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="Symbols">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconList}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Symbols" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="Backfill">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconDownload}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Backfill" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="Storage">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconDatabase}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Storage" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="DataExport">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconExport}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Export" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="PackageManager">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconFolder}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Packages" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                </ListBox>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsGovernanceWorkspaceActive, Converter={StaticResource BoolToVisibility}}">
                                <ListBox x:Name="GovernanceNavList"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ItemContainerStyle="{StaticResource ShellNavItemStyle}"
                                         SelectedValuePath="Tag"
                                         SelectedValue="{Binding CurrentPageTag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ListBoxItem Tag="DataQuality">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconCheckmark}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Data Quality" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="ProviderHealth">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconNetwork}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Provider Health" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="SystemHealth">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconConnected}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="System Health" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="Diagnostics">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconTerminal}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Diagnostics" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="DashboardWeb"
                                                 AutomationProperties.AutomationId="NavDashboardWeb"
                                                 AutomationProperties.Name="Web Dashboard Navigation">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconGlobe}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Web Dashboard" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="Settings">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconSettings}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Settings" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="AdminMaintenance">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconLock}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Admin" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                </ListBox>
                            </StackPanel>

                            <Rectangle Style="{StaticResource HorizontalDividerStyle}" Margin="16,10,16,10" />

                            <TextBlock Text="Recent"
                                       Style="{StaticResource ShellSectionLabelStyle}"
                                       Margin="16,0,0,6" />
                            <ItemsControl ItemsSource="{Binding RecentPages}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Margin="12,0" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource RecentPageButtonStyle}"
                                                Command="{Binding DataContext.NavigateToPageCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding PageTag}"
                                                Content="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="RecentPagesEmptyText"
                                       Text="Navigate to any page to start building history."
                                       Visibility="{Binding RecentPagesEmptyVisibility}"
                                       Style="{StaticResource CardDescriptionStyle}"
                                       Margin="16,0,0,0" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Compact footer actions -->
                    <Border Grid.Row="3"
                            Padding="12,10"
                            BorderBrush="{StaticResource SidebarBorderBrush}"
                            BorderThickness="0,1,0,0">
                        <StackPanel>
                            <Button Style="{StaticResource FooterNavButtonStyle}"
                                    Click="OnOpenCommandPaletteClick"
                                    AutomationProperties.Name="Open Command Palette"
                                    ToolTip="Quick Command (Ctrl+K)">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{StaticResource IconSearch}"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Text="Command Palette"
                                               Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource FooterNavButtonStyle}"
                                    Margin="0,4,0,0"
                                    Command="{Binding OpenNotificationsCommand}"
                                    ToolTip="Notifications">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{StaticResource IconBell}"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Text="Notifications"
                                               Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource FooterNavButtonStyle}"
                                    Margin="0,4,0,0"
                                    Command="{Binding OpenHelpCommand}"
                                    AutomationProperties.Name="Help and Support">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{StaticResource IconHelp}"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Text="Help"
                                               Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="TickerStripToggleButton"
                                    Style="{StaticResource FooterNavButtonStyle}"
                                    Margin="0,4,0,0"
                                    Command="{Binding ToggleTickerStripCommand}"
                                    AutomationProperties.Name="Toggle Ticker Strip"
                                    ToolTip="Toggle live ticker strip">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4C8;" FontSize="11" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding TickerStripLabel}"
                                               Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border x:Name="FixtureModeBanner"
                        Grid.Row="0"
                        Margin="0"
                        Padding="16,10"
                        CornerRadius="0"
                        Visibility="{Binding FixtureModeBannerVisibility}"
                        Panel.ZIndex="10">
                    <Border.Background>
                        <LinearGradientBrush x:Name="FixtureModeBannerBrush" StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource ModeFixtureColor}" Offset="0" />
                            <GradientStop Color="#C98A2B" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#x26A0;"
                                       FontSize="14"
                                       Foreground="#1A1A2E"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <TextBlock x:Name="FixtureModeLabel"
                                       Text="{Binding FixtureModeBannerText}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#1A1A2E"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <Button x:Name="FixtureModeDismissButton"
                                Grid.Column="1"
                                Style="{StaticResource IconButtonStyle}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Command="{Binding DismissFixtureModeBannerCommand}"
                                ToolTip="Dismiss banner">
                            <TextBlock Text="&#x2715;"
                                       FontSize="12"
                                       Foreground="#1A1A2E" />
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{StaticResource ConsoleBackgroundLightBrush}"
                        BorderBrush="{StaticResource ConsoleBorderBrush}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="0"
                        Padding="24,16"
                        Margin="0,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="BackButton"
                                        Style="{StaticResource IconButtonStyle}"
                                        Visibility="{Binding BackButtonVisibility}"
                                        Command="{Binding GoBackCommand}"
                                        ToolTip="Go Back">
                                    <TextBlock Text="{StaticResource IconBack}"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="16" />
                                </Button>
                                <TextBlock Text="{Binding WorkspaceHeading}"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource ShellSectionLabelStyle}" />
                            </StackPanel>
                            <TextBlock Text="{Binding CurrentPageTitle}"
                                       Margin="0,6,0,0"
                                       FontFamily="{StaticResource MeridianDisplayFontFamily}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                       AutomationProperties.AutomationId="PageTitleText"
                                       AutomationProperties.Name="Current Page Title" />
                            <TextBlock x:Name="PageSubtitleText"
                                       Margin="0,8,0,0"
                                       Text="{Binding CurrentPageSubtitle}"
                                       Style="{StaticResource CardDescriptionStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top">
                            <WrapPanel HorizontalAlignment="Right" Margin="0,0,0,12">
                                <Border x:Name="ConnectionStatusBadge"
                                        Style="{StaticResource SuccessBadgeStyle}"
                                        Margin="0,0,10,10">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="ConnectionStatusDot"
                                                 Width="8"
                                                 Height="8"
                                                 Fill="{StaticResource SuccessColorBrush}"
                                                 Margin="0,0,6,0" />
                                        <TextBlock x:Name="ConnectionStatusText"
                                                   Text="Connected"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SuccessColorBrush}" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource NeutralBadgeStyle}" Margin="0,0,10,10">
                                    <TextBlock Text="{Binding WorkspaceSummary}"
                                               FontSize="12"
                                               Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                </Border>
                            </WrapPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource GhostButtonStyle}"
                                        ToolTip="Refresh (F5)"
                                        Command="{Binding RefreshPageCommand}"
                                        Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconRefresh}"
                                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                   FontSize="14"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="Refresh"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource GhostButtonStyle}"
                                        ToolTip="Notifications"
                                        Margin="0,0,8,0"
                                        Command="{Binding OpenNotificationsCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconBell}"
                                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                   FontSize="14"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="Alerts"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        ToolTip="Command Palette (Ctrl+K)"
                                        Click="OnOpenCommandPaletteClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconSearch}"
                                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                   FontSize="14"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="Command Palette"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <DockPanel Grid.Row="2">
                    <Border DockPanel.Dock="Top" Height="32"
                            Background="{StaticResource CommandBarBackground}"
                            BorderBrush="{StaticResource CommandBarBorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                            <TextBlock Text="Layout:" VerticalAlignment="Center" FontSize="11" Margin="0,0,8,0" Opacity="0.7"/>
                            <ItemsControl ItemsSource="{Binding SplitPane.Layouts}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.SplitPane.SelectLayoutCommand,
                                                        RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="{Binding Label}"
                                                Padding="6,2" Margin="0,0,2,0" FontSize="13"
                                                Content="{Binding Icon}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    <!-- ContentFrame kept collapsed; code-behind references this name for initial init -->
                    <Frame x:Name="ContentFrame"
                           Visibility="Collapsed"
                           NavigationUIVisibility="Hidden"
                           Background="Transparent"
                           AutomationProperties.AutomationId="ContentFrame"
                           AutomationProperties.Name="Main Content Frame"
                           Navigated="OnContentFrameNavigated" />
                    <views:SplitPaneHostControl x:Name="SplitPaneHost"
                                               Layout="{Binding SplitPane.SelectedLayout}"
                                               Loaded="OnSplitPaneHostLoaded" />
                </DockPanel>
            </Grid>
        </DockPanel>
    </Grid>
</Page>
