<Page x:Class="Meridian.Wpf.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="1400"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      AutomationProperties.Name="Main"
      AutomationProperties.AutomationId="MainPage">

    <Page.Resources>
        <!-- Navigation Item Style -->
        <Style x:Key="NavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="10,3" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource ConsoleBackgroundHoverBrush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource ConsoleAccentBlueAlpha10Brush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource InfoColorBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Navigation Icon Style -->
        <Style x:Key="NavIconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource SymbolThemeFontFamily}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Width" Value="22" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Navigation Label Style -->
        <Style x:Key="NavLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="10,0,0,0" />
        </Style>

        <!-- Section Header Style -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontFamily" Value="{StaticResource MeridianBodyFontFamily}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextMutedBrush}" />
            <Setter Property="Margin" Value="20,16,20,8" />
        </Style>
    </Page.Resources>

    <Page.InputBindings>
        <KeyBinding Key="K" Modifiers="Control" Command="{x:Null}" />
    </Page.InputBindings>

    <Grid Background="{DynamicResource ShellWindowBackgroundBrush}">
        <TextBlock x:Name="ShellAutomationStateText"
                   Visibility="Collapsed"
                   AutomationProperties.AutomationId="ShellAutomationState"
                   AutomationProperties.Name="Shell Automation State" />
        <!-- Command Palette Overlay -->
        <Grid x:Name="CommandPaletteOverlay" Visibility="Collapsed"
              Panel.ZIndex="100"
              Background="#80000000"
              AutomationProperties.AutomationId="CommandPaletteOverlay"
              AutomationProperties.Name="Command Palette Overlay"
              MouseDown="CommandPaletteOverlay_MouseDown">
            <Border HorizontalAlignment="Center" VerticalAlignment="Top"
                    Margin="0,80,0,0" Width="560"
                    Background="{StaticResource ConsoleBackgroundDarkBrush}"
                    CornerRadius="12"
                    BorderBrush="{StaticResource ConsoleBorderBrush}"
                    BorderThickness="1"
                    Padding="0"
                    MouseDown="CommandPaletteBorder_MouseDown">
                <StackPanel>
                    <TextBox x:Name="CommandPaletteTextBox"
                             Margin="12,12,12,4"
                             Padding="10,8"
                             FontSize="14"
                             Background="{StaticResource ConsoleBackgroundMediumBrush}"
                             Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                             BorderBrush="{StaticResource ConsoleBorderBrush}"
                             BorderThickness="1"
                             AutomationProperties.AutomationId="CommandPaletteInput"
                             AutomationProperties.Name="Command Palette Input"
                             TextChanged="CommandPaletteTextBox_TextChanged"
                             KeyDown="CommandPaletteTextBox_KeyDown" />
                    <ListBox x:Name="CommandPaletteResults"
                             MaxHeight="320"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource NavItemStyle}"
                             SelectionChanged="CommandPaletteResults_SelectionChanged"
                             AutomationProperties.AutomationId="CommandPaletteResults"
                             AutomationProperties.Name="Command Palette Results"
                             Margin="4,0,4,4" />
                    <TextBlock Text="Ctrl+K to open  ·  Esc to close  ·  Enter to select"
                               FontSize="11"
                               Opacity="0.4"
                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10" />
                </StackPanel>
            </Border>
        </Grid>

        <DockPanel>
            <!-- Sidebar Navigation -->
            <Border DockPanel.Dock="Left"
                    Width="288"
                    Margin="16"
                    CornerRadius="20"
                    Background="{StaticResource ShellRailBackgroundBrush}"
                    BorderBrush="{StaticResource ConsoleBorderBrush}"
                    BorderThickness="1">
                <DockPanel>
                    <!-- Header with Logo/Title -->
                    <Border DockPanel.Dock="Top"
                            Padding="22,22,22,18"
                            BorderBrush="{StaticResource ConsoleBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <!-- App Title -->
                            <StackPanel Orientation="Horizontal">
                                <Border Width="44"
                                        Height="44"
                                        CornerRadius="14"
                                        Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                        BorderBrush="{StaticResource InfoColorBrush}"
                                        BorderThickness="1">
                                    <TextBlock Text="{StaticResource IconChart}"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="22"
                                               Foreground="{StaticResource InfoColorBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="12,0,0,0">
                                    <TextBlock Text="Meridian"
                                               FontFamily="{StaticResource MeridianDisplayFontFamily}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                    <TextBlock Text="Operations Workstation"
                                               FontSize="12"
                                               Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="Research, data operations, and governance in one operator shell."
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource CardDescriptionStyle}" />

                            <!-- Version Badge -->
                            <Border Margin="0,10,0,0"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource NeutralBadgeStyle}">
                                <TextBlock Text="Institutional premium shell"
                                           FontSize="11"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           FontFamily="{StaticResource MeridianDataFontFamily}" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Footer with Help Link -->
                    <Border DockPanel.Dock="Bottom"
                            Padding="20,12"
                            BorderBrush="{StaticResource ConsoleBorderBrush}"
                            BorderThickness="0,1,0,0">
                        <StackPanel>
                            <Button Style="{StaticResource GhostButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Click="OnCommandPaletteButtonClick"
                                    AutomationProperties.AutomationId="OpenCommandPaletteButton"
                                    AutomationProperties.Name="Open Command Palette"
                                    ToolTip="Quick Command (Ctrl+K)">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="{StaticResource IconSearch}"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="14"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Ctrl+K"
                                               Margin="8,0,0,0"
                                               FontSize="12"
                                               Opacity="0.6"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource GhostButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Click="OnHelpButtonClick"
                                    AutomationProperties.AutomationId="HelpSupportButton"
                                    AutomationProperties.Name="Help and Support"
                                    Margin="0,4,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="{StaticResource IconHelp}"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="16"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Help &amp; Support"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Navigation Menu -->
                    <ScrollViewer DockPanel.Dock="Top"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,4,0,4">

                            <!-- ═══ RESEARCH Section ═══ -->
                            <TextBlock Text="RESEARCH" Style="{StaticResource SectionHeaderStyle}" />

                            <ListBox x:Name="ResearchNavList"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemContainerStyle="{StaticResource NavItemStyle}"
                                     AutomationProperties.AutomationId="ResearchNavList"
                                     AutomationProperties.Name="Research Navigation"
                                     SelectionChanged="OnResearchNavSelectionChanged">
                                <ListBoxItem Tag="Dashboard"
                                             AutomationProperties.AutomationId="ResearchNavDashboard"
                                             AutomationProperties.Name="Dashboard Navigation">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconDashboard}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Dashboard" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="LiveData"
                                             AutomationProperties.AutomationId="ResearchNavLiveData"
                                             AutomationProperties.Name="Live Data Navigation">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconChart}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Live Data" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="Charts"
                                             AutomationProperties.AutomationId="ResearchNavCharts"
                                             AutomationProperties.Name="Charts Navigation">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconChartLine}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Charts" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="RunMat"
                                             AutomationProperties.AutomationId="ResearchNavRunMat"
                                             AutomationProperties.Name="RunMat Lab Navigation">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconCode}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="RunMat Lab" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="StrategyRuns"
                                             AutomationProperties.AutomationId="ResearchNavStrategyRuns"
                                             AutomationProperties.Name="Strategy Runs Navigation">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconList}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Strategy Runs" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="OrderBook"
                                             AutomationProperties.AutomationId="ResearchNavOrderBook"
                                             AutomationProperties.Name="Order Book Navigation">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconTable}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Order Book" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="Watchlist"
                                             AutomationProperties.AutomationId="ResearchNavWatchlist"
                                             AutomationProperties.Name="Watchlist Navigation">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconFavorite}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Watchlist" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                            </ListBox>

                            <Rectangle Style="{StaticResource HorizontalDividerStyle}" Margin="20,6" />

                            <!-- ═══ TRADING Section ═══ -->
                            <TextBlock Text="TRADING" Style="{StaticResource SectionHeaderStyle}" />

                            <ListBox x:Name="TradingNavList"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemContainerStyle="{StaticResource NavItemStyle}"
                                     SelectionChanged="OnTradingNavSelectionChanged">
                                <ListBoxItem Tag="Backtest">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconPlay}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Backtest" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="StrategyRuns">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconList}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Strategy Runs" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="LeanIntegration">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconCode}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Lean Engine" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="PortfolioImport">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconImport}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Portfolio Import" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="TradingHours">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconClock}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Trading Hours" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                            </ListBox>

                            <Rectangle Style="{StaticResource HorizontalDividerStyle}" Margin="20,6" />

                            <!-- ═══ DATA OPS Section ═══ -->
                            <TextBlock Text="DATA OPS" Style="{StaticResource SectionHeaderStyle}" />

                            <ListBox x:Name="DataOpsNavList"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemContainerStyle="{StaticResource NavItemStyle}"
                                     SelectionChanged="OnDataOpsNavSelectionChanged">
                                <ListBoxItem Tag="Provider">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconNetwork}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Provider" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="Symbols">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconList}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Symbols" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="Backfill">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconDownload}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Backfill" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="Storage">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconDatabase}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Storage" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="DataExport">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconExport}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Export" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="PackageManager">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconFolder}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Packages" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                            </ListBox>

                            <Rectangle Style="{StaticResource HorizontalDividerStyle}" Margin="20,6" />

                            <!-- ═══ GOVERNANCE Section ═══ -->
                            <TextBlock Text="GOVERNANCE" Style="{StaticResource SectionHeaderStyle}" />

                            <ListBox x:Name="GovernanceNavList"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemContainerStyle="{StaticResource NavItemStyle}"
                                     SelectionChanged="OnGovernanceNavSelectionChanged">
                                <ListBoxItem Tag="DataQuality">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconCheckmark}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Data Quality" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="ProviderHealth">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconNetwork}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Provider Health" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="SystemHealth">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconConnected}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="System Health" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="Diagnostics">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconTerminal}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Diagnostics" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="Settings">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconSettings}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Settings" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="AdminMaintenance">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconLock}" Style="{StaticResource NavIconStyle}" />
                                        <TextBlock Text="Admin" Style="{StaticResource NavLabelStyle}" />
                                    </StackPanel>
                                </ListBoxItem>
                            </ListBox>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Main Content Area -->
            <Grid Margin="0,16,16,16">
                <!-- Fixture/Offline Mode Banner (P0: Hard visual distinction for sample/offline mode) -->
                <Border x:Name="FixtureModeBanner"
                        VerticalAlignment="Top"
                        Height="40"
                        Margin="0,0,0,8"
                        CornerRadius="14"
                        Visibility="Collapsed"
                        Panel.ZIndex="10">
                    <Border.Background>
                        <LinearGradientBrush x:Name="FixtureModeBannerBrush" StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource ModeFixtureColor}" Offset="0" />
                            <GradientStop Color="#C98A2B" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="&#x26A0;"
                                       FontSize="14"
                                       Foreground="#1A1A2E"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <TextBlock x:Name="FixtureModeLabel"
                                       Text="FIXTURE MODE — Showing sample data, not connected to live backend"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#1A1A2E"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <Button x:Name="FixtureModeDismissButton"
                                Style="{StaticResource IconButtonStyle}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                Click="OnFixtureModeDismiss"
                                ToolTip="Dismiss banner">
                            <TextBlock Text="&#x2715;"
                                       FontSize="12"
                                       Foreground="#1A1A2E" />
                        </Button>
                    </Grid>
                </Border>

                <!-- Top Header Bar -->
                <Border DockPanel.Dock="Top"
                        Height="74"
                        VerticalAlignment="Top"
                        Background="{StaticResource HeaderBandBackgroundBrush}"
                        BorderBrush="{StaticResource ConsoleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="24,0">
                    <Grid>
                        <!-- Page Title (Breadcrumb) -->
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left">
                            <Button x:Name="BackButton"
                                    Style="{StaticResource IconButtonStyle}"
                                    Visibility="Collapsed"
                                    Click="OnBackButtonClick"
                                    ToolTip="Go Back">
                                <TextBlock Text="{StaticResource IconBack}"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="16" />
                            </Button>
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock x:Name="PageTitleText"
                                           Text="Dashboard"
                                           FontFamily="{StaticResource MeridianDisplayFontFamily}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           AutomationProperties.AutomationId="PageTitleText"
                                           AutomationProperties.Name="Current Page Title" />
                                <TextBlock Text="High-trust operator view with live posture, alerts, and action shortcuts."
                                           FontSize="12"
                                           Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Connection Status and Actions -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <!-- Connection Status Indicator -->
                            <Border x:Name="ConnectionStatusBadge"
                                    Style="{StaticResource SuccessBadgeStyle}"
                                    Margin="0,0,16,0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="ConnectionStatusDot"
                                             Width="8" Height="8"
                                             Fill="{StaticResource SuccessColorBrush}"
                                             Margin="0,0,6,0" />
                                    <TextBlock x:Name="ConnectionStatusText"
                                               Text="Connected"
                                               FontSize="12"
                                               Foreground="{StaticResource SuccessColorBrush}" />
                                </StackPanel>
                            </Border>

                            <!-- Refresh Button -->
                            <Button Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Refresh (F5)"
                                    Click="OnRefreshButtonClick">
                                <TextBlock Text="{StaticResource IconRefresh}"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="16" />
                            </Button>

                            <!-- Notifications Button -->
                            <Button Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Notifications"
                                    Margin="4,0,0,0"
                                    Click="OnNotificationsButtonClick">
                                <TextBlock Text="{StaticResource IconBell}"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="16" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Content Frame -->
                <Frame x:Name="ContentFrame"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent"
                       Margin="0,86,0,0"
                       AutomationProperties.AutomationId="ContentFrame"
                       AutomationProperties.Name="Main Content Frame"
                       Navigated="OnContentFrameNavigated" />
            </Grid>
        </DockPanel>
    </Grid>
</Page>
