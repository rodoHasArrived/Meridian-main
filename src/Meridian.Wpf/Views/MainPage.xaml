<Page x:Class="Meridian.Wpf.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:views="clr-namespace:Meridian.Wpf.Views"
      mc:Ignorable="d"
      d:DesignHeight="900"
      d:DesignWidth="1400"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      Unloaded="OnPageUnloaded"
      AutomationProperties.Name="Main"
      AutomationProperties.AutomationId="MainPage">

    <Page.Resources>
        <!-- Marquee-inspired nav item: left-bar indicator on active, flat hover -->
        <Style x:Key="ShellNavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,1,0,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="{StaticResource NavItemForegroundBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid x:Name="ItemGrid" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!-- Left indicator bar: visible only when selected -->
                            <Rectangle x:Name="ActiveIndicator"
                                       Grid.Column="0"
                                       Fill="{StaticResource SidebarActiveIndicatorBrush}"
                                       Visibility="Collapsed" />
                            <Border x:Name="ItemContent"
                                    Grid.Column="1"
                                    Background="Transparent"
                                    Padding="12,9">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemContent" Property="Background" Value="{StaticResource SidebarHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource NavItemForegroundHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemContent" Property="Background" Value="{StaticResource SidebarActiveBrush}" />
                                <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible" />
                                <Setter Property="Foreground" Value="{StaticResource NavItemForegroundActiveBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShellNavIconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource SymbolThemeFontFamily}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Width" Value="18" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ShellNavLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MeridianBodyFontFamily}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="10,0,0,0" />
        </Style>

        <Style x:Key="ShellNavTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource ShellNavLabelStyle}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ShellNavSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MeridianBodyFontFamily}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource NavItemForegroundBrush}" />
            <Setter Property="Opacity" Value="0.78" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!-- Dark-shell variant for the left rail and command palette surfaces. -->
        <Style x:Key="SidebarShellSectionLabelStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource ShellSectionLabelStyle}">
            <Setter Property="Foreground" Value="{StaticResource NavSectionLabelBrush}" />
        </Style>

        <!-- Marquee-style workspace tiles on dark sidebar background -->
        <Style x:Key="WorkspaceTileStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SidebarTileBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SidebarBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource NavItemForegroundBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="MinHeight" Value="52" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template" Value="{StaticResource SidebarButtonTemplate}" />
        </Style>

        <Style x:Key="ActiveWorkspaceTileStyle" TargetType="Button" BasedOn="{StaticResource WorkspaceTileStyle}">
            <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SidebarActiveIndicatorBrush}" />
            <Setter Property="Foreground" Value="{StaticResource NavItemForegroundActiveBrush}" />
        </Style>

        <Style x:Key="RecentPageButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource SidebarBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource NavItemForegroundBrush}" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template" Value="{StaticResource SidebarButtonTemplate}" />
        </Style>

        <!-- Shared style for the sidebar footer action buttons -->
        <Style x:Key="FooterNavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource NavItemForegroundBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template" Value="{StaticResource SidebarButtonTemplate}" />
        </Style>

        <DataTemplate x:Key="ShellNavigationItemTemplate">
            <Grid Margin="0,2,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding Glyph}"
                           Style="{StaticResource ShellNavIconStyle}"
                           VerticalAlignment="Top" />

                <StackPanel Grid.Column="1"
                            Margin="10,0,0,0">
                    <TextBlock Text="{Binding Title}"
                               Style="{StaticResource ShellNavTitleStyle}" />
                    <TextBlock Text="{Binding Subtitle}"
                               Style="{StaticResource ShellNavSubtitleStyle}"
                               Margin="0,2,0,0" />
                    <TextBlock Text="{Binding MetaLine}"
                               Style="{StaticResource SidebarShellSectionLabelStyle}"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </DataTemplate>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>

    <Page.InputBindings>
        <KeyBinding Key="K" Modifiers="Control" Command="{Binding ShowCommandPaletteCommand}" />
    </Page.InputBindings>

    <Grid Background="{DynamicResource ShellWindowBackgroundBrush}">
        <TextBlock x:Name="ShellAutomationStateText"
                   Text="{Binding CurrentPageTag}"
                   Visibility="Collapsed"
                   AutomationProperties.AutomationId="ShellAutomationState"
                   AutomationProperties.Name="Shell Automation State" />

        <Grid x:Name="CommandPaletteOverlay"
              Visibility="{Binding CommandPaletteVisibility}"
              Panel.ZIndex="100"
              Background="#80000000"
              AutomationProperties.AutomationId="CommandPaletteOverlay"
              AutomationProperties.Name="Command Palette Overlay"
              MouseDown="CommandPaletteOverlay_MouseDown">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,80,0,0"
                    Width="620"
                    Background="{StaticResource SidebarBackgroundBrush}"
                    CornerRadius="3"
                    BorderBrush="{StaticResource SidebarBorderBrush}"
                    BorderThickness="1"
                    Padding="0"
                    MouseDown="CommandPaletteBorder_MouseDown">
                <StackPanel>
                    <TextBox x:Name="CommandPaletteTextBox"
                             Margin="16,16,16,6"
                             Padding="12,10"
                             FontSize="14"
                             Background="{StaticResource SidebarTileBrush}"
                             Foreground="{StaticResource NavItemForegroundHoverBrush}"
                             BorderBrush="{StaticResource SidebarBorderBrush}"
                             BorderThickness="1"
                             AutomationProperties.AutomationId="CommandPaletteInput"
                             AutomationProperties.Name="Command Palette Input"
                             Text="{Binding CommandPaletteQuery, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Escape" Command="{Binding HideCommandPaletteCommand}" />
                            <KeyBinding Key="Enter" Command="{Binding OpenSelectedCommandPalettePageCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                    <DockPanel Margin="16,0,16,8" LastChildFill="False">
                        <TextBlock x:Name="CommandPaletteSummaryText"
                                   Text="{Binding CommandPaletteResultSummary}"
                                   FontSize="11"
                                   Opacity="0.78"
                                   Foreground="{StaticResource NavSectionLabelBrush}"
                                   AutomationProperties.AutomationId="CommandPaletteSummaryText"
                                   AutomationProperties.Name="Command Palette Summary" />
                        <Button x:Name="CommandPaletteClearButton"
                                DockPanel.Dock="Right"
                                Style="{StaticResource SubtleButtonStyle}"
                                Padding="8,3"
                                Command="{Binding ClearCommandPaletteQueryCommand}"
                                AutomationProperties.AutomationId="CommandPaletteClearButton"
                                AutomationProperties.Name="Clear Command Palette Search">
                            <TextBlock Text="Clear search" />
                        </Button>
                    </DockPanel>
                    <ListBox x:Name="CommandPaletteResults"
                             MaxHeight="360"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource ShellNavItemStyle}"
                             SelectionChanged="CommandPaletteResults_SelectionChanged"
                             ItemsSource="{Binding CommandPalettePages}"
                             SelectedItem="{Binding SelectedCommandPalettePage, Mode=TwoWay}"
                             AutomationProperties.AutomationId="CommandPaletteResults"
                             AutomationProperties.Name="Command Palette Results"
                             Margin="10,0,10,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Glyph}"
                                               Style="{StaticResource ShellNavIconStyle}"
                                               VerticalAlignment="Top" />

                                    <StackPanel Grid.Column="1"
                                                Margin="10,0,0,0">
                                        <DockPanel LastChildFill="True">
                                            <TextBlock Text="{Binding Title}"
                                                       Style="{StaticResource ShellNavTitleStyle}" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       Margin="12,0,0,0"
                                                       Text="{Binding WorkspaceTitle}"
                                                       Style="{StaticResource SidebarShellSectionLabelStyle}"
                                                       VerticalAlignment="Center" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding Subtitle}"
                                                   Style="{StaticResource ShellNavSubtitleStyle}"
                                                   Margin="0,2,0,0" />
                                        <TextBlock Text="{Binding MetaLine}"
                                                   Style="{StaticResource SidebarShellSectionLabelStyle}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Border x:Name="CommandPaletteEmptyState"
                            Margin="16,0,16,12"
                            Padding="16"
                            Visibility="{Binding CommandPaletteEmptyVisibility}"
                            Style="{StaticResource CompactCardStyle}"
                            AutomationProperties.AutomationId="CommandPaletteEmptyState"
                            AutomationProperties.Name="Command Palette Empty State">
                        <StackPanel>
                            <TextBlock x:Name="CommandPaletteEmptyTitleText"
                                       Text="{Binding CommandPaletteEmptyTitle}"
                                       Style="{StaticResource CardHeaderStyle}"
                                       FontSize="15"
                                       AutomationProperties.AutomationId="CommandPaletteEmptyTitleText" />
                            <TextBlock x:Name="CommandPaletteEmptyDescriptionText"
                                       Margin="0,6,0,0"
                                       Text="{Binding CommandPaletteEmptyDescription}"
                                       Style="{StaticResource CardDescriptionStyle}"
                                       AutomationProperties.AutomationId="CommandPaletteEmptyDescriptionText" />
                        </StackPanel>
                    </Border>
                    <TextBlock Text="Ctrl+K to open - Esc to close - Enter to open selection"
                               FontSize="11"
                               Opacity="0.7"
                               Foreground="{StaticResource NavSectionLabelBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14" />
                </StackPanel>
            </Border>
        </Grid>

        <DockPanel LastChildFill="True">
            <!-- ── Marquee-style dark top header bar ── -->
            <Border DockPanel.Dock="Top"
                    Height="44"
                    Background="{StaticResource TopBarBackgroundBrush}"
                    BorderBrush="{StaticResource TopBarBorderBrush}"
                    BorderThickness="0,0,0,1">
                <DockPanel Margin="16,0" LastChildFill="False">
                    <!-- Brand -->
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{StaticResource IconChart}"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="16"
                                   Foreground="{StaticResource TopBarIconAccentBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="Meridian"
                                   FontFamily="{StaticResource MeridianDisplayFontFamily}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TopBarTextBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Operator Workstation"
                                   FontFamily="{StaticResource MeridianBodyFontFamily}"
                                   FontSize="12"
                                   Foreground="#6B7280"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0" />
                    </StackPanel>
                    <!-- Mode badge + search icon -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource TopBarBorderBrush}"
                                CornerRadius="3"
                                Padding="8,3"
                                Margin="0,0,12,0"
                                Visibility="{Binding ActiveFundVisibility}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B7;"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="11"
                                           Foreground="#F59E0B"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding ActiveFundName}"
                                           Margin="6,0,0,0"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TopBarTextBrush}" />
                                <TextBlock Text="{Binding ActiveFundSubtitle}"
                                           Margin="6,0,0,0"
                                           FontSize="11"
                                           Foreground="#9CA3AF" />
                            </StackPanel>
                        </Border>
                        <ComboBox Width="220"
                                  Margin="0,0,8,0"
                                  ItemsSource="{Binding OperatingContexts}"
                                  SelectedItem="{Binding SelectedOperatingContext, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"
                                  Background="{StaticResource TopBarBorderBrush}"
                                  Foreground="{StaticResource TopBarTextBrush}"
                                  BorderBrush="{StaticResource SidebarBorderBrush}"
                                  Padding="6,2"
                                  ToolTip="Switch operating context"
                                  AutomationProperties.Name="Operating Context Switcher" />
                        <Button Style="{StaticResource IconButtonStyle}"
                                Command="{Binding SwitchFundCommand}"
                                ToolTip="Choose Operating Context"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource TopBarTextBrush}"
                                Width="28" Height="28" Padding="4"
                                Margin="0,0,8,0"
                                AutomationProperties.Name="Choose Operating Context">
                            <TextBlock Text="&#xE777;"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="14"
                                       Foreground="#9CA3AF" />
                        </Button>
                        <ComboBox Width="132"
                                  Margin="0,0,8,0"
                                  ItemsSource="{Binding WindowModes}"
                                  SelectedItem="{Binding SelectedWindowMode, Mode=TwoWay}"
                                  Background="{StaticResource TopBarBorderBrush}"
                                  Foreground="{StaticResource TopBarTextBrush}"
                                  BorderBrush="{StaticResource SidebarBorderBrush}"
                                  Padding="6,2"
                                  ToolTip="Select bounded window mode"
                                  AutomationProperties.Name="Window Mode Switcher" />
                        <Border Background="{StaticResource TopBarBorderBrush}"
                                CornerRadius="3"
                                Padding="8,3"
                                Margin="0,0,12,0">
                            <TextBlock Text="{Binding CurrentModeName}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#60A5FA" />
                        </Border>
                        <Button Style="{StaticResource IconButtonStyle}"
                                Click="OnOpenCommandPaletteClick"
                                ToolTip="Search (Ctrl+K)"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource TopBarTextBrush}"
                                Width="28" Height="28" Padding="4"
                                AutomationProperties.Name="Search">
                            <TextBlock Text="{StaticResource IconSearch}"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="14"
                                       Foreground="#9CA3AF" />
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ── Marquee-style dark navy sidebar ── -->
            <Border DockPanel.Dock="Left"
                    Width="220"
                    Background="{StaticResource SidebarBackgroundBrush}"
                    BorderBrush="{StaticResource SidebarBorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Compact workspace selector -->
                    <Border Grid.Row="0"
                            Padding="12,10"
                            BorderBrush="{StaticResource SidebarBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="Workspaces"
                                       Style="{StaticResource SidebarShellSectionLabelStyle}"
                                       Margin="4,0,0,4"/>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button x:Name="ResearchWorkspaceButton"
                                        Grid.Row="0" Grid.Column="0"
                                        Command="{Binding NavigateToPageCommand}"
                                        CommandParameter="ResearchShell"
                                        Margin="0,0,4,4"
                                        AutomationProperties.AutomationId="WorkspaceResearchButton"
                                        AutomationProperties.Name="Research Workspace">
                                    <Button.ToolTip>
                                        <ToolTip Placement="Right"
                                                 HasDropShadow="False">
                                            <Border Background="{StaticResource SidebarBackgroundBrush}"
                                                    BorderBrush="{StaticResource SidebarBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="12">
                                                <StackPanel>
                                                    <TextBlock Text="Shared workflow groups"
                                                               Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                                    <TextBlock Text="Home"
                                                               Margin="0,8,0,0"
                                                               Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                                    <TextBlock Text="Active Work"
                                                               Margin="0,2,0,0"
                                                               Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                                    <TextBlock Text="Review / Alerts"
                                                               Margin="0,2,0,0"
                                                               Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                                    <TextBlock Text="Admin / Support"
                                                               Margin="0,2,0,0"
                                                               Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                                </StackPanel>
                                            </Border>
                                        </ToolTip>
                                    </Button.ToolTip>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource WorkspaceTileStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsResearchWorkspaceActive}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource SidebarActiveIndicatorBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="Foreground" Value="{StaticResource NavItemForegroundActiveBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel>
                                        <TextBlock Text="Research" FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="Studio · Compare"
                                                   Margin="0,2,0,0" FontSize="10"
                                                   Opacity="0.75" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button>

                                <Button x:Name="TradingWorkspaceButton"
                                        Grid.Row="0" Grid.Column="1"
                                        Command="{Binding NavigateToPageCommand}"
                                        CommandParameter="TradingShell"
                                        Margin="4,0,0,4"
                                        AutomationProperties.AutomationId="WorkspaceTradingButton"
                                        AutomationProperties.Name="Trading Workspace">
                                    <Button.ToolTip>
                                        <ToolTip Placement="Right"
                                                 HasDropShadow="False">
                                            <Border Background="{StaticResource SidebarBackgroundBrush}"
                                                    BorderBrush="{StaticResource SidebarBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="12">
                                                <StackPanel>
                                                    <TextBlock Text="Shared workflow groups"
                                                               Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                                    <TextBlock Text="Home"
                                                               Margin="0,8,0,0"
                                                               Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                                    <TextBlock Text="Active Work"
                                                               Margin="0,2,0,0"
                                                               Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                                    <TextBlock Text="Review / Alerts"
                                                               Margin="0,2,0,0"
                                                               Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                                    <TextBlock Text="Admin / Support"
                                                               Margin="0,2,0,0"
                                                               Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                                </StackPanel>
                                            </Border>
                                        </ToolTip>
                                    </Button.ToolTip>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource WorkspaceTileStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTradingWorkspaceActive}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource SidebarActiveIndicatorBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="Foreground" Value="{StaticResource NavItemForegroundActiveBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel>
                                        <TextBlock Text="Trading" FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="Live · Orders · Risk"
                                                   Margin="0,2,0,0" FontSize="10"
                                                   Opacity="0.75" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button>

                                <Button x:Name="DataOperationsWorkspaceButton"
                                        Grid.Row="1" Grid.Column="0"
                                        Command="{Binding NavigateToPageCommand}"
                                        CommandParameter="DataOperationsShell"
                                        Margin="0,0,4,0"
                                        AutomationProperties.AutomationId="WorkspaceDataOperationsButton"
                                        AutomationProperties.Name="Data Operations Workspace">
                                    <Button.ToolTip>
                                        <ToolTip Placement="Right"
                                                 HasDropShadow="False">
                                            <Border Background="{StaticResource SidebarBackgroundBrush}"
                                                    BorderBrush="{StaticResource SidebarBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="12">
                                                <StackPanel>
                                                    <TextBlock Text="Shared workflow groups"
                                                               Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                                    <TextBlock Text="Home"
                                                               Margin="0,8,0,0"
                                                               Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                                    <TextBlock Text="Active Work"
                                                               Margin="0,2,0,0"
                                                               Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                                    <TextBlock Text="Review / Alerts"
                                                               Margin="0,2,0,0"
                                                               Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                                    <TextBlock Text="Admin / Support"
                                                               Margin="0,2,0,0"
                                                               Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                                </StackPanel>
                                            </Border>
                                        </ToolTip>
                                    </Button.ToolTip>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource WorkspaceTileStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDataOperationsWorkspaceActive}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource SidebarActiveIndicatorBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="Foreground" Value="{StaticResource NavItemForegroundActiveBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel>
                                        <TextBlock Text="Data Ops" FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="Providers · Jobs"
                                                   Margin="0,2,0,0" FontSize="10"
                                                   Opacity="0.75" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button>

                                <Button x:Name="GovernanceWorkspaceButton"
                                        Grid.Row="1" Grid.Column="1"
                                        Command="{Binding NavigateToPageCommand}"
                                        CommandParameter="GovernanceShell"
                                        Margin="4,0,0,0"
                                        AutomationProperties.AutomationId="WorkspaceGovernanceButton"
                                        AutomationProperties.Name="Governance Workspace">
                                    <Button.ToolTip>
                                        <ToolTip Placement="Right"
                                                 HasDropShadow="False">
                                            <Border Background="{StaticResource SidebarBackgroundBrush}"
                                                    BorderBrush="{StaticResource SidebarBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="12">
                                                <StackPanel>
                                                    <TextBlock Text="Shared workflow groups"
                                                               Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                                    <TextBlock Text="Home"
                                                               Margin="0,8,0,0"
                                                               Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                                    <TextBlock Text="Active Work"
                                                               Margin="0,2,0,0"
                                                               Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                                    <TextBlock Text="Review / Alerts"
                                                               Margin="0,2,0,0"
                                                               Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                                    <TextBlock Text="Admin / Support"
                                                               Margin="0,2,0,0"
                                                               Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                                </StackPanel>
                                            </Border>
                                        </ToolTip>
                                    </Button.ToolTip>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource WorkspaceTileStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGovernanceWorkspaceActive}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource SidebarActiveIndicatorBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="Foreground" Value="{StaticResource NavItemForegroundActiveBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel>
                                        <TextBlock Text="Governance" FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="Ledger · Audit · Controls"
                                                   Margin="0,2,0,0" FontSize="10"
                                                   Opacity="0.75" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Current workspace label -->
                    <Border Grid.Row="1"
                            Padding="16,8"
                            BorderBrush="{StaticResource SidebarBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="{Binding ActiveNavigationLabel}"
                                       Style="{StaticResource SidebarShellSectionLabelStyle}" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,6,0,12">
                        <StackPanel>
                            <TextBlock Text="{Binding WorkspaceSummary}"
                                       Style="{StaticResource CardDescriptionStyle}"
                                       Margin="16,0,16,10"
                                       TextWrapping="Wrap" />

                            <TextBlock Text="Home"
                                       Style="{StaticResource SidebarShellSectionLabelStyle}"
                                       Margin="16,0,0,6" />
                            <ListBox x:Name="WorkspacePrimaryNavList"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemContainerStyle="{StaticResource ShellNavItemStyle}"
                                     ItemTemplate="{StaticResource ShellNavigationItemTemplate}"
                                     ItemsSource="{Binding PrimaryNavigationItems}"
                                     SelectedValuePath="PageTag"
                                     SelectedValue="{Binding CurrentPageTag, Mode=OneWay}"
                                     SelectionChanged="WorkspaceNavigationList_SelectionChanged"
                                     AutomationProperties.AutomationId="WorkspacePrimaryNavList"
                                     AutomationProperties.Name="Home Navigation" />

                            <StackPanel Visibility="{Binding HasSecondaryNavigation, Converter={StaticResource BoolToVisibility}}">
                                <Rectangle Style="{StaticResource HorizontalDividerStyle}" Margin="16,10,16,10" />
                                <TextBlock Text="Active Work"
                                           Style="{StaticResource SidebarShellSectionLabelStyle}"
                                           Margin="16,0,0,6" />
                                <ListBox x:Name="WorkspaceSecondaryNavList"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ItemContainerStyle="{StaticResource ShellNavItemStyle}"
                                         ItemTemplate="{StaticResource ShellNavigationItemTemplate}"
                                         ItemsSource="{Binding SecondaryNavigationItems}"
                                         SelectedValuePath="PageTag"
                                         SelectedValue="{Binding CurrentPageTag, Mode=OneWay}"
                                         SelectionChanged="WorkspaceNavigationList_SelectionChanged"
                                         AutomationProperties.AutomationId="WorkspaceSecondaryNavList"
                                         AutomationProperties.Name="Active Work Navigation" />
                            </StackPanel>

                            <StackPanel Visibility="{Binding HasOverflowNavigation, Converter={StaticResource BoolToVisibility}}">
                                <Rectangle Style="{StaticResource HorizontalDividerStyle}" Margin="16,10,16,10" />
                                <TextBlock Text="Review / Alerts"
                                           Style="{StaticResource SidebarShellSectionLabelStyle}"
                                           Margin="16,0,0,6" />
                                <ListBox x:Name="WorkspaceOverflowNavList"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ItemContainerStyle="{StaticResource ShellNavItemStyle}"
                                         ItemTemplate="{StaticResource ShellNavigationItemTemplate}"
                                         ItemsSource="{Binding OverflowNavigationItems}"
                                         SelectedValuePath="PageTag"
                                         SelectedValue="{Binding CurrentPageTag, Mode=OneWay}"
                                         SelectionChanged="WorkspaceNavigationList_SelectionChanged"
                                         AutomationProperties.AutomationId="WorkspaceOverflowNavList"
                                         AutomationProperties.Name="Review and Alerts Navigation" />
                            </StackPanel>

                            <StackPanel Visibility="{Binding HasRelatedWorkflows, Converter={StaticResource BoolToVisibility}}">
                                <Rectangle Style="{StaticResource HorizontalDividerStyle}" Margin="16,10,16,10" />
                                <TextBlock Text="Admin / Support"
                                           Style="{StaticResource SidebarShellSectionLabelStyle}"
                                           Margin="16,0,0,6" />
                                <ListBox x:Name="RelatedWorkflowNavList"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ItemContainerStyle="{StaticResource ShellNavItemStyle}"
                                         ItemTemplate="{StaticResource ShellNavigationItemTemplate}"
                                         ItemsSource="{Binding RelatedWorkflowItems}"
                                         SelectedValuePath="PageTag"
                                         SelectedValue="{Binding CurrentPageTag, Mode=OneWay}"
                                         SelectionChanged="WorkspaceNavigationList_SelectionChanged"
                                         AutomationProperties.AutomationId="RelatedWorkflowNavList"
                                         AutomationProperties.Name="Admin and Support Navigation" />
                            </StackPanel>

                            <Rectangle Style="{StaticResource HorizontalDividerStyle}" Margin="16,10,16,10" />

                            <DockPanel Margin="16,0,16,6" LastChildFill="False">
                                <TextBlock Text="Recent"
                                           Style="{StaticResource SidebarShellSectionLabelStyle}" />
                                <Border DockPanel.Dock="Right"
                                        Style="{StaticResource NeutralBadgeStyle}">
                                    <TextBlock x:Name="RecentPagesSummaryText"
                                               Text="{Binding RecentPagesSummaryText}"
                                               FontSize="11"
                                               Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                               AutomationProperties.AutomationId="RecentPagesSummaryText" />
                                </Border>
                            </DockPanel>
                            <ItemsControl ItemsSource="{Binding RecentPages}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Margin="12,0" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource RecentPageButtonStyle}"
                                                Command="{Binding DataContext.NavigateToPageCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding PageTag}"
                                                Content="{Binding DisplayName}"
                                                AutomationProperties.AutomationId="{Binding PageTag, StringFormat=RecentPage{0}}"
                                                AutomationProperties.Name="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Border x:Name="RecentPagesEmptyState"
                                    Margin="16,0,16,0"
                                    Padding="14"
                                    Visibility="{Binding RecentPagesEmptyVisibility}"
                                    Style="{StaticResource CompactCardStyle}"
                                    AutomationProperties.AutomationId="RecentPagesEmptyState"
                                    AutomationProperties.Name="Recent Pages Empty State">
                                <StackPanel>
                                    <TextBlock x:Name="RecentPagesEmptyText"
                                               Text="No recent pages yet."
                                               AutomationProperties.AutomationId="RecentPagesEmptyText"
                                               AutomationProperties.Name="Recent Pages Empty Title"
                                               Style="{StaticResource CardHeaderStyle}"
                                               FontSize="14" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding RecentPagesHintText}"
                                               Style="{StaticResource CardDescriptionStyle}" />
                                    <Button x:Name="RecentPagesEmptyActionButton"
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding ShowCommandPaletteCommand}"
                                            AutomationProperties.AutomationId="RecentPagesEmptyActionButton"
                                            AutomationProperties.Name="Open Command Palette From Recent Empty State">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconSearch}"
                                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="Open Command Palette"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Compact footer actions -->
                    <Border Grid.Row="3"
                            Padding="12,10"
                            BorderBrush="{StaticResource SidebarBorderBrush}"
                            BorderThickness="0,1,0,0">
                        <StackPanel>
                            <Button Style="{StaticResource FooterNavButtonStyle}"
                                    Click="OnOpenCommandPaletteClick"
                                    AutomationProperties.Name="Open Command Palette"
                                    ToolTip="Quick Command (Ctrl+K)">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{StaticResource IconSearch}"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Text="Command Palette"
                                               Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource FooterNavButtonStyle}"
                                    Margin="0,4,0,0"
                                    Command="{Binding OpenNotificationsCommand}"
                                    ToolTip="Notifications">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{StaticResource IconBell}"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Text="Notifications"
                                               Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource FooterNavButtonStyle}"
                                    Margin="0,4,0,0"
                                    Command="{Binding OpenHelpCommand}"
                                    AutomationProperties.Name="Help and Support">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{StaticResource IconHelp}"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Text="Help"
                                               Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="TickerStripToggleButton"
                                    Style="{StaticResource FooterNavButtonStyle}"
                                    Margin="0,4,0,0"
                                    Command="{Binding ToggleTickerStripCommand}"
                                    AutomationProperties.AutomationId="TickerStripToggleButton"
                                    AutomationProperties.Name="Toggle Ticker Strip"
                                    ToolTip="Toggle live ticker strip">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4C8;" FontSize="11" VerticalAlignment="Center" />
                                    <TextBlock x:Name="TickerStripToggleLabelText"
                                               Text="{Binding TickerStripLabel}"
                                               Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border x:Name="FixtureModeBanner"
                        Grid.Row="0"
                        Margin="0"
                        Padding="16,10"
                        CornerRadius="0"
                        Visibility="{Binding FixtureModeBannerVisibility}"
                        AutomationProperties.AutomationId="FixtureModeBanner"
                        AutomationProperties.Name="Fixture Mode Banner"
                        Panel.ZIndex="10">
                    <Border.Background>
                        <LinearGradientBrush x:Name="FixtureModeBannerBrush" StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource ModeFixtureColor}" Offset="0" />
                            <GradientStop Color="#C98A2B" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#x26A0;"
                                       FontSize="14"
                                       Foreground="#1A1A2E"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <TextBlock x:Name="FixtureModeLabel"
                                       Text="{Binding FixtureModeBannerText}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#1A1A2E"
                                       AutomationProperties.AutomationId="FixtureModeLabel"
                                       AutomationProperties.Name="Fixture Mode Label"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <Button x:Name="FixtureModeDismissButton"
                                Grid.Column="1"
                                Style="{StaticResource IconButtonStyle}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Command="{Binding DismissFixtureModeBannerCommand}"
                                AutomationProperties.AutomationId="FixtureModeDismissButton"
                                AutomationProperties.Name="Dismiss Fixture Mode Banner"
                                ToolTip="Dismiss banner">
                            <TextBlock Text="&#x2715;"
                                       FontSize="12"
                                       Foreground="#1A1A2E" />
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{StaticResource ConsoleBackgroundLightBrush}"
                        BorderBrush="{StaticResource ConsoleBorderBrush}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="0"
                        Padding="24,12"
                        Margin="0,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="BackButton"
                                        Style="{StaticResource IconButtonStyle}"
                                        Visibility="{Binding BackButtonVisibility}"
                                        Command="{Binding GoBackCommand}"
                                        AutomationProperties.AutomationId="ShellBackButton"
                                        AutomationProperties.Name="Shell Back Button"
                                        ToolTip="Go Back">
                                    <TextBlock Text="{StaticResource IconBack}"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="16" />
                                </Button>
                                <TextBlock Text="{Binding WorkspaceHeading}"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource ShellSectionLabelStyle}" />
                            </StackPanel>
                            <TextBlock x:Name="PageTitleTextBlock"
                                       Text="{Binding CurrentPageTitle}"
                                       Margin="0,6,0,0"
                                       Visibility="Collapsed"
                                       FontFamily="{StaticResource MeridianDisplayFontFamily}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                       AutomationProperties.AutomationId="PageTitleText"
                                       AutomationProperties.Name="Current Page Title" />
                            <TextBlock x:Name="PageSubtitleText"
                                       Margin="0,8,0,0"
                                       Text="{Binding CurrentPageSubtitle}"
                                       Visibility="Collapsed"
                                       Style="{StaticResource CardDescriptionStyle}" />
                            <Border x:Name="ContextSelectionHint"
                                    Margin="0,12,0,0"
                                    Padding="12,10"
                                    Visibility="{Binding ContextSelectionHintVisibility}"
                                    Style="{StaticResource WarningBadgeInlineStyle}"
                                    AutomationProperties.AutomationId="ContextSelectionHint"
                                    AutomationProperties.Name="Context Selection Hint">
                                <DockPanel LastChildFill="False">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7BA;"
                                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource WarningColorBrush}" />
                                        <TextBlock x:Name="ContextSelectionHintTextBlock"
                                                   Margin="8,0,0,0"
                                                   Text="{Binding ContextSelectionHintText}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                                   AutomationProperties.AutomationId="ContextSelectionHintText" />
                                    </StackPanel>
                                    <Button x:Name="ContextSelectionHintButton"
                                            DockPanel.Dock="Right"
                                            Margin="12,0,0,0"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Command="{Binding SwitchFundCommand}"
                                            AutomationProperties.AutomationId="ContextSelectionHintButton"
                                            AutomationProperties.Name="Choose Operating Context">
                                        <TextBlock Text="Choose Context" />
                                    </Button>
                                </DockPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top">
                            <WrapPanel HorizontalAlignment="Right" Margin="0,0,0,12">
                                <Border x:Name="ConnectionStatusBadge"
                                        Margin="0,0,10,10">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource NeutralBadgeStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShellStatusTone}" Value="Success">
                                                    <Setter Property="Background" Value="{StaticResource ConsoleAccentGreenAlpha10Brush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource SuccessColorBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ShellStatusTone}" Value="Warning">
                                                    <Setter Property="Background" Value="{StaticResource ConsoleAccentOrangeAlpha10Brush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource WarningColorBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ShellStatusTone}" Value="Danger">
                                                    <Setter Property="Background" Value="{StaticResource ConsoleAccentRedAlpha10Brush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource ErrorColorBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ShellStatusTone}" Value="Info">
                                                    <Setter Property="Background" Value="{StaticResource ConsoleAccentBlueAlpha10Brush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource InfoColorBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="ConnectionStatusDot"
                                                 Width="8"
                                                 Height="8"
                                                 Margin="0,0,6,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource SuccessColorBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShellStatusTone}" Value="Warning">
                                                            <Setter Property="Fill" Value="{StaticResource WarningColorBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ShellStatusTone}" Value="Danger">
                                                            <Setter Property="Fill" Value="{StaticResource ErrorColorBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ShellStatusTone}" Value="Info">
                                                            <Setter Property="Fill" Value="{StaticResource InfoColorBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock x:Name="ConnectionStatusText"
                                                   Text="{Binding ShellStatusText}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource NeutralBadgeStyle}" Margin="0,0,10,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE823;"
                                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                        <TextBlock Text="{Binding ShellLastRefreshText}"
                                                   Margin="6,0,0,0"
                                                   FontSize="12"
                                                   Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                    </StackPanel>
                                </Border>
                            </WrapPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        ToolTip="Choose operating context"
                                        Margin="0,0,8,0"
                                        Command="{Binding SwitchFundCommand}"
                                        AutomationProperties.AutomationId="SwitchContextButton"
                                        AutomationProperties.Name="Switch Operating Context">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE777;"
                                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                   FontSize="14"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding SwitchContextActionText}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource GhostButtonStyle}"
                                        ToolTip="Refresh (F5)"
                                        Command="{Binding RefreshPageCommand}"
                                        Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconRefresh}"
                                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                   FontSize="14"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="Refresh"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource GhostButtonStyle}"
                                        ToolTip="Notifications"
                                        Margin="0,0,8,0"
                                        Command="{Binding OpenNotificationsCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconBell}"
                                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                   FontSize="14"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="Alerts"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        ToolTip="Command Palette (Ctrl+K)"
                                        Click="OnOpenCommandPaletteClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconSearch}"
                                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                   FontSize="14"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="Command Palette"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <views:WorkspaceShellContextStripControl Grid.Row="2"
                                                        Margin="24,0,24,16"
                                                        Visibility="Collapsed"
                                                        ShellContext="{Binding ShellContext}" />

                <DockPanel Grid.Row="3">
                    <Border DockPanel.Dock="Top" Height="32"
                            Background="{StaticResource CommandBarBackground}"
                            BorderBrush="{StaticResource CommandBarBorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                            <TextBlock Text="Layout:" VerticalAlignment="Center" FontSize="11" Margin="0,0,8,0" Opacity="0.7"/>
                            <ItemsControl ItemsSource="{Binding SplitPane.Layouts}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.SplitPane.SelectLayoutCommand,
                                                        RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="{Binding Label}"
                                                Padding="6,2" Margin="0,0,2,0" FontSize="13"
                                                Content="{Binding Icon}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    <!-- ContentFrame kept collapsed; code-behind references this name for initial init -->
                    <Frame x:Name="ContentFrame"
                           Visibility="Collapsed"
                           NavigationUIVisibility="Hidden"
                           Background="Transparent"
                           AutomationProperties.AutomationId="ContentFrame"
                           AutomationProperties.Name="Main Content Frame"
                           Navigated="OnContentFrameNavigated" />
                    <views:SplitPaneHostControl x:Name="SplitPaneHost"
                                               Layout="{Binding SplitPane.SelectedLayout}"
                                               Loaded="OnSplitPaneHostLoaded" />
                </DockPanel>
            </Grid>
        </DockPanel>
    </Grid>
</Page>
