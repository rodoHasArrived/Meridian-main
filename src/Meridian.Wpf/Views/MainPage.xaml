<Page x:Class="Meridian.Wpf.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="900"
      d:DesignWidth="1400"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      AutomationProperties.Name="Main"
      AutomationProperties.AutomationId="MainPage">

    <Page.Resources>
        <Style x:Key="ShellNavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ConsoleBackgroundHoverBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ConsoleAccentBlueAlpha10Brush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource InfoColorBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShellNavIconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource SymbolThemeFontFamily}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Width" Value="22" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ShellNavLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MeridianBodyFontFamily}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="12,0,0,0" />
        </Style>

        <Style x:Key="ShellSectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MeridianBodyFontFamily}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextMutedBrush}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="WorkspaceTileStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="MinHeight" Value="86" />
        </Style>

        <Style x:Key="ActiveWorkspaceTileStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="MinHeight" Value="86" />
        </Style>

        <Style x:Key="RecentPageButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Page.Resources>

    <Page.InputBindings>
        <KeyBinding Key="K" Modifiers="Control" Command="{x:Null}" />
    </Page.InputBindings>

    <Grid Background="{DynamicResource ShellWindowBackgroundBrush}">
        <TextBlock x:Name="ShellAutomationStateText"
                   Visibility="Collapsed"
                   AutomationProperties.AutomationId="ShellAutomationState"
                   AutomationProperties.Name="Shell Automation State" />

        <Grid x:Name="CommandPaletteOverlay"
              Visibility="Collapsed"
              Panel.ZIndex="100"
              Background="#80000000"
              AutomationProperties.AutomationId="CommandPaletteOverlay"
              AutomationProperties.Name="Command Palette Overlay"
              MouseDown="CommandPaletteOverlay_MouseDown">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,80,0,0"
                    Width="620"
                    Background="{StaticResource ConsoleBackgroundDarkBrush}"
                    CornerRadius="18"
                    BorderBrush="{StaticResource ConsoleBorderBrush}"
                    BorderThickness="1"
                    Padding="0"
                    MouseDown="CommandPaletteBorder_MouseDown">
                <StackPanel>
                    <TextBox x:Name="CommandPaletteTextBox"
                             Margin="16,16,16,6"
                             Padding="12,10"
                             FontSize="14"
                             Background="{StaticResource ConsoleBackgroundMediumBrush}"
                             Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                             BorderBrush="{StaticResource ConsoleBorderBrush}"
                             BorderThickness="1"
                             AutomationProperties.AutomationId="CommandPaletteInput"
                             AutomationProperties.Name="Command Palette Input"
                             TextChanged="CommandPaletteTextBox_TextChanged"
                             KeyDown="CommandPaletteTextBox_KeyDown" />
                    <ListBox x:Name="CommandPaletteResults"
                             MaxHeight="360"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource ShellNavItemStyle}"
                             SelectionChanged="CommandPaletteResults_SelectionChanged"
                             AutomationProperties.AutomationId="CommandPaletteResults"
                             AutomationProperties.Name="Command Palette Results"
                             Margin="10,0,10,8" />
                    <TextBlock Text="Ctrl+K to open - Esc to close - Enter to open selection"
                               FontSize="11"
                               Opacity="0.7"
                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14" />
                </StackPanel>
            </Border>
        </Grid>

        <DockPanel LastChildFill="True">
            <Border DockPanel.Dock="Left"
                    Width="340"
                    Margin="16"
                    CornerRadius="24"
                    Background="{StaticResource ShellRailBackgroundBrush}"
                    BorderBrush="{StaticResource ConsoleBorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="24,24,24,18"
                            BorderBrush="{StaticResource ConsoleBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="48"
                                        Height="48"
                                        CornerRadius="16"
                                        Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                        BorderBrush="{StaticResource InfoColorBrush}"
                                        BorderThickness="1">
                                    <TextBlock Text="{StaticResource IconChart}"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="24"
                                               Foreground="{StaticResource InfoColorBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="14,0,0,0">
                                    <TextBlock Text="Meridian"
                                               FontFamily="{StaticResource MeridianDisplayFontFamily}"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                    <TextBlock Text="Operator Workstation"
                                               FontFamily="{StaticResource MeridianBodyFontFamily}"
                                               FontSize="12"
                                               Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="A clearer shell for research, trading, data operations, and governance."
                                       Margin="0,14,0,0"
                                       Style="{StaticResource CardDescriptionStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Padding="24,18"
                            BorderBrush="{StaticResource ConsoleBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="Workspaces"
                                       Style="{StaticResource ShellSectionLabelStyle}" />
                            <TextBlock Text="Choose the workflow you want in focus. The navigation below updates with the active workspace."
                                       Margin="0,6,0,14"
                                       Style="{StaticResource CardDescriptionStyle}" />
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button x:Name="ResearchWorkspaceButton"
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Tag="research"
                                        Style="{StaticResource WorkspaceTileStyle}"
                                        Click="OnWorkspaceButtonClick"
                                        Margin="0,0,8,8">
                                    <StackPanel>
                                        <TextBlock Text="Research" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Text="Runs, charts, replay"
                                                   Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Opacity="0.8"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button>

                                <Button x:Name="TradingWorkspaceButton"
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Tag="trading"
                                        Style="{StaticResource WorkspaceTileStyle}"
                                        Click="OnWorkspaceButtonClick"
                                        Margin="8,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="Trading" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Text="Live monitoring, order flow"
                                                   Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Opacity="0.8"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button>

                                <Button x:Name="DataOperationsWorkspaceButton"
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Tag="data-operations"
                                        Style="{StaticResource WorkspaceTileStyle}"
                                        Click="OnWorkspaceButtonClick"
                                        Margin="0,8,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Data Operations" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Text="Providers, symbols, storage"
                                                   Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Opacity="0.8"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button>

                                <Button x:Name="GovernanceWorkspaceButton"
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Tag="governance"
                                        Style="{StaticResource WorkspaceTileStyle}"
                                        Click="OnWorkspaceButtonClick"
                                        Margin="8,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Governance" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Text="Quality, diagnostics, policy"
                                                   Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Opacity="0.8"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="24,18,24,18">
                        <StackPanel>
                            <Border Style="{StaticResource CompactCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Current Workspace"
                                               Style="{StaticResource ShellSectionLabelStyle}" />
                                    <TextBlock x:Name="WorkspaceHeadingText"
                                               Margin="0,8,0,0"
                                               FontFamily="{StaticResource MeridianDisplayFontFamily}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                    <TextBlock x:Name="WorkspaceDescriptionText"
                                               Margin="0,6,0,0"
                                               Style="{StaticResource CardDescriptionStyle}" />
                                    <TextBlock x:Name="WorkspaceSummaryText"
                                               Margin="0,10,0,0"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                </StackPanel>
                            </Border>

                            <TextBlock x:Name="ActiveNavigationLabel"
                                       Margin="0,20,0,8"
                                       Style="{StaticResource ShellSectionLabelStyle}" />

                            <StackPanel x:Name="ResearchNavigationSection">
                                <ListBox x:Name="ResearchNavList"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ItemContainerStyle="{StaticResource ShellNavItemStyle}"
                                         AutomationProperties.AutomationId="ResearchNavList"
                                         AutomationProperties.Name="Research Navigation"
                                         SelectionChanged="OnResearchNavSelectionChanged">
                                    <ListBoxItem Tag="Dashboard"
                                                 AutomationProperties.AutomationId="ResearchNavDashboard"
                                                 AutomationProperties.Name="Dashboard Navigation">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconDashboard}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Dashboard" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="LiveData"
                                                 AutomationProperties.AutomationId="ResearchNavLiveData"
                                                 AutomationProperties.Name="Live Data Navigation">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconChart}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Live Data" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="Charts"
                                                 AutomationProperties.AutomationId="ResearchNavCharts"
                                                 AutomationProperties.Name="Charts Navigation">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconChartLine}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Charts" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="RunMat"
                                                 AutomationProperties.AutomationId="ResearchNavRunMat"
                                                 AutomationProperties.Name="RunMat Lab Navigation">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconCode}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="RunMat Lab" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="StrategyRuns"
                                                 AutomationProperties.AutomationId="ResearchNavStrategyRuns"
                                                 AutomationProperties.Name="Strategy Runs Navigation">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconList}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Strategy Runs" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="OrderBook"
                                                 AutomationProperties.AutomationId="ResearchNavOrderBook"
                                                 AutomationProperties.Name="Order Book Navigation">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconTable}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Order Book" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="Watchlist"
                                                 AutomationProperties.AutomationId="ResearchNavWatchlist"
                                                 AutomationProperties.Name="Watchlist Navigation">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconFavorite}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Watchlist" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                </ListBox>
                            </StackPanel>

                            <StackPanel x:Name="TradingNavigationSection" Visibility="Collapsed">
                                <ListBox x:Name="TradingNavList"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ItemContainerStyle="{StaticResource ShellNavItemStyle}"
                                         SelectionChanged="OnTradingNavSelectionChanged">
                                    <ListBoxItem Tag="Backtest">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconPlay}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Backtest" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="StrategyRuns">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconList}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Strategy Runs" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="LeanIntegration">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconCode}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Lean Engine" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="PortfolioImport">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconImport}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Portfolio Import" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="TradingHours">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconClock}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Trading Hours" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                </ListBox>
                            </StackPanel>

                            <StackPanel x:Name="DataOperationsNavigationSection" Visibility="Collapsed">
                                <ListBox x:Name="DataOpsNavList"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ItemContainerStyle="{StaticResource ShellNavItemStyle}"
                                         SelectionChanged="OnDataOpsNavSelectionChanged">
                                    <ListBoxItem Tag="Provider">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconNetwork}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Provider" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="Symbols">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconList}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Symbols" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="Backfill">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconDownload}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Backfill" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="Storage">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconDatabase}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Storage" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="DataExport">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconExport}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Export" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="PackageManager">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconFolder}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Packages" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                </ListBox>
                            </StackPanel>

                            <StackPanel x:Name="GovernanceNavigationSection" Visibility="Collapsed">
                                <ListBox x:Name="GovernanceNavList"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ItemContainerStyle="{StaticResource ShellNavItemStyle}"
                                         SelectionChanged="OnGovernanceNavSelectionChanged">
                                    <ListBoxItem Tag="DataQuality">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconCheckmark}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Data Quality" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="ProviderHealth">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconNetwork}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Provider Health" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="SystemHealth">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconConnected}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="System Health" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="Diagnostics">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconTerminal}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Diagnostics" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="Settings">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconSettings}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Settings" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Tag="AdminMaintenance">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource IconLock}" Style="{StaticResource ShellNavIconStyle}" />
                                            <TextBlock Text="Admin" Style="{StaticResource ShellNavLabelStyle}" />
                                        </StackPanel>
                                    </ListBoxItem>
                                </ListBox>
                            </StackPanel>

                            <Rectangle Style="{StaticResource HorizontalDividerStyle}" Margin="0,18,0,18" />

                            <TextBlock Text="Recent Pages"
                                       Style="{StaticResource ShellSectionLabelStyle}" />
                            <TextBlock x:Name="RecentPagesHintText"
                                       Margin="0,6,0,10"
                                       Style="{StaticResource CardDescriptionStyle}" />
                            <WrapPanel x:Name="RecentPagesPanel" />
                            <TextBlock x:Name="RecentPagesEmptyText"
                                       Text="Recent pages will appear here as you move around the workstation."
                                       Visibility="Collapsed"
                                       Style="{StaticResource CardDescriptionStyle}" />
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="3"
                            Padding="24,18"
                            BorderBrush="{StaticResource ConsoleBorderBrush}"
                            BorderThickness="0,1,0,0">
                        <StackPanel>
                            <Button Style="{StaticResource GhostButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Click="OnCommandPaletteButtonClick"
                                    AutomationProperties.AutomationId="OpenCommandPaletteButton"
                                    AutomationProperties.Name="Open Command Palette"
                                    ToolTip="Quick Command (Ctrl+K)">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="{StaticResource IconSearch}"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="14"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Open Command Palette"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource GhostButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Click="OnNotificationsButtonClick"
                                    Margin="0,8,0,0"
                                    ToolTip="Open Notifications">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="{StaticResource IconBell}"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="14"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Notification Center"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource GhostButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Click="OnHelpButtonClick"
                                    Margin="0,8,0,0"
                                    AutomationProperties.AutomationId="HelpSupportButton"
                                    AutomationProperties.Name="Help and Support">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="{StaticResource IconHelp}"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="16"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Help and Support"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Margin="0,16,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border x:Name="FixtureModeBanner"
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        Padding="16,12"
                        CornerRadius="16"
                        Visibility="Collapsed"
                        Panel.ZIndex="10">
                    <Border.Background>
                        <LinearGradientBrush x:Name="FixtureModeBannerBrush" StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource ModeFixtureColor}" Offset="0" />
                            <GradientStop Color="#C98A2B" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#x26A0;"
                                       FontSize="14"
                                       Foreground="#1A1A2E"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <TextBlock x:Name="FixtureModeLabel"
                                       Text="FIXTURE MODE - Showing sample data, not connected to live backend"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#1A1A2E"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <Button x:Name="FixtureModeDismissButton"
                                Grid.Column="1"
                                Style="{StaticResource IconButtonStyle}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Click="OnFixtureModeDismiss"
                                ToolTip="Dismiss banner">
                            <TextBlock Text="&#x2715;"
                                       FontSize="12"
                                       Foreground="#1A1A2E" />
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{StaticResource HeaderBandBackgroundBrush}"
                        BorderBrush="{StaticResource ConsoleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="28,22"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="BackButton"
                                        Style="{StaticResource IconButtonStyle}"
                                        Visibility="Collapsed"
                                        Click="OnBackButtonClick"
                                        ToolTip="Go Back">
                                    <TextBlock Text="{StaticResource IconBack}"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="16" />
                                </Button>
                                <TextBlock x:Name="WorkspaceBadgeText"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource ShellSectionLabelStyle}" />
                            </StackPanel>
                            <TextBlock x:Name="PageTitleText"
                                       Margin="0,12,0,0"
                                       Text="Dashboard"
                                       FontFamily="{StaticResource MeridianDisplayFontFamily}"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                       AutomationProperties.AutomationId="PageTitleText"
                                       AutomationProperties.Name="Current Page Title" />
                            <TextBlock x:Name="PageSubtitleText"
                                       Margin="0,8,0,0"
                                       Text="High-trust operator view with live posture, alerts, and action shortcuts."
                                       Style="{StaticResource CardDescriptionStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top">
                            <WrapPanel HorizontalAlignment="Right" Margin="0,0,0,12">
                                <Border x:Name="ConnectionStatusBadge"
                                        Style="{StaticResource SuccessBadgeStyle}"
                                        Margin="0,0,10,10">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="ConnectionStatusDot"
                                                 Width="8"
                                                 Height="8"
                                                 Fill="{StaticResource SuccessColorBrush}"
                                                 Margin="0,0,6,0" />
                                        <TextBlock x:Name="ConnectionStatusText"
                                                   Text="Connected"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SuccessColorBrush}" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource NeutralBadgeStyle}" Margin="0,0,10,10">
                                    <TextBlock x:Name="HeaderWorkspaceSummaryText"
                                               FontSize="12"
                                               Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                </Border>
                            </WrapPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource GhostButtonStyle}"
                                        ToolTip="Refresh (F5)"
                                        Click="OnRefreshButtonClick"
                                        Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconRefresh}"
                                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                   FontSize="14"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="Refresh"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource GhostButtonStyle}"
                                        ToolTip="Notifications"
                                        Margin="0,0,8,0"
                                        Click="OnNotificationsButtonClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconBell}"
                                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                   FontSize="14"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="Alerts"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        ToolTip="Command Palette (Ctrl+K)"
                                        Click="OnCommandPaletteButtonClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource IconSearch}"
                                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                   FontSize="14"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="Command Palette"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Frame x:Name="ContentFrame"
                       Grid.Row="2"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent"
                       AutomationProperties.AutomationId="ContentFrame"
                       AutomationProperties.Name="Main Content Frame"
                       Navigated="OnContentFrameNavigated" />
            </Grid>
        </DockPanel>
    </Grid>
</Page>
