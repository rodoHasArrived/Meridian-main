<Page x:Class="Meridian.Wpf.Views.WatchlistPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      Unloaded="OnPageUnloaded"
      AutomationProperties.Name="Watchlist">
    <Page.Resources>
        <Style x:Key="WatchlistCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ConsoleBackgroundMediumBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ConsoleTextMutedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource ConsoleTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20,28,32">
        <Grid MaxWidth="1200">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Style="{StaticResource EmbeddedShellHeroCardStyle}" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="14"
                            Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                            BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1">
                        <TextBlock Text="&#xE7B3;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="24" Foreground="{StaticResource InfoColorBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Watchlists" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="Curate symbol sets for operator monitoring, imports, and quick workspace loading."
                                   Style="{StaticResource CardDescriptionStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Toolbar -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBox x:Name="SearchBox" Width="250"
                                 AutomationProperties.AutomationId="WatchlistSearchBox"
                                 Background="{DynamicResource ConsoleBackgroundDarkBrush}"
                                 Foreground="{DynamicResource ConsoleTextBrush}"
                                 BorderBrush="{DynamicResource ConsoleBorderBrush}"
                                 Padding="8,6" Margin="0,0,12,0"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{DynamicResource ConsoleBackgroundDarkBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <TextBlock Text="Search watchlists..." Foreground="{DynamicResource ConsoleTextMutedBrush}"
                                   VerticalAlignment="Center" IsHitTestVisible="False" Margin="-230,0,0,0"
                                   Visibility="{Binding Text.Length, ElementName=SearchBox, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=Inverse, FallbackValue=Visible}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="+ New Watchlist" Command="{Binding CreateWatchlistCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Import" Command="{Binding ImportWatchlistCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Watchlist posture -->
            <Border x:Name="WatchlistPostureCard"
                    Grid.Row="2"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,16"
                    Padding="16"
                    AutomationProperties.Name="Watchlist posture"
                    AutomationProperties.AutomationId="WatchlistPostureCard">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Width="32" Height="32" CornerRadius="10"
                                    Background="{StaticResource ConsoleAccentBlueAlpha10Brush}"
                                    BorderBrush="{StaticResource InfoColorBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,10,0">
                                <TextBlock Text="&#xE8A5;"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="15"
                                           Foreground="{StaticResource InfoColorBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <StackPanel>
                                <TextBlock Text="{Binding PostureTitle}"
                                           AutomationProperties.AutomationId="WatchlistPostureTitle"
                                           Style="{StaticResource CardHeaderStyle}"
                                           Margin="0" />
                                <TextBlock Text="{Binding PostureDetail}"
                                           AutomationProperties.AutomationId="WatchlistPostureDetail"
                                           Style="{StaticResource CardDescriptionStyle}"
                                           Margin="0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <WrapPanel Grid.Column="1"
                               MaxWidth="560"
                               Margin="24,0,0,0"
                               VerticalAlignment="Center">
                        <Border Background="{StaticResource ConsoleBackgroundLightBrush}"
                                BorderBrush="{StaticResource ConsoleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,6"
                                Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Saved"
                                           FontSize="10"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                <TextBlock Text="{Binding TotalWatchlistsText}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource ConsoleBackgroundLightBrush}"
                                BorderBrush="{StaticResource ConsoleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,6"
                                Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Pinned"
                                           FontSize="10"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                <TextBlock Text="{Binding PinnedWatchlistsText}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource ConsoleBackgroundLightBrush}"
                                BorderBrush="{StaticResource ConsoleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,6"
                                Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Symbols"
                                           FontSize="10"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                <TextBlock Text="{Binding SymbolCoverageText}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource ConsoleAccentBlueAlpha10Brush}"
                                BorderBrush="{StaticResource InfoColorBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,6">
                            <StackPanel>
                                <TextBlock Text="{Binding VisibleScopeText}"
                                           AutomationProperties.AutomationId="WatchlistVisibleScopeText"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InfoColorBrush}" />
                                <TextBlock Text="{Binding PostureActionText}"
                                           FontSize="10"
                                           Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- Watchlist Grid -->
            <ItemsControl x:Name="WatchlistsContainer" Grid.Row="3"
                          ItemsSource="{Binding FilteredWatchlists}"
                          Visibility="{Binding ListVisibility}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="350" Margin="0,0,16,16" CornerRadius="12"
                                Background="{StaticResource PremiumPanelBrush}" BorderBrush="{StaticResource ConsoleBorderBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <Border Grid.Row="0" CornerRadius="8,8,0,0" Padding="16,12">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding ColorValue, FallbackValue={StaticResource ChartSurfaceColor}}"/>
                                    </Border.Background>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="16"
                                                       Foreground="White" TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding SymbolCount}" Foreground="{StaticResource TopBarTextBrush}" FontSize="12"
                                                           VerticalAlignment="Center"/>
                                                <Border Visibility="{Binding PinnedBadgeVisibility}"
                                                        AutomationProperties.Name="Pinned watchlist"
                                                        AutomationProperties.AutomationId="WatchlistPinnedBadge"
                                                        Background="#33FFFFFF"
                                                        BorderBrush="#66FFFFFF"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="6,1"
                                                        Margin="8,0,0,0">
                                                    <TextBlock Text="Pinned"
                                                               Foreground="White"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="&#xE718;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                    Style="{StaticResource ActionButtonStyle}" Foreground="White"
                                                    Tag="{Binding Id}" Click="PinWatchlist_Click"
                                                    ToolTip="Pin watchlist"/>
                                            <Button Content="&#xE712;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                    Style="{StaticResource ActionButtonStyle}" Foreground="White"
                                                    Tag="{Binding Id}" Click="WatchlistMenu_Click"
                                                    ToolTip="More options"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Symbols Preview -->
                                <Border Grid.Row="1" Padding="16,12" MinHeight="100">
                                    <ItemsControl ItemsSource="{Binding SymbolsPreview}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource ConsoleBackgroundDarkBrush}"
                                                        CornerRadius="4" Padding="8,4" Margin="0,0,6,6">
                                                    <TextBlock Text="{Binding}" FontFamily="{StaticResource MeridianDataFontFamily}" FontSize="12"
                                                               Foreground="{DynamicResource ConsoleTextBrush}"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>

                                <!-- Actions -->
                                <Border Grid.Row="2" BorderThickness="0,1,0,0"
                                        BorderBrush="{DynamicResource ConsoleBorderBrush}" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding ModifiedText}"
                                                   Foreground="{DynamicResource ConsoleTextMutedBrush}" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="Load" Tag="{Binding Id}" Click="LoadWatchlist_Click"
                                                    Background="{StaticResource InfoColorBrush}" Foreground="White"
                                                    BorderThickness="0" Padding="12,4" Margin="0,0,6,0" FontSize="12"/>
                                            <Button Content="Edit" Tag="{Binding Id}" Click="EditWatchlist_Click"
                                                    Background="{DynamicResource ConsoleBackgroundDarkBrush}"
                                                    Foreground="{DynamicResource ConsoleTextBrush}"
                                                    BorderThickness="0" Padding="12,4" FontSize="12"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Empty State -->
            <Border x:Name="EmptyState" Grid.Row="3" Visibility="{Binding EmptyStateVisibility}"
                    Style="{StaticResource CardStyle}" Padding="48" HorizontalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE8F1;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                               FontSize="48" Foreground="{StaticResource ConsoleTextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="{Binding EmptyStateTitle}" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource ConsoleTextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding EmptyStateDescription}"
                               Foreground="{DynamicResource ConsoleTextMutedBrush}"
                               TextWrapping="Wrap"
                               MaxWidth="420"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Clear Search"
                                Command="{Binding ClearSearchCommand}"
                                Visibility="{Binding SearchText.Length, Converter={StaticResource IntToVisibilityConverter}}"
                                AutomationProperties.AutomationId="WatchlistClearSearchButton"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,0"/>
                        <Button Content="Create Watchlist"
                                Command="{Binding CreateWatchlistCommand}"
                                AutomationProperties.AutomationId="WatchlistCreateWatchlistButton"
                                Background="{StaticResource SuccessColorBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="24,12"
                                HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
