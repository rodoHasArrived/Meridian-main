<UserControl x:Class="Meridian.Wpf.Views.ClusterStatusPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Meridian.Wpf.Views"
             xmlns:converters="clr-namespace:Meridian.Wpf.Converters"
             Background="White">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="16,12,16,12" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="Cluster Status" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       VerticalAlignment="Center"/>
            
            <ProgressBar Width="20" Height="20" Margin="12,0,0,0"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=True}"
                        IsIndeterminate="True"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#F5F5F5" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
            <Grid>
                <!-- Mesh Disabled State -->
                <Grid Visibility="{Binding IsMeshEnabled, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=True}">
                    <TextBlock Text="{Binding StatusMessage}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Foreground="#666666"
                              FontSize="14"/>
                </Grid>

                <!-- Mesh Enabled State with DataGrid -->
                <Grid Visibility="{Binding IsMeshEnabled, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Status Bar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,12,16,12" VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusMessage}"
                                  Foreground="#333333"
                                  FontSize="12"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding LocalNodeId, StringFormat=' (Local: {0})'}"
                                  Foreground="#999999"
                                  FontSize="11"
                                  Margin="8,0,0,0"
                                  VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1" 
                             ItemsSource="{Binding Nodes}"
                             AutoGenerateColumns="False"
                             CanUserAddRows="False"
                             CanUserDeleteRows="False"
                             CanUserResizeRows="False"
                             SelectionMode="Single"
                             BorderThickness="0"
                             HeadersVisibility="Column">
                        
                        <DataGrid.Columns>
                            <!-- Node ID -->
                            <DataGridTextColumn Header="Node ID" 
                                              Binding="{Binding NodeId}"
                                              Width="*"
                                              IsReadOnly="True"/>
                            
                            <!-- Symbols Owned -->
                            <DataGridTextColumn Header="Symbols Owned" 
                                              Binding="{Binding OwnedSymbolCount}"
                                              Width="120"
                                              IsReadOnly="True"/>
                            
                            <!-- Last Seen -->
                            <DataGridTextColumn Header="Last Seen" 
                                              Binding="{Binding LastSeenAgo}"
                                              Width="100"
                                              IsReadOnly="True"/>
                            
                            <!-- Local -->
                            <DataGridTemplateColumn Header="Local" Width="60" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE73E;" 
                                                      FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                      Foreground="{Binding StatusColor}"
                                                      FontSize="14"
                                                      FontWeight="Bold"
                                                      Visibility="{Binding IsLocal, Converter={StaticResource BoolToVisibilityConverter}}"
                                                      HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
