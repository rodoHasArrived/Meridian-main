<Page x:Class="Meridian.Wpf.Views.TradingHoursPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      AutomationProperties.Name="Trading Hours">

    <Page.Resources>
        <Style x:Key="TableHeaderCellStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="TableCellStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="TableCellMutedStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20,28,32">
        <StackPanel MaxWidth="1200">
            <!-- Header -->
            <Border Style="{StaticResource EmbeddedShellHeroCardStyle}" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="14"
                            Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                            BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1">
                        <TextBlock Text="&#xE823;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="24" Foreground="{StaticResource InfoColorBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Trading Hours" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="Market sessions, extended hours, and exchange-level status windows for major venues."
                                   Style="{StaticResource CardDescriptionStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Current Market Status -->
            <Border Style="{StaticResource CardStyle}"
                    Margin="0,0,0,24"
                    AutomationProperties.AutomationId="TradingHoursMarketStatusCard">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,24,0">
                            <Ellipse Width="12" Height="12"
                                     Fill="{Binding MarketStatusDotFill}"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding MarketStatusText}"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="{Binding MarketStatusTextForeground}"
                                       VerticalAlignment="Center"
                                       AutomationProperties.AutomationId="TradingHoursMarketStatusText" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding MarketStatusReasonText}"
                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                       FontSize="13" />
                            <TextBlock Text="{Binding NextSessionText}"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       FontSize="12" Margin="0,2,0,0" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{Binding MarketStatusTimeText}"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   FontSize="11" VerticalAlignment="Center" />
                    </Grid>

                    <Rectangle Grid.Row="1"
                               Height="1"
                               Fill="{StaticResource ConsoleBorderBrush}"
                               Margin="0,18" />

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,18,0">
                            <TextBlock Text="{Binding SessionBriefingToneLabel}"
                                       Foreground="{StaticResource InfoColorBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       AutomationProperties.AutomationId="TradingHoursSessionBriefingTone" />
                            <TextBlock Text="{Binding SessionBriefingTitle}"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"
                                       AutomationProperties.AutomationId="TradingHoursSessionBriefingTitle" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SessionBriefingDetail}"
                                   Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   AutomationProperties.AutomationId="TradingHoursSessionBriefingDetail" />
                        <Border Grid.Column="2"
                                Background="{StaticResource PremiumPanelBrush}"
                                BorderBrush="{StaticResource ConsoleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,6"
                                MaxWidth="260"
                                Margin="18,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding SessionBriefingTargetText}"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       AutomationProperties.AutomationId="TradingHoursSessionBriefingTarget" />
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- US Markets Card -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="{StaticResource IconGlobe}"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="18"
                                   Foreground="{StaticResource InfoColorBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="US Markets"
                                   Style="{StaticResource CardHeaderStyle}"
                                   Margin="8,0,0,0" />
                    </StackPanel>

                    <!-- Table Header -->
                    <Border Background="{StaticResource PremiumPanelBrush}"
                            BorderBrush="{StaticResource ConsoleBorderBrush}" BorderThickness="1"
                            CornerRadius="12,12,0,0" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Exchange" Style="{StaticResource TableHeaderCellStyle}" />
                            <TextBlock Grid.Column="1" Text="Session" Style="{StaticResource TableHeaderCellStyle}" />
                            <TextBlock Grid.Column="2" Text="Hours (ET)" Style="{StaticResource TableHeaderCellStyle}" />
                            <TextBlock Grid.Column="3" Text="Status" Style="{StaticResource TableHeaderCellStyle}" />
                        </Grid>
                    </Border>

                    <!-- Row 1: NYSE Regular -->
                    <Border Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="NYSE" Style="{StaticResource TableCellStyle}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Regular Session" Style="{StaticResource TableCellStyle}" />
                            <TextBlock Grid.Column="2" Text="9:30 AM - 4:00 PM ET" Style="{StaticResource TableCellStyle}" />
                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{Binding NyseRegularStatusDotFill}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding NyseRegularStatusText}" Foreground="{Binding NyseRegularStatusForeground}" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Row 2: NYSE Pre-Market (alternating bg) -->
                    <Border Background="{StaticResource PremiumPanelBrush}" BorderBrush="{StaticResource ConsoleBorderBrush}" BorderThickness="1,0,1,0" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="NYSE" Style="{StaticResource TableCellMutedStyle}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Pre-Market" Style="{StaticResource TableCellMutedStyle}" />
                            <TextBlock Grid.Column="2" Text="4:00 AM - 9:30 AM ET" Style="{StaticResource TableCellMutedStyle}" />
                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource InfoColorBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Extended" Foreground="{StaticResource InfoColorBrush}" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Row 3: NYSE After-Hours -->
                    <Border Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="NYSE" Style="{StaticResource TableCellMutedStyle}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="After-Hours" Style="{StaticResource TableCellMutedStyle}" />
                            <TextBlock Grid.Column="2" Text="4:00 PM - 8:00 PM ET" Style="{StaticResource TableCellMutedStyle}" />
                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource InfoColorBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Extended" Foreground="{StaticResource InfoColorBrush}" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Separator -->
                    <Rectangle Height="1" Fill="{StaticResource ConsoleBorderBrush}" Margin="0,4" />

                    <!-- Row 4: NASDAQ Regular (alternating bg) -->
                    <Border Background="{StaticResource ConsoleBackgroundMediumBrush}" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="NASDAQ" Style="{StaticResource TableCellStyle}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Regular Session" Style="{StaticResource TableCellStyle}" />
                            <TextBlock Grid.Column="2" Text="9:30 AM - 4:00 PM ET" Style="{StaticResource TableCellStyle}" />
                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{Binding NasdaqRegularStatusDotFill}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding NasdaqRegularStatusText}" Foreground="{Binding NasdaqRegularStatusForeground}" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Row 5: NASDAQ Pre-Market -->
                    <Border Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="NASDAQ" Style="{StaticResource TableCellMutedStyle}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Pre-Market" Style="{StaticResource TableCellMutedStyle}" />
                            <TextBlock Grid.Column="2" Text="4:00 AM - 9:30 AM ET" Style="{StaticResource TableCellMutedStyle}" />
                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource InfoColorBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Extended" Foreground="{StaticResource InfoColorBrush}" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Row 6: NASDAQ Extended Hours (alternating bg) -->
                    <Border Background="{StaticResource PremiumPanelBrush}" BorderBrush="{StaticResource ConsoleBorderBrush}" BorderThickness="1,0,1,1" Padding="12,10"
                            CornerRadius="0,0,12,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="NASDAQ" Style="{StaticResource TableCellMutedStyle}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Extended Hours" Style="{StaticResource TableCellMutedStyle}" />
                            <TextBlock Grid.Column="2" Text="4:00 PM - 8:00 PM ET" Style="{StaticResource TableCellMutedStyle}" />
                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource InfoColorBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Extended" Foreground="{StaticResource InfoColorBrush}" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- International Markets Card -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="{StaticResource IconGlobe}"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="18"
                                   Foreground="{StaticResource InfoColorBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="International Markets"
                                   Style="{StaticResource CardHeaderStyle}"
                                   Margin="8,0,0,0" />
                    </StackPanel>

                    <!-- Table Header -->
                    <Border Background="{StaticResource PremiumPanelBrush}"
                            BorderBrush="{StaticResource ConsoleBorderBrush}" BorderThickness="1"
                            CornerRadius="12,12,0,0" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Exchange" Style="{StaticResource TableHeaderCellStyle}" />
                            <TextBlock Grid.Column="1" Text="Location" Style="{StaticResource TableHeaderCellStyle}" />
                            <TextBlock Grid.Column="2" Text="Trading Hours" Style="{StaticResource TableHeaderCellStyle}" />
                            <TextBlock Grid.Column="3" Text="Timezone" Style="{StaticResource TableHeaderCellStyle}" />
                        </Grid>
                    </Border>

                    <!-- Row 1: LSE -->
                    <Border Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="LSE" Style="{StaticResource TableCellStyle}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="London" Style="{StaticResource TableCellMutedStyle}" />
                            <TextBlock Grid.Column="2" Text="8:00 AM - 4:30 PM" Style="{StaticResource TableCellStyle}" />
                            <TextBlock Grid.Column="3" Text="GMT" Style="{StaticResource TableCellMutedStyle}" />
                        </Grid>
                    </Border>

                    <!-- Row 2: TSE (alternating bg) -->
                    <Border Background="{StaticResource ConsoleBackgroundMediumBrush}" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="TSE" Style="{StaticResource TableCellStyle}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Tokyo" Style="{StaticResource TableCellMutedStyle}" />
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="9:00 AM - 3:00 PM" Style="{StaticResource TableCellStyle}" />
                                <TextBlock Text="Lunch break: 11:30 AM - 12:30 PM" FontSize="11"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,2,0,0" />
                            </StackPanel>
                            <TextBlock Grid.Column="3" Text="JST" Style="{StaticResource TableCellMutedStyle}" />
                        </Grid>
                    </Border>

                    <!-- Row 3: HKEX -->
                    <Border Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="HKEX" Style="{StaticResource TableCellStyle}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Hong Kong" Style="{StaticResource TableCellMutedStyle}" />
                            <TextBlock Grid.Column="2" Text="9:30 AM - 4:00 PM" Style="{StaticResource TableCellStyle}" />
                            <TextBlock Grid.Column="3" Text="HKT" Style="{StaticResource TableCellMutedStyle}" />
                        </Grid>
                    </Border>

                    <!-- Row 4: ASX (alternating bg) -->
                    <Border Background="{StaticResource ConsoleBackgroundMediumBrush}" Padding="12,10"
                            CornerRadius="0,0,8,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ASX" Style="{StaticResource TableCellStyle}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Sydney" Style="{StaticResource TableCellMutedStyle}" />
                            <TextBlock Grid.Column="2" Text="10:00 AM - 4:00 PM" Style="{StaticResource TableCellStyle}" />
                            <TextBlock Grid.Column="3" Text="AEST" Style="{StaticResource TableCellMutedStyle}" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- US Market Holidays Card -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="{StaticResource IconCalendar}"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="18"
                                   Foreground="{StaticResource InfoColorBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding HolidaysHeaderText}"
                                   Style="{StaticResource CardHeaderStyle}"
                                   Margin="8,0,0,0" />
                    </StackPanel>

                    <!-- Table Header -->
                    <Border Background="{StaticResource ConsoleBackgroundLightBrush}"
                            CornerRadius="8,8,0,0" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Date" Style="{StaticResource TableHeaderCellStyle}" />
                            <TextBlock Grid.Column="1" Text="Holiday" Style="{StaticResource TableHeaderCellStyle}" />
                            <TextBlock Grid.Column="2" Text="Market Status" Style="{StaticResource TableHeaderCellStyle}" />
                        </Grid>
                    </Border>

                    <!-- Dynamic holiday rows -->
                    <ItemsControl ItemsSource="{Binding Holidays}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding DateText}" Style="{StaticResource TableCellStyle}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Style="{StaticResource TableCellStyle}" FontWeight="SemiBold" />
                                        <Border Grid.Column="2" Style="{StaticResource ErrorBadgeStyle}" HorizontalAlignment="Left">
                                            <TextBlock Text="Closed" Foreground="{StaticResource ErrorColorBrush}" FontSize="12" FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
