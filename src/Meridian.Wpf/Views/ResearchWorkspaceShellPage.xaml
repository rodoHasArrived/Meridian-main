<views:ResearchWorkspaceShellPageBase x:Class="Meridian.Wpf.Views.ResearchWorkspaceShellPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:views="clr-namespace:Meridian.Wpf.Views"
      xmlns:copy="clr-namespace:Meridian.Wpf.Copy"
      mc:Ignorable="d"
      d:DesignHeight="900"
      d:DesignWidth="1400"
      Background="{DynamicResource ConsoleBackgroundDarkBrush}"
      Loaded="OnPageLoaded"
      Unloaded="OnPageUnloaded"
      AutomationProperties.Name="{x:Static copy:WorkspaceCopyCatalog.Research.ShellTitle}"
      AutomationProperties.AutomationId="ResearchWorkspaceShellPage">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="200" />
        </Grid.RowDefinitions>

        <views:WorkspaceShellContextStripControl x:Name="ContextStrip" />

        <ScrollViewer Grid.Row="1"
                      Margin="0,16,0,0"
                      VerticalScrollBarVisibility="Auto"
                      Padding="8,4,8,16">
            <StackPanel MaxWidth="1400">
                <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="44"
                                        Height="44"
                                        CornerRadius="14"
                                        Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                        BorderBrush="{StaticResource InfoColorBrush}"
                                        BorderThickness="1">
                                    <TextBlock Text="&#xE9D9;"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="24"
                                               Foreground="{StaticResource InfoColorBrush}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="12,0,0,0">
                                    <TextBlock Text="Research" Style="{StaticResource PageTitleStyle}" />
                                    <TextBlock Text="Market briefing, run studio, and paper-promotion review"
                                               Style="{StaticResource CardDescriptionStyle}" />
                                </StackPanel>
                            </StackPanel>

                            <Border Margin="0,18,0,0"
                                    Padding="14,12"
                                    CornerRadius="12"
                                    Background="#12253A"
                                    BorderBrush="#22486B"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Selected Run"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="#7EA3C5" />
                                    <TextBlock x:Name="ActiveRunNameText"
                                               Margin="0,6,0,0"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               Text="No selected run" />
                                    <TextBlock x:Name="ActiveRunMetaText"
                                               Margin="0,4,0,0"
                                               FontSize="12"
                                               Foreground="#A8BED7"
                                               Text="Start a backtest or choose a run from history." />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top"
                                    Margin="16,0,0,0">
                            <Border Style="{StaticResource WorkspaceKpiTileStyle}" Margin="0,0,12,0">
                                <StackPanel Style="{StaticResource WorkspaceSummaryTileContentStyle}">
                                    <TextBlock Text="Runs"
                                               FontSize="11"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock x:Name="TotalRunsText"
                                               Text="—"
                                               Margin="0,4,0,0"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="All tracked runs"
                                               Margin="0,4,0,0"
                                               FontSize="11"
                                               Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource WorkspaceKpiTileStyle}" Margin="0,0,12,0">
                                <StackPanel Style="{StaticResource WorkspaceSummaryTileContentStyle}">
                                    <TextBlock Text="Promoted"
                                               FontSize="11"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock x:Name="PromotedText"
                                               Text="—"
                                               Margin="0,4,0,0"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource SuccessColorBrush}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="Ready for next mode"
                                               Margin="0,4,0,0"
                                               FontSize="11"
                                               Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource WorkspaceKpiTileStyle}">
                                <StackPanel Style="{StaticResource WorkspaceSummaryTileContentStyle}">
                                    <TextBlock Text="Pending"
                                               FontSize="11"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock x:Name="PendingReviewText"
                                               Text="—"
                                               Margin="0,4,0,0"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource WarningColorBrush}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="Awaiting review"
                                               Margin="0,4,0,0"
                                               FontSize="11"
                                               Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <views:WorkspaceCommandBarControl x:Name="CommandBar"
                                                  CommandInvoked="OnCommandBarCommandInvoked"
                                                  Margin="0,0,0,24" />

                <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,24">
                    <StackPanel>
                        <Grid Style="{StaticResource WorkspaceCardHeaderGridStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Market Briefing" Style="{StaticResource CardHeaderStyle}" />
                                <TextBlock x:Name="BriefingSummaryText"
                                           Text="Pinned research context, watchlists, saved comparisons, and workflow alerts."
                                           Style="{StaticResource CardDescriptionStyle}"
                                           Margin="0,6,0,0" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Style="{StaticResource InfoBadgeInlineStyle}"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="BriefingGeneratedText"
                                           Text="Updated just now"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BadgeInfoForegroundBrush}" />
                            </Border>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource StudioPanelStyle}" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="Pinned Insights" Style="{StaticResource StudioPanelTitleStyle}" />

                                    <ItemsControl x:Name="BriefingInsightsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource WorkspaceQueueItemCardStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                                            <TextBlock Text="{Binding Headline}"
                                                                       Margin="0,4,0,0"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource SuccessColorBrush}" />
                                                            <TextBlock Text="{Binding Subtitle}"
                                                                       Margin="0,4,0,0"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                                            <TextBlock Text="{Binding Summary}"
                                                                       Margin="0,4,0,0"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                        <Button Grid.Column="1"
                                                                Content="Open"
                                                                Tag="{Binding RunId}"
                                                                Click="OpenBriefingRun_Click"
                                                                Style="{StaticResource SecondaryButtonStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock x:Name="NoBriefingInsightsText"
                                               Margin="0,8,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                               Text="Pinned insights will appear here once runs are available."
                                               Visibility="Collapsed" />

                                    <Rectangle Margin="0,16,0,14"
                                               Height="1"
                                               Fill="{StaticResource ConsoleBorderBrush}" />

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Watchlists" Style="{StaticResource StudioPanelTitleStyle}" />
                                        <Button Grid.Column="1"
                                                Content="Open Watchlists"
                                                Click="OpenWatchlists_Click"
                                                Style="{StaticResource LinkButtonStyle}" />
                                    </Grid>

                                    <ItemsControl x:Name="BriefingWatchlistsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource WorkspaceQueueItemCardStyle}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                                        <TextBlock Text="{Binding Summary}"
                                                                   Margin="0,4,0,0"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock x:Name="NoBriefingWatchlistsText"
                                               Margin="0,8,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                               Text="Pinned watchlists will appear here."
                                               Visibility="Collapsed" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource StudioPanelStyle}" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="What Changed" Style="{StaticResource StudioPanelTitleStyle}" />

                                    <ItemsControl x:Name="BriefingWhatChangedList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource WorkspaceQueueItemCardStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                                            <TextBlock Text="{Binding Summary}"
                                                                       Margin="0,4,0,0"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding RelativeTime}"
                                                                       Margin="0,4,0,0"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                                        </StackPanel>
                                                        <Button Grid.Column="1"
                                                                Content="Open"
                                                                Tag="{Binding RunId}"
                                                                Click="OpenBriefingRun_Click"
                                                                Style="{StaticResource SecondaryButtonStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock x:Name="NoBriefingWhatChangedText"
                                               Margin="0,8,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                               Text="Recent workflow changes will appear here."
                                               Visibility="Collapsed" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource StudioPanelStyle}">
                                <StackPanel>
                                    <TextBlock Text="Alerts" Style="{StaticResource StudioPanelTitleStyle}" />

                                    <ItemsControl x:Name="BriefingAlertsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource WorkspaceQueueItemCardStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                                            <TextBlock Text="{Binding Summary}"
                                                                       Margin="0,4,0,0"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                        <Button Grid.Column="1"
                                                                Content="{Binding ActionLabel}"
                                                                Tag="{Binding RunId}"
                                                                Click="OpenBriefingAlert_Click"
                                                                Style="{StaticResource SecondaryButtonStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock x:Name="NoBriefingAlertsText"
                                               Margin="0,8,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                               Text="Blocking alerts will appear here."
                                               Visibility="Collapsed" />

                                    <Rectangle Margin="0,16,0,14"
                                               Height="1"
                                               Fill="{StaticResource ConsoleBorderBrush}" />

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Saved Comparisons" Style="{StaticResource StudioPanelTitleStyle}" />
                                        <Button Grid.Column="1"
                                                Content="Run Browser"
                                                Click="OpenStrategyRuns_Click"
                                                Style="{StaticResource LinkButtonStyle}" />
                                    </Grid>

                                    <ItemsControl x:Name="BriefingComparisonsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource WorkspaceQueueItemCardStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding StrategyName}"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                                            <TextBlock Text="{Binding ModeSummary}"
                                                                       Margin="0,4,0,0"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                                            <TextBlock Text="{Binding Summary}"
                                                                       Margin="0,4,0,0"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                        <Button Grid.Column="1"
                                                                Content="Compare"
                                                                Tag="{Binding AnchorRunId}"
                                                                Click="OpenBriefingComparison_Click"
                                                                Style="{StaticResource SecondaryButtonStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock x:Name="NoBriefingComparisonsText"
                                               Margin="0,8,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                               Text="Saved comparisons will appear here once runs can be staged side by side."
                                               Visibility="Collapsed" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource StudioPanelStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Scenario &amp; Session" Style="{StaticResource StudioPanelTitleStyle}" />
                            <TextBlock x:Name="ScenarioStrategyText"
                                       Margin="0,10,0,0"
                                       Style="{StaticResource StudioValueStyle}"
                                       Text="No strategy selected" />
                            <TextBlock x:Name="ScenarioCoverageText"
                                       Margin="0,8,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                       Text="No research session restored." />
                            <Rectangle Margin="0,14,0,14"
                                       Height="1"
                                       Fill="{StaticResource ConsoleBorderBrush}" />
                            <TextBlock Text="Studio posture" Style="{StaticResource StudioPanelTitleStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                       Text="Left rail: strategy setup and data coverage. Center: run progress and compare surface. Right rail: portfolio, ledger, and attribution inspectors." />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource StudioPanelStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Run Studio" Style="{StaticResource StudioPanelTitleStyle}" />
                            <TextBlock x:Name="RunStatusText"
                                       Margin="0,10,0,0"
                                       Style="{StaticResource StudioValueStyle}"
                                       Text="Awaiting run selection" />
                            <TextBlock x:Name="RunPerformanceText"
                                       Margin="0,8,0,0"
                                       FontSize="13"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                       Text="Compare runs, equity, and fills from a selected strategy run." />
                            <TextBlock x:Name="RunCompareText"
                                       Margin="0,8,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                       Text="Use the bottom history rail to select a run and load detail panels." />
                            <Border Margin="0,16,0,0"
                                    Padding="14"
                                    CornerRadius="12"
                                    Background="{StaticResource ConsoleAccentBlueAlpha10Brush}"
                                    BorderBrush="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                    BorderThickness="1">
                                <TextBlock Text="Drag pages into the dock below to split left, right, below, tab, or float them into a separate window."
                                           FontSize="12"
                                           Foreground="{StaticResource InfoColorBrush}"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource StudioPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Inspector Rail" Style="{StaticResource StudioPanelTitleStyle}" />
                            <TextBlock Text="Portfolio"
                                       Margin="0,10,0,0"
                                       Style="{StaticResource StudioPanelTitleStyle}" />
                            <TextBlock x:Name="PortfolioPreviewText"
                                       Margin="0,6,0,0"
                                       FontSize="13"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                       Text="Portfolio inspector opens here once a run is selected." />
                            <TextBlock Text="Ledger"
                                       Margin="0,14,0,0"
                                       Style="{StaticResource StudioPanelTitleStyle}" />
                            <TextBlock x:Name="LedgerPreviewText"
                                       Margin="0,6,0,0"
                                       FontSize="13"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                       Text="Ledger inspector opens here once a run is selected." />
                            <TextBlock Text="Risk snapshot"
                                       Margin="0,14,0,0"
                                       Style="{StaticResource StudioPanelTitleStyle}" />
                            <TextBlock x:Name="RiskPreviewText"
                                       Margin="0,6,0,0"
                                       FontSize="13"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                       Text="Risk preview becomes available after a completed run is selected." />
                            <WrapPanel Style="{StaticResource WorkspaceCardFooterPanelStyle}">
                                <Button Content="Accounting Impact"
                                        Click="OpenAccountingImpact_Click"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Margin="0,0,10,8" />
                                <Button Content="Reconciliation"
                                        Click="OpenReconciliationPreview_Click"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Margin="0,0,10,8" />
                                <Button Content="Audit Trail"
                                        Click="OpenAuditTrail_Click"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Margin="0,0,10,8" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource StudioPanelStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Run History Rail" Style="{StaticResource StudioPanelTitleStyle}" />
                                <Button Grid.Column="1"
                                        Content="Browse All"
                                        Click="OpenStrategyRuns_Click"
                                        Style="{StaticResource LinkButtonStyle}" />
                            </Grid>

                            <ItemsControl x:Name="RecentRunsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource WorkspaceQueueItemCardStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding StrategyName}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                                    <TextBlock Text="{Binding NetPnlFormatted}"
                                                               Margin="0,4,0,0"
                                                               FontSize="12"
                                                               Foreground="{Binding NetPnlBrush}" />
                                                    <TextBlock Text="{Binding StatusLabel}"
                                                               Margin="0,4,0,0"
                                                               FontSize="11"
                                                               Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Content="Open"
                                                        Tag="{Binding RunId}"
                                                        Click="OpenRunFromHistory_Click"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock x:Name="NoRunsText"
                                       Margin="0,8,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       Text="No strategy runs yet. Start a new backtest to see results here."
                                       Visibility="Collapsed" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Promotion Pipeline" Style="{StaticResource CardHeaderStyle}" />
                                <Border Style="{StaticResource InfoBadgeInlineStyle}"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="PromotionCountBadge"
                                               Text="0"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BadgeInfoForegroundBrush}" />
                                </Border>
                            </StackPanel>

                            <TextBlock Text="Strategies that have completed backtesting and are candidates for paper or live promotion."
                                       Style="{StaticResource CardDescriptionStyle}"
                                       Margin="0,0,0,12" />

                            <ItemsControl x:Name="PromotionCandidatesList"
                                          AutomationProperties.AutomationId="PromotionCandidatesList"
                                          AutomationProperties.Name="Promotion Candidates">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource ConsoleBackgroundLightBrush}"
                                                CornerRadius="10"
                                                Padding="16,12"
                                                Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding StrategyName}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                                    <TextBlock Text="{Binding PromotionReason}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <Border Background="{StaticResource SuccessColorAlpha20Brush}"
                                                            CornerRadius="6"
                                                            Padding="10,4"
                                                            Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding NextModeLabel}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource SuccessColorBrush}" />
                                                    </Border>
                                                    <Button Content="Review"
                                                            Tag="{Binding RunId}"
                                                            Click="ReviewPromotion_Click"
                                                            Style="{StaticResource SecondaryButtonStyle}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock x:Name="NoPromotionsText"
                                       Text="No promotion candidates. Complete a backtest run to see it here."
                                       FontSize="13"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       Visibility="Collapsed"
