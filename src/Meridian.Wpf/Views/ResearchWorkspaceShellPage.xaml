<Page x:Class="Meridian.Wpf.Views.ResearchWorkspaceShellPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:views="clr-namespace:Meridian.Wpf.Views"
      mc:Ignorable="d"
      d:DesignHeight="900"
      d:DesignWidth="1440"
      Background="{DynamicResource ConsoleBackgroundDarkBrush}"
      Loaded="OnPageLoaded"
      Unloaded="OnPageUnloaded"
      AutomationProperties.Name="Research Workspace"
      AutomationProperties.AutomationId="ResearchWorkspaceShellPage">

    <Page.Resources>
        <Style x:Key="StudioPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ConsoleCardSurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,16,16" />
        </Style>
        <Style x:Key="StudioPanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
        </Style>
        <Style x:Key="StudioValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextPrimaryBrush}" />
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#0C1826"
                BorderBrush="#213852"
                BorderThickness="1"
                CornerRadius="18"
                Padding="22"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="42"
                                Height="42"
                                CornerRadius="12"
                                Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                BorderBrush="{StaticResource InfoColorBrush}"
                                BorderThickness="1">
                            <TextBlock Text="&#xE9D9;"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="22"
                                       Foreground="{StaticResource InfoColorBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Backtest Studio"
                                       FontFamily="{StaticResource MeridianDisplayFontFamily}"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="White" />
                            <TextBlock Text="Configure, compare, inspect, and promote strategies without leaving the research workspace."
                                       Margin="0,6,0,0"
                                       FontSize="13"
                                       Foreground="#A8BED7"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>

                    <Border Margin="0,18,0,0"
                            Padding="14,12"
                            CornerRadius="12"
                            Background="#12253A"
                            BorderBrush="#22486B"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Selected Run"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#7EA3C5" />
                            <TextBlock x:Name="ActiveRunNameText"
                                       Margin="0,6,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Text="No selected run" />
                            <TextBlock x:Name="ActiveRunMetaText"
                                       Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="#A8BED7"
                                       Text="Start a backtest or choose a run from history." />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <Border Style="{StaticResource WorkspaceKpiTileStyle}"
                            Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock x:Name="TotalRunsText"
                                       Text="—"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Runs"
                                       FontSize="11"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WorkspaceKpiTileStyle}"
                            Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock x:Name="PromotedText"
                                       Text="—"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource SuccessColorBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Promoted"
                                       FontSize="11"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WorkspaceKpiTileStyle}">
                        <StackPanel>
                            <TextBlock x:Name="PendingReviewText"
                                       Text="—"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource WarningColorBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Pending"
                                       FontSize="11"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource ConsoleBackgroundMediumBrush}"
                BorderBrush="{StaticResource ConsoleBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14"
                Margin="0,0,0,16">
            <WrapPanel>
                <Button Content="&#xE9D9;  Reset Studio"
                        Click="NewBacktest_Click"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,10,0" />
                <Button x:Name="PromoteActiveRunButton"
                        Content="&#xE8FB;  Promote to Paper"
                        Click="PromoteActiveRun_Click"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,10,0" />
                <Button x:Name="OpenTradingCockpitButton"
                        Content="&#xE9F5;  Open Trading Cockpit"
                        Click="OpenTradingCockpit_Click"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,10,0" />
                <Button Content="&#xE8FD;  Run Browser"
                        Click="OpenStrategyRuns_Click"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="0,0,10,0" />
                <Button Content="&#xE7C3;  Run Detail"
                        Click="OpenRunDetailDocked_Click"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="0,0,10,0" />
                <Button Content="&#xE8B5;  Portfolio Inspector"
                        Click="OpenPortfolioInspector_Click"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="0,0,10,0" />
                <Button Content="&#xEE94;  Ledger Inspector"
                        Click="OpenLedgerInspector_Click"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="0,0,10,0" />
                <Button Content="&#xE943;  Lean Integration"
                        Click="OpenLean_Click"
                        Style="{StaticResource GhostButtonStyle}" />
            </WrapPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="1.1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource StudioPanelStyle}">
                <StackPanel>
                    <TextBlock Text="Scenario &amp; Session" Style="{StaticResource StudioPanelTitleStyle}" />
                    <TextBlock x:Name="ScenarioStrategyText"
                               Margin="0,10,0,0"
                               Style="{StaticResource StudioValueStyle}"
                               Text="No strategy selected" />
                    <TextBlock x:Name="ScenarioCoverageText"
                               Margin="0,8,0,0"
                               FontSize="12"
                               Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                               Text="No research session restored." />
                    <Rectangle Margin="0,14,0,14"
                               Height="1"
                               Fill="{StaticResource ConsoleBorderBrush}" />
                    <TextBlock Text="Studio posture"
                               Style="{StaticResource StudioPanelTitleStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="12"
                               Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                               Text="Left rail: strategy setup and data coverage. Center: run progress and compare surface. Right rail: portfolio, ledger, and attribution inspectors." />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource StudioPanelStyle}">
                <StackPanel>
                    <TextBlock Text="Run Studio" Style="{StaticResource StudioPanelTitleStyle}" />
                    <TextBlock x:Name="RunStatusText"
                               Margin="0,10,0,0"
                               Style="{StaticResource StudioValueStyle}"
                               Text="Awaiting run selection" />
                    <TextBlock x:Name="RunPerformanceText"
                               Margin="0,8,0,0"
                               FontSize="13"
                               Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                               Text="Compare runs, equity, and fills from a selected strategy run." />
                    <TextBlock x:Name="RunCompareText"
                               Margin="0,8,0,0"
                               FontSize="12"
                               Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                               Text="Use the bottom history rail to select a run and load detail panels." />
                    <Border Margin="0,16,0,0"
                            Padding="14"
                            CornerRadius="12"
                            Background="{StaticResource ConsoleAccentBlueAlpha10Brush}"
                            BorderBrush="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                            BorderThickness="1">
                        <TextBlock Text="Drag pages into the dock below to split left, right, below, tab, or float them into a separate window."
                                   FontSize="12"
                                   Foreground="{StaticResource InfoColorBrush}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource StudioPanelStyle}"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Inspector Rail" Style="{StaticResource StudioPanelTitleStyle}" />
                    <TextBlock Text="Portfolio"
                               Margin="0,10,0,0"
                               Style="{StaticResource StudioPanelTitleStyle}" />
                    <TextBlock x:Name="PortfolioPreviewText"
                               Margin="0,6,0,0"
                               FontSize="13"
                               Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                               Text="Portfolio inspector opens here once a run is selected." />
                    <TextBlock Text="Ledger"
                               Margin="0,14,0,0"
                               Style="{StaticResource StudioPanelTitleStyle}" />
                    <TextBlock x:Name="LedgerPreviewText"
                               Margin="0,6,0,0"
                               FontSize="13"
                               Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                               Text="Ledger inspector opens here once a run is selected." />
                    <TextBlock Text="Risk snapshot"
                               Margin="0,14,0,0"
                               Style="{StaticResource StudioPanelTitleStyle}" />
                    <TextBlock x:Name="RiskPreviewText"
                               Margin="0,6,0,0"
                               FontSize="13"
                               Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                               Text="Risk preview becomes available after a completed run is selected." />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.6*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StudioPanelStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Run History Rail" Style="{StaticResource StudioPanelTitleStyle}" />
                            <Button Grid.Column="1"
                                    Content="Browse All"
                                    Click="OpenStrategyRuns_Click"
                                    Style="{StaticResource LinkButtonStyle}" />
                        </Grid>

                        <ItemsControl x:Name="RecentRunsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource WorkspaceQueueItemCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding StrategyName}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                                <TextBlock Text="{Binding NetPnlFormatted}"
                                                           Margin="0,4,0,0"
                                                           FontSize="12"
                                                           Foreground="{Binding NetPnlBrush}" />
                                                <TextBlock Text="{Binding StatusLabel}"
                                                           Margin="0,4,0,0"
                                                           FontSize="11"
                                                           Foreground="{StaticResource ConsoleTextSecondaryBrush}" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="Open"
                                                    Tag="{Binding RunId}"
                                                    Click="OpenRunFromHistory_Click"
                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="NoRunsText"
                                   Margin="0,8,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   Text="No strategy runs yet. Start a new backtest to see results here."
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource StudioPanelStyle}"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Promotion Rail" Style="{StaticResource StudioPanelTitleStyle}" />
                            <Border Margin="10,0,0,0"
                                    Padding="8,2"
                                    CornerRadius="999"
                                    Background="{StaticResource ConsoleAccentBlueAlpha10Brush}">
                                <TextBlock x:Name="PromotionCountBadge"
                                           Text="0"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InfoColorBrush}" />
                            </Border>
                        </StackPanel>

                        <ItemsControl x:Name="PromotionCandidatesList"
                                      Margin="0,12,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource WorkspaceQueueItemCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding StrategyName}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                                <TextBlock Text="{Binding PromotionReason}"
                                                           Margin="0,4,0,0"
                                                           FontSize="11"
                                                           Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding NextModeLabel}"
                                                           Margin="0,4,0,0"
                                                           FontSize="11"
                                                           Foreground="{StaticResource SuccessColorBrush}" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="Review"
                                                    Tag="{Binding RunId}"
                                                    Click="ReviewPromotion_Click"
                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="NoPromotionsText"
                                   Margin="0,8,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   Text="No promotion candidates. Complete a backtest run to see them here."
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Background="{StaticResource ConsoleBackgroundMediumBrush}"
                    BorderBrush="{StaticResource ConsoleBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="12">
                <views:MeridianDockingManager x:Name="ResearchDockManager"
                                              PaneDropRequested="OnPaneDropRequested"
                                              AutomationProperties.Name="Research Dock Manager" />
            </Border>
        </Grid>
    </Grid>
</Page>
