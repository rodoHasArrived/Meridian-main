<Page x:Class="Meridian.Wpf.Views.TimeSeriesAlignmentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      AutomationProperties.Name="Time Series Alignment">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20,28,32">
        <StackPanel MaxWidth="1200">
            <Border Style="{StaticResource EmbeddedShellHeroCardStyle}" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="14"
                            Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                            BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1">
                        <TextBlock Text="&#xE9D9;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="24" Foreground="{StaticResource InfoColorBrush}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Time Series Alignment" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="Align multi-symbol time series for cross-sectional research, correlation studies, and paired analysis."
                                   Style="{StaticResource CardDescriptionStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16"
                    AutomationProperties.AutomationId="TimeSeriesAlignmentReadinessCard">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding AlignmentReadinessTitle}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ConsoleTextBrush}"
                                   AutomationProperties.AutomationId="TimeSeriesAlignmentReadinessTitle" />
                        <TextBlock Text="{Binding AlignmentReadinessDetail}"
                                   Style="{StaticResource CardDescriptionStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"
                                   AutomationProperties.AutomationId="TimeSeriesAlignmentReadinessDetail" />
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="{Binding SelectedSymbolsCountText}"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       FontSize="12"
                                       Margin="0,0,16,0" />
                            <TextBlock Text="{Binding DateScopeText}"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       FontSize="12"
                                       Margin="0,0,16,0" />
                            <TextBlock Text="{Binding SelectedFieldsText}"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       FontSize="12" />
                        </StackPanel>
                    </StackPanel>

                    <ProgressBar Grid.Column="1"
                                 Width="120"
                                 Height="8"
                                 IsIndeterminate="{Binding IsRunning}"
                                 Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"
                                 VerticalAlignment="Center"
                                 Margin="24,0,0,0"
                                 AutomationProperties.AutomationId="TimeSeriesAlignmentProgress" />
                </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Alignment Configuration" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,16" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,16,8">
                            <TextBlock Text="Alignment Name" Style="{StaticResource FormLabelStyle}" />
                            <TextBox Style="{StaticResource FormTextBoxStyle}"
                                     Text="{Binding AlignmentName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.AutomationId="TimeSeriesAlignmentNameBox" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,16,8">
                            <TextBlock Text="Target Frequency" Style="{StaticResource FormLabelStyle}" />
                            <ComboBox Style="{StaticResource FormComboBoxStyle}"
                                      ItemsSource="{Binding FrequencyOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Key"
                                      SelectedValue="{Binding SelectedFrequencyKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      AutomationProperties.AutomationId="TimeSeriesAlignmentFrequencyCombo" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,0,8">
                            <TextBlock Text="Preset" Style="{StaticResource FormLabelStyle}" />
                            <ComboBox Style="{StaticResource FormComboBoxStyle}"
                                      ItemsSource="{Binding PresetOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Key"
                                      SelectedValue="{Binding SelectedPresetKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      AutomationProperties.AutomationId="TimeSeriesAlignmentPresetCombo" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="From Date" Style="{StaticResource FormLabelStyle}" />
                            <DatePicker SelectedDate="{Binding FromDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="To Date" Style="{StaticResource FormLabelStyle}" />
                            <DatePicker SelectedDate="{Binding ToDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Symbols (comma-separated)" Style="{StaticResource FormLabelStyle}" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Style="{StaticResource FormTextBoxStyle}"
                                 Text="{Binding SymbolInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.AutomationId="TimeSeriesAlignmentSymbolsBox" />
                        <Button Grid.Column="1"
                                Content="Add"
                                Command="{Binding AddSymbolsCommand}"
                                Style="{StaticResource FormButtonStyle}"
                                Margin="8,0,0,0"
                                AutomationProperties.AutomationId="TimeSeriesAlignmentAddSymbolsButton" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding SelectedSymbols}" Margin="0,0,0,8"
                                  AutomationProperties.AutomationId="TimeSeriesAlignmentSelectedSymbolsList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource PremiumPanelBrush}"
                                        BorderBrush="{StaticResource ConsoleBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="999"
                                        Padding="8,4"
                                        Margin="0,0,4,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" Foreground="{DynamicResource ConsoleTextBrush}" />
                                        <Button Content=" x"
                                                Command="{Binding DataContext.RemoveSymbolCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                FontSize="10"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="{StaticResource ConsoleTextMutedBrush}"
                                                Cursor="Hand"
                                                Margin="4,0,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Alignment Options" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,16" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="Gap Handling" Style="{StaticResource FormLabelStyle}" />
                            <ComboBox Style="{StaticResource FormComboBoxStyle}"
                                      ItemsSource="{Binding GapStrategyOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Key"
                                      SelectedValue="{Binding SelectedGapStrategyKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,0,0,8"
                                      AutomationProperties.AutomationId="TimeSeriesAlignmentGapCombo" />

                            <TextBlock Text="Timezone" Style="{StaticResource FormLabelStyle}" />
                            <ComboBox Style="{StaticResource FormComboBoxStyle}"
                                      ItemsSource="{Binding TimezoneOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Key"
                                      SelectedValue="{Binding SelectedTimezoneKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,0,0,8"
                                      AutomationProperties.AutomationId="TimeSeriesAlignmentTimezoneCombo" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="Data Fields" Style="{StaticResource FormLabelStyle}" />
                            <CheckBox Content="Close" IsChecked="{Binding IncludeClose, Mode=TwoWay}" Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,0,0,4" />
                            <CheckBox Content="Open" IsChecked="{Binding IncludeOpen, Mode=TwoWay}" Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,0,0,4" />
                            <CheckBox Content="High" IsChecked="{Binding IncludeHigh, Mode=TwoWay}" Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,0,0,4" />
                            <CheckBox Content="Low" IsChecked="{Binding IncludeLow, Mode=TwoWay}" Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,0,0,4" />
                            <CheckBox Content="Volume" IsChecked="{Binding IncludeVolume, Mode=TwoWay}" Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,0,0,4" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Export Format" Style="{StaticResource FormLabelStyle}" Margin="0,8,0,0" />
                    <ComboBox Style="{StaticResource FormComboBoxStyle}"
                              ItemsSource="{Binding ExportFormatOptions}"
                              DisplayMemberPath="Label"
                              SelectedValuePath="Key"
                              SelectedValue="{Binding SelectedExportFormatKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Margin="0,0,0,8"
                              AutomationProperties.AutomationId="TimeSeriesAlignmentExportFormatCombo" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Run Alignment"
                                Command="{Binding RunAlignmentCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                AutomationProperties.AutomationId="TimeSeriesAlignmentRunButton" />
                        <Button Content="Save Preset"
                                Command="{Binding SavePresetCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="8,0,0,0"
                                AutomationProperties.AutomationId="TimeSeriesAlignmentSavePresetButton" />
                        <TextBlock Text="{Binding StatusText}"
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   FontSize="12"
                                   AutomationProperties.AutomationId="TimeSeriesAlignmentStatusText" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16"
                    Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibilityConverter}}"
                    AutomationProperties.AutomationId="TimeSeriesAlignmentResultsCard">
                <StackPanel>
                    <TextBlock Text="Alignment Results" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12" />
                    <UniformGrid Columns="4" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{Binding ResultRowsText}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource InfoColorBrush}" />
                            <TextBlock Text="Aligned Rows" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{Binding ResultSymbolsText}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource ConsoleTextBrush}" />
                            <TextBlock Text="Symbols" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{Binding ResultGapsText}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource WarningColorBrush}" />
                            <TextBlock Text="Gaps Filled" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{Binding ResultFormatText}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource ConsoleTextBrush}" />
                            <TextBlock Text="Output Format" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                        </StackPanel>
                    </UniformGrid>
                    <TextBlock Text="{Binding ResultOutputPathText}" FontSize="12" Foreground="{StaticResource ConsoleTextMutedBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Recent Alignments" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding RecentAlignments}"
                                  AutomationProperties.AutomationId="TimeSeriesAlignmentRecentAlignmentsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,0,0,4" BorderBrush="{DynamicResource ConsoleBackgroundBrush}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource ConsoleTextBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding DetailsText}" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="16,0" FontSize="12" />
                                        <TextBlock Grid.Column="2" Text="{Binding DateText}" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="No recent alignments."
                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                               FontSize="12"
                               Visibility="{Binding IsRecentAlignmentsEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                               AutomationProperties.AutomationId="TimeSeriesAlignmentRecentEmptyState" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
