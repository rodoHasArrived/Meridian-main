<Page x:Class="Meridian.Wpf.Views.ChartingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      AutomationProperties.Name="Charting">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header & Controls -->
        <Border Grid.Row="0" Style="{StaticResource EmbeddedShellHeroCardStyle}" Margin="24,24,24,0">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Border Width="44" Height="44" CornerRadius="14"
                            Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                            BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1">
                        <TextBlock Text="&#xE9D9;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="24" Foreground="{StaticResource InfoColorBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Advanced Charts" Style="{StaticResource PageTitleStyle}" VerticalAlignment="Center" />
                        <TextBlock Text="Dense technical charting with timeframe, indicator, and market structure controls."
                                   Style="{StaticResource CardDescriptionStyle}" />
                    </StackPanel>
                </StackPanel>

                <WrapPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                        <TextBlock Text="Symbol" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox x:Name="SymbolCombo" MinWidth="120"
                                  ItemsSource="{Binding SymbolItems}"
                                  DisplayMemberPath="Symbol"
                                  SelectionChanged="Symbol_SelectionChanged" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                        <TextBlock Text="Timeframe" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox x:Name="TimeframeCombo" MinWidth="100" SelectedIndex="6" SelectionChanged="Timeframe_SelectionChanged">
                            <ComboBoxItem Content="1 Min" Tag="Minute1" />
                            <ComboBoxItem Content="5 Min" Tag="Minute5" />
                            <ComboBoxItem Content="15 Min" Tag="Minute15" />
                            <ComboBoxItem Content="30 Min" Tag="Minute30" />
                            <ComboBoxItem Content="1 Hour" Tag="Hour1" />
                            <ComboBoxItem Content="4 Hour" Tag="Hour4" />
                            <ComboBoxItem Content="Daily" Tag="Daily" />
                            <ComboBoxItem Content="Weekly" Tag="Weekly" />
                            <ComboBoxItem Content="Monthly" Tag="Monthly" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                        <TextBlock Text="From" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <DatePicker x:Name="FromDatePicker" SelectedDateChanged="DatePicker_Changed" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                        <TextBlock Text="To" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <DatePicker x:Name="ToDatePicker" SelectedDateChanged="DatePicker_Changed" />
                    </StackPanel>

                    <Button Content="Refresh" Click="Refresh_Click" Margin="0,0,8,4" Style="{StaticResource PrimaryButtonStyle}" />

                    <StackPanel Orientation="Horizontal" Margin="16,0,0,4">
                        <TextBlock Text="Indicators:" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <CheckBox Content="SMA" Click="Indicator_Click" Tag="sma" Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,0,8,0" />
                        <CheckBox Content="EMA" Click="Indicator_Click" Tag="ema" Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,0,8,0" />
                        <CheckBox Content="RSI" Click="Indicator_Click" Tag="rsi" Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,0,8,0" />
                        <CheckBox Content="MACD" Click="Indicator_Click" Tag="macd" Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,0,8,0" />
                        <CheckBox Content="BB" Click="Indicator_Click" Tag="bb" Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,0,8,0" />
                        <CheckBox Content="VWAP" Click="Indicator_Click" Tag="vwap" Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,0,8,0" />
                        <CheckBox Content="ATR" Click="Indicator_Click" Tag="atr" Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,0,8,0" />
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="24,16,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="150" />
                </Grid.RowDefinitions>

                <!-- Price Header -->
                <Border Grid.Row="0" Style="{StaticResource ChartCardStyle}" Margin="0,0,0,8" Padding="16">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,32,0">
                            <TextBlock Text="{Binding CurrentPrice}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TopBarTextBrush}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding PriceChange}" FontSize="14" Margin="0,0,8,0" Foreground="{Binding PriceChangeBrush}" />
                                <TextBlock Text="{Binding PriceChangePercent}" FontSize="14" Foreground="{Binding PriceChangeBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <UniformGrid Rows="2" Columns="4" Margin="0,0,32,0">
                            <TextBlock Text="O" FontSize="11" Foreground="{StaticResource ChartAxisLabelBrush}" />
                            <TextBlock Text="{Binding OpenPrice}" FontSize="12" FontFamily="{StaticResource MeridianDataFontFamily}" Foreground="{StaticResource TopBarTextBrush}" />
                            <TextBlock Text="Volume" FontSize="11" Foreground="{StaticResource ChartAxisLabelBrush}" />
                            <TextBlock Text="{Binding Volume}" FontSize="12" FontFamily="{StaticResource MeridianDataFontFamily}" Foreground="{StaticResource TopBarTextBrush}" />
                            <TextBlock Text="H" FontSize="11" Foreground="{StaticResource ChartAxisLabelBrush}" />
                            <TextBlock Text="{Binding HighPrice}" FontSize="12" FontFamily="{StaticResource MeridianDataFontFamily}" Foreground="{StaticResource ChartEquityBrush}" />
                            <TextBlock Text="L" FontSize="11" Foreground="{StaticResource ChartAxisLabelBrush}" />
                            <TextBlock Text="{Binding LowPrice}" FontSize="12" FontFamily="{StaticResource MeridianDataFontFamily}" Foreground="{StaticResource ChartDrawdownBrush}" />
                        </UniformGrid>

                        <TextBlock Text="{Binding ActiveIndicatorsText}" FontSize="11" Foreground="{StaticResource ChartAxisLabelBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Candlestick Chart (LiveCharts2 CandlesticksSeries) -->
                <Border Grid.Row="1" Style="{StaticResource ChartCardStyle}" Margin="0,0,0,8" Padding="12">
                    <Border Style="{StaticResource ChartPlotAreaStyle}">
                        <Grid>
                            <lvc:CartesianChart Series="{Binding CandleSeries}"
                                                XAxes="{Binding CandleXAxes}"
                                                YAxes="{Binding CandleYAxes}"
                                                ZoomMode="X"
                                                LegendPosition="Hidden"
                                                TooltipPosition="Top"
                                                Background="Transparent" />

                            <TextBlock Text="{Binding NoChartDataMessage}"
                                       Visibility="{Binding NoChartDataVisible}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{StaticResource ChartAxisLabelBrush}" FontStyle="Italic" />
                        </Grid>
                    </Border>
                </Border>

                <!-- Volume Chart -->
                <Border Grid.Row="2" Style="{StaticResource ChartCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Volume" Style="{StaticResource ChartHeaderTextStyle}" Margin="0,0,0,8" />

                        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding VolumeItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="10" Margin="1,0"
                                                Height="{Binding Height}" Background="{Binding BarBrush}"
                                                VerticalAlignment="Bottom" ToolTip="{Binding Tooltip}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Side Panel -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Volume Profile -->
                    <Border Style="{StaticResource ChartCardStyle}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Volume Profile" Style="{StaticResource ChartHeaderTextStyle}" Margin="0,0,0,12" />

                            <ItemsControl ItemsSource="{Binding VolumeProfileItems}" MaxHeight="300">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="14" Margin="0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="55" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding PriceLabel}" FontSize="10" FontFamily="{StaticResource MeridianDataFontFamily}"
                                                       Foreground="{StaticResource ChartAxisLabelBrush}" VerticalAlignment="Center" />
                                            <Border Grid.Column="1" Height="10" HorizontalAlignment="Left"
                                                    Width="{Binding BarWidth}" Background="{Binding BarBrush}" CornerRadius="2" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="No volume profile data"
                                       Visibility="{Binding NoVolumeProfileVisible}"
                                       HorizontalAlignment="Center" Foreground="{StaticResource ChartAxisLabelBrush}"
                                       FontStyle="Italic" FontSize="12" />

                            <StackPanel Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="POC:" FontSize="11" Foreground="{StaticResource ChartAxisLabelBrush}" Width="35" />
                                    <TextBlock Text="{Binding Poc}" FontSize="11" FontFamily="{StaticResource MeridianDataFontFamily}" Foreground="{StaticResource TopBarTextBrush}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="VAH:" FontSize="11" Foreground="{StaticResource ChartAxisLabelBrush}" Width="35" />
                                    <TextBlock Text="{Binding Vah}" FontSize="11" FontFamily="{StaticResource MeridianDataFontFamily}" Foreground="{StaticResource TopBarTextBrush}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="VAL:" FontSize="11" Foreground="{StaticResource ChartAxisLabelBrush}" Width="35" />
                                    <TextBlock Text="{Binding Val}" FontSize="11" FontFamily="{StaticResource MeridianDataFontFamily}" Foreground="{StaticResource TopBarTextBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Indicator Values -->
                    <Border Style="{StaticResource ChartCardStyle}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Indicator Values" Style="{StaticResource ChartHeaderTextStyle}" Margin="0,0,0,12" />

                            <ItemsControl ItemsSource="{Binding IndicatorValues}" MaxHeight="250">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="12" Foreground="{StaticResource TopBarTextBrush}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="12" FontFamily="{StaticResource MeridianDataFontFamily}"
                                                       Foreground="{Binding ValueBrush}" FontWeight="SemiBold" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Select indicators from the toolbar"
                                       Visibility="{Binding NoIndicatorsVisible}"
                                       Foreground="{StaticResource ChartAxisLabelBrush}" FontStyle="Italic"
                                       FontSize="12" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Period Statistics -->
                    <Border Style="{StaticResource ChartCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Period Statistics" Style="{StaticResource ChartHeaderTextStyle}" Margin="0,0,0,12" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="High" FontSize="11" Foreground="{StaticResource ChartAxisLabelBrush}" Margin="0,2" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PeriodHigh}" FontSize="11" FontFamily="{StaticResource MeridianDataFontFamily}"
                                           Foreground="{StaticResource ChartEquityBrush}" HorizontalAlignment="Right" Margin="0,2" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Low" FontSize="11" Foreground="{StaticResource ChartAxisLabelBrush}" Margin="0,2" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PeriodLow}" FontSize="11" FontFamily="{StaticResource MeridianDataFontFamily}"
                                           Foreground="{StaticResource ChartDrawdownBrush}" HorizontalAlignment="Right" Margin="0,2" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Total Volume" FontSize="11" Foreground="{StaticResource ChartAxisLabelBrush}" Margin="0,2" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PeriodVolume}" FontSize="11" FontFamily="{StaticResource MeridianDataFontFamily}"
                                           Foreground="{StaticResource TopBarTextBrush}" HorizontalAlignment="Right" Margin="0,2" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Candles" FontSize="11" Foreground="{StaticResource ChartAxisLabelBrush}" Margin="0,2" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CandleCount}" FontSize="11" FontFamily="{StaticResource MeridianDataFontFamily}"
                                           Foreground="{StaticResource TopBarTextBrush}" HorizontalAlignment="Right" Margin="0,2" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="2" Visibility="{Binding LoadingVisible}" Background="{StaticResource ChartLoadingOverlayBrush}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Loading chart data..." Foreground="{StaticResource TopBarTextBrush}" FontSize="14" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
