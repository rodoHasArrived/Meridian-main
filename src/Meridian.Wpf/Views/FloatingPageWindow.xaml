<Window x:Class="Meridian.Wpf.Views.FloatingPageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        MinWidth="640" MinHeight="480"
        Width="1024" Height="700"
        ShowInTaskbar="True"
        Background="#0A0A12">
    <Grid Background="#0A0A12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar: drag to move, shows page title and close button -->
        <Border Grid.Row="0" Background="#1A2A4A" Padding="12,6"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                Cursor="SizeAll">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           x:Name="TitleTextBlock"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="✕"
                        Foreground="#888888" Background="Transparent"
                        BorderThickness="0" Padding="8,2"
                        Cursor="Arrow"
                        FontSize="12"
                        Click="Close_Click"/>
            </Grid>
        </Border>

        <!-- Page content area -->
        <ContentPresenter Grid.Row="1" x:Name="PageContentPresenter"/>
    </Grid>
</Window>
