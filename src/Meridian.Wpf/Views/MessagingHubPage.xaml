<Page x:Class="Meridian.Wpf.Views.MessagingHubPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      Unloaded="OnPageUnloaded"
      AutomationProperties.Name="Messaging Hub">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20,28,32">
        <StackPanel MaxWidth="1200">

            <!-- Header -->
            <Border Style="{StaticResource EmbeddedShellCompactHeaderCardStyle}" Margin="0,0,0,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Style="{StaticResource EmbeddedShellHeaderIdentityStackPanelStyle}">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="44" Height="44" CornerRadius="14"
                                Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1">
                            <TextBlock Text="&#xE715;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="24" Foreground="{StaticResource InfoColorBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Messaging Hub" Style="{StaticResource PageTitleStyle}" Margin="12,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="Monitor inter-service messaging, webhook delivery, and notification channels"
                               Style="{StaticResource CardDescriptionStyle}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="ConnectionBadge" CornerRadius="999" Padding="8,3" Margin="0,0,12,0"
                            Background="{Binding ConnectionBadgeBackground}" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ConnectionStatusText}" FontSize="11"
                                   Foreground="White" FontWeight="SemiBold" />
                    </Border>
                    <Button x:Name="RefreshButton" Click="Refresh_Click"
                            Style="{StaticResource SecondaryButtonStyle}" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14" Margin="0,0,6,0" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
            </Border>

            <!-- Message Statistics -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" /><ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" /><ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" /><ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding TotalMessagesText}" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource InfoColorBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="Total Messages" HorizontalAlignment="Center" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding SubscribersText}" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessColorBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="Subscribers" HorizontalAlignment="Center" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding FailedMessagesText}" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource WarningColorBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="Failed" HorizontalAlignment="Center" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="6" Style="{StaticResource CardStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding MessageRateText}" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource InfoColorBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="Rate" HorizontalAlignment="Center" Foreground="{StaticResource ConsoleTextMutedBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Delivery posture -->
            <Border Style="{StaticResource CardStyle}"
                    Margin="0,0,0,24"
                    AutomationProperties.AutomationId="MessagingHubPostureCard"
                    AutomationProperties.Name="{Binding MessagingPostureTitle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="360" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="&#xE7B0;"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="16"
                                       Foreground="{StaticResource InfoColorBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="{Binding MessagingPostureTitle}"
                                       Style="{StaticResource CardHeaderStyle}"
                                       AutomationProperties.AutomationId="MessagingHubPostureTitle" />
                        </StackPanel>
                        <TextBlock Text="{Binding MessagingPostureDetail}"
                                   Style="{StaticResource CardDescriptionStyle}"
                                   TextWrapping="Wrap"
                                   AutomationProperties.AutomationId="MessagingHubPostureDetail" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Background="{StaticResource ConsoleAccentBlueAlpha10Brush}"
                            BorderBrush="{StaticResource InfoColorBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,9"
                            Margin="20,0,0,0"
                            VerticalAlignment="Center"
                            AutomationProperties.AutomationId="MessagingHubActivityScopeChip">
                        <StackPanel>
                            <TextBlock Text="{Binding RecentActivityScopeText}"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                            <TextBlock Text="Recent activity"
                                       FontSize="10"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Message Types -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="16" Foreground="{StaticResource InfoColorBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Registered Message Types" Style="{StaticResource CardHeaderStyle}" />
                    </StackPanel>
                    <ListView ItemsSource="{Binding MessageTypes}" SelectionMode="Single" MaxHeight="200"
                              Background="Transparent" BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,4" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource PremiumPanelBrush}"
                                        CornerRadius="12" Padding="12,8"
                                        BorderBrush="{StaticResource ConsoleBorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding TypeName}" FontSize="13"
                                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}" VerticalAlignment="Center" />
                                        <Border Grid.Column="1" Background="{StaticResource ConsoleAccentBlueAlpha10Brush}"
                                                CornerRadius="999" Padding="8,3">
                                            <TextBlock Text="{Binding CountText}" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource InfoColorBrush}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- Recent Activity -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="&#xE7BA;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="16" Foreground="{StaticResource InfoColorBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="Recent Activity" Style="{StaticResource CardHeaderStyle}" />
                            </StackPanel>
                            <TextBlock Text="{Binding RecentActivityScopeText}"
                                       FontSize="11"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                                       AutomationProperties.AutomationId="MessagingHubRecentActivityScopeText" />
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="ClearActivityButton"
                                Command="{Binding ClearActivityCommand}"
                                Style="{StaticResource GhostButtonStyle}" Content="Clear"
                                AutomationProperties.AutomationId="MessagingHubClearActivityButton" />
                    </Grid>
                    <ListView ItemsSource="{Binding ActivityItems}" SelectionMode="Single" MaxHeight="300"
                              Background="Transparent" BorderThickness="0"
                              AutomationProperties.AutomationId="MessagingHubRecentActivityList">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,2" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding DirectionIcon}" FontSize="14"
                                               Foreground="{Binding DirectionColor}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Grid.Column="1" Text="{Binding MessageType}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="0,0,8,0" Width="180" />
                                    <TextBlock Grid.Column="2" Text="{Binding Detail}" FontSize="12"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Text="{Binding TimeText}" FontSize="11"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}"
                                               VerticalAlignment="Center" Margin="12,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Visibility="{Binding NoActivityVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                Margin="0,12,0,0"
                                AutomationProperties.AutomationId="MessagingHubActivityEmptyStatePanel"
                                AutomationProperties.Name="{Binding ActivityEmptyStateTitle}">
                        <TextBlock Text="{Binding ActivityEmptyStateTitle}" FontSize="13"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   AutomationProperties.AutomationId="MessagingHubActivityEmptyStateTitle" />
                        <TextBlock Text="{Binding ActivityEmptyStateDetail}" FontSize="11"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"
                                   AutomationProperties.AutomationId="MessagingHubActivityEmptyStateDetail" />
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
