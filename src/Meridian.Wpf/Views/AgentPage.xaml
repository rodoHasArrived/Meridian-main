<Page x:Class="Meridian.Wpf.Views.AgentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      AutomationProperties.Name="Agent">

    <Page.Resources>
        <DataTemplate x:Key="MessageTemplate">
            <Border Margin="0,4" Padding="12,8" CornerRadius="8" MaxWidth="500"
                    HorizontalAlignment="{Binding Alignment}"
                    Background="{StaticResource ConsoleBackgroundMediumBrush}">
                <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                           Foreground="{StaticResource ConsoleTextSecondaryBrush}"/>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: Model selector + Ollama status -->
        <DockPanel Grid.Row="0" Margin="16,12,16,12" Background="{StaticResource ConsoleBackgroundLightBrush}">
            <TextBlock Text="Local AI Agent" FontSize="16" FontWeight="SemiBold" DockPanel.Dock="Left" 
                       Foreground="{StaticResource ConsoleTextPrimaryBrush}" VerticalAlignment="Center"/>

            <!-- Status indicator -->
            <Border Background="{Binding OllamaStatusBrush}" Width="10" Height="10" 
                    CornerRadius="5" DockPanel.Dock="Right" Margin="8,0,0,0" VerticalAlignment="Center"/>

            <!-- Model selector -->
            <ComboBox ItemsSource="{Binding AvailableModels}" 
                      SelectedItem="{Binding SelectedModel, UpdateSourceTrigger=PropertyChanged}"
                      DockPanel.Dock="Right" Width="180" Margin="8,0"
                      IsEnabled="{Binding IsOllamaAvailable}"/>
        </DockPanel>

        <!-- Message history -->
        <ScrollViewer Grid.Row="1" x:Name="MessagesScroller" Padding="16,8" 
                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Messages}" 
                          ItemTemplate="{StaticResource MessageTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input bar -->
        <Border Grid.Row="2" Margin="16,8" Background="{StaticResource ConsoleBackgroundLightBrush}" Padding="0,8">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Send" 
                        Command="{Binding SendCommand}" 
                        Width="70" Margin="8,0,0,0"/>
                
                <Button DockPanel.Dock="Right" Content="Clear" 
                        Command="{Binding ClearCommand}" 
                        Width="70" Margin="0,0,8,0"/>

                <TextBox Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="False" Padding="8,6"
                         IsEnabled="{Binding IsOllamaAvailable}"/>
            </DockPanel>
        </Border>
    </Grid>
</Page>
