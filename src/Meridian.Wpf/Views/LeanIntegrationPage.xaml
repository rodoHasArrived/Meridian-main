<Page x:Class="Meridian.Wpf.Views.LeanIntegrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource ShellWindowBackgroundBrush}"
      Loaded="OnPageLoaded"
      Unloaded="OnPageUnloaded"
      AutomationProperties.Name="Lean Integration">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="28,20,16,32">
            <StackPanel MaxWidth="900">
                <!-- Header -->
                <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="44" Height="44" CornerRadius="14"
                                Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                BorderBrush="{StaticResource InfoColorBrush}" BorderThickness="1">
                            <TextBlock Text="&#xE943;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="24" Foreground="{StaticResource InfoColorBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="QuantConnect Lean Integration" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="Sync Meridian archives into Lean-compatible datasets and orchestrate validation and backtest handoff."
                                       Style="{StaticResource CardDescriptionStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Status Card -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Ellipse Width="12" Height="12" Fill="{Binding StatusIndicatorBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding StatusText}" Style="{StaticResource CardHeaderStyle}" Margin="8,0,0,0" />
                            </StackPanel>
                            <TextBlock Text="{Binding StatusDetailsText}"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="12" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Verify Installation"
                                Command="{Binding VerifyInstallationCommand}"
                                Style="{StaticResource FormButtonStyle}" />
                    </Grid>
                </Border>

                <!-- Configuration -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Configuration" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,16" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Lean Installation Path" Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding LeanPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FormTextBoxStyle}" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="Browse..." VerticalAlignment="Bottom"
                                    Click="BrowseLeanPath_Click"
                                    Style="{StaticResource FormButtonStyle}" Margin="8,0,0,0" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Lean Data Path" Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding DataPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FormTextBoxStyle}" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="Browse..." VerticalAlignment="Bottom"
                                    Click="BrowseDataPath_Click"
                                    Style="{StaticResource FormButtonStyle}" Margin="8,0,0,0" />
                        </Grid>
                        <CheckBox Content="Auto-sync data after collection"
                                  IsChecked="{Binding AutoSync, Mode=TwoWay}"
                                  Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,0,0,12" />
                        <Button Content="Save Configuration"
                                Command="{Binding SaveConfigurationCommand}"
                                Style="{StaticResource FormButtonStyle}" />
                    </StackPanel>
                </Border>

                <!-- Data Sync -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Data Synchronization" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,4" />
                        <TextBlock Text="Convert collected data to Lean format for backtesting."
                                   Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="12" Margin="0,0,0,16" />

                        <TextBlock Text="Symbols (comma-separated, empty for all)" Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding SyncSymbols, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}" Margin="0,0,0,8" />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="From Date" Style="{StaticResource FormLabelStyle}" />
                                <DatePicker SelectedDate="{Binding SyncFromDate, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="To Date" Style="{StaticResource FormLabelStyle}" />
                                <DatePicker SelectedDate="{Binding SyncToDate, Mode=TwoWay}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Resolution" Style="{StaticResource FormLabelStyle}" />
                        <ComboBox Style="{StaticResource FormComboBoxStyle}"
                                  SelectedValue="{Binding SelectedResolution, Mode=TwoWay}"
                                  SelectedValuePath="Tag"
                                  SelectedIndex="2"
                                  Margin="0,0,0,8">
                            <ComboBoxItem Content="Tick" Tag="Tick" />
                            <ComboBoxItem Content="Second" Tag="Second" />
                            <ComboBoxItem Content="Minute" Tag="Minute" />
                            <ComboBoxItem Content="Hour" Tag="Hour" />
                            <ComboBoxItem Content="Daily" Tag="Daily" />
                        </ComboBox>

                        <CheckBox Content="Overwrite existing Lean data"
                                  IsChecked="{Binding OverwriteSync, Mode=TwoWay}"
                                  Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Sync Data"
                                    Command="{Binding SyncDataCommand}"
                                    IsEnabled="{Binding IsSyncEnabled}"
                                    Style="{StaticResource FormButtonStyle}" />
                            <TextBlock Text="{Binding SyncStatusText}" VerticalAlignment="Center"
                                       Margin="12,0,0,0" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Backtest Runner -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Run Backtest" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,16" />

                        <TextBlock Text="Algorithm" Style="{StaticResource FormLabelStyle}" />
                        <ComboBox ItemsSource="{Binding Algorithms}"
                                  SelectedItem="{Binding SelectedAlgorithm, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource FormComboBoxStyle}" Margin="0,0,0,8" />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Start Date" Style="{StaticResource FormLabelStyle}" />
                                <DatePicker SelectedDate="{Binding BacktestStartDate, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="End Date" Style="{StaticResource FormLabelStyle}" />
                                <DatePicker SelectedDate="{Binding BacktestEndDate, Mode=TwoWay}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Initial Capital ($)" Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding InitialCapitalText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}" Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Run Backtest"
                                    Command="{Binding RunBacktestCommand}"
                                    IsEnabled="{Binding IsBacktestEnabled}"
                                    Style="{StaticResource FormButtonStyle}" />
                            <Button Content="Stop"
                                    Command="{Binding StopBacktestCommand}"
                                    Visibility="{Binding IsStopButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Style="{StaticResource FormButtonStyle}" Margin="8,0,0,0" />
                        </StackPanel>

                        <!-- Progress -->
                        <StackPanel Visibility="{Binding IsBacktestProgressVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Margin="0,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding BacktestProgressText}" Foreground="{DynamicResource ConsoleTextBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding BacktestProgressPercent}" Foreground="{DynamicResource ConsoleTextBrush}" />
                            </Grid>
                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding BacktestProgress}" Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Backtest Results -->
                <Border Style="{StaticResource CardStyle}"
                        Visibility="{Binding IsResultsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Backtest Results" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,16" />
                        <UniformGrid Columns="4" Margin="0,0,0,8">
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="{Binding TotalReturnText}" FontSize="20" FontWeight="Bold"
                                           Foreground="{Binding TotalReturnBrush}" />
                                <TextBlock Text="Total Return" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="{Binding AnnualizedReturnText}" FontSize="20" FontWeight="Bold"
                                           Foreground="{Binding TotalReturnBrush}" />
                                <TextBlock Text="Ann. Return" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="{Binding SharpeRatioText}" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource InfoColorBrush}" />
                                <TextBlock Text="Sharpe Ratio" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding MaxDrawdownText}" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource ErrorColorBrush}" />
                                <TextBlock Text="Max Drawdown" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                            </StackPanel>
                        </UniformGrid>
                        <UniformGrid Columns="3" Margin="0,4,0,0">
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="{Binding TotalTradesText}" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource InfoColorBrush}" />
                                <TextBlock Text="Total Trades" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="{Binding WinRateText}" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource SuccessColorBrush}" />
                                <TextBlock Text="Win Rate" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding ProfitFactorText}" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource InfoColorBrush}" />
                                <TextBlock Text="Profit Factor" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="11" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Auto-Export -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Auto-Export to Lean" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,4" />
                        <TextBlock Text="Continuously export collected data to Lean's data directory after each collection cycle."
                                   Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="12" Margin="0,0,0,16" />

                        <CheckBox Content="Enable auto-export"
                                  IsChecked="{Binding AutoExportEnabled, Mode=TwoWay}"
                                  Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,0,0,8" />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Lean Data Directory" Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding AutoExportLeanDataPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FormTextBoxStyle}" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="Browse..." VerticalAlignment="Bottom"
                                    Click="BrowseAutoExportPath_Click"
                                    Style="{StaticResource FormButtonStyle}" Margin="8,0,0,0" />
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Export Interval (seconds)" Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding AutoExportIntervalSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FormTextBoxStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Symbols (empty for all)" Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding AutoExportSymbols, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FormTextBoxStyle}" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Save Auto-Export Settings"
                                    Command="{Binding ConfigureAutoExportCommand}"
                                    Style="{StaticResource FormButtonStyle}" />
                            <TextBlock Text="{Binding AutoExportStatusText}" VerticalAlignment="Center"
                                       Margin="12,0,0,0" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Symbol Mapping -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Symbol Mapping" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,4" />
                        <TextBlock Text="Resolve Meridian symbols to their QuantConnect Lean ticker equivalents."
                                   Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="12" Margin="0,0,0,16" />

                        <TextBlock Text="Symbols (comma-separated)" Style="{StaticResource FormLabelStyle}" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBox Text="{Binding MappingSymbols, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBoxStyle}" Width="300" />
                            <Button Content="Resolve"
                                    Command="{Binding ResolveSymbolMappingCommand}"
                                    Style="{StaticResource FormButtonStyle}" Margin="8,0,0,0" />
                            <TextBlock Text="{Binding MappingStatusText}" VerticalAlignment="Center"
                                       Margin="12,0,0,0" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="12" />
                        </StackPanel>

                        <!-- Mapping Table -->
                        <DataGrid ItemsSource="{Binding SymbolMappings}"
                                  Visibility="{Binding IsMappingTableVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  MaxHeight="200"
                                  Background="Transparent"
                                  Foreground="{DynamicResource ConsoleTextBrush}"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{DynamicResource ConsoleTextMutedBrush}"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="Transparent">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Meridian Symbol" Binding="{Binding MdcSymbol}" Width="*" />
                                <DataGridTextColumn Header="Lean Ticker" Binding="{Binding LeanTicker}" Width="*" />
                                <DataGridTextColumn Header="Type" Binding="{Binding SecurityType}" Width="80" />
                                <DataGridTextColumn Header="Market" Binding="{Binding Market}" Width="80" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Results Ingestion -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Import Backtest Results" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,4" />
                        <TextBlock Text="Import backtest results from a local Lean JSON results file into the history."
                                   Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="12" Margin="0,0,0,16" />

                        <TextBlock Text="Results File" Style="{StaticResource FormLabelStyle}" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding IngestFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBoxStyle}" IsReadOnly="True" />
                            <Button Grid.Column="1" Content="Browse..."
                                    Click="BrowseIngestFile_Click"
                                    Style="{StaticResource FormButtonStyle}" Margin="8,0,0,0" />
                        </Grid>

                        <TextBlock Text="Algorithm Name (optional override)" Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding IngestAlgorithmName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}" Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Import Results"
                                    Command="{Binding IngestResultsCommand}"
                                    Style="{StaticResource FormButtonStyle}" />
                            <TextBlock Text="{Binding IngestStatusText}" VerticalAlignment="Center"
                                       Margin="12,0,0,0" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="12"
                                       TextWrapping="Wrap" MaxWidth="300" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Right Panel -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="12,24,24,24">
            <StackPanel>
                <!-- Quick Actions -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Quick Actions" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12" />
                        <Button Content="Refresh Algorithms"
                                Command="{Binding RefreshAlgorithmsCommand}"
                                Style="{StaticResource FormButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,8" />
                    </StackPanel>
                </Border>

                <!-- Recent Backtests -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Recent Backtests" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12" />
                        <ItemsControl ItemsSource="{Binding RecentBacktests}" MaxHeight="250">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="4" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding AlgorithmName}"
                                                       FontWeight="SemiBold" Foreground="{DynamicResource ConsoleTextBrush}" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ReturnText}"
                                                       Foreground="{Binding ReturnBrush}" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                       Text="{Binding DateText}" FontSize="11"
                                                       Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No recent backtests"
                                   Visibility="{Binding IsNoBacktestsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="12" />
                    </StackPanel>
                </Border>

                <!-- Data Sync Stats -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Data Sync Stats" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Symbols Synced"
                                       Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,2" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SymbolsSyncedText}"
                                       FontWeight="SemiBold" Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,2" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Total Data Files"
                                       Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,2" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DataFilesText}"
                                       FontWeight="SemiBold" Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,2" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Last Sync"
                                       Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,2" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastSyncText}"
                                       FontWeight="SemiBold" Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,2" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Auto-Export Stats -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Auto-Export Stats" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Files Exported"
                                       Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,2" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AutoExportTotalFilesText}"
                                       FontWeight="SemiBold" Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,2" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Last Export"
                                       Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,2" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AutoExportLastRunText}"
                                       FontWeight="SemiBold" Foreground="{DynamicResource ConsoleTextBrush}" Margin="0,2" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- About Lean -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="About Lean" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,8" />
                        <TextBlock Text="QuantConnect Lean is an open-source algorithmic trading engine for backtesting and live trading."
                                   TextWrapping="Wrap" Foreground="{StaticResource ConsoleTextMutedBrush}" FontSize="12" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
