<Page x:Class="Meridian.Wpf.Views.SymbolMappingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource ConsoleBackgroundDarkBrush}"
      Loaded="OnPageLoaded"
      AutomationProperties.Name="Symbol Mapping">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel MaxWidth="1200">

            <!-- Header -->
            <Grid Margin="0,0,0,24" Style="{StaticResource EmbeddedShellHeaderGridStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xE8E9;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="28" Foreground="{StaticResource InfoColorBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="Symbol Mapping" Style="{StaticResource PageTitleStyle}" Margin="12,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="Manage provider-specific symbol translations (e.g., BRK.B to BRK B for Interactive Brokers)"
                               Style="{StaticResource CardDescriptionStyle}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Import CSV" Click="ImportCsv_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"
                            AutomationProperties.AutomationId="SymbolMappingImportCsvButton" />
                    <Button Content="Export CSV" Click="ExportCsv_Click" Style="{StaticResource SecondaryButtonStyle}"
                            AutomationProperties.AutomationId="SymbolMappingExportCsvButton" />
                </StackPanel>
            </Grid>

            <!-- Test Mapping -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Test Symbol Mapping" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,12" />
                    <TextBlock Text="Enter a canonical symbol to see how it maps across all providers"
                               FontSize="12" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBox Width="200" Style="{StaticResource FormTextBoxStyle}" Margin="0,0,12,0"
                                 Text="{Binding TestSymbol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.AutomationId="SymbolMappingTestSymbolBox" />
                        <Button Content="Test Mapping"
                                Command="{Binding TestMappingCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                AutomationProperties.AutomationId="SymbolMappingTestButton" />
                    </StackPanel>
                    <TextBlock Text="{Binding TestScopeText}" FontSize="12"
                               Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,0,0,12"
                               AutomationProperties.AutomationId="SymbolMappingTestScopeText" />
                    <ListView SelectionMode="Single" MaxHeight="250"
                              ItemsSource="{Binding TestResults}"
                              Background="Transparent" BorderThickness="0"
                              Visibility="{Binding TestResultsVisibility}"
                              AutomationProperties.AutomationId="SymbolMappingTestResultsList">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,2" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ProviderName}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource ConsoleTextSecondaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="&#x2192;" FontSize="14"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                    <TextBlock Grid.Column="2" Text="{Binding MappedSymbol}" FontSize="13"
                                               Foreground="{StaticResource InfoColorBrush}" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- Known Providers -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Known Providers" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,16" />
                    <ListView SelectionMode="Single" MaxHeight="300"
                              ItemsSource="{Binding Providers}"
                              Background="Transparent" BorderThickness="0"
                              AutomationProperties.AutomationId="SymbolMappingProvidersList">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,4" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource ConsoleBackgroundLightBrush}"
                                        CornerRadius="6" Padding="12,8"
                                        BorderBrush="{StaticResource ConsoleBorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Id}" FontSize="13" FontWeight="Bold"
                                                   Foreground="{StaticResource InfoColorBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding Description}" FontSize="12"
                                                   Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding DisplayName}" FontSize="12"
                                                   Foreground="{StaticResource ConsoleTextSecondaryBrush}" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- Add/Edit Mapping -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Add Symbol Mapping" Style="{StaticResource CardHeaderStyle}" Margin="0,0,0,16" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Canonical Symbol" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource FormTextBoxStyle}"
                                     Text="{Binding NewCanonicalSymbol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.AutomationId="SymbolMappingNewCanonicalBox" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Provider" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding ProviderOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding SelectedProviderId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      AutomationProperties.AutomationId="SymbolMappingProviderCombo" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Provider Symbol" FontSize="11" Foreground="{StaticResource ConsoleTextMutedBrush}" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource FormTextBoxStyle}"
                                     Text="{Binding NewProviderSymbol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.AutomationId="SymbolMappingNewProviderSymbolBox" />
                        </StackPanel>
                    </Grid>
                    <Border Background="{StaticResource PremiumPanelBrush}"
                            BorderBrush="{StaticResource ConsoleBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,12"
                            AutomationProperties.AutomationId="SymbolMappingAddReadinessCard">
                        <StackPanel>
                            <TextBlock Text="{Binding MappingReadinessTitle}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource ConsoleTextBrush}"
                                       AutomationProperties.AutomationId="SymbolMappingAddReadinessTitle" />
                            <TextBlock Text="{Binding MappingReadinessDetail}" FontSize="12"
                                       Foreground="{StaticResource ConsoleTextMutedBrush}" TextWrapping="Wrap"
                                       AutomationProperties.AutomationId="SymbolMappingAddReadinessDetail" />
                        </StackPanel>
                    </Border>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Add Mapping"
                                Command="{Binding AddMappingCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Left"
                                AutomationProperties.AutomationId="SymbolMappingAddButton" />
                        <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="12,0,0,0"
                                   FontSize="12" Foreground="{StaticResource ConsoleTextMutedBrush}"
                                   AutomationProperties.AutomationId="SymbolMappingStatusMessage" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Current Mappings -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Current Mappings" Style="{StaticResource CardHeaderStyle}" />
                        <TextBlock Grid.Column="1" Text="{Binding MappingCountText}" FontSize="12"
                                   Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" />
                    </Grid>
                    <Border Background="{StaticResource ConsoleBackgroundMediumBrush}"
                            BorderBrush="{StaticResource WarningColorBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,12"
                            Visibility="{Binding RemoveConfirmationVisibility}"
                            AutomationProperties.AutomationId="SymbolMappingRemoveConfirmation">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Remove mapping override?" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextBrush}" />
                                <TextBlock Text="{Binding PendingRemoveCanonicalSymbol, StringFormat=This removes the custom provider symbols for {0}. Default provider transformations will still apply.}"
                                           FontSize="12"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                                <Button Content="Remove"
                                        Command="{Binding ConfirmRemoveMappingCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,0"
                                        AutomationProperties.AutomationId="SymbolMappingConfirmRemoveButton" />
                                <Button Content="Cancel"
                                        Command="{Binding CancelRemoveMappingCommand}"
                                        Style="{StaticResource GhostButtonStyle}"
                                        AutomationProperties.AutomationId="SymbolMappingCancelRemoveButton" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ListView SelectionMode="Single" MaxHeight="300"
                              ItemsSource="{Binding Mappings}"
                              Background="Transparent" BorderThickness="0"
                              Visibility="{Binding MappingsVisibility}"
                              AutomationProperties.AutomationId="SymbolMappingMappingsList">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,4" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource ConsoleBackgroundLightBrush}"
                                        CornerRadius="6" Padding="12,8"
                                        BorderBrush="{StaticResource ConsoleBorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding CanonicalSymbol}" FontSize="13" FontWeight="Bold"
                                                   Foreground="{StaticResource InfoColorBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding ProviderMappingsText}" FontSize="12"
                                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" Text="{Binding UpdatedText}" FontSize="11"
                                                   Foreground="{StaticResource ConsoleTextMutedBrush}" VerticalAlignment="Center" Margin="12,0" />
                                        <Button Grid.Column="3" Content="Remove"
                                                Command="{Binding DataContext.RequestRemoveMappingCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding CanonicalSymbol}"
                                                Style="{StaticResource GhostButtonStyle}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Visibility="{Binding EmptyMappingsVisibility}" Margin="0,8,0,0"
                                AutomationProperties.AutomationId="SymbolMappingEmptyMappingsPanel">
                        <TextBlock Text="No custom symbol mappings configured. Default provider transformations are used."
                                   FontSize="13" Foreground="{StaticResource ConsoleTextMutedBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
