<UserControl x:Class="Meridian.Wpf.Views.WorkspaceCommandBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:Meridian.Wpf.Models"
             xmlns:views="clr-namespace:Meridian.Wpf.Views"
             x:Name="Root"
             mc:Ignorable="d"
             d:DesignHeight="70"
             d:DesignWidth="1200">
    <Border>
        <Border.Style>
            <Style TargetType="Border" BasedOn="{StaticResource WorkspaceCommandBarSurfaceStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ElementName=Root, Path=IsCompactSurface}" Value="True">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="CornerRadius" Value="0" />
                        <Setter Property="Effect" Value="{x:Null}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ItemsControl ItemsSource="{Binding ElementName=Root, Path=CommandGroup.PrimaryCommands}"
                          AutomationProperties.Name="Workspace Command Bar">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:WorkspaceCommandItem}">
                        <Button Tag="{Binding}"
                                Click="OnPrimaryCommandClick"
                                Margin="0,0,8,8"
                                IsEnabled="{Binding IsEnabled}"
                                AutomationProperties.Name="{Binding Description}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                    <Setter Property="Padding" Value="14,10" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCompactSurface, RelativeSource={RelativeSource AncestorType={x:Type views:WorkspaceCommandBarControl}}}" Value="True">
                                            <Setter Property="Padding" Value="12,7" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Tone}" Value="Primary">
                                            <Setter Property="Background" Value="{StaticResource InfoColorBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource ConsoleAccentBlueBrush}" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Tone}" Value="Danger">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderBrush" Value="{StaticResource ErrorColorBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource ErrorColorBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Glyph}"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="13"
                                           VerticalAlignment="Center" />
                                <StackPanel Margin="8,0,0,0">
                                    <TextBlock Text="{Binding Label}"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding ShortcutHint}"
                                               FontSize="10"
                                               Foreground="{StaticResource ConsoleTextMutedBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompactSurface, RelativeSource={RelativeSource AncestorType={x:Type views:WorkspaceCommandBarControl}}}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ShortcutHint}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button x:Name="MoreButton"
                    Grid.Column="1"
                    Margin="8,0,0,8"
                    Click="OnMoreButtonClick"
                    AutomationProperties.Name="More Workspace Commands">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                        <Setter Property="Padding" Value="14,10" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=Root, Path=IsCompactSurface}" Value="True">
                                <Setter Property="Padding" Value="12,7" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE712;"
                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                               FontSize="13"
                               VerticalAlignment="Center" />
                    <TextBlock Text="More"
                               Margin="8,0,0,0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>
    </Border>
</UserControl>
