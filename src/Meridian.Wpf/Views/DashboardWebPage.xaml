<Page x:Class="Meridian.Wpf.Views.DashboardWebPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="1400"
      Background="{DynamicResource ConsoleBackgroundDarkBrush}"
      Loaded="OnPageLoaded"
      Unloaded="OnPageUnloaded"
      AutomationProperties.Name="Web Dashboard"
      AutomationProperties.AutomationId="DashboardWebPage">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Toolbar row with refresh / open-in-browser buttons -->
            <RowDefinition Height="Auto" />
            <!-- WebView2 / fallback content -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Toolbar ────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource ConsoleBackgroundMediumBrush}"
                BorderBrush="{DynamicResource CommandBarBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="UrlText"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource ConsoleTextMutedBrush}"
                               Text="Connecting to dashboard…" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="&#xE72C; Refresh"
                            Click="OnRefreshClicked"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,0"
                            AutomationProperties.Name="Refresh Dashboard" />
                    <Button Content="&#xE8A7; Open in Browser"
                            Click="OnOpenInBrowserClicked"
                            Style="{StaticResource SecondaryButtonStyle}"
                            AutomationProperties.Name="Open Dashboard in External Browser" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── WebView2 ───────────────────────────────────────────────── -->
        <wv2:WebView2 x:Name="DashboardWebView"
                      Grid.Row="1"
                      Visibility="Collapsed"
                      AutomationProperties.Name="Dashboard Web View" />

        <!-- ── Runtime-absent fallback ────────────────────────────────── -->
        <Border x:Name="FallbackPanel"
                Grid.Row="1"
                Visibility="Visible"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE9CE;"
                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                           FontSize="48"
                           Foreground="{DynamicResource ConsoleTextMutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16" />
                <TextBlock x:Name="FallbackHeading"
                           Text="Loading Dashboard…"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource ConsoleTextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />
                <TextBlock x:Name="FallbackDetail"
                           Text="Initialising WebView2 runtime. This may take a moment."
                           FontSize="13"
                           Foreground="{DynamicResource ConsoleTextMutedBrush}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="480" />
                <Button x:Name="InstallRuntimeButton"
                        Content="Install WebView2 Runtime"
                        Click="OnInstallRuntimeClicked"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Center"
                        Visibility="Collapsed"
                        AutomationProperties.Name="Install WebView2 Runtime" />
            </StackPanel>
        </Border>

    </Grid>
</Page>
